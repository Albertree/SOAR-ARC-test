{
  "concept_id": "mirror_and_concat",
  "version": 1,
  "description": "Stack input with its vertical flip (output height = 2x input)",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 1]
  },
  "parameters": {},
  "steps": [
    {
      "id": "s1",
      "primitive": "flip_vertical",
      "args": {"grid": "$input"},
      "output": "flipped"
    },
    {
      "id": "s2",
      "primitive": "concat_vertical",
      "args": {"grid_a": "$input", "grid_b": "$flipped"},
      "output": "result"
    }
  ],
  "result": "$result"
}
