{
  "concept_id": "keep_center_column",
  "version": 1,
  "description": "Keep only the center column (W//2) of the grid, zero everything else",
  "signature": {
    "grid_size_preserved": true,
    "color_preserved": false,
    "requires_content_diff": true,
    "input_constraints": []
  },
  "parameters": {
    "col_index": {"type": "int", "infer": "column_index_from_arckg"}
  },
  "steps": [
    {"id": "s1", "primitive": "make_uniform", "args": {"height": "$input_height", "width": "$input_width", "color": 0}, "output": "blank"},
    {"id": "s2", "primitive": "extract_column", "args": {"grid": "$input", "col_index": "$col_index"}, "output": "col"},
    {"id": "s3", "primitive": "place_column", "args": {"grid": "$blank", "column": "$col", "col_index": "$col_index"}, "output": "result"}
  ],
  "result": "$result"
}
