{
  "concept_id": "invert_tile_2x2",
  "version": 1,
  "description": "Invert binary grid (swap 0 and non-zero color) then tile 2x2",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 2],
    "requires_content_diff": true
  },
  "parameters": {},
  "steps": [
    {
      "id": "s1",
      "primitive": "invert_binary",
      "args": {"grid": "$input"},
      "output": "inv"
    },
    {
      "id": "s2",
      "primitive": "concat_horizontal",
      "args": {"grid_a": "$inv", "grid_b": "$inv"},
      "output": "top"
    },
    {
      "id": "s3",
      "primitive": "concat_vertical",
      "args": {"grid_a": "$top", "grid_b": "$top"},
      "output": "result"
    }
  ],
  "result": "$result"
}
