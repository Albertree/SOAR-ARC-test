{
  "concept_id": "border_interior_fill",
  "version": 1,
  "description": "Recolor connected components of a target color: border-touching regions get one color, interior regions get another",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "target_color": {"type": "color", "infer": "source_color_from_arckg"},
    "border_color": {"type": "color", "infer": "from_examples"},
    "interior_color": {"type": "color", "infer": "from_examples"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "border_interior_fill",
      "args": {
        "grid": "$input",
        "target_color": "$target_color",
        "border_color": "$border_color",
        "interior_color": "$interior_color"
      },
      "output": "result"
    }
  ],
  "result": "$result"
}
