{
  "concept_id": "staircase_fill",
  "version": 1,
  "description": "Build a staircase from a 1-row input, each row adds one more colored cell",
  "signature": {
    "grid_size_preserved": false,
    "requires_content_diff": true
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "first_nonzero_color", "args": {"grid": "$input"}, "output": "color"},
    {"id": "s2", "primitive": "staircase_fill", "args": {"grid": "$input", "color": "$color"}, "output": "result"}
  ],
  "result": "$result"
}
