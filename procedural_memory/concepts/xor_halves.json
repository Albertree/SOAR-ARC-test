{
  "concept_id": "xor_halves",
  "version": 1,
  "description": "Split grid at separator row, XOR two binary halves into result color",
  "signature": {
    "grid_size_preserved": false,
    "requires_content_diff": true
  },
  "parameters": {
    "result_color": {"type": "color", "infer": "color_added_in_output"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "xor_halves",
      "args": {"grid": "$input", "result_color": "$result_color"},
      "output": "result"
    }
  ],
  "result": "$result"
}
