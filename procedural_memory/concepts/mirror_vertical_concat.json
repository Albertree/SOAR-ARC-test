{
  "concept_id": "mirror_vertical_concat",
  "version": 1,
  "description": "Stack input on top of its vertical flip: output = concat(input, flip_vertical(input))",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 1],
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": ["integer_ratio"]
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "flip_vertical", "args": {"grid": "$input"}, "output": "flipped"},
    {"id": "s2", "primitive": "concat_vertical", "args": {"grid_a": "$input", "grid_b": "$flipped"}, "output": "result"}
  ],
  "result": "$result"
}
