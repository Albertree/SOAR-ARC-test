{
  "concept_id": "mirror_four_way",
  "version": 1,
  "description": "Tile input in 2x2 with horizontal and vertical mirror symmetry",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 2],
    "requires_content_diff": true
  },
  "parameters": {},
  "steps": [
    {
      "id": "s1",
      "primitive": "flip_horizontal",
      "args": {"grid": "$input"},
      "output": "hflip"
    },
    {
      "id": "s2",
      "primitive": "concat_horizontal",
      "args": {"grid_a": "$input", "grid_b": "$hflip"},
      "output": "top"
    },
    {
      "id": "s3",
      "primitive": "flip_vertical",
      "args": {"grid": "$top"},
      "output": "bottom"
    },
    {
      "id": "s4",
      "primitive": "concat_vertical",
      "args": {"grid_a": "$top", "grid_b": "$bottom"},
      "output": "result"
    }
  ],
  "result": "$result"
}
