{
  "concept_id": "mark_domino_cross",
  "version": 1,
  "description": "Find perpendicular matched domino pairs and mark their crossing center with a new color",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "domino_color": {"type": "int", "infer": "non_bg_single"},
    "mark_color": {"type": "int", "infer": "color_added_in_output"},
    "bg": {"type": "int", "infer": "bg_color"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "mark_domino_cross_centers",
      "args": {"grid": "$input", "domino_color": "$domino_color", "mark_color": "$mark_color", "bg": "$bg"},
      "output": "result"
    }
  ],
  "result": "$result"
}
