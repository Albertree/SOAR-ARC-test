{
  "concept_id": "corner_blocks_reflect",
  "version": 1,
  "description": "Corner blocks of colored rectangles; majority color reflects inward by block size, minority stays in place",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "bg": {"type": "color", "infer": "bg_color"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "corner_blocks_reflect_inward",
      "args": {"grid": "$input", "bg": "$bg"},
      "output": "result"
    }
  ],
  "result": "$result"
}
