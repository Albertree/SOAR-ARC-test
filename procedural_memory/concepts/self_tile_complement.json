{
  "concept_id": "self_tile_complement",
  "version": 1,
  "description": "Complement self-tiling: each non-bg cell becomes inverted copy of the grid, bg cells become empty blocks",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [3, 3],
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": ["uniform_scale", "integer_ratio"]
  },
  "parameters": {
    "bg": {"type": "color", "default": 0}
  },
  "steps": [
    {"id": "s1", "primitive": "self_tile_complement", "args": {"grid": "$input", "bg": "$bg"}, "output": "result"}
  ],
  "result": "$result"
}
