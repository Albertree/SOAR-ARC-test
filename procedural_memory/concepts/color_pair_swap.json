{
  "concept_id": "color_pair_swap",
  "version": 1,
  "description": "Swap each color to its partner using a consistent color mapping inferred from examples",
  "signature": {
    "grid_size_preserved": true,
    "size_ratio": null,
    "color_preserved": false,
    "requires_content_diff": true,
    "input_constraints": []
  },
  "parameters": {
    "mapping": {"type": "color_map", "infer": "color_map_from_arckg"}
  },
  "steps": [
    {"id": "s1", "primitive": "recolor", "args": {"grid": "$input", "mapping": "$mapping"}, "output": "result"}
  ],
  "result": "$result"
}
