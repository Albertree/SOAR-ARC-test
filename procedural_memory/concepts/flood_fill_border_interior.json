{
  "concept_id": "flood_fill_border_interior",
  "version": 1,
  "description": "Replace background cells: border-connected become exterior_color, enclosed become interior_color",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "bg": {"type": "color", "default": 0},
    "exterior_color": {"type": "color", "infer": "from_examples"},
    "interior_color": {"type": "color", "infer": "from_examples"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "flood_fill_border_interior",
      "args": {"grid": "$input", "bg": "$bg", "exterior_color": "$exterior_color", "interior_color": "$interior_color"},
      "output": "result"
    }
  ],
  "result": "$result"
}
