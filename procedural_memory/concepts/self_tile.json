{
  "concept_id": "self_tile",
  "version": 2,
  "description": "Kronecker self-tiling: replace each non-bg cell with copy of grid, bg cells become bg blocks",
  "signature": {
    "grid_size_preserved": false,
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": ["uniform_scale", "integer_ratio"]
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "find_bg_color", "args": {"grid": "$input"}, "output": "bg"},
    {"id": "s2", "primitive": "self_tile", "args": {"grid": "$input", "bg": "$bg"}, "output": "result"}
  ],
  "result": "$result"
}
