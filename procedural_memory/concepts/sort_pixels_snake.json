{
  "concept_id": "sort_pixels_snake",
  "version": 1,
  "description": "Extract scattered pixels, sort by column, fill into compact grid in snake order",
  "signature": {
    "grid_size_preserved": false,
    "requires_content_diff": true
  },
  "parameters": {
    "bg": {"type": "color", "infer": "bg_color"},
    "out_h": {"type": "int", "infer": "from_examples", "candidates": [3, 4, 5]},
    "out_w": {"type": "int", "infer": "from_examples", "candidates": [3, 4, 5]}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "sort_pixels_snake",
      "args": {"grid": "$input", "bg": "$bg", "out_h": "$out_h", "out_w": "$out_w"},
      "output": "result"
    }
  ],
  "result": "$result"
}
