{
  "concept_id": "scale_2x",
  "version": 1,
  "description": "Scale each cell into a 2x2 block, doubling grid dimensions",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 2],
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": ["uniform_scale", "integer_ratio"]
  },
  "parameters": {
    "factor": {"type": "int", "infer": "ratio_hw"}
  },
  "steps": [
    {"id": "s1", "primitive": "scale", "args": {"grid": "$input", "factor": "$factor"}, "output": "result"}
  ],
  "result": "$result"
}
