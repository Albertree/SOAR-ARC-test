{
  "concept_id": "fill_quadrants_from_corners",
  "version": 1,
  "description": "Find rectangles of a fill color with 4 diagonal corner markers. Replace each rectangle with 4 quadrants colored by the corner markers, then remove the corner markers.",
  "signature": {
    "grid_size_preserved": true,
    "color_preserved": false,
    "requires_content_diff": true
  },
  "parameters": {
    "fill_color": {"type": "color", "infer": "from_examples"},
    "bg": {"type": "color", "default": 0}
  },
  "steps": [
    {"id": "s1", "primitive": "fill_quadrants_from_corners", "args": {"grid": "$input", "fill_color": "$fill_color", "bg": "$bg"}, "output": "result"}
  ],
  "result": "$result"
}
