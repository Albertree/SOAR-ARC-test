{
  "concept_id": "mirror_h_tile_2x",
  "version": 1,
  "description": "Flip input horizontally, concat with original, then repeat that pair 2x wide",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [1, 4],
    "requires_content_diff": true
  },
  "parameters": {},
  "steps": [
    {
      "id": "s1",
      "primitive": "flip_horizontal",
      "args": {"grid": "$input"},
      "output": "hflip"
    },
    {
      "id": "s2",
      "primitive": "concat_horizontal",
      "args": {"grid_a": "$hflip", "grid_b": "$input"},
      "output": "pair"
    },
    {
      "id": "s3",
      "primitive": "concat_horizontal",
      "args": {"grid_a": "$pair", "grid_b": "$pair"},
      "output": "result"
    }
  ],
  "result": "$result"
}
