{
  "concept_id": "separator_block_decode",
  "version": 1,
  "description": "Grid divided into NxN blocks by separators; find block without noise color 8, use its color positions to fill corresponding output blocks",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "sep_color": {"type": "color", "infer": "separator_color"},
    "noise_color": {"type": "color", "default": 8},
    "bg": {"type": "color", "infer": "bg_color"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "separator_block_decode",
      "args": {"grid": "$input", "sep_color": "$sep_color", "noise_color": "$noise_color", "bg": "$bg"},
      "output": "result"
    }
  ],
  "result": "$result"
}
