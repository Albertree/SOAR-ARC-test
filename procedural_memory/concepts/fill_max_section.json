{
  "concept_id": "fill_max_section",
  "version": 1,
  "description": "Grid divided by separator lines into sections; fill section(s) with most colored dots, clear others",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "sep_color": {"type": "color", "infer": "separator_color"},
    "bg": {"type": "color", "infer": "bg_color"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "fill_max_section",
      "args": {"grid": "$input", "sep_color": "$sep_color", "bg": "$bg"},
      "output": "result"
    }
  ],
  "result": "$result"
}
