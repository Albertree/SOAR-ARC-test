{
  "concept_id": "vertical_mirror_below",
  "version": 1,
  "description": "Output = input concatenated above its vertically flipped copy (height doubles, width unchanged).",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2.0, 1.0]
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "flip_vertical", "args": {"grid": "$input"}, "output": "flipped"},
    {"id": "s2", "primitive": "concat_vertical", "args": {"grid_a": "$input", "grid_b": "$flipped"}, "output": "result"}
  ],
  "result": "$result"
}
