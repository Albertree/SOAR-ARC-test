{
  "concept_id": "quadrant_mirror_tile",
  "version": 1,
  "description": "Output = 2x2 tile of input with mirrored quadrants (top-left=input, top-right=h-flip, bottom-left=v-flip, bottom-right=180-rotated). Both dimensions double.",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2.0, 2.0]
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "flip_horizontal", "args": {"grid": "$input"}, "output": "h_flip"},
    {"id": "s2", "primitive": "flip_vertical", "args": {"grid": "$input"}, "output": "v_flip"},
    {"id": "s3", "primitive": "flip_horizontal", "args": {"grid": "$v_flip"}, "output": "vh_flip"},
    {"id": "s4", "primitive": "concat_horizontal", "args": {"grid_a": "$input", "grid_b": "$h_flip"}, "output": "top_row"},
    {"id": "s5", "primitive": "concat_horizontal", "args": {"grid_a": "$v_flip", "grid_b": "$vh_flip"}, "output": "bottom_row"},
    {"id": "s6", "primitive": "concat_vertical", "args": {"grid_a": "$top_row", "grid_b": "$bottom_row"}, "output": "result"}
  ],
  "result": "$result"
}
