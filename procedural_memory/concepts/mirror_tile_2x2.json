{
  "concept_id": "mirror_tile_2x2",
  "version": 1,
  "description": "Tile input into 2x2 arrangement using horizontal and vertical reflections",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 2],
    "color_preserved": true,
    "requires_content_diff": true,
    "input_constraints": []
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "flip_horizontal", "args": {"grid": "$input"}, "output": "h_flip"},
    {"id": "s2", "primitive": "concat_horizontal", "args": {"grid_a": "$h_flip", "grid_b": "$input"}, "output": "bottom"},
    {"id": "s3", "primitive": "flip_vertical", "args": {"grid": "$bottom"}, "output": "top"},
    {"id": "s4", "primitive": "concat_vertical", "args": {"grid_a": "$top", "grid_b": "$bottom"}, "output": "result"}
  ],
  "result": "$result"
}
