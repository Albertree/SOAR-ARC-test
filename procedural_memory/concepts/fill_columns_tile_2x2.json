{
  "concept_id": "fill_columns_tile_2x2",
  "version": 1,
  "description": "Fill 0s in columns that have non-zero pixels with color 8, then tile 2x2",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 2],
    "requires_content_diff": true
  },
  "parameters": {},
  "steps": [
    {
      "id": "s1",
      "primitive": "fill_active_columns",
      "args": {"grid": "$input", "fill_color": 8},
      "output": "filled"
    },
    {
      "id": "s2",
      "primitive": "concat_horizontal",
      "args": {"grid_a": "$filled", "grid_b": "$filled"},
      "output": "top"
    },
    {
      "id": "s3",
      "primitive": "concat_vertical",
      "args": {"grid_a": "$top", "grid_b": "$top"},
      "output": "result"
    }
  ],
  "result": "$result"
}
