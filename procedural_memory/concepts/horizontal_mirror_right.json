{
  "concept_id": "horizontal_mirror_right",
  "version": 1,
  "description": "Output = input concatenated to the left of its horizontally flipped copy (width doubles, height unchanged).",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [1.0, 2.0]
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "flip_horizontal", "args": {"grid": "$input"}, "output": "flipped"},
    {"id": "s2", "primitive": "concat_horizontal", "args": {"grid_a": "$input", "grid_b": "$flipped"}, "output": "result"}
  ],
  "result": "$result"
}
