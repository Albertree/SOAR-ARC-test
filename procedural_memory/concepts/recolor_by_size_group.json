{
  "concept_id": "recolor_by_size_group",
  "version": 1,
  "description": "Connected components of one color recolored by size group (same size = same color)",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "source_color": {
      "type": "color",
      "infer": "source_color_from_arckg"
    },
    "sort_order": {
      "type": "str",
      "infer": "from_examples",
      "candidates": ["desc", "asc"]
    },
    "start_color": {
      "type": "color",
      "infer": "start_color_from_arckg"
    }
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "recolor_components_by_size_group",
      "args": {
        "grid": "$input",
        "source_color": "$source_color",
        "sort_order": "$sort_order",
        "start_color": "$start_color"
      },
      "output": "result"
    }
  ],
  "result": "$result"
}
