{
  "concept_id": "replace_frames_with_interiors",
  "version": 1,
  "description": "Find rectangular frames of a single non-bg color, erase frames, fill interiors with a new color.",
  "signature": {
    "grid_size_preserved": true,
    "color_preserved": false,
    "requires_content_diff": true
  },
  "parameters": {
    "border_color": {"type": "color", "infer": "non_bg_single"},
    "fill_color": {"type": "color", "infer": "from_examples"}
  },
  "steps": [
    {"id": "s1", "primitive": "replace_frames_with_interiors", "args": {"grid": "$input", "border_color": "$border_color", "fill_color": "$fill_color"}, "output": "result"}
  ],
  "result": "$result"
}
