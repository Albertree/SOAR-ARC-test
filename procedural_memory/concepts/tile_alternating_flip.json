{
  "concept_id": "tile_alternating_flip",
  "version": 1,
  "description": "Tile grid in NxN arrangement with odd block-rows horizontally flipped",
  "signature": {
    "grid_size_preserved": false,
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": ["uniform_scale", "integer_ratio"]
  },
  "parameters": {
    "reps": {"type": "int", "infer": "ratio_hw"}
  },
  "steps": [
    {"id": "s1", "primitive": "tile_alternating_flip", "args": {"grid": "$input", "reps_h": "$reps", "reps_w": "$reps"}, "output": "result"}
  ],
  "result": "$result"
}
