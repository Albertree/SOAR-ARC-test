{
  "concept_id": "waypoint_turn_path",
  "version": 1,
  "description": "Draw L-shaped path from start pixel, turning CW/CCW at colored waypoints",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "path_color": {"type": "color", "infer": "path_start_color"},
    "bg": {"type": "color", "infer": "bg_color"},
    "cw_color": {"type": "color", "infer": "from_examples"},
    "ccw_color": {"type": "color", "infer": "from_examples"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "draw_turn_path",
      "args": {
        "grid": "$input",
        "path_color": "$path_color",
        "cw_color": "$cw_color",
        "ccw_color": "$ccw_color",
        "bg": "$bg"
      },
      "output": "result"
    }
  ],
  "result": "$result"
}
