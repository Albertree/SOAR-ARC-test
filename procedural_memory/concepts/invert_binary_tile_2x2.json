{
  "concept_id": "invert_binary_tile_2x2",
  "version": 1,
  "description": "Invert a binary grid (swap 0 and the non-zero color) then tile it 2x2",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 2],
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": []
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "invert_binary", "args": {"grid": "$input"}, "output": "inverted"},
    {"id": "s2", "primitive": "concat_horizontal", "args": {"grid_a": "$inverted", "grid_b": "$inverted"}, "output": "top_row"},
    {"id": "s3", "primitive": "concat_vertical", "args": {"grid_a": "$top_row", "grid_b": "$top_row"}, "output": "result"}
  ],
  "result": "$result"
}
