{
  "concept_id": "color_remap",
  "version": 1,
  "description": "Remap all colors in the grid according to a consistent bijective mapping",
  "signature": {
    "grid_size_preserved": true,
    "color_preserved": false,
    "requires_content_diff": true,
    "input_constraints": []
  },
  "parameters": {
    "mapping": {"type": "color_map", "infer": "color_map_from_arckg"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "recolor",
      "args": {"grid": "$input", "mapping": "$mapping"},
      "output": "result"
    }
  ],
  "result": "$result"
}
