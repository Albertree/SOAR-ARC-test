{
  "concept_id": "mirror_horizontal_tile_4x",
  "version": 1,
  "description": "Each row becomes [reversed | original] repeated twice, producing 4x wider output",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [1, 4],
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": ["integer_ratio"]
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "flip_horizontal", "args": {"grid": "$input"}, "output": "mirrored"},
    {"id": "s2", "primitive": "concat_horizontal", "args": {"grid_a": "$mirrored", "grid_b": "$input"}, "output": "unit"},
    {"id": "s3", "primitive": "concat_horizontal", "args": {"grid_a": "$unit", "grid_b": "$unit"}, "output": "result"}
  ],
  "result": "$result"
}
