{
  "concept_id": "mirror_recolor_symmetric",
  "version": 1,
  "description": "Recolor target-color pixels to replace-color when their vertical-axis mirror also has target-color",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "target_color": {"type": "color", "infer": "non_bg_single"},
    "replace_color": {"type": "color", "infer": "from_examples"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "mirror_recolor_vertical",
      "args": {"grid": "$input", "target_color": "$target_color", "replace_color": "$replace_color"},
      "output": "result"
    }
  ],
  "result": "$result"
}
