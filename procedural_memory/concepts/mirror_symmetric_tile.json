{
  "concept_id": "mirror_symmetric_tile",
  "version": 1,
  "description": "Mirror input horizontally and vertically to create 2x2 symmetric output (double width and height)",
  "signature": {
    "grid_size_preserved": false,
    "size_ratio": [2, 2],
    "color_preserved": true,
    "requires_content_diff": false,
    "input_constraints": []
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "flip_horizontal", "args": {"grid": "$input"}, "output": "flipped_h"},
    {"id": "s2", "primitive": "concat_horizontal", "args": {"grid_a": "$input", "grid_b": "$flipped_h"}, "output": "top_row"},
    {"id": "s3", "primitive": "flip_vertical", "args": {"grid": "$top_row"}, "output": "bottom_row"},
    {"id": "s4", "primitive": "concat_vertical", "args": {"grid_a": "$top_row", "grid_b": "$bottom_row"}, "output": "result"}
  ],
  "result": "$result"
}
