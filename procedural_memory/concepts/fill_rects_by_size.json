{
  "concept_id": "fill_rects_by_size",
  "version": 1,
  "description": "Fill interiors of bordered rectangles with colors ranked by interior area",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "border_color": {
      "type": "color",
      "infer": "from_examples"
    },
    "start_color": {
      "type": "color",
      "infer": "from_examples"
    }
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "fill_rects_by_size",
      "args": {"grid": "$input", "border_color": "$border_color", "bg": 0, "start_color": "$start_color"},
      "output": "result"
    }
  ],
  "result": "$result"
}
