{
  "concept_id": "fill_bbox_holes",
  "version": 1,
  "description": "Fill background cells within bounding box of non-bg shape with a new color",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "bg": {"type": "color", "infer": "bg_color"},
    "fill_color": {"type": "color", "infer": "color_added_in_output"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "fill_bbox_holes",
      "args": {"grid": "$input", "bg": "$bg", "fill_color": "$fill_color"},
      "output": "result"
    }
  ],
  "result": "$result"
}
