{
  "concept_id": "anti_diagonal_flip",
  "version": 1,
  "description": "Output = input mirrored along the anti-diagonal (top-right to bottom-left). Equivalent to transpose followed by 180-degree rotation. Only matches square grids.",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {},
  "steps": [
    {"id": "s1", "primitive": "transpose", "args": {"grid": "$input"}, "output": "transposed"},
    {"id": "s2", "primitive": "rotate_cw", "args": {"grid": "$transposed", "times": 2}, "output": "result"}
  ],
  "result": "$result"
}
