{
  "concept_id": "connect_aligned_diamonds",
  "version": 1,
  "description": "Connect diamond/cross shapes sharing same row or column center with lines",
  "signature": {
    "grid_size_preserved": true,
    "requires_content_diff": true
  },
  "parameters": {
    "diamond_color": {"type": "color", "infer": "non_bg_single"},
    "line_color": {"type": "color", "infer": "from_examples"},
    "bg": {"type": "color", "infer": "bg_color"}
  },
  "steps": [
    {
      "id": "s1",
      "primitive": "connect_aligned_diamonds",
      "args": {
        "grid": "$input",
        "diamond_color": "$diamond_color",
        "line_color": "$line_color",
        "bg": "$bg"
      },
      "output": "result"
    }
  ],
  "result": "$result"
}
