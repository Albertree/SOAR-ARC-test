    "input_constraints": []
  },
  "parameters": {
    "target_color": {"type": "color", "infer": "non_bg_single"},
    "bg": {"type": "color", "infer": "bg_color"}
  },
  "steps": [
    {"id": "s1", "primitive": "rank_recolor_objects", "args": {"grid": "$input", "target_color": "$target_color", "bg": "$bg"}, "output": "result"}
