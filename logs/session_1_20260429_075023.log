{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CzbzebcKGwf4T7Wi3VH7VC","type":"tool_result","content":"1\t\"\"\"\n2\tactive_operators -- SOAR Operator implementations.\n3\t\n4\tPipeline operators (all fire in S2, read/write S1):\n5\t  SelectTargetOperator  -> set up comparison agenda from example pairs\n6\t  CompareOperator       -> execute one comparison using ARCKG compare()\n7\t  ExtractPatternOperator-> cell-level analysis of input/output changes\n8\t  GeneralizeOperator    -> create transformation rule from patterns\n9\t  PredictOperator       -> apply rule to test input\n10\t  SubmitOperator        -> write prediction to output-link, satisfy goal\n11\t\"\"\"\n12\t\n13\tfrom agent.operators import Operator\n14\tfrom ARCKG.comparison import compare as arckg_compare\n15\t\n16\t\n17\t# ======================================================================\n18\t# SolveTaskOperator -- abstract top-level goal (S1)\n19\t# ======================================================================\n20\t\n21\tclass SolveTaskOperator(Operator):\n22\t    \"\"\"\n23\t    Abstract operator at S1. Intentionally makes no WM change so\n24\t    the cycle detects no-change and creates an S2 substate.\n25\t    \"\"\"\n26\t\n27\t    def __init__(self):\n28\t        super().__init__(\"solve-task\")\n29\t        self.proposal_preference = \"+\"\n30\t\n31\t    def precondition(self, wm) -> bool:\n32\t        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n33\t\n34\t    def effect(self, wm):\n35\t        # Intentionally empty -- triggers no-change impasse -> S2\n36\t        return\n37\t\n38\t\n39\t# ======================================================================\n40\t# SelectTargetOperator -- set up comparison agenda\n41\t# ======================================================================\n42\t\n43\tclass SelectTargetOperator(Operator):\n44\t    \"\"\"\n45\t    Reads wm.task to find example pairs and sets up comparison targets.\n46\t    For each example pair: compare input grid (G0) vs output grid (G1).\n47\t    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n48\t    \"\"\"\n49\t\n50\t    def __init__(self):\n51\t        super().__init__(\"select_target\")\n52\t\n53\t    def precondition(self, wm) -> bool:\n54\t        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n55\t\n56\t    def effect(self, wm):\n57\t        task = wm.task\n58\t        if task is None:\n59\t            return\n60\t\n61\t        agenda = []\n62\t        pending = []\n63\t\n64\t        for idx, pair in enumerate(task.example_pairs):\n65\t            if pair.input_grid is not None and pair.output_grid is not None:\n66\t                spec = {\n67\t                    \"type\": \"grid\",\n68\t                    \"pair_idx\": idx,\n69\t                    \"pair_type\": \"example\",\n70\t                    \"id1\": pair.input_grid.node_id,\n71\t                    \"id2\": pair.output_grid.node_id,\n72\t                }\n73\t                agenda.append(spec)\n74\t                pending.append(spec)\n75\t\n76\t        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n77\t        node_lookup = {}\n78\t        for pair in task.example_pairs + task.test_pairs:\n79\t            if pair.input_grid:\n80\t                node_lookup[pair.input_grid.node_id] = pair.input_grid\n81\t            if pair.output_grid:\n82\t                node_lookup[pair.output_grid.node_id] = pair.output_grid\n83\t        wm.node_lookup = node_lookup\n84\t\n85\t        wm.s1[\"comparison-agenda\"] = agenda\n86\t        wm.s1[\"pending-comparisons\"] = pending\n87\t        wm.s1[\"comparisons\"] = {}\n88\t\n89\t\n90\t# ======================================================================\n91\t# CompareOperator -- execute one comparison\n92\t# ======================================================================\n93\t\n94\tclass CompareOperator(Operator):\n95\t    \"\"\"\n96\t    Pops one item from pending-comparisons, calls ARCKG compare(),\n97\t    and stores the result in the comparisons dict on S1.\n98\t    \"\"\"\n99\t\n100\t    def __init__(self, compare_fn=None):\n101\t        super().__init__(\"compare\")\n102\t        self._compare_fn = compare_fn\n103\t\n104\t    def precondition(self, wm) -> bool:\n105\t        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n106\t\n107\t    def effect(self, wm):\n108\t        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n109\t        if not pending:\n110\t            return\n111\t\n112\t        item = pending.pop(0)\n113\t\n114\t        # Find the actual ARCKG nodes\n115\t        node_lookup = getattr(wm, \"node_lookup\", {})\n116\t        node_a = node_lookup.get(item[\"id1\"])\n117\t        node_b = node_lookup.get(item[\"id2\"])\n118\t\n119\t        if node_a is None or node_b is None:\n120\t            wm.s1[\"pending-comparisons\"] = pending\n121\t            return\n122\t\n123\t        # Execute comparison\n124\t        fn = self._compare_fn or arckg_compare\n125\t        result = fn(node_a, node_b)\n126\t\n127\t        # Store result keyed by type and pair index\n128\t        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n129\t        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n130\t        comparisons[key] = {\"spec\": item, \"result\": result}\n131\t\n132\t        wm.s1[\"pending-comparisons\"] = pending\n133\t        wm.s1[\"comparisons\"] = comparisons\n134\t\n135\t\n136\t# ======================================================================\n137\t# ExtractPatternOperator -- cell-level transformation analysis\n138\t# ======================================================================\n139\t\n140\tclass ExtractPatternOperator(Operator):\n141\t    \"\"\"\n142\t    Analyzes each example pair at the cell level to discover what changes\n143\t    between input and output grids. Groups changed cells into connected\n144\t    components and records color/position information for generalization.\n145\t    \"\"\"\n146\t\n147\t    def __init__(self):\n148\t        super().__init__(\"extract_pattern\")\n149\t\n150\t    def precondition(self, wm) -> bool:\n151\t        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n152\t\n153\t    def effect(self, wm):\n154\t        task = wm.task\n155\t        if task is None:\n156\t            return\n157\t\n158\t        patterns = {\n159\t            \"grid_size_preserved\": True,\n160\t            \"pair_analyses\": [],\n161\t        }\n162\t\n163\t        for pair in task.example_pairs:\n164\t            g0 = pair.input_grid\n165\t            g1 = pair.output_grid\n166\t            if g0 is None or g1 is None:\n167\t                continue\n168\t\n169\t            analysis = self._analyze_pair(g0, g1)\n170\t            patterns[\"pair_analyses\"].append(analysis)\n171\t\n172\t            if g0.height != g1.height or g0.width != g1.width:\n173\t                patterns[\"grid_size_preserved\"] = False\n174\t\n175\t        wm.s1[\"patterns\"] = patterns\n176\t\n177\t    # ---- internal helpers ------------------------------------------------\n178\t\n179\t    def _analyze_pair(self, g0, g1):\n180\t        \"\"\"Cell-level diff between input and output grid.\"\"\"\n181\t        raw_in = g0.raw\n182\t        raw_out = g1.raw\n183\t        h = min(len(raw_in), len(raw_out))\n184\t        w = min(\n185\t            len(raw_in[0]) if raw_in else 0,\n186\t            len(raw_out[0]) if raw_out else 0,\n187\t        )\n188\t\n189\t        changes = []\n190\t        for r in range(h):\n191\t            for c in range(w):\n192\t                if raw_in[r][c] != raw_out[r][c]:\n193\t                    changes.append({\n194\t                        \"row\": r, \"col\": c,\n195\t                        \"input_color\": raw_in[r][c],\n196\t                        \"output_color\": raw_out[r][c],\n197\t                    })\n198\t\n199\t        groups = self._group_changes(changes)\n200\t\n201\t        group_analyses = []\n202\t        for group_cells in groups:\n203\t            input_colors = set()\n204\t            output_colors = set()\n205\t            positions = []\n206\t            for cell in group_cells:\n207\t                input_colors.add(cell[\"input_color\"])\n208\t                output_colors.add(cell[\"output_color\"])\n209\t                positions.append((cell[\"row\"], cell[\"col\"]))\n210\t\n211\t            top_row = min(r for r, c in positions)\n212\t            top_col = min(c for r, c in positions)\n213\t\n214\t            group_analyses.append({\n215\t                \"input_colors\": sorted(input_colors),\n216\t                \"output_colors\": sorted(output_colors),\n217\t                \"top_row\": top_row,\n218\t                \"top_col\": top_col,\n219\t                \"cell_count\": len(group_cells),\n220\t            })\n221\t\n222\t        return {\n223\t            \"total_changes\": len(changes),\n224\t            \"num_groups\": len(groups),\n225\t            \"groups\": group_analyses,\n226\t            \"size_match\": (\n227\t                len(raw_in) == len(raw_out)\n228\t                and (len(raw_in[0]) if raw_in else 0)\n229\t                    == (len(raw_out[0]) if raw_out else 0)\n230\t            ),\n231\t        }\n232\t\n233\t    @staticmethod\n234\t    def _group_changes(changes):\n235\t        \"\"\"Group changed cells into 4-connected components.\"\"\"\n236\t        if not changes:\n237\t            return []\n238\t\n239\t        pos_to_change = {}\n240\t        for c in changes:\n241\t            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n242\t\n243\t        visited = set()\n244\t        groups = []\n245\t\n246\t        for change in changes:\n247\t            pos = (change[\"row\"], change[\"col\"])\n248\t            if pos in visited:\n249\t                continue\n250\t\n251\t            group = []\n252\t            queue = [pos]\n253\t            while queue:\n254\t                p = queue.pop(0)\n255\t                if p in visited or p not in pos_to_change:\n256\t                    continue\n257\t                visited.add(p)\n258\t                group.append(pos_to_change[p])\n259\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n260\t                    nb = (p[0] + dr, p[1] + dc)\n261\t                    if nb in pos_to_change and nb not in visited:\n262\t                        queue.append(nb)\n263\t            groups.append(group)\n264\t\n265\t        return groups\n266\t\n267\t\n268\t# ======================================================================\n269\t# GeneralizeOperator -- rule creation from patterns\n270\t# ======================================================================\n271\t\n272\tclass GeneralizeOperator(Operator):\n273\t    \"\"\"\n274\t    Reads extracted patterns and attempts to create a transformation rule.\n275\t    Tries multiple strategies in priority order. If no strategy succeeds,\n276\t    falls back to an identity rule so the pipeline can still complete.\n277\t    \"\"\"\n278\t\n279\t    def __init__(self, generalize_fn=None, save_fn=None):\n280\t        super().__init__(\"generalize\")\n281\t        self._generalize_fn = generalize_fn\n282\t        self._save_fn = save_fn\n283\t\n284\t    def precondition(self, wm) -> bool:\n285\t        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n286\t\n287\t    def effect(self, wm):\n288\t        patterns = wm.s1.get(\"patterns\")\n289\t        if not patterns:\n290\t            return\n291\t\n292\t        task = wm.task\n293\t        example_pairs = self._collect_example_pairs(task)\n294\t\n295\t        rule = None\n296\t\n297\t        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n298\t        rule = self._try_recolor_sequential(patterns)\n299\t\n300\t        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n301\t        if rule is None:\n302\t            rule = self._try_bbox_fill(example_pairs)\n303\t\n304\t        # Strategy 3: horizontal mirror recolor — recolor cells whose\n305\t        #   horizontal-mirror partner has the same color\n306\t        if rule is None:\n307\t            rule = self._try_axis_mirror_recolor(example_pairs)\n308\t\n309\t        # Strategy 4: simple 1:1 color mapping\n310\t        if rule is None:\n311\t            rule = self._try_color_mapping(patterns)\n312\t\n313\t        # Fallback: identity (copy input as output)\n314\t        if rule is None:\n315\t            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n316\t\n317\t        wm.s1[\"active-rules\"] = [rule]\n318\t\n319\t    @staticmethod\n320\t    def _collect_example_pairs(task):\n321\t        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n322\t        if task is None:\n323\t            return []\n324\t        out = []\n325\t        for pair in task.example_pairs:\n326\t            g0, g1 = pair.input_grid, pair.output_grid\n327\t            if g0 is None or g1 is None:\n328\t                continue\n329\t            out.append((g0.raw, g1.raw))\n330\t        return out\n331\t\n332\t    # ---- strategy: sequential recoloring --------------------------------\n333\t\n334\t    def _try_recolor_sequential(self, patterns):\n335\t        \"\"\"\n336\t        Detect pattern: all changed-cell groups have one source color,\n337\t        output colors are sequential (1,2,3,...), ordered by position.\n338\t        \"\"\"\n339\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n340\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n341\t            return None\n342\t\n343\t        # All pairs must have the same number of change groups\n344\t        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n345\t        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n346\t            return None\n347\t\n348\t        all_source_colors = set()\n349\t\n350\t        for analysis in pair_analyses:\n351\t            for g in analysis[\"groups\"]:\n352\t                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n353\t                    return None\n354\t                all_source_colors.add(g[\"input_colors\"][0])\n355\t\n356\t            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n357\t            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n358\t            if out_colors != expected:\n359\t                return None\n360\t\n361\t        # Try sorting by different position keys\n362\t        for sort_key in [\"top_row\", \"top_col\"]:\n363\t            if self._check_sort_key(pair_analyses, sort_key):\n364\t                start_color = min(\n365\t                    g[\"output_colors\"][0]\n366\t                    for g in pair_analyses[0][\"groups\"]\n367\t                )\n368\t                return {\n369\t                    \"type\": \"recolor_sequential\",\n370\t                    \"sort_key\": sort_key,\n371\t                    \"start_color\": start_color,\n372\t                    \"source_colors\": sorted(all_source_colors),\n373\t                    \"confidence\": 1.0,\n374\t                }\n375\t\n376\t        return None\n377\t\n378\t    @staticmethod\n379\t    def _check_sort_key(pair_analyses, sort_key):\n380\t        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n381\t        for analysis in pair_analyses:\n382\t            groups = analysis[\"groups\"]\n383\t            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n384\t            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n385\t            if colors != list(range(colors[0], colors[0] + len(colors))):\n386\t                return False\n387\t        return True\n388\t\n389\t    # ---- strategy: simple color mapping ---------------------------------\n390\t\n391\t    def _try_color_mapping(self, patterns):\n392\t        \"\"\"\n393\t        Detect pattern: each input color consistently maps to one output color.\n394\t        \"\"\"\n395\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n396\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n397\t            return None\n398\t\n399\t        # Collect all observed color transitions\n400\t        color_map = {}\n401\t        for analysis in pair_analyses:\n402\t            for group in analysis[\"groups\"]:\n403\t                for ic in group[\"input_colors\"]:\n404\t                    for oc in group[\"output_colors\"]:\n405\t                        if ic not in color_map:\n406\t                            color_map[ic] = set()\n407\t                        color_map[ic].add(oc)\n408\t\n409\t        # Each input color must map to exactly one output color\n410\t        simple_map = {}\n411\t        for ic, ocs in color_map.items():\n412\t            if len(ocs) != 1:\n413\t                return None\n414\t            simple_map[ic] = list(ocs)[0]\n415\t\n416\t        if simple_map:\n417\t            return {\n418\t                \"type\": \"color_mapping\",\n419\t                \"mapping\": simple_map,\n420\t                \"confidence\": 0.8,\n421\t            }\n422\t\n423\t        return None\n424\t\n425\t    # ---- strategy: bounding-box fill ------------------------------------\n426\t\n427\t    def _try_bbox_fill(self, example_pairs):\n428\t        \"\"\"\n429\t        Detect: same grid size; output equals input except every background\n430\t        cell within the bounding box of the foreground color has been\n431\t        recolored to a single marker color (a color not present in input).\n432\t        \"\"\"\n433\t        if not example_pairs:\n434\t            return None\n435\t\n436\t        marker = None\n437\t        bg_color = None\n438\t        fg_color = None\n439\t\n440\t        for raw_in, raw_out in example_pairs:\n441\t            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n442\t            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n443\t                return None\n444\t\n445\t            in_colors = {c for row in raw_in for c in row}\n446\t            out_colors = {c for row in raw_out for c in row}\n447\t            new_colors = out_colors - in_colors\n448\t            if len(new_colors) != 1:\n449\t                return None\n450\t            m = next(iter(new_colors))\n451\t\n452\t            # Background = most-frequent color in input\n453\t            counts = {}\n454\t            for row in raw_in:\n455\t                for c in row:\n456\t                    counts[c] = counts.get(c, 0) + 1\n457\t            bg = max(counts, key=counts.get)\n458\t\n459\t            # Foreground = the other input color (must be exactly two)\n460\t            fg_set = {c for c in in_colors if c != bg}\n461\t            if len(fg_set) != 1:\n462\t                return None\n463\t            fg = next(iter(fg_set))\n464\t\n465\t            # Compute bbox of foreground in input\n466\t            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n467\t            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n468\t            if not rows:\n469\t                return None\n470\t            r0, r1 = min(rows), max(rows)\n471\t            c0, c1 = min(cols), max(cols)\n472\t\n473\t            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n474\t            for r in range(h):\n475\t                for c in range(w):\n476\t                    inside = r0 <= r <= r1 and c0 <= c <= c1\n477\t                    if inside and raw_in[r][c] == bg:\n478\t                        if raw_out[r][c] != m:\n479\t                            return None\n480\t                    else:\n481\t                        if raw_out[r][c] != raw_in[r][c]:\n482\t                            return None\n483\t\n484\t            if marker is None:\n485\t                marker, bg_color, fg_color = m, bg, fg\n486\t            elif (m, bg, fg) != (marker, bg_color, fg_color):\n487\t                return None\n488\t\n489\t        return {\n490\t            \"type\": \"bbox_fill\",\n491\t            \"marker\": marker,\n492\t            \"background\": bg_color,\n493\t            \"foreground\": fg_color,\n494\t            \"confidence\": 1.0,\n495\t        }\n496\t\n497\t    # ---- strategy: axis mirror recolor ----------------------------------\n498\t\n499\t    def _try_axis_mirror_recolor(self, example_pairs):\n500\t        \"\"\"\n501\t        Detect: same grid size, exactly one new color in output (marker).\n502\t        For some axis (horizontal/vertical), every changed cell is the\n503\t        original foreground color and its mirror partner along that axis\n504\t        also has the original foreground color in the input.\n505\t        Unchanged cells are those without a same-color mirror partner.\n506\t        \"\"\"\n507\t        if not example_pairs:\n508\t            return None\n509\t\n510\t        for axis in (\"horizontal\", \"vertical\"):\n511\t            params = self._check_mirror_axis(example_pairs, axis)\n512\t            if params is not None:\n513\t                return {\n514\t                    \"type\": \"axis_mirror_recolor\",\n515\t                    \"axis\": axis,\n516\t                    \"marker\": params[\"marker\"],\n517\t                    \"foreground\": params[\"foreground\"],\n518\t                    \"confidence\": 1.0,\n519\t                }\n520\t        return None\n521\t\n522\t    @staticmethod\n523\t    def _check_mirror_axis(example_pairs, axis):\n524\t        marker = None\n525\t        fg = None\n526\t        had_change = False\n527\t\n528\t        for raw_in, raw_out in example_pairs:\n529\t            h = len(raw_in)\n530\t            w = len(raw_in[0]) if raw_in else 0\n531\t            if h != len(raw_out) or (w and w != len(raw_out[0])):\n532\t                return None\n533\t\n534\t            new_colors = (\n535\t                {c for row in raw_out for c in row}\n536\t                - {c for row in raw_in for c in row}\n537\t            )\n538\t            if len(new_colors) != 1:\n539\t                return None\n540\t            m = next(iter(new_colors))\n541\t\n542\t            for r in range(h):\n543\t                for c in range(w):\n544\t                    if axis == \"horizontal\":\n545\t                        rr, cc = r, w - 1 - c\n546\t                    else:\n547\t                        rr, cc = h - 1 - r, c\n548\t                    in_v = raw_in[r][c]\n549\t                    out_v = raw_out[r][c]\n550\t                    mirror_v = raw_in[rr][cc]\n551\t                    if out_v == in_v:\n552\t                        # If this cell HAS a same-color mirror partner of\n553\t                        # a non-bg color, the rule would have flipped it.\n554\t                        # We require: not changed → no same-color partner\n555\t                        # OR cell is on the axis and equals itself (trivial).\n556\t                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n557\t                            # only allow when in_v is the background\n558\t                            # (but bg already excluded by != 0 check is rough);\n559\t                            # we'll defer to fg check below.\n560\t                            pass\n561\t                        continue\n562\t                    # Changed: must change FROM some fg TO marker, with mirror\n563\t                    # partner also equal to fg in the input.\n564\t                    if out_v != m:\n565\t                        return None\n566\t                    if in_v == 0:\n567\t                        # background-cells turning into marker — not this rule\n568\t                        return None\n569\t                    if mirror_v != in_v:\n570\t                        return None\n571\t                    if fg is None:\n572\t                        fg = in_v\n573\t                    elif fg != in_v:\n574\t                        return None\n575\t                    had_change = True\n576\t\n577\t            if marker is None:\n578\t                marker = m\n579\t            elif marker != m:\n580\t                return None\n581\t\n582\t        if not had_change or fg is None:\n583\t            return None\n584\t\n585\t        # Final sanity: re-apply rule and confirm exact match.\n586\t        for raw_in, raw_out in example_pairs:\n587\t            h = len(raw_in)\n588\t            w = len(raw_in[0]) if raw_in else 0\n589\t            for r in range(h):\n590\t                for c in range(w):\n591\t                    if axis == \"horizontal\":\n592\t                        rr, cc = r, w - 1 - c\n593\t                    else:\n594\t                        rr, cc = h - 1 - r, c\n595\t                    expected = raw_in[r][c]\n596\t                    if (raw_in[r][c] == fg\n597\t                            and (r, c) != (rr, cc)\n598\t                            and raw_in[rr][cc] == fg):\n599\t                        expected = marker\n600\t                    if raw_out[r][c] != expected:\n601\t                        return None\n602\t\n603\t        return {\"marker\": marker, \"foreground\": fg}\n604\t\n605\t\n606\t# ======================================================================\n607\t# DescendOperator -- placeholder for deeper KG exploration\n608\t# ======================================================================\n609\t\n610\tclass DescendOperator(Operator):\n611\t    \"\"\"\n612\t    Placeholder: moves focus to a deeper KG level when current-level\n613\t    analysis is insufficient. Not yet needed for the basic pipeline.\n614\t    \"\"\"\n615\t\n616\t    def __init__(self):\n617\t        super().__init__(\"descend\")\n618\t\n619\t    def precondition(self, wm) -> bool:\n620\t        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n621\t\n622\t    def effect(self, wm):\n623\t        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n624\t\n625\t\n626\t# ======================================================================\n627\t# PredictOperator -- apply rule to test input\n628\t# ======================================================================\n629\t\n630\tclass PredictOperator(Operator):\n631\t    \"\"\"\n632\t    Reads the best rule from active-rules and applies it to each test\n633\t    pair's input grid to produce a predicted output grid.\n634\t    \"\"\"\n635\t\n636\t    def __init__(self):\n637\t        super().__init__(\"predict\")\n638\t\n639\t    def precondition(self, wm) -> bool:\n640\t        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n641\t\n642\t    def effect(self, wm):\n643\t        task = wm.task\n644\t        active_rules = wm.s1.get(\"active-rules\")\n645\t        if not task or not active_rules:\n646\t            return\n647\t\n648\t        rule = active_rules[0]\n649\t        predictions = dict(wm.s1.get(\"predictions\") or {})\n650\t\n651\t        for i, test_pair in enumerate(task.test_pairs):\n652\t            key = f\"test_{i}\"\n653\t            if key in predictions:\n654\t                continue\n655\t            g0 = test_pair.input_grid\n656\t            if g0 is None:\n657\t                continue\n658\t            predicted = self._apply_rule(rule, g0)\n659\t            if predicted is not None:\n660\t                predictions[key] = predicted\n661\t\n662\t        wm.s1[\"predictions\"] = predictions\n663\t\n664\t    # ---- rule application dispatchers ------------------------------------\n665\t\n666\t    def _apply_rule(self, rule, input_grid):\n667\t        rule_type = rule.get(\"type\")\n668\t        if rule_type == \"recolor_sequential\":\n669\t            return self._apply_recolor_sequential(rule, input_grid)\n670\t        if rule_type == \"color_mapping\":\n671\t            return self._apply_color_mapping(rule, input_grid)\n672\t        if rule_type == \"bbox_fill\":\n673\t            return self._apply_bbox_fill(rule, input_grid)\n674\t        if rule_type == \"axis_mirror_recolor\":\n675\t            return self._apply_axis_mirror_recolor(rule, input_grid)\n676\t        if rule_type == \"identity\":\n677\t            return [row[:] for row in input_grid.raw]\n678\t        return None\n679\t\n680\t    def _apply_recolor_sequential(self, rule, input_grid):\n681\t        raw = input_grid.raw\n682\t        height = len(raw)\n683\t        width = len(raw[0]) if raw else 0\n684\t        sort_key = rule[\"sort_key\"]\n685\t        start_color = rule[\"start_color\"]\n686\t        source_colors = set(rule.get(\"source_colors\", []))\n687\t\n688\t        # Find target cells\n689\t        target_cells = []\n690\t        for r in range(height):\n691\t            for c in range(width):\n692\t                if raw[r][c] in source_colors:\n693\t                    target_cells.append((r, c))\n694\t\n695\t        if not target_cells:\n696\t            return [row[:] for row in raw]\n697\t\n698\t        # Group into connected components\n699\t        groups = self._group_positions(target_cells)\n700\t\n701\t        # Sort groups by the rule's sort key\n702\t        def _sort_val(group):\n703\t            if sort_key == \"top_row\":\n704\t                return min(r for r, c in group)\n705\t            if sort_key == \"top_col\":\n706\t                return min(c for r, c in group)\n707\t            return 0\n708\t\n709\t        sorted_groups = sorted(groups, key=_sort_val)\n710\t\n711\t        # Build output grid\n712\t        output = [row[:] for row in raw]\n713\t        for idx, group in enumerate(sorted_groups):\n714\t            new_color = start_color + idx\n715\t            for r, c in group:\n716\t                output[r][c] = new_color\n717\t\n718\t        return output\n719\t\n720\t    def _apply_color_mapping(self, rule, input_grid):\n721\t        raw = input_grid.raw\n722\t        mapping = rule.get(\"mapping\", {})\n723\t\n724\t        output = []\n725\t        for row in raw:\n726\t            output.append([mapping.get(cell, cell) for cell in row])\n727\t        return output\n728\t\n729\t    def _apply_bbox_fill(self, rule, input_grid):\n730\t        raw = input_grid.raw\n731\t        h = len(raw)\n732\t        w = len(raw[0]) if raw else 0\n733\t        marker = rule.get(\"marker\")\n734\t        fg = rule.get(\"foreground\")\n735\t        bg = rule.get(\"background\")\n736\t        if marker is None or fg is None or bg is None:\n737\t            return None\n738\t\n739\t        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n740\t        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n741\t        if not rows:\n742\t            return [row[:] for row in raw]\n743\t        r0, r1 = min(rows), max(rows)\n744\t        c0, c1 = min(cols), max(cols)\n745\t\n746\t        out = [row[:] for row in raw]\n747\t        for r in range(r0, r1 + 1):\n748\t            for c in range(c0, c1 + 1):\n749\t                if out[r][c] == bg:\n750\t                    out[r][c] = marker\n751\t        return out\n752\t\n753\t    def _apply_axis_mirror_recolor(self, rule, input_grid):\n754\t        raw = input_grid.raw\n755\t        h = len(raw)\n756\t        w = len(raw[0]) if raw else 0\n757\t        marker = rule.get(\"marker\")\n758\t        fg = rule.get(\"foreground\")\n759\t        axis = rule.get(\"axis\", \"horizontal\")\n760\t        if marker is None or fg is None:\n761\t            return None\n762\t\n763\t        out = [row[:] for row in raw]\n764\t        for r in range(h):\n765\t            for c in range(w):\n766\t                if raw[r][c] != fg:\n767\t                    continue\n768\t                if axis == \"horizontal\":\n769\t                    rr, cc = r, w - 1 - c\n770\t                else:\n771\t                    rr, cc = h - 1 - r, c\n772\t                if (r, c) == (rr, cc):\n773\t                    continue\n774\t                if raw[rr][cc] == fg:\n775\t                    out[r][c] = marker\n776\t        return out\n777\t\n778\t    # ---- helpers ---------------------------------------------------------\n779\t\n780\t    @staticmethod\n781\t    def _group_positions(positions):\n782\t        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n783\t        pos_set = set(positions)\n784\t        visited = set()\n785\t        groups = []\n786\t\n787\t        for pos in positions:\n788\t            if pos in visited:\n789\t                continue\n790\t            group = []\n791\t            queue = [pos]\n792\t            while queue:\n793\t                p = queue.pop(0)\n794\t                if p in visited or p not in pos_set:\n795\t                    continue\n796\t                visited.add(p)\n797\t                group.append(p)\n798\t                r, c = p\n799\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n800\t                    nb = (r + dr, c + dc)\n801\t                    if nb in pos_set and nb not in visited:\n802\t                        queue.append(nb)\n803\t            groups.append(group)\n804\t\n805\t        return groups\n806\t\n807\t\n808\t# ======================================================================\n809\t# SubmitOperator -- finalize and satisfy goal\n810\t# ======================================================================\n811\t\n812\tclass SubmitOperator(Operator):\n813\t    \"\"\"\n814\t    Writes predicted grids to S1 output-link in the format expected by\n815\t    run_task.py, and marks the goal as satisfied.\n816\t    \"\"\"\n817\t\n818\t    def __init__(self):\n819\t        super().__init__(\"submit\")\n820\t\n821\t    def precondition(self, wm) -> bool:\n822\t        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n823\t\n824\t    def effect(self, wm):\n825\t        predictions = wm.s1.get(\"predictions\")\n826\t        if not predictions:\n827\t            return\n828\t\n829\t        task = wm.task\n830\t        if not task:\n831\t            return\n832\t\n833\t        predicted_grids = []\n834\t        for i in range(len(task.test_pairs)):\n835\t            grid = predictions.get(f\"test_{i}\")\n836\t            if grid is not None:\n837\t                predicted_grids.append(grid)\n838\t\n839\t        if not predicted_grids:\n840\t            return\n841\t\n842\t        # Write to output-link (format expected by run_task.py)\n843\t        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n844\t        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n845\t\n846\t        # Mark goal as satisfied\n847\t        wm.s1[\"goal\"] = {\"subgoals\": {\n848\t            f\"test_{i}\": {\"status\": \"solved\"}\n849\t            for i in range(len(predicted_grids))\n850\t        }}\n851\t\n852\t\n853\tclass VerifyOperator(SubmitOperator):\n854\t    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n855\t\n856\t    def __init__(self):\n857\t        super().__init__()\n858\t        self.name = \"verify\"\n859\t"}]},"parent_tool_use_id":null,"session_id":"c666cd65-4352-4ea4-aa82-85b60e6a4fe2","uuid":"e5dc0e3b-89e8-4a51-9f24-7310b33ff427","timestamp":"2026-04-28T22:50:43.684Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"\"\"\"\nactive_operators -- SOAR Operator implementations.\n\nPipeline operators (all fire in S2, read/write S1):\n  SelectTargetOperator  -> set up comparison agenda from example pairs\n  CompareOperator       -> execute one comparison using ARCKG compare()\n  ExtractPatternOperator-> cell-level analysis of input/output changes\n  GeneralizeOperator    -> create transformation rule from patterns\n  PredictOperator       -> apply rule to test input\n  SubmitOperator        -> write prediction to output-link, satisfy goal\n\"\"\"\n\nfrom agent.operators import Operator\nfrom ARCKG.comparison import compare as arckg_compare\n\n\n# ======================================================================\n# SolveTaskOperator -- abstract top-level goal (S1)\n# ======================================================================\n\nclass SolveTaskOperator(Operator):\n    \"\"\"\n    Abstract operator at S1. Intentionally makes no WM change so\n    the cycle detects no-change and creates an S2 substate.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"solve-task\")\n        self.proposal_preference = \"+\"\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        # Intentionally empty -- triggers no-change impasse -> S2\n        return\n\n\n# ======================================================================\n# SelectTargetOperator -- set up comparison agenda\n# ======================================================================\n\nclass SelectTargetOperator(Operator):\n    \"\"\"\n    Reads wm.task to find example pairs and sets up comparison targets.\n    For each example pair: compare input grid (G0) vs output grid (G1).\n    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"select_target\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        agenda = []\n        pending = []\n\n        for idx, pair in enumerate(task.example_pairs):\n            if pair.input_grid is not None and pair.output_grid is not None:\n                spec = {\n                    \"type\": \"grid\",\n                    \"pair_idx\": idx,\n                    \"pair_type\": \"example\",\n                    \"id1\": pair.input_grid.node_id,\n                    \"id2\": pair.output_grid.node_id,\n                }\n                agenda.append(spec)\n                pending.append(spec)\n\n        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n        node_lookup = {}\n        for pair in task.example_pairs + task.test_pairs:\n            if pair.input_grid:\n                node_lookup[pair.input_grid.node_id] = pair.input_grid\n            if pair.output_grid:\n                node_lookup[pair.output_grid.node_id] = pair.output_grid\n        wm.node_lookup = node_lookup\n\n        wm.s1[\"comparison-agenda\"] = agenda\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = {}\n\n\n# ======================================================================\n# CompareOperator -- execute one comparison\n# ======================================================================\n\nclass CompareOperator(Operator):\n    \"\"\"\n    Pops one item from pending-comparisons, calls ARCKG compare(),\n    and stores the result in the comparisons dict on S1.\n    \"\"\"\n\n    def __init__(self, compare_fn=None):\n        super().__init__(\"compare\")\n        self._compare_fn = compare_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n        if not pending:\n            return\n\n        item = pending.pop(0)\n\n        # Find the actual ARCKG nodes\n        node_lookup = getattr(wm, \"node_lookup\", {})\n        node_a = node_lookup.get(item[\"id1\"])\n        node_b = node_lookup.get(item[\"id2\"])\n\n        if node_a is None or node_b is None:\n            wm.s1[\"pending-comparisons\"] = pending\n            return\n\n        # Execute comparison\n        fn = self._compare_fn or arckg_compare\n        result = fn(node_a, node_b)\n\n        # Store result keyed by type and pair index\n        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n        comparisons[key] = {\"spec\": item, \"result\": result}\n\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = comparisons\n\n\n# ======================================================================\n# ExtractPatternOperator -- cell-level transformation analysis\n# ======================================================================\n\nclass ExtractPatternOperator(Operator):\n    \"\"\"\n    Analyzes each example pair at the cell level to discover what changes\n    between input and output grids. Groups changed cells into connected\n    components and records color/position information for generalization.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"extract_pattern\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        patterns = {\n            \"grid_size_preserved\": True,\n            \"pair_analyses\": [],\n        }\n\n        for pair in task.example_pairs:\n            g0 = pair.input_grid\n            g1 = pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n\n            analysis = self._analyze_pair(g0, g1)\n            patterns[\"pair_analyses\"].append(analysis)\n\n            if g0.height != g1.height or g0.width != g1.width:\n                patterns[\"grid_size_preserved\"] = False\n\n        wm.s1[\"patterns\"] = patterns\n\n    # ---- internal helpers ------------------------------------------------\n\n    def _analyze_pair(self, g0, g1):\n        \"\"\"Cell-level diff between input and output grid.\"\"\"\n        raw_in = g0.raw\n        raw_out = g1.raw\n        h = min(len(raw_in), len(raw_out))\n        w = min(\n            len(raw_in[0]) if raw_in else 0,\n            len(raw_out[0]) if raw_out else 0,\n        )\n\n        changes = []\n        for r in range(h):\n            for c in range(w):\n                if raw_in[r][c] != raw_out[r][c]:\n                    changes.append({\n                        \"row\": r, \"col\": c,\n                        \"input_color\": raw_in[r][c],\n                        \"output_color\": raw_out[r][c],\n                    })\n\n        groups = self._group_changes(changes)\n\n        group_analyses = []\n        for group_cells in groups:\n            input_colors = set()\n            output_colors = set()\n            positions = []\n            for cell in group_cells:\n                input_colors.add(cell[\"input_color\"])\n                output_colors.add(cell[\"output_color\"])\n                positions.append((cell[\"row\"], cell[\"col\"]))\n\n            top_row = min(r for r, c in positions)\n            top_col = min(c for r, c in positions)\n\n            group_analyses.append({\n                \"input_colors\": sorted(input_colors),\n                \"output_colors\": sorted(output_colors),\n                \"top_row\": top_row,\n                \"top_col\": top_col,\n                \"cell_count\": len(group_cells),\n            })\n\n        return {\n            \"total_changes\": len(changes),\n            \"num_groups\": len(groups),\n            \"groups\": group_analyses,\n            \"size_match\": (\n                len(raw_in) == len(raw_out)\n                and (len(raw_in[0]) if raw_in else 0)\n                    == (len(raw_out[0]) if raw_out else 0)\n            ),\n        }\n\n    @staticmethod\n    def _group_changes(changes):\n        \"\"\"Group changed cells into 4-connected components.\"\"\"\n        if not changes:\n            return []\n\n        pos_to_change = {}\n        for c in changes:\n            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n\n        visited = set()\n        groups = []\n\n        for change in changes:\n            pos = (change[\"row\"], change[\"col\"])\n            if pos in visited:\n                continue\n\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_to_change:\n                    continue\n                visited.add(p)\n                group.append(pos_to_change[p])\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (p[0] + dr, p[1] + dc)\n                    if nb in pos_to_change and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# GeneralizeOperator -- rule creation from patterns\n# ======================================================================\n\nclass GeneralizeOperator(Operator):\n    \"\"\"\n    Reads extracted patterns and attempts to create a transformation rule.\n    Tries multiple strategies in priority order. If no strategy succeeds,\n    falls back to an identity rule so the pipeline can still complete.\n    \"\"\"\n\n    def __init__(self, generalize_fn=None, save_fn=None):\n        super().__init__(\"generalize\")\n        self._generalize_fn = generalize_fn\n        self._save_fn = save_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        patterns = wm.s1.get(\"patterns\")\n        if not patterns:\n            return\n\n        task = wm.task\n        example_pairs = self._collect_example_pairs(task)\n\n        rule = None\n\n        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n        rule = self._try_recolor_sequential(patterns)\n\n        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n        if rule is None:\n            rule = self._try_bbox_fill(example_pairs)\n\n        # Strategy 3: horizontal mirror recolor — recolor cells whose\n        #   horizontal-mirror partner has the same color\n        if rule is None:\n            rule = self._try_axis_mirror_recolor(example_pairs)\n\n        # Strategy 4: simple 1:1 color mapping\n        if rule is None:\n            rule = self._try_color_mapping(patterns)\n\n        # Fallback: identity (copy input as output)\n        if rule is None:\n            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n\n        wm.s1[\"active-rules\"] = [rule]\n\n    @staticmethod\n    def _collect_example_pairs(task):\n        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n        if task is None:\n            return []\n        out = []\n        for pair in task.example_pairs:\n            g0, g1 = pair.input_grid, pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n            out.append((g0.raw, g1.raw))\n        return out\n\n    # ---- strategy: sequential recoloring --------------------------------\n\n    def _try_recolor_sequential(self, patterns):\n        \"\"\"\n        Detect pattern: all changed-cell groups have one source color,\n        output colors are sequential (1,2,3,...), ordered by position.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # All pairs must have the same number of change groups\n        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n            return None\n\n        all_source_colors = set()\n\n        for analysis in pair_analyses:\n            for g in analysis[\"groups\"]:\n                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n                    return None\n                all_source_colors.add(g[\"input_colors\"][0])\n\n            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n            if out_colors != expected:\n                return None\n\n        # Try sorting by different position keys\n        for sort_key in [\"top_row\", \"top_col\"]:\n            if self._check_sort_key(pair_analyses, sort_key):\n                start_color = min(\n                    g[\"output_colors\"][0]\n                    for g in pair_analyses[0][\"groups\"]\n                )\n                return {\n                    \"type\": \"recolor_sequential\",\n                    \"sort_key\": sort_key,\n                    \"start_color\": start_color,\n                    \"source_colors\": sorted(all_source_colors),\n                    \"confidence\": 1.0,\n                }\n\n        return None\n\n    @staticmethod\n    def _check_sort_key(pair_analyses, sort_key):\n        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n        for analysis in pair_analyses:\n            groups = analysis[\"groups\"]\n            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n            if colors != list(range(colors[0], colors[0] + len(colors))):\n                return False\n        return True\n\n    # ---- strategy: simple color mapping ---------------------------------\n\n    def _try_color_mapping(self, patterns):\n        \"\"\"\n        Detect pattern: each input color consistently maps to one output color.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # Collect all observed color transitions\n        color_map = {}\n        for analysis in pair_analyses:\n            for group in analysis[\"groups\"]:\n                for ic in group[\"input_colors\"]:\n                    for oc in group[\"output_colors\"]:\n                        if ic not in color_map:\n                            color_map[ic] = set()\n                        color_map[ic].add(oc)\n\n        # Each input color must map to exactly one output color\n        simple_map = {}\n        for ic, ocs in color_map.items():\n            if len(ocs) != 1:\n                return None\n            simple_map[ic] = list(ocs)[0]\n\n        if simple_map:\n            return {\n                \"type\": \"color_mapping\",\n                \"mapping\": simple_map,\n                \"confidence\": 0.8,\n            }\n\n        return None\n\n    # ---- strategy: bounding-box fill ------------------------------------\n\n    def _try_bbox_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; output equals input except every background\n        cell within the bounding box of the foreground color has been\n        recolored to a single marker color (a color not present in input).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        marker = None\n        bg_color = None\n        fg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n                return None\n\n            in_colors = {c for row in raw_in for c in row}\n            out_colors = {c for row in raw_out for c in row}\n            new_colors = out_colors - in_colors\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            # Background = most-frequent color in input\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n\n            # Foreground = the other input color (must be exactly two)\n            fg_set = {c for c in in_colors if c != bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            # Compute bbox of foreground in input\n            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            if not rows:\n                return None\n            r0, r1 = min(rows), max(rows)\n            c0, c1 = min(cols), max(cols)\n\n            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n            for r in range(h):\n                for c in range(w):\n                    inside = r0 <= r <= r1 and c0 <= c <= c1\n                    if inside and raw_in[r][c] == bg:\n                        if raw_out[r][c] != m:\n                            return None\n                    else:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n\n            if marker is None:\n                marker, bg_color, fg_color = m, bg, fg\n            elif (m, bg, fg) != (marker, bg_color, fg_color):\n                return None\n\n        return {\n            \"type\": \"bbox_fill\",\n            \"marker\": marker,\n            \"background\": bg_color,\n            \"foreground\": fg_color,\n            \"confidence\": 1.0,\n        }\n\n    # ---- strategy: axis mirror recolor ----------------------------------\n\n    def _try_axis_mirror_recolor(self, example_pairs):\n        \"\"\"\n        Detect: same grid size, exactly one new color in output (marker).\n        For some axis (horizontal/vertical), every changed cell is the\n        original foreground color and its mirror partner along that axis\n        also has the original foreground color in the input.\n        Unchanged cells are those without a same-color mirror partner.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for axis in (\"horizontal\", \"vertical\"):\n            params = self._check_mirror_axis(example_pairs, axis)\n            if params is not None:\n                return {\n                    \"type\": \"axis_mirror_recolor\",\n                    \"axis\": axis,\n                    \"marker\": params[\"marker\"],\n                    \"foreground\": params[\"foreground\"],\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_mirror_axis(example_pairs, axis):\n        marker = None\n        fg = None\n        had_change = False\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or (w and w != len(raw_out[0])):\n                return None\n\n            new_colors = (\n                {c for row in raw_out for c in row}\n                - {c for row in raw_in for c in row}\n            )\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    in_v = raw_in[r][c]\n                    out_v = raw_out[r][c]\n                    mirror_v = raw_in[rr][cc]\n                    if out_v == in_v:\n                        # If this cell HAS a same-color mirror partner of\n                        # a non-bg color, the rule would have flipped it.\n                        # We require: not changed → no same-color partner\n                        # OR cell is on the axis and equals itself (trivial).\n                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n                            # only allow when in_v is the background\n                            # (but bg already excluded by != 0 check is rough);\n                            # we'll defer to fg check below.\n                            pass\n                        continue\n                    # Changed: must change FROM some fg TO marker, with mirror\n                    # partner also equal to fg in the input.\n                    if out_v != m:\n                        return None\n                    if in_v == 0:\n                        # background-cells turning into marker — not this rule\n                        return None\n                    if mirror_v != in_v:\n                        return None\n                    if fg is None:\n                        fg = in_v\n                    elif fg != in_v:\n                        return None\n                    had_change = True\n\n            if marker is None:\n                marker = m\n            elif marker != m:\n                return None\n\n        if not had_change or fg is None:\n            return None\n\n        # Final sanity: re-apply rule and confirm exact match.\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    expected = raw_in[r][c]\n                    if (raw_in[r][c] == fg\n                            and (r, c) != (rr, cc)\n                            and raw_in[rr][cc] == fg):\n                        expected = marker\n                    if raw_out[r][c] != expected:\n                        return None\n\n        return {\"marker\": marker, \"foreground\": fg}\n\n\n# ======================================================================\n# DescendOperator -- placeholder for deeper KG exploration\n# ======================================================================\n\nclass DescendOperator(Operator):\n    \"\"\"\n    Placeholder: moves focus to a deeper KG level when current-level\n    analysis is insufficient. Not yet needed for the basic pipeline.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"descend\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n\n\n# ======================================================================\n# PredictOperator -- apply rule to test input\n# ======================================================================\n\nclass PredictOperator(Operator):\n    \"\"\"\n    Reads the best rule from active-rules and applies it to each test\n    pair's input grid to produce a predicted output grid.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"predict\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        active_rules = wm.s1.get(\"active-rules\")\n        if not task or not active_rules:\n            return\n\n        rule = active_rules[0]\n        predictions = dict(wm.s1.get(\"predictions\") or {})\n\n        for i, test_pair in enumerate(task.test_pairs):\n            key = f\"test_{i}\"\n            if key in predictions:\n                continue\n            g0 = test_pair.input_grid\n            if g0 is None:\n                continue\n            predicted = self._apply_rule(rule, g0)\n            if predicted is not None:\n                predictions[key] = predicted\n\n        wm.s1[\"predictions\"] = predictions\n\n    # ---- rule application dispatchers ------------------------------------\n\n    def _apply_rule(self, rule, input_grid):\n        rule_type = rule.get(\"type\")\n        if rule_type == \"recolor_sequential\":\n            return self._apply_recolor_sequential(rule, input_grid)\n        if rule_type == \"color_mapping\":\n            return self._apply_color_mapping(rule, input_grid)\n        if rule_type == \"bbox_fill\":\n            return self._apply_bbox_fill(rule, input_grid)\n        if rule_type == \"axis_mirror_recolor\":\n            return self._apply_axis_mirror_recolor(rule, input_grid)\n        if rule_type == \"identity\":\n            return [row[:] for row in input_grid.raw]\n        return None\n\n    def _apply_recolor_sequential(self, rule, input_grid):\n        raw = input_grid.raw\n        height = len(raw)\n        width = len(raw[0]) if raw else 0\n        sort_key = rule[\"sort_key\"]\n        start_color = rule[\"start_color\"]\n        source_colors = set(rule.get(\"source_colors\", []))\n\n        # Find target cells\n        target_cells = []\n        for r in range(height):\n            for c in range(width):\n                if raw[r][c] in source_colors:\n                    target_cells.append((r, c))\n\n        if not target_cells:\n            return [row[:] for row in raw]\n\n        # Group into connected components\n        groups = self._group_positions(target_cells)\n\n        # Sort groups by the rule's sort key\n        def _sort_val(group):\n            if sort_key == \"top_row\":\n                return min(r for r, c in group)\n            if sort_key == \"top_col\":\n                return min(c for r, c in group)\n            return 0\n\n        sorted_groups = sorted(groups, key=_sort_val)\n\n        # Build output grid\n        output = [row[:] for row in raw]\n        for idx, group in enumerate(sorted_groups):\n            new_color = start_color + idx\n            for r, c in group:\n                output[r][c] = new_color\n\n        return output\n\n    def _apply_color_mapping(self, rule, input_grid):\n        raw = input_grid.raw\n        mapping = rule.get(\"mapping\", {})\n\n        output = []\n        for row in raw:\n            output.append([mapping.get(cell, cell) for cell in row])\n        return output\n\n    def _apply_bbox_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        bg = rule.get(\"background\")\n        if marker is None or fg is None or bg is None:\n            return None\n\n        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n        if not rows:\n            return [row[:] for row in raw]\n        r0, r1 = min(rows), max(rows)\n        c0, c1 = min(cols), max(cols)\n\n        out = [row[:] for row in raw]\n        for r in range(r0, r1 + 1):\n            for c in range(c0, c1 + 1):\n                if out[r][c] == bg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_axis_mirror_recolor(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        axis = rule.get(\"axis\", \"horizontal\")\n        if marker is None or fg is None:\n            return None\n\n        out = [row[:] for row in raw]\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != fg:\n                    continue\n                if axis == \"horizontal\":\n                    rr, cc = r, w - 1 - c\n                else:\n                    rr, cc = h - 1 - r, c\n                if (r, c) == (rr, cc):\n                    continue\n                if raw[rr][cc] == fg:\n                    out[r][c] = marker\n        return out\n\n    # ---- helpers ---------------------------------------------------------\n\n    @staticmethod\n    def _group_positions(positions):\n        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n        pos_set = set(positions)\n        visited = set()\n        groups = []\n\n        for pos in positions:\n            if pos in visited:\n                continue\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_set:\n                    continue\n                visited.add(p)\n                group.append(p)\n                r, c = p\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (r + dr, c + dc)\n                    if nb in pos_set and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# SubmitOperator -- finalize and satisfy goal\n# ======================================================================\n\nclass SubmitOperator(Operator):\n    \"\"\"\n    Writes predicted grids to S1 output-link in the format expected by\n    run_task.py, and marks the goal as satisfied.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"submit\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        predictions = wm.s1.get(\"predictions\")\n        if not predictions:\n            return\n\n        task = wm.task\n        if not task:\n            return\n\n        predicted_grids = []\n        for i in range(len(task.test_pairs)):\n            grid = predictions.get(f\"test_{i}\")\n            if grid is not None:\n                predicted_grids.append(grid)\n\n        if not predicted_grids:\n            return\n\n        # Write to output-link (format expected by run_task.py)\n        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n\n        # Mark goal as satisfied\n        wm.s1[\"goal\"] = {\"subgoals\": {\n            f\"test_{i}\": {\"status\": \"solved\"}\n            for i in range(len(predicted_grids))\n        }}\n\n\nclass VerifyOperator(SubmitOperator):\n    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n\n    def __init__(self):\n        super().__init__()\n        self.name = \"verify\"\n","numLines":859,"startLine":1,"totalLines":859}}}
