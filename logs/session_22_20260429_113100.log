{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M6vjdz8zinFjubSTjnXff5","type":"tool_result","content":"272\tclass GeneralizeOperator(Operator):\n273\t    \"\"\"\n274\t    Reads extracted patterns and attempts to create a transformation rule.\n275\t    Tries multiple strategies in priority order. If no strategy succeeds,\n276\t    falls back to an identity rule so the pipeline can still complete.\n277\t    \"\"\"\n278\t\n279\t    def __init__(self, generalize_fn=None, save_fn=None):\n280\t        super().__init__(\"generalize\")\n281\t        self._generalize_fn = generalize_fn\n282\t        self._save_fn = save_fn\n283\t\n284\t    def precondition(self, wm) -> bool:\n285\t        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n286\t\n287\t    def effect(self, wm):\n288\t        patterns = wm.s1.get(\"patterns\")\n289\t        if not patterns:\n290\t            return\n291\t\n292\t        task = wm.task\n293\t        example_pairs = self._collect_example_pairs(task)\n294\t\n295\t        rule = None\n296\t\n297\t        # Strategy 0: ricochet ray — single 'shooter' cell on a grid edge\n298\t        #   shoots a ray of its own color into the grid, ricocheting 90°\n299\t        #   off each isolated 'marker' cell. Tried first because the\n300\t        #   sequential-recolor strategy can false-positive on these tasks.\n301\t        rule = self._try_ricochet_ray(example_pairs)\n302\t\n303\t        # Strategy 0b: mirror shoot anchor — divider line splits grid into\n304\t        #   top/bottom; bottom has anchor+pointer-trail objects; top has\n305\t        #   marker cells at mirror of anchors. Output: each anchor moves\n306\t        #   to far end of its pointer trail; each marker moves to mirror\n307\t        #   of new anchor position.\n308\t        if rule is None:\n309\t            rule = self._try_mirror_shoot_anchor(example_pairs)\n310\t\n311\t        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n312\t        if rule is None:\n313\t            rule = self._try_recolor_sequential(patterns)\n314\t\n315\t        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n316\t        if rule is None:\n317\t            rule = self._try_bbox_fill(example_pairs)\n318\t\n319\t        # Strategy 3: horizontal mirror recolor — recolor cells whose\n320\t        #   horizontal-mirror partner has the same color\n321\t        if rule is None:\n322\t            rule = self._try_axis_mirror_recolor(example_pairs)\n323\t\n324\t        # Strategy 4: integer upscale — each input cell becomes a kxk block\n325\t        if rule is None:\n326\t            rule = self._try_integer_upscale(example_pairs)\n327\t\n328\t        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n329\t        if rule is None:\n330\t            rule = self._try_stack_with_mirror(example_pairs)\n331\t\n332\t        # Strategy 6: rectangle interior fill — hollow rect borders get interior\n333\t        #   filled with a color determined by interior dimensions\n334\t        if rule is None:\n335\t            rule = self._try_rect_interior_fill(example_pairs)\n336\t\n337\t        # Strategy 7: staircase extend right — 1-row input becomes a triangular\n338\t        #   stack of rows where each row's prefix grows by one cell\n339\t        if rule is None:\n340\t            rule = self._try_staircase_extend_right(example_pairs)\n341\t\n342\t        # Strategy 8: corner quadrant fill — 4 single-cell corner markers\n343\t        #   surround a solid inner rectangle which is split into quadrants\n344\t        if rule is None:\n345\t            rule = self._try_corner_quadrant_fill(example_pairs)\n346\t\n347\t        # Strategy 9: diamond connector — collinear '+'-shaped 4-cell objects\n348\t        #   are joined by lines of a marker color\n349\t        if rule is None:\n350\t            rule = self._try_diamond_connector(example_pairs)\n351\t\n352\t        # Strategy 10: axis line keep — output preserves a single row or\n353\t        #   column of the input; everything else collapses to background\n354\t        if rule is None:\n355\t            rule = self._try_axis_line_keep(example_pairs)\n356\t\n357\t        # Strategy 11: recolor by component size — single fg color split into\n358\t        #   connected components, each recolored by cell count\n359\t        if rule is None:\n360\t            rule = self._try_recolor_by_size(example_pairs)\n361\t\n362\t        # Strategy 12: rect interior marker fill — hollow-border rectangles\n363\t        #   get interior background cells filled with a constant marker color,\n364\t        #   while pre-existing foreground cells inside are preserved\n365\t        if rule is None:\n366\t            rule = self._try_rect_interior_marker_fill(example_pairs)\n367\t\n368\t        # Strategy 13: object extract + color swap — input has bg + exactly two\n369\t        #   non-background colors forming a bounded object; output is the\n370\t        #   object's bbox with the two non-bg colors swapped\n371\t        if rule is None:\n372\t            rule = self._try_object_extract_swap(example_pairs)\n373\t\n374\t        # Strategy 14: keep solid rectangles — keep only foreground components\n375\t        #   that fill their bounding box solidly with both dimensions >= 2;\n376\t        #   erase scattered/non-rectangular foreground cells to background\n377\t        if rule is None:\n378\t            rule = self._try_keep_solid_rectangles(example_pairs)\n379\t\n380\t        # Strategy 15: tile pattern vertical — input has all-bg top rows and\n381\t        #   a non-bg pattern at the bottom; output tiles the pattern upward\n382\t        #   anchored to the bottom of the grid\n383\t        if rule is None:\n384\t            rule = self._try_tile_pattern_vertical(example_pairs)\n385\t\n386\t        # Strategy 16: diagonal tail extend — input has a solid 2x2 fg block\n387\t        #   plus 1-4 tail cells at diagonal-adjacent positions; each tail is\n388\t        #   extended in its diagonal direction until the grid edge\n389\t        if rule is None:\n390\t            rule = self._try_diagonal_tail_extend(example_pairs)\n391\t\n392\t        # Strategy 17: corner diagonal 2x2 — input has a 2x2 block of 4 unique\n393\t        #   non-bg colors; output places 2x2 blocks at offsets (+/-2, +/-2)\n394\t        #   from the source's top-left, each filled with the diagonally\n395\t        #   opposite cell's color (clipped to grid bounds)\n396\t        if rule is None:\n397\t            rule = self._try_corner_diagonal_2x2(example_pairs)\n398\t\n399\t        # Strategy 18: rotational quadrants 2x — square HxH input becomes\n400\t        #   2H x 2H output with TL=input, TR=rot90 CCW, BL=rot180,\n401\t        #   BR=rot90 CW\n402\t        if rule is None:\n403\t            rule = self._try_rotational_quadrants_2x(example_pairs)\n404\t\n405\t        # Strategy 19: inside marker count 3x3 — input has bg + a rectangle\n406\t        #   border color + a third 'marker' color; output is 3x3 with N\n407\t        #   marker cells filled in row-major order (N = marker count\n408\t        #   strictly inside the rectangle)\n409\t        if rule is None:\n410\t            rule = self._try_inside_marker_count_3x3(example_pairs)\n411\t\n412\t        # Strategy 20: corner L shoot — each isolated non-bg pixel projects\n413\t        #   an L-shape (vertical + horizontal arm) to the two grid edges\n414\t        #   meeting at its nearest Manhattan corner\n415\t        if rule is None:\n416\t            rule = self._try_corner_l_shoot(example_pairs)\n417\t\n418\t        # Strategy 21: concentric ring reverse — input is concentric\n419\t        #   rectangular layers each painted in a single color; output is the\n420\t        #   same shape with the layer color order reversed\n421\t        if rule is None:\n422\t            rule = self._try_concentric_ring_reverse(example_pairs)\n423\t\n424\t        # Strategy 22: square corner marker — each connected component that\n425\t        #   forms a square (h==w>=2) and is either a complete hollow border\n426\t        #   or a solid filled block gets 8 marker cells placed orthogonally\n427\t        #   adjacent to its 4 corners (just outside the bbox)\n428\t        if rule is None:\n429\t            rule = self._try_square_corner_marker(example_pairs)\n430\t\n431\t        # Strategy 23: plus center marker — wherever a \"+\" of 8 fg cells\n432\t        #   surrounds a bg cell (offsets ±2 and ±3 on each axis), the center\n433\t        #   cell becomes a constant marker color\n434\t        if rule is None:\n435\t            rule = self._try_plus_center_marker(example_pairs)\n436\t\n437\t        # Strategy 24: rotational 4-fold kaleidoscope — output is\n438\t        #   4*H by 4*W with each 2x2 tile-quadrant filled by a rotation of\n439\t        #   input tiled 2x2: BR=identity, TR=rot90CW, TL=rot180, BL=rot90CCW\n440\t        if rule is None:\n441\t            rule = self._try_rotational_4fold(example_pairs)\n442\t\n443\t        # Strategy 25: cross zone fill — single main line + several\n444\t        #   perpendicular cross-lines partition the grid into zones; each\n445\t        #   background row/col gets its nearest cross-line color, main and\n446\t        #   intersect colors swap at intersections\n447\t        if rule is None:\n448\t            rule = self._try_cross_zone_fill(example_pairs)\n449\t\n450\t        # Strategy 26: plus majority color — input has scattered 'marker'\n451\t        #   cells whose 4 cardinal neighbors are all the same color; output\n452\t        #   is 1x1 with the most common surrounding color\n453\t        if rule is None:\n454\t            rule = self._try_plus_majority_color(example_pairs)\n455\t\n456\t        # Strategy 27: framed recolor legend — input has a 'main' multicolor\n457\t        #   bordered region plus several 2-cell pairs that act as a color\n458\t        #   recoloring legend; output is the main region's bbox recolored\n459\t        if rule is None:\n460\t            rule = self._try_framed_recolor_legend(example_pairs)\n461\t\n462\t        # Strategy 28: interior/exterior recolor — one input fill color is\n463\t        #   split into two output colors based on whether each cell is\n464\t        #   reachable from the grid border via 4-connected fill cells\n465\t        if rule is None:\n466\t            rule = self._try_interior_exterior_recolor(example_pairs)\n467\t\n468\t        # Strategy 29: grid summary corners — large grid divided by full\n469\t        #   non-bg gridlines; some intersections carry a third 'marker'\n470\t        #   color. Output is a small grid summarising which (i, j) cell\n471\t        #   of the gridded layout has all 4 corner intersections sharing\n472\t        #   one marker color\n473\t        if rule is None:\n474\t            rule = self._try_grid_summary_corners(example_pairs)\n475\t\n476\t        # Strategy 30: anchor dotted ray — each connected component is one\n477\t        #   filler color plus a single anchor cell with a unique color and\n478\t        #   exactly one open cardinal direction; output adds, per anchor, a\n479\t        #   dotted ray (every other cell) in the open direction plus a\n480\t        #   boundary edge fill of anchor color, with corner intersections of\n481\t        #   different anchors' boundary lines reset to background\n482\t        if rule is None:\n483\t            rule = self._try_anchor_dotted_ray(example_pairs)\n484\t\n485\t        # Strategy 31: directional line extract — input has two full-row and\n486\t        #   two full-column borders in 4 distinct non-bg colors framing a\n487\t        #   sub-rectangle, plus scattered 'noise' cells whose color matches\n488\t        #   exactly one border. Output is the bounded sub-rectangle, with\n489\t        #   each interior noise cell extended into a line toward its\n490\t        #   matching border.\n491\t        if rule is None:\n492\t            rule = self._try_directional_line_extract(example_pairs)\n493\t\n494\t        # Strategy 32: quadrant repair — input divided by mostly-bg row(s)\n495\t        #   and column(s) into an N×M grid of equal-size cells. A canonical\n496\t        #   pattern is derived by majority-voting cells from quadrants whose\n497\t        #   dominant color is the primary. Output: quadrants that contain\n498\t        #   the primary color get filled with all-primary; quadrants that\n499\t        #   contain no primary (only accent + noise) get the canonical\n500\t        #   pattern. Divider rows/cols become uniform background.\n501\t        if rule is None:\n502\t            rule = self._try_quadrant_repair(example_pairs)\n503\t\n504\t        # Strategy 33: panel swap — input is split by uniform-bg rows into\n505\t        #   N stacked panels, and each panel is split by a uniform-bg\n506\t        #   column into Left and Right halves. Each half has its own\n507\t        #   sub-bg color and a noise-colored shape. Output: panels where\n508\t        #   left.bg != right.bg get their shapes swapped (left receives\n509\t        #   right's shape recolored to right.bg; right receives left's\n510\t        #   shape recolored to left.bg). Panels where bgs match are\n511\t        #   cleared to bg.\n512\t        if rule is None:\n513\t            rule = self._try_panel_swap(example_pairs)\n514\t\n515\t        # Strategy 34: template replication — input has one or more \"template\"\n516\t        #   shapes (each: connector cells + unique anchor cells) and several\n517\t        #   \"scattered\" anchor cells. Output erases the templates and draws\n518\t        #   the matching template (under d8 transform) at each scattered\n519\t        #   group's anchor positions.\n520\t        if rule is None:\n521\t            rule = self._try_template_replication(example_pairs)\n522\t\n523\t        # Strategy 31: simple 1:1 color mapping\n524\t        if rule is None:\n525\t            rule = self._try_color_mapping(patterns)\n526\t\n527\t        # Fallback: identity (copy input as output)\n528\t        if rule is None:\n529\t            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n530\t\n531\t        wm.s1[\"active-rules\"] = [rule]\n532\t\n533\t    @staticmethod\n534\t    def _collect_example_pairs(task):\n535\t        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n536\t        if task is None:\n537\t            return []\n538\t        out = []\n539\t        for pair in task.example_pairs:\n540\t            g0, g1 = pair.input_grid, pair.output_grid\n541\t            if g0 is None or g1 is None:\n542\t                continue\n543\t            out.append((g0.raw, g1.raw))\n544\t        return out\n545\t\n546\t    # ---- strategy: sequential recoloring --------------------------------\n547\t\n548\t    def _try_recolor_sequential(self, patterns):\n549\t        \"\"\"\n550\t        Detect pattern: all changed-cell groups have one source color,\n551\t        output colors are sequential (1,2,3,...), ordered by position.\n552\t        \"\"\"\n553\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n554\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n555\t            return None\n556\t\n557\t        # All pairs must have the same number of change groups\n558\t        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n559\t        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n560\t            return None\n561\t\n562\t        all_source_colors = set()\n563\t\n564\t        for analysis in pair_analyses:\n565\t            for g in analysis[\"groups\"]:\n566\t                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n567\t                    return None\n568\t                all_source_colors.add(g[\"input_colors\"][0])\n569\t\n570\t            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n571\t            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n572\t            if out_colors != expected:\n573\t                return None\n574\t\n575\t        # Try sorting by different position keys\n576\t        for sort_key in [\"top_row\", \"top_col\"]:\n577\t            if self._check_sort_key(pair_analyses, sort_key):\n578\t                start_color = min(\n579\t                    g[\"output_colors\"][0]\n580\t                    for g in pair_analyses[0][\"groups\"]\n581\t                )\n582\t                return {\n583\t                    \"type\": \"recolor_sequential\",\n584\t                    \"sort_key\": sort_key,\n585\t                    \"start_color\": start_color,\n586\t                    \"source_colors\": sorted(all_source_colors),\n587\t                    \"confidence\": 1.0,\n588\t                }\n589\t\n590\t        return None\n591\t\n592\t    @staticmethod\n593\t    def _check_sort_key(pair_analyses, sort_key):\n594\t        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n595\t        for analysis in pair_analyses:\n596\t            groups = analysis[\"groups\"]\n597\t            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n598\t            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n599\t            if colors != list(range(colors[0], colors[0] + len(colors))):\n600\t                return False\n601\t        return True\n602\t\n603\t    # ---- strategy: simple color mapping ---------------------------------\n604\t\n605\t    def _try_color_mapping(self, patterns):\n606\t        \"\"\"\n607\t        Detect pattern: each input color consistently maps to one output color.\n608\t        \"\"\"\n609\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n610\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n611\t            return None"}]},"parent_tool_use_id":null,"session_id":"ec4c5e05-363c-429a-936b-49817c1e32cd","uuid":"8fae5055-4772-4fa8-971d-2d352eba2d90","timestamp":"2026-04-29T02:34:52.393Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"class GeneralizeOperator(Operator):\n    \"\"\"\n    Reads extracted patterns and attempts to create a transformation rule.\n    Tries multiple strategies in priority order. If no strategy succeeds,\n    falls back to an identity rule so the pipeline can still complete.\n    \"\"\"\n\n    def __init__(self, generalize_fn=None, save_fn=None):\n        super().__init__(\"generalize\")\n        self._generalize_fn = generalize_fn\n        self._save_fn = save_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        patterns = wm.s1.get(\"patterns\")\n        if not patterns:\n            return\n\n        task = wm.task\n        example_pairs = self._collect_example_pairs(task)\n\n        rule = None\n\n        # Strategy 0: ricochet ray — single 'shooter' cell on a grid edge\n        #   shoots a ray of its own color into the grid, ricocheting 90°\n        #   off each isolated 'marker' cell. Tried first because the\n        #   sequential-recolor strategy can false-positive on these tasks.\n        rule = self._try_ricochet_ray(example_pairs)\n\n        # Strategy 0b: mirror shoot anchor — divider line splits grid into\n        #   top/bottom; bottom has anchor+pointer-trail objects; top has\n        #   marker cells at mirror of anchors. Output: each anchor moves\n        #   to far end of its pointer trail; each marker moves to mirror\n        #   of new anchor position.\n        if rule is None:\n            rule = self._try_mirror_shoot_anchor(example_pairs)\n\n        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n        if rule is None:\n            rule = self._try_recolor_sequential(patterns)\n\n        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n        if rule is None:\n            rule = self._try_bbox_fill(example_pairs)\n\n        # Strategy 3: horizontal mirror recolor — recolor cells whose\n        #   horizontal-mirror partner has the same color\n        if rule is None:\n            rule = self._try_axis_mirror_recolor(example_pairs)\n\n        # Strategy 4: integer upscale — each input cell becomes a kxk block\n        if rule is None:\n            rule = self._try_integer_upscale(example_pairs)\n\n        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n        if rule is None:\n            rule = self._try_stack_with_mirror(example_pairs)\n\n        # Strategy 6: rectangle interior fill — hollow rect borders get interior\n        #   filled with a color determined by interior dimensions\n        if rule is None:\n            rule = self._try_rect_interior_fill(example_pairs)\n\n        # Strategy 7: staircase extend right — 1-row input becomes a triangular\n        #   stack of rows where each row's prefix grows by one cell\n        if rule is None:\n            rule = self._try_staircase_extend_right(example_pairs)\n\n        # Strategy 8: corner quadrant fill — 4 single-cell corner markers\n        #   surround a solid inner rectangle which is split into quadrants\n        if rule is None:\n            rule = self._try_corner_quadrant_fill(example_pairs)\n\n        # Strategy 9: diamond connector — collinear '+'-shaped 4-cell objects\n        #   are joined by lines of a marker color\n        if rule is None:\n            rule = self._try_diamond_connector(example_pairs)\n\n        # Strategy 10: axis line keep — output preserves a single row or\n        #   column of the input; everything else collapses to background\n        if rule is None:\n            rule = self._try_axis_line_keep(example_pairs)\n\n        # Strategy 11: recolor by component size — single fg color split into\n        #   connected components, each recolored by cell count\n        if rule is None:\n            rule = self._try_recolor_by_size(example_pairs)\n\n        # Strategy 12: rect interior marker fill — hollow-border rectangles\n        #   get interior background cells filled with a constant marker color,\n        #   while pre-existing foreground cells inside are preserved\n        if rule is None:\n            rule = self._try_rect_interior_marker_fill(example_pairs)\n\n        # Strategy 13: object extract + color swap — input has bg + exactly two\n        #   non-background colors forming a bounded object; output is the\n        #   object's bbox with the two non-bg colors swapped\n        if rule is None:\n            rule = self._try_object_extract_swap(example_pairs)\n\n        # Strategy 14: keep solid rectangles — keep only foreground components\n        #   that fill their bounding box solidly with both dimensions >= 2;\n        #   erase scattered/non-rectangular foreground cells to background\n        if rule is None:\n            rule = self._try_keep_solid_rectangles(example_pairs)\n\n        # Strategy 15: tile pattern vertical — input has all-bg top rows and\n        #   a non-bg pattern at the bottom; output tiles the pattern upward\n        #   anchored to the bottom of the grid\n        if rule is None:\n            rule = self._try_tile_pattern_vertical(example_pairs)\n\n        # Strategy 16: diagonal tail extend — input has a solid 2x2 fg block\n        #   plus 1-4 tail cells at diagonal-adjacent positions; each tail is\n        #   extended in its diagonal direction until the grid edge\n        if rule is None:\n            rule = self._try_diagonal_tail_extend(example_pairs)\n\n        # Strategy 17: corner diagonal 2x2 — input has a 2x2 block of 4 unique\n        #   non-bg colors; output places 2x2 blocks at offsets (+/-2, +/-2)\n        #   from the source's top-left, each filled with the diagonally\n        #   opposite cell's color (clipped to grid bounds)\n        if rule is None:\n            rule = self._try_corner_diagonal_2x2(example_pairs)\n\n        # Strategy 18: rotational quadrants 2x — square HxH input becomes\n        #   2H x 2H output with TL=input, TR=rot90 CCW, BL=rot180,\n        #   BR=rot90 CW\n        if rule is None:\n            rule = self._try_rotational_quadrants_2x(example_pairs)\n\n        # Strategy 19: inside marker count 3x3 — input has bg + a rectangle\n        #   border color + a third 'marker' color; output is 3x3 with N\n        #   marker cells filled in row-major order (N = marker count\n        #   strictly inside the rectangle)\n        if rule is None:\n            rule = self._try_inside_marker_count_3x3(example_pairs)\n\n        # Strategy 20: corner L shoot — each isolated non-bg pixel projects\n        #   an L-shape (vertical + horizontal arm) to the two grid edges\n        #   meeting at its nearest Manhattan corner\n        if rule is None:\n            rule = self._try_corner_l_shoot(example_pairs)\n\n        # Strategy 21: concentric ring reverse — input is concentric\n        #   rectangular layers each painted in a single color; output is the\n        #   same shape with the layer color order reversed\n        if rule is None:\n            rule = self._try_concentric_ring_reverse(example_pairs)\n\n        # Strategy 22: square corner marker — each connected component that\n        #   forms a square (h==w>=2) and is either a complete hollow border\n        #   or a solid filled block gets 8 marker cells placed orthogonally\n        #   adjacent to its 4 corners (just outside the bbox)\n        if rule is None:\n            rule = self._try_square_corner_marker(example_pairs)\n\n        # Strategy 23: plus center marker — wherever a \"+\" of 8 fg cells\n        #   surrounds a bg cell (offsets ±2 and ±3 on each axis), the center\n        #   cell becomes a constant marker color\n        if rule is None:\n            rule = self._try_plus_center_marker(example_pairs)\n\n        # Strategy 24: rotational 4-fold kaleidoscope — output is\n        #   4*H by 4*W with each 2x2 tile-quadrant filled by a rotation of\n        #   input tiled 2x2: BR=identity, TR=rot90CW, TL=rot180, BL=rot90CCW\n        if rule is None:\n            rule = self._try_rotational_4fold(example_pairs)\n\n        # Strategy 25: cross zone fill — single main line + several\n        #   perpendicular cross-lines partition the grid into zones; each\n        #   background row/col gets its nearest cross-line color, main and\n        #   intersect colors swap at intersections\n        if rule is None:\n            rule = self._try_cross_zone_fill(example_pairs)\n\n        # Strategy 26: plus majority color — input has scattered 'marker'\n        #   cells whose 4 cardinal neighbors are all the same color; output\n        #   is 1x1 with the most common surrounding color\n        if rule is None:\n            rule = self._try_plus_majority_color(example_pairs)\n\n        # Strategy 27: framed recolor legend — input has a 'main' multicolor\n        #   bordered region plus several 2-cell pairs that act as a color\n        #   recoloring legend; output is the main region's bbox recolored\n        if rule is None:\n            rule = self._try_framed_recolor_legend(example_pairs)\n\n        # Strategy 28: interior/exterior recolor — one input fill color is\n        #   split into two output colors based on whether each cell is\n        #   reachable from the grid border via 4-connected fill cells\n        if rule is None:\n            rule = self._try_interior_exterior_recolor(example_pairs)\n\n        # Strategy 29: grid summary corners — large grid divided by full\n        #   non-bg gridlines; some intersections carry a third 'marker'\n        #   color. Output is a small grid summarising which (i, j) cell\n        #   of the gridded layout has all 4 corner intersections sharing\n        #   one marker color\n        if rule is None:\n            rule = self._try_grid_summary_corners(example_pairs)\n\n        # Strategy 30: anchor dotted ray — each connected component is one\n        #   filler color plus a single anchor cell with a unique color and\n        #   exactly one open cardinal direction; output adds, per anchor, a\n        #   dotted ray (every other cell) in the open direction plus a\n        #   boundary edge fill of anchor color, with corner intersections of\n        #   different anchors' boundary lines reset to background\n        if rule is None:\n            rule = self._try_anchor_dotted_ray(example_pairs)\n\n        # Strategy 31: directional line extract — input has two full-row and\n        #   two full-column borders in 4 distinct non-bg colors framing a\n        #   sub-rectangle, plus scattered 'noise' cells whose color matches\n        #   exactly one border. Output is the bounded sub-rectangle, with\n        #   each interior noise cell extended into a line toward its\n        #   matching border.\n        if rule is None:\n            rule = self._try_directional_line_extract(example_pairs)\n\n        # Strategy 32: quadrant repair — input divided by mostly-bg row(s)\n        #   and column(s) into an N×M grid of equal-size cells. A canonical\n        #   pattern is derived by majority-voting cells from quadrants whose\n        #   dominant color is the primary. Output: quadrants that contain\n        #   the primary color get filled with all-primary; quadrants that\n        #   contain no primary (only accent + noise) get the canonical\n        #   pattern. Divider rows/cols become uniform background.\n        if rule is None:\n            rule = self._try_quadrant_repair(example_pairs)\n\n        # Strategy 33: panel swap — input is split by uniform-bg rows into\n        #   N stacked panels, and each panel is split by a uniform-bg\n        #   column into Left and Right halves. Each half has its own\n        #   sub-bg color and a noise-colored shape. Output: panels where\n        #   left.bg != right.bg get their shapes swapped (left receives\n        #   right's shape recolored to right.bg; right receives left's\n        #   shape recolored to left.bg). Panels where bgs match are\n        #   cleared to bg.\n        if rule is None:\n            rule = self._try_panel_swap(example_pairs)\n\n        # Strategy 34: template replication — input has one or more \"template\"\n        #   shapes (each: connector cells + unique anchor cells) and several\n        #   \"scattered\" anchor cells. Output erases the templates and draws\n        #   the matching template (under d8 transform) at each scattered\n        #   group's anchor positions.\n        if rule is None:\n            rule = self._try_template_replication(example_pairs)\n\n        # Strategy 31: simple 1:1 color mapping\n        if rule is None:\n            rule = self._try_color_mapping(patterns)\n\n        # Fallback: identity (copy input as output)\n        if rule is None:\n            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n\n        wm.s1[\"active-rules\"] = [rule]\n\n    @staticmethod\n    def _collect_example_pairs(task):\n        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n        if task is None:\n            return []\n        out = []\n        for pair in task.example_pairs:\n            g0, g1 = pair.input_grid, pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n            out.append((g0.raw, g1.raw))\n        return out\n\n    # ---- strategy: sequential recoloring --------------------------------\n\n    def _try_recolor_sequential(self, patterns):\n        \"\"\"\n        Detect pattern: all changed-cell groups have one source color,\n        output colors are sequential (1,2,3,...), ordered by position.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # All pairs must have the same number of change groups\n        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n            return None\n\n        all_source_colors = set()\n\n        for analysis in pair_analyses:\n            for g in analysis[\"groups\"]:\n                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n                    return None\n                all_source_colors.add(g[\"input_colors\"][0])\n\n            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n            if out_colors != expected:\n                return None\n\n        # Try sorting by different position keys\n        for sort_key in [\"top_row\", \"top_col\"]:\n            if self._check_sort_key(pair_analyses, sort_key):\n                start_color = min(\n                    g[\"output_colors\"][0]\n                    for g in pair_analyses[0][\"groups\"]\n                )\n                return {\n                    \"type\": \"recolor_sequential\",\n                    \"sort_key\": sort_key,\n                    \"start_color\": start_color,\n                    \"source_colors\": sorted(all_source_colors),\n                    \"confidence\": 1.0,\n                }\n\n        return None\n\n    @staticmethod\n    def _check_sort_key(pair_analyses, sort_key):\n        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n        for analysis in pair_analyses:\n            groups = analysis[\"groups\"]\n            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n            if colors != list(range(colors[0], colors[0] + len(colors))):\n                return False\n        return True\n\n    # ---- strategy: simple color mapping ---------------------------------\n\n    def _try_color_mapping(self, patterns):\n        \"\"\"\n        Detect pattern: each input color consistently maps to one output color.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None","numLines":340,"startLine":272,"totalLines":5530}}}
