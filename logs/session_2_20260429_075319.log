{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018WkXt8a8uqBzj2qekujTSr","type":"tool_result","content":"1\t\"\"\"\n2\tactive_operators -- SOAR Operator implementations.\n3\t\n4\tPipeline operators (all fire in S2, read/write S1):\n5\t  SelectTargetOperator  -> set up comparison agenda from example pairs\n6\t  CompareOperator       -> execute one comparison using ARCKG compare()\n7\t  ExtractPatternOperator-> cell-level analysis of input/output changes\n8\t  GeneralizeOperator    -> create transformation rule from patterns\n9\t  PredictOperator       -> apply rule to test input\n10\t  SubmitOperator        -> write prediction to output-link, satisfy goal\n11\t\"\"\"\n12\t\n13\tfrom agent.operators import Operator\n14\tfrom ARCKG.comparison import compare as arckg_compare\n15\t\n16\t\n17\t# ======================================================================\n18\t# SolveTaskOperator -- abstract top-level goal (S1)\n19\t# ======================================================================\n20\t\n21\tclass SolveTaskOperator(Operator):\n22\t    \"\"\"\n23\t    Abstract operator at S1. Intentionally makes no WM change so\n24\t    the cycle detects no-change and creates an S2 substate.\n25\t    \"\"\"\n26\t\n27\t    def __init__(self):\n28\t        super().__init__(\"solve-task\")\n29\t        self.proposal_preference = \"+\"\n30\t\n31\t    def precondition(self, wm) -> bool:\n32\t        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n33\t\n34\t    def effect(self, wm):\n35\t        # Intentionally empty -- triggers no-change impasse -> S2\n36\t        return\n37\t\n38\t\n39\t# ======================================================================\n40\t# SelectTargetOperator -- set up comparison agenda\n41\t# ======================================================================\n42\t\n43\tclass SelectTargetOperator(Operator):\n44\t    \"\"\"\n45\t    Reads wm.task to find example pairs and sets up comparison targets.\n46\t    For each example pair: compare input grid (G0) vs output grid (G1).\n47\t    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n48\t    \"\"\"\n49\t\n50\t    def __init__(self):\n51\t        super().__init__(\"select_target\")\n52\t\n53\t    def precondition(self, wm) -> bool:\n54\t        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n55\t\n56\t    def effect(self, wm):\n57\t        task = wm.task\n58\t        if task is None:\n59\t            return\n60\t\n61\t        agenda = []\n62\t        pending = []\n63\t\n64\t        for idx, pair in enumerate(task.example_pairs):\n65\t            if pair.input_grid is not None and pair.output_grid is not None:\n66\t                spec = {\n67\t                    \"type\": \"grid\",\n68\t                    \"pair_idx\": idx,\n69\t                    \"pair_type\": \"example\",\n70\t                    \"id1\": pair.input_grid.node_id,\n71\t                    \"id2\": pair.output_grid.node_id,\n72\t                }\n73\t                agenda.append(spec)\n74\t                pending.append(spec)\n75\t\n76\t        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n77\t        node_lookup = {}\n78\t        for pair in task.example_pairs + task.test_pairs:\n79\t            if pair.input_grid:\n80\t                node_lookup[pair.input_grid.node_id] = pair.input_grid\n81\t            if pair.output_grid:\n82\t                node_lookup[pair.output_grid.node_id] = pair.output_grid\n83\t        wm.node_lookup = node_lookup\n84\t\n85\t        wm.s1[\"comparison-agenda\"] = agenda\n86\t        wm.s1[\"pending-comparisons\"] = pending\n87\t        wm.s1[\"comparisons\"] = {}\n88\t\n89\t\n90\t# ======================================================================\n91\t# CompareOperator -- execute one comparison\n92\t# ======================================================================\n93\t\n94\tclass CompareOperator(Operator):\n95\t    \"\"\"\n96\t    Pops one item from pending-comparisons, calls ARCKG compare(),\n97\t    and stores the result in the comparisons dict on S1.\n98\t    \"\"\"\n99\t\n100\t    def __init__(self, compare_fn=None):\n101\t        super().__init__(\"compare\")\n102\t        self._compare_fn = compare_fn\n103\t\n104\t    def precondition(self, wm) -> bool:\n105\t        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n106\t\n107\t    def effect(self, wm):\n108\t        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n109\t        if not pending:\n110\t            return\n111\t\n112\t        item = pending.pop(0)\n113\t\n114\t        # Find the actual ARCKG nodes\n115\t        node_lookup = getattr(wm, \"node_lookup\", {})\n116\t        node_a = node_lookup.get(item[\"id1\"])\n117\t        node_b = node_lookup.get(item[\"id2\"])\n118\t\n119\t        if node_a is None or node_b is None:\n120\t            wm.s1[\"pending-comparisons\"] = pending\n121\t            return\n122\t\n123\t        # Execute comparison\n124\t        fn = self._compare_fn or arckg_compare\n125\t        result = fn(node_a, node_b)\n126\t\n127\t        # Store result keyed by type and pair index\n128\t        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n129\t        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n130\t        comparisons[key] = {\"spec\": item, \"result\": result}\n131\t\n132\t        wm.s1[\"pending-comparisons\"] = pending\n133\t        wm.s1[\"comparisons\"] = comparisons\n134\t\n135\t\n136\t# ======================================================================\n137\t# ExtractPatternOperator -- cell-level transformation analysis\n138\t# ======================================================================\n139\t\n140\tclass ExtractPatternOperator(Operator):\n141\t    \"\"\"\n142\t    Analyzes each example pair at the cell level to discover what changes\n143\t    between input and output grids. Groups changed cells into connected\n144\t    components and records color/position information for generalization.\n145\t    \"\"\"\n146\t\n147\t    def __init__(self):\n148\t        super().__init__(\"extract_pattern\")\n149\t\n150\t    def precondition(self, wm) -> bool:\n151\t        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n152\t\n153\t    def effect(self, wm):\n154\t        task = wm.task\n155\t        if task is None:\n156\t            return\n157\t\n158\t        patterns = {\n159\t            \"grid_size_preserved\": True,\n160\t            \"pair_analyses\": [],\n161\t        }\n162\t\n163\t        for pair in task.example_pairs:\n164\t            g0 = pair.input_grid\n165\t            g1 = pair.output_grid\n166\t            if g0 is None or g1 is None:\n167\t                continue\n168\t\n169\t            analysis = self._analyze_pair(g0, g1)\n170\t            patterns[\"pair_analyses\"].append(analysis)\n171\t\n172\t            if g0.height != g1.height or g0.width != g1.width:\n173\t                patterns[\"grid_size_preserved\"] = False\n174\t\n175\t        wm.s1[\"patterns\"] = patterns\n176\t\n177\t    # ---- internal helpers ------------------------------------------------\n178\t\n179\t    def _analyze_pair(self, g0, g1):\n180\t        \"\"\"Cell-level diff between input and output grid.\"\"\"\n181\t        raw_in = g0.raw\n182\t        raw_out = g1.raw\n183\t        h = min(len(raw_in), len(raw_out))\n184\t        w = min(\n185\t            len(raw_in[0]) if raw_in else 0,\n186\t            len(raw_out[0]) if raw_out else 0,\n187\t        )\n188\t\n189\t        changes = []\n190\t        for r in range(h):\n191\t            for c in range(w):\n192\t                if raw_in[r][c] != raw_out[r][c]:\n193\t                    changes.append({\n194\t                        \"row\": r, \"col\": c,\n195\t                        \"input_color\": raw_in[r][c],\n196\t                        \"output_color\": raw_out[r][c],\n197\t                    })\n198\t\n199\t        groups = self._group_changes(changes)\n200\t\n201\t        group_analyses = []\n202\t        for group_cells in groups:\n203\t            input_colors = set()\n204\t            output_colors = set()\n205\t            positions = []\n206\t            for cell in group_cells:\n207\t                input_colors.add(cell[\"input_color\"])\n208\t                output_colors.add(cell[\"output_color\"])\n209\t                positions.append((cell[\"row\"], cell[\"col\"]))\n210\t\n211\t            top_row = min(r for r, c in positions)\n212\t            top_col = min(c for r, c in positions)\n213\t\n214\t            group_analyses.append({\n215\t                \"input_colors\": sorted(input_colors),\n216\t                \"output_colors\": sorted(output_colors),\n217\t                \"top_row\": top_row,\n218\t                \"top_col\": top_col,\n219\t                \"cell_count\": len(group_cells),\n220\t            })\n221\t\n222\t        return {\n223\t            \"total_changes\": len(changes),\n224\t            \"num_groups\": len(groups),\n225\t            \"groups\": group_analyses,\n226\t            \"size_match\": (\n227\t                len(raw_in) == len(raw_out)\n228\t                and (len(raw_in[0]) if raw_in else 0)\n229\t                    == (len(raw_out[0]) if raw_out else 0)\n230\t            ),\n231\t        }\n232\t\n233\t    @staticmethod\n234\t    def _group_changes(changes):\n235\t        \"\"\"Group changed cells into 4-connected components.\"\"\"\n236\t        if not changes:\n237\t            return []\n238\t\n239\t        pos_to_change = {}\n240\t        for c in changes:\n241\t            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n242\t\n243\t        visited = set()\n244\t        groups = []\n245\t\n246\t        for change in changes:\n247\t            pos = (change[\"row\"], change[\"col\"])\n248\t            if pos in visited:\n249\t                continue\n250\t\n251\t            group = []\n252\t            queue = [pos]\n253\t            while queue:\n254\t                p = queue.pop(0)\n255\t                if p in visited or p not in pos_to_change:\n256\t                    continue\n257\t                visited.add(p)\n258\t                group.append(pos_to_change[p])\n259\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n260\t                    nb = (p[0] + dr, p[1] + dc)\n261\t                    if nb in pos_to_change and nb not in visited:\n262\t                        queue.append(nb)\n263\t            groups.append(group)\n264\t\n265\t        return groups\n266\t\n267\t\n268\t# ======================================================================\n269\t# GeneralizeOperator -- rule creation from patterns\n270\t# ======================================================================\n271\t\n272\tclass GeneralizeOperator(Operator):\n273\t    \"\"\"\n274\t    Reads extracted patterns and attempts to create a transformation rule.\n275\t    Tries multiple strategies in priority order. If no strategy succeeds,\n276\t    falls back to an identity rule so the pipeline can still complete.\n277\t    \"\"\"\n278\t\n279\t    def __init__(self, generalize_fn=None, save_fn=None):\n280\t        super().__init__(\"generalize\")\n281\t        self._generalize_fn = generalize_fn\n282\t        self._save_fn = save_fn\n283\t\n284\t    def precondition(self, wm) -> bool:\n285\t        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n286\t\n287\t    def effect(self, wm):\n288\t        patterns = wm.s1.get(\"patterns\")\n289\t        if not patterns:\n290\t            return\n291\t\n292\t        task = wm.task\n293\t        example_pairs = self._collect_example_pairs(task)\n294\t\n295\t        rule = None\n296\t\n297\t        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n298\t        rule = self._try_recolor_sequential(patterns)\n299\t\n300\t        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n301\t        if rule is None:\n302\t            rule = self._try_bbox_fill(example_pairs)\n303\t\n304\t        # Strategy 3: horizontal mirror recolor — recolor cells whose\n305\t        #   horizontal-mirror partner has the same color\n306\t        if rule is None:\n307\t            rule = self._try_axis_mirror_recolor(example_pairs)\n308\t\n309\t        # Strategy 4: integer upscale — each input cell becomes a kxk block\n310\t        if rule is None:\n311\t            rule = self._try_integer_upscale(example_pairs)\n312\t\n313\t        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n314\t        if rule is None:\n315\t            rule = self._try_stack_with_mirror(example_pairs)\n316\t\n317\t        # Strategy 6: simple 1:1 color mapping\n318\t        if rule is None:\n319\t            rule = self._try_color_mapping(patterns)\n320\t\n321\t        # Fallback: identity (copy input as output)\n322\t        if rule is None:\n323\t            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n324\t\n325\t        wm.s1[\"active-rules\"] = [rule]\n326\t\n327\t    @staticmethod\n328\t    def _collect_example_pairs(task):\n329\t        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n330\t        if task is None:\n331\t            return []\n332\t        out = []\n333\t        for pair in task.example_pairs:\n334\t            g0, g1 = pair.input_grid, pair.output_grid\n335\t            if g0 is None or g1 is None:\n336\t                continue\n337\t            out.append((g0.raw, g1.raw))\n338\t        return out\n339\t\n340\t    # ---- strategy: sequential recoloring --------------------------------\n341\t\n342\t    def _try_recolor_sequential(self, patterns):\n343\t        \"\"\"\n344\t        Detect pattern: all changed-cell groups have one source color,\n345\t        output colors are sequential (1,2,3,...), ordered by position.\n346\t        \"\"\"\n347\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n348\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n349\t            return None\n350\t\n351\t        # All pairs must have the same number of change groups\n352\t        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n353\t        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n354\t            return None\n355\t\n356\t        all_source_colors = set()\n357\t\n358\t        for analysis in pair_analyses:\n359\t            for g in analysis[\"groups\"]:\n360\t                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n361\t                    return None\n362\t                all_source_colors.add(g[\"input_colors\"][0])\n363\t\n364\t            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n365\t            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n366\t            if out_colors != expected:\n367\t                return None\n368\t\n369\t        # Try sorting by different position keys\n370\t        for sort_key in [\"top_row\", \"top_col\"]:\n371\t            if self._check_sort_key(pair_analyses, sort_key):\n372\t                start_color = min(\n373\t                    g[\"output_colors\"][0]\n374\t                    for g in pair_analyses[0][\"groups\"]\n375\t                )\n376\t                return {\n377\t                    \"type\": \"recolor_sequential\",\n378\t                    \"sort_key\": sort_key,\n379\t                    \"start_color\": start_color,\n380\t                    \"source_colors\": sorted(all_source_colors),\n381\t                    \"confidence\": 1.0,\n382\t                }\n383\t\n384\t        return None\n385\t\n386\t    @staticmethod\n387\t    def _check_sort_key(pair_analyses, sort_key):\n388\t        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n389\t        for analysis in pair_analyses:\n390\t            groups = analysis[\"groups\"]\n391\t            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n392\t            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n393\t            if colors != list(range(colors[0], colors[0] + len(colors))):\n394\t                return False\n395\t        return True\n396\t\n397\t    # ---- strategy: simple color mapping ---------------------------------\n398\t\n399\t    def _try_color_mapping(self, patterns):\n400\t        \"\"\"\n401\t        Detect pattern: each input color consistently maps to one output color.\n402\t        \"\"\"\n403\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n404\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n405\t            return None\n406\t\n407\t        # Collect all observed color transitions\n408\t        color_map = {}\n409\t        for analysis in pair_analyses:\n410\t            for group in analysis[\"groups\"]:\n411\t                for ic in group[\"input_colors\"]:\n412\t                    for oc in group[\"output_colors\"]:\n413\t                        if ic not in color_map:\n414\t                            color_map[ic] = set()\n415\t                        color_map[ic].add(oc)\n416\t\n417\t        # Each input color must map to exactly one output color\n418\t        simple_map = {}\n419\t        for ic, ocs in color_map.items():\n420\t            if len(ocs) != 1:\n421\t                return None\n422\t            simple_map[ic] = list(ocs)[0]\n423\t\n424\t        if simple_map:\n425\t            return {\n426\t                \"type\": \"color_mapping\",\n427\t                \"mapping\": simple_map,\n428\t                \"confidence\": 0.8,\n429\t            }\n430\t\n431\t        return None\n432\t\n433\t    # ---- strategy: bounding-box fill ------------------------------------\n434\t\n435\t    def _try_bbox_fill(self, example_pairs):\n436\t        \"\"\"\n437\t        Detect: same grid size; output equals input except every background\n438\t        cell within the bounding box of the foreground color has been\n439\t        recolored to a single marker color (a color not present in input).\n440\t        \"\"\"\n441\t        if not example_pairs:\n442\t            return None\n443\t\n444\t        marker = None\n445\t        bg_color = None\n446\t        fg_color = None\n447\t\n448\t        for raw_in, raw_out in example_pairs:\n449\t            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n450\t            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n451\t                return None\n452\t\n453\t            in_colors = {c for row in raw_in for c in row}\n454\t            out_colors = {c for row in raw_out for c in row}\n455\t            new_colors = out_colors - in_colors\n456\t            if len(new_colors) != 1:\n457\t                return None\n458\t            m = next(iter(new_colors))\n459\t\n460\t            # Background = most-frequent color in input\n461\t            counts = {}\n462\t            for row in raw_in:\n463\t                for c in row:\n464\t                    counts[c] = counts.get(c, 0) + 1\n465\t            bg = max(counts, key=counts.get)\n466\t\n467\t            # Foreground = the other input color (must be exactly two)\n468\t            fg_set = {c for c in in_colors if c != bg}\n469\t            if len(fg_set) != 1:\n470\t                return None\n471\t            fg = next(iter(fg_set))\n472\t\n473\t            # Compute bbox of foreground in input\n474\t            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n475\t            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n476\t            if not rows:\n477\t                return None\n478\t            r0, r1 = min(rows), max(rows)\n479\t            c0, c1 = min(cols), max(cols)\n480\t\n481\t            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n482\t            for r in range(h):\n483\t                for c in range(w):\n484\t                    inside = r0 <= r <= r1 and c0 <= c <= c1\n485\t                    if inside and raw_in[r][c] == bg:\n486\t                        if raw_out[r][c] != m:\n487\t                            return None\n488\t                    else:\n489\t                        if raw_out[r][c] != raw_in[r][c]:\n490\t                            return None\n491\t\n492\t            if marker is None:\n493\t                marker, bg_color, fg_color = m, bg, fg\n494\t            elif (m, bg, fg) != (marker, bg_color, fg_color):\n495\t                return None\n496\t\n497\t        return {\n498\t            \"type\": \"bbox_fill\",\n499\t            \"marker\": marker,\n500\t            \"background\": bg_color,\n501\t            \"foreground\": fg_color,\n502\t            \"confidence\": 1.0,\n503\t        }\n504\t\n505\t    # ---- strategy: axis mirror recolor ----------------------------------\n506\t\n507\t    def _try_axis_mirror_recolor(self, example_pairs):\n508\t        \"\"\"\n509\t        Detect: same grid size, exactly one new color in output (marker).\n510\t        For some axis (horizontal/vertical), every changed cell is the\n511\t        original foreground color and its mirror partner along that axis\n512\t        also has the original foreground color in the input.\n513\t        Unchanged cells are those without a same-color mirror partner.\n514\t        \"\"\"\n515\t        if not example_pairs:\n516\t            return None\n517\t\n518\t        for axis in (\"horizontal\", \"vertical\"):\n519\t            params = self._check_mirror_axis(example_pairs, axis)\n520\t            if params is not None:\n521\t                return {\n522\t                    \"type\": \"axis_mirror_recolor\",\n523\t                    \"axis\": axis,\n524\t                    \"marker\": params[\"marker\"],\n525\t                    \"foreground\": params[\"foreground\"],\n526\t                    \"confidence\": 1.0,\n527\t                }\n528\t        return None\n529\t\n530\t    @staticmethod\n531\t    def _check_mirror_axis(example_pairs, axis):\n532\t        marker = None\n533\t        fg = None\n534\t        had_change = False\n535\t\n536\t        for raw_in, raw_out in example_pairs:\n537\t            h = len(raw_in)\n538\t            w = len(raw_in[0]) if raw_in else 0\n539\t            if h != len(raw_out) or (w and w != len(raw_out[0])):\n540\t                return None\n541\t\n542\t            new_colors = (\n543\t                {c for row in raw_out for c in row}\n544\t                - {c for row in raw_in for c in row}\n545\t            )\n546\t            if len(new_colors) != 1:\n547\t                return None\n548\t            m = next(iter(new_colors))\n549\t\n550\t            for r in range(h):\n551\t                for c in range(w):\n552\t                    if axis == \"horizontal\":\n553\t                        rr, cc = r, w - 1 - c\n554\t                    else:\n555\t                        rr, cc = h - 1 - r, c\n556\t                    in_v = raw_in[r][c]\n557\t                    out_v = raw_out[r][c]\n558\t                    mirror_v = raw_in[rr][cc]\n559\t                    if out_v == in_v:\n560\t                        # If this cell HAS a same-color mirror partner of\n561\t                        # a non-bg color, the rule would have flipped it.\n562\t                        # We require: not changed → no same-color partner\n563\t                        # OR cell is on the axis and equals itself (trivial).\n564\t                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n565\t                            # only allow when in_v is the background\n566\t                            # (but bg already excluded by != 0 check is rough);\n567\t                            # we'll defer to fg check below.\n568\t                            pass\n569\t                        continue\n570\t                    # Changed: must change FROM some fg TO marker, with mirror\n571\t                    # partner also equal to fg in the input.\n572\t                    if out_v != m:\n573\t                        return None\n574\t                    if in_v == 0:\n575\t                        # background-cells turning into marker — not this rule\n576\t                        return None\n577\t                    if mirror_v != in_v:\n578\t                        return None\n579\t                    if fg is None:\n580\t                        fg = in_v\n581\t                    elif fg != in_v:\n582\t                        return None\n583\t                    had_change = True\n584\t\n585\t            if marker is None:\n586\t                marker = m\n587\t            elif marker != m:\n588\t                return None\n589\t\n590\t        if not had_change or fg is None:\n591\t            return None\n592\t\n593\t        # Final sanity: re-apply rule and confirm exact match.\n594\t        for raw_in, raw_out in example_pairs:\n595\t            h = len(raw_in)\n596\t            w = len(raw_in[0]) if raw_in else 0\n597\t            for r in range(h):\n598\t                for c in range(w):\n599\t                    if axis == \"horizontal\":\n600\t                        rr, cc = r, w - 1 - c\n601\t                    else:\n602\t                        rr, cc = h - 1 - r, c\n603\t                    expected = raw_in[r][c]\n604\t                    if (raw_in[r][c] == fg\n605\t                            and (r, c) != (rr, cc)\n606\t                            and raw_in[rr][cc] == fg):\n607\t                        expected = marker\n608\t                    if raw_out[r][c] != expected:\n609\t                        return None\n610\t\n611\t        return {\"marker\": marker, \"foreground\": fg}\n612\t\n613\t    # ---- strategy: integer upscale --------------------------------------\n614\t\n615\t    def _try_integer_upscale(self, example_pairs):\n616\t        \"\"\"\n617\t        Detect: output dimensions are k * input dimensions (same k for both\n618\t        height and width, and the same k across all examples). Each input\n619\t        cell at (r, c) becomes a kxk block at rows [k*r, k*r+k) and cols\n620\t        [k*c, k*c+k) in the output, all filled with the same color.\n621\t        \"\"\"\n622\t        if not example_pairs:\n623\t            return None\n624\t\n625\t        factor = None\n626\t        for raw_in, raw_out in example_pairs:\n627\t            ih = len(raw_in)\n628\t            iw = len(raw_in[0]) if raw_in else 0\n629\t            oh = len(raw_out)\n630\t            ow = len(raw_out[0]) if raw_out else 0\n631\t            if ih == 0 or iw == 0 or oh == 0 or ow == 0:\n632\t                return None\n633\t            if oh % ih != 0 or ow % iw != 0:\n634\t                return None\n635\t            kh, kw = oh // ih, ow // iw\n636\t            if kh != kw or kh < 2:\n637\t                return None\n638\t            if factor is None:\n639\t                factor = kh\n640\t            elif factor != kh:\n641\t                return None\n642\t            for r in range(ih):\n643\t                for c in range(iw):\n644\t                    v = raw_in[r][c]\n645\t                    for dr in range(factor):\n646\t                        for dc in range(factor):\n647\t                            if raw_out[r * factor + dr][c * factor + dc] != v:\n648\t                                return None\n649\t\n650\t        if factor is None:\n651\t            return None\n652\t        return {\"type\": \"integer_upscale\", \"factor\": factor, \"confidence\": 1.0}\n653\t\n654\t    # ---- strategy: stack with mirror ------------------------------------\n655\t\n656\t    def _try_stack_with_mirror(self, example_pairs):\n657\t        \"\"\"\n658\t        Detect: output = concatenation of input and a flipped copy of input\n659\t        along one axis. Tries four configurations:\n660\t          - direction=vertical,   order=input_first  (rows: input, vflip(input))\n661\t          - direction=vertical,   order=flip_first   (rows: vflip(input), input)\n662\t          - direction=horizontal, order=input_first  (cols: input, hflip(input))\n663\t          - direction=horizontal, order=flip_first   (cols: hflip(input), input)\n664\t        The same configuration must hold across every example.\n665\t        \"\"\"\n666\t        if not example_pairs:\n667\t            return None\n668\t\n669\t        configs = [\n670\t            (\"vertical\", \"input_first\"),\n671\t            (\"vertical\", \"flip_first\"),\n672\t            (\"horizontal\", \"input_first\"),\n673\t            (\"horizontal\", \"flip_first\"),\n674\t        ]\n675\t\n676\t        for direction, order in configs:\n677\t            ok = True\n678\t            for raw_in, raw_out in example_pairs:\n679\t                if not self._check_stack_mirror(raw_in, raw_out, direction, order):\n680\t                    ok = False\n681\t                    break\n682\t            if ok:\n683\t                return {\n684\t                    \"type\": \"stack_with_mirror\",\n685\t                    \"direction\": direction,\n686\t                    \"order\": order,\n687\t                    \"confidence\": 1.0,\n688\t                }\n689\t        return None\n690\t\n691\t    @staticmethod\n692\t    def _check_stack_mirror(raw_in, raw_out, direction, order):\n693\t        ih = len(raw_in)\n694\t        iw = len(raw_in[0]) if raw_in else 0\n695\t        oh = len(raw_out)\n696\t        ow = len(raw_out[0]) if raw_out else 0\n697\t        if ih == 0 or iw == 0:\n698\t            return False\n699\t\n700\t        if direction == \"vertical\":\n701\t            if ow != iw or oh != 2 * ih:\n702\t                return False\n703\t            flipped = list(reversed(raw_in))\n704\t            top = raw_in if order == \"input_first\" else flipped\n705\t            bot = flipped if order == \"input_first\" else raw_in\n706\t            for r in range(ih):\n707\t                if list(raw_out[r]) != list(top[r]):\n708\t                    return False\n709\t                if list(raw_out[ih + r]) != list(bot[r]):\n710\t                    return False\n711\t            return True\n712\t        else:  # horizontal\n713\t            if oh != ih or ow != 2 * iw:\n714\t                return False\n715\t            flipped = [list(reversed(row)) for row in raw_in]\n716\t            left = raw_in if order == \"input_first\" else flipped\n717\t            right = flipped if order == \"input_first\" else raw_in\n718\t            for r in range(ih):\n719\t                if list(raw_out[r][:iw]) != list(left[r]):\n720\t                    return False\n721\t                if list(raw_out[r][iw:]) != list(right[r]):\n722\t                    return False\n723\t            return True\n724\t\n725\t\n726\t# ======================================================================\n727\t# DescendOperator -- placeholder for deeper KG exploration\n728\t# ======================================================================\n729\t\n730\tclass DescendOperator(Operator):\n731\t    \"\"\"\n732\t    Placeholder: moves focus to a deeper KG level when current-level\n733\t    analysis is insufficient. Not yet needed for the basic pipeline.\n734\t    \"\"\"\n735\t\n736\t    def __init__(self):\n737\t        super().__init__(\"descend\")\n738\t\n739\t    def precondition(self, wm) -> bool:\n740\t        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n741\t\n742\t    def effect(self, wm):\n743\t        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n744\t\n745\t\n746\t# ======================================================================\n747\t# PredictOperator -- apply rule to test input\n748\t# ======================================================================\n749\t\n750\tclass PredictOperator(Operator):\n751\t    \"\"\"\n752\t    Reads the best rule from active-rules and applies it to each test\n753\t    pair's input grid to produce a predicted output grid.\n754\t    \"\"\"\n755\t\n756\t    def __init__(self):\n757\t        super().__init__(\"predict\")\n758\t\n759\t    def precondition(self, wm) -> bool:\n760\t        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n761\t\n762\t    def effect(self, wm):\n763\t        task = wm.task\n764\t        active_rules = wm.s1.get(\"active-rules\")\n765\t        if not task or not active_rules:\n766\t            return\n767\t\n768\t        rule = active_rules[0]\n769\t        predictions = dict(wm.s1.get(\"predictions\") or {})\n770\t\n771\t        for i, test_pair in enumerate(task.test_pairs):\n772\t            key = f\"test_{i}\"\n773\t            if key in predictions:\n774\t                continue\n775\t            g0 = test_pair.input_grid\n776\t            if g0 is None:\n777\t                continue\n778\t            predicted = self._apply_rule(rule, g0)\n779\t            if predicted is not None:\n780\t                predictions[key] = predicted\n781\t\n782\t        wm.s1[\"predictions\"] = predictions\n783\t\n784\t    # ---- rule application dispatchers ------------------------------------\n785\t\n786\t    def _apply_rule(self, rule, input_grid):\n787\t        rule_type = rule.get(\"type\")\n788\t        if rule_type == \"recolor_sequential\":\n789\t            return self._apply_recolor_sequential(rule, input_grid)\n790\t        if rule_type == \"color_mapping\":\n791\t            return self._apply_color_mapping(rule, input_grid)\n792\t        if rule_type == \"bbox_fill\":\n793\t            return self._apply_bbox_fill(rule, input_grid)\n794\t        if rule_type == \"axis_mirror_recolor\":\n795\t            return self._apply_axis_mirror_recolor(rule, input_grid)\n796\t        if rule_type == \"integer_upscale\":\n797\t            return self._apply_integer_upscale(rule, input_grid)\n798\t        if rule_type == \"stack_with_mirror\":\n799\t            return self._apply_stack_with_mirror(rule, input_grid)\n800\t        if rule_type == \"identity\":\n801\t            return [row[:] for row in input_grid.raw]\n802\t        return None\n803\t\n804\t    def _apply_recolor_sequential(self, rule, input_grid):\n805\t        raw = input_grid.raw\n806\t        height = len(raw)\n807\t        width = len(raw[0]) if raw else 0\n808\t        sort_key = rule[\"sort_key\"]\n809\t        start_color = rule[\"start_color\"]\n810\t        source_colors = set(rule.get(\"source_colors\", []))\n811\t\n812\t        # Find target cells\n813\t        target_cells = []\n814\t        for r in range(height):\n815\t            for c in range(width):\n816\t                if raw[r][c] in source_colors:\n817\t                    target_cells.append((r, c))\n818\t\n819\t        if not target_cells:\n820\t            return [row[:] for row in raw]\n821\t\n822\t        # Group into connected components\n823\t        groups = self._group_positions(target_cells)\n824\t\n825\t        # Sort groups by the rule's sort key\n826\t        def _sort_val(group):\n827\t            if sort_key == \"top_row\":\n828\t                return min(r for r, c in group)\n829\t            if sort_key == \"top_col\":\n830\t                return min(c for r, c in group)\n831\t            return 0\n832\t\n833\t        sorted_groups = sorted(groups, key=_sort_val)\n834\t\n835\t        # Build output grid\n836\t        output = [row[:] for row in raw]\n837\t        for idx, group in enumerate(sorted_groups):\n838\t            new_color = start_color + idx\n839\t            for r, c in group:\n840\t                output[r][c] = new_color\n841\t\n842\t        return output\n843\t\n844\t    def _apply_color_mapping(self, rule, input_grid):\n845\t        raw = input_grid.raw\n846\t        mapping = rule.get(\"mapping\", {})\n847\t\n848\t        output = []\n849\t        for row in raw:\n850\t            output.append([mapping.get(cell, cell) for cell in row])\n851\t        return output\n852\t\n853\t    def _apply_bbox_fill(self, rule, input_grid):\n854\t        raw = input_grid.raw\n855\t        h = len(raw)\n856\t        w = len(raw[0]) if raw else 0\n857\t        marker = rule.get(\"marker\")\n858\t        fg = rule.get(\"foreground\")\n859\t        bg = rule.get(\"background\")\n860\t        if marker is None or fg is None or bg is None:\n861\t            return None\n862\t\n863\t        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n864\t        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n865\t        if not rows:\n866\t            return [row[:] for row in raw]\n867\t        r0, r1 = min(rows), max(rows)\n868\t        c0, c1 = min(cols), max(cols)\n869\t\n870\t        out = [row[:] for row in raw]\n871\t        for r in range(r0, r1 + 1):\n872\t            for c in range(c0, c1 + 1):\n873\t                if out[r][c] == bg:\n874\t                    out[r][c] = marker\n875\t        return out\n876\t\n877\t    def _apply_axis_mirror_recolor(self, rule, input_grid):\n878\t        raw = input_grid.raw\n879\t        h = len(raw)\n880\t        w = len(raw[0]) if raw else 0\n881\t        marker = rule.get(\"marker\")\n882\t        fg = rule.get(\"foreground\")\n883\t        axis = rule.get(\"axis\", \"horizontal\")\n884\t        if marker is None or fg is None:\n885\t            return None\n886\t\n887\t        out = [row[:] for row in raw]\n888\t        for r in range(h):\n889\t            for c in range(w):\n890\t                if raw[r][c] != fg:\n891\t                    continue\n892\t                if axis == \"horizontal\":\n893\t                    rr, cc = r, w - 1 - c\n894\t                else:\n895\t                    rr, cc = h - 1 - r, c\n896\t                if (r, c) == (rr, cc):\n897\t                    continue\n898\t                if raw[rr][cc] == fg:\n899\t                    out[r][c] = marker\n900\t        return out\n901\t\n902\t    def _apply_integer_upscale(self, rule, input_grid):\n903\t        raw = input_grid.raw\n904\t        k = rule.get(\"factor\")\n905\t        if not isinstance(k, int) or k < 2:\n906\t            return None\n907\t        out = []\n908\t        for row in raw:\n909\t            new_row = []\n910\t            for v in row:\n911\t                new_row.extend([v] * k)\n912\t            for _ in range(k):\n913\t                out.append(new_row[:])\n914\t        return out\n915\t\n916\t    def _apply_stack_with_mirror(self, rule, input_grid):\n917\t        raw = input_grid.raw\n918\t        direction = rule.get(\"direction\")\n919\t        order = rule.get(\"order\")\n920\t        if direction not in (\"vertical\", \"horizontal\"):\n921\t            return None\n922\t        if order not in (\"input_first\", \"flip_first\"):\n923\t            return None\n924\t\n925\t        if direction == \"vertical\":\n926\t            flipped = list(reversed([row[:] for row in raw]))\n927\t            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n928\t            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n929\t            return [r[:] for r in top] + [r[:] for r in bot]\n930\t        else:\n931\t            flipped = [list(reversed(row)) for row in raw]\n932\t            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n933\t            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n934\t            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n935\t\n936\t    # ---- helpers ---------------------------------------------------------\n937\t\n938\t    @staticmethod\n939\t    def _group_positions(positions):\n940\t        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n941\t        pos_set = set(positions)\n942\t        visited = set()\n943\t        groups = []\n944\t\n945\t        for pos in positions:\n946\t            if pos in visited:\n947\t                continue\n948\t            group = []\n949\t            queue = [pos]\n950\t            while queue:\n951\t                p = queue.pop(0)\n952\t                if p in visited or p not in pos_set:\n953\t                    continue\n954\t                visited.add(p)\n955\t                group.append(p)\n956\t                r, c = p\n957\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n958\t                    nb = (r + dr, c + dc)\n959\t                    if nb in pos_set and nb not in visited:\n960\t                        queue.append(nb)\n961\t            groups.append(group)\n962\t\n963\t        return groups\n964\t\n965\t\n966\t# ======================================================================\n967\t# SubmitOperator -- finalize and satisfy goal\n968\t# ======================================================================\n969\t\n970\tclass SubmitOperator(Operator):\n971\t    \"\"\"\n972\t    Writes predicted grids to S1 output-link in the format expected by\n973\t    run_task.py, and marks the goal as satisfied.\n974\t    \"\"\"\n975\t\n976\t    def __init__(self):\n977\t        super().__init__(\"submit\")\n978\t\n979\t    def precondition(self, wm) -> bool:\n980\t        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n981\t\n982\t    def effect(self, wm):\n983\t        predictions = wm.s1.get(\"predictions\")\n984\t        if not predictions:\n985\t            return\n986\t\n987\t        task = wm.task\n988\t        if not task:\n989\t            return\n990\t\n991\t        predicted_grids = []\n992\t        for i in range(len(task.test_pairs)):\n993\t            grid = predictions.get(f\"test_{i}\")\n994\t            if grid is not None:\n995\t                predicted_grids.append(grid)\n996\t\n997\t        if not predicted_grids:\n998\t            return\n999\t\n1000\t        # Write to output-link (format expected by run_task.py)\n1001\t        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n1002\t        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n1003\t\n1004\t        # Mark goal as satisfied\n1005\t        wm.s1[\"goal\"] = {\"subgoals\": {\n1006\t            f\"test_{i}\": {\"status\": \"solved\"}\n1007\t            for i in range(len(predicted_grids))\n1008\t        }}\n1009\t\n1010\t\n1011\tclass VerifyOperator(SubmitOperator):\n1012\t    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n1013\t\n1014\t    def __init__(self):\n1015\t        super().__init__()\n1016\t        self.name = \"verify\"\n1017\t"}]},"parent_tool_use_id":null,"session_id":"7ce310b4-6aae-4681-86cb-d8313c221a2f","uuid":"3855a109-0d12-4bd9-b7b7-b9d647c63e2b","timestamp":"2026-04-28T22:53:34.856Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"\"\"\"\nactive_operators -- SOAR Operator implementations.\n\nPipeline operators (all fire in S2, read/write S1):\n  SelectTargetOperator  -> set up comparison agenda from example pairs\n  CompareOperator       -> execute one comparison using ARCKG compare()\n  ExtractPatternOperator-> cell-level analysis of input/output changes\n  GeneralizeOperator    -> create transformation rule from patterns\n  PredictOperator       -> apply rule to test input\n  SubmitOperator        -> write prediction to output-link, satisfy goal\n\"\"\"\n\nfrom agent.operators import Operator\nfrom ARCKG.comparison import compare as arckg_compare\n\n\n# ======================================================================\n# SolveTaskOperator -- abstract top-level goal (S1)\n# ======================================================================\n\nclass SolveTaskOperator(Operator):\n    \"\"\"\n    Abstract operator at S1. Intentionally makes no WM change so\n    the cycle detects no-change and creates an S2 substate.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"solve-task\")\n        self.proposal_preference = \"+\"\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        # Intentionally empty -- triggers no-change impasse -> S2\n        return\n\n\n# ======================================================================\n# SelectTargetOperator -- set up comparison agenda\n# ======================================================================\n\nclass SelectTargetOperator(Operator):\n    \"\"\"\n    Reads wm.task to find example pairs and sets up comparison targets.\n    For each example pair: compare input grid (G0) vs output grid (G1).\n    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"select_target\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        agenda = []\n        pending = []\n\n        for idx, pair in enumerate(task.example_pairs):\n            if pair.input_grid is not None and pair.output_grid is not None:\n                spec = {\n                    \"type\": \"grid\",\n                    \"pair_idx\": idx,\n                    \"pair_type\": \"example\",\n                    \"id1\": pair.input_grid.node_id,\n                    \"id2\": pair.output_grid.node_id,\n                }\n                agenda.append(spec)\n                pending.append(spec)\n\n        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n        node_lookup = {}\n        for pair in task.example_pairs + task.test_pairs:\n            if pair.input_grid:\n                node_lookup[pair.input_grid.node_id] = pair.input_grid\n            if pair.output_grid:\n                node_lookup[pair.output_grid.node_id] = pair.output_grid\n        wm.node_lookup = node_lookup\n\n        wm.s1[\"comparison-agenda\"] = agenda\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = {}\n\n\n# ======================================================================\n# CompareOperator -- execute one comparison\n# ======================================================================\n\nclass CompareOperator(Operator):\n    \"\"\"\n    Pops one item from pending-comparisons, calls ARCKG compare(),\n    and stores the result in the comparisons dict on S1.\n    \"\"\"\n\n    def __init__(self, compare_fn=None):\n        super().__init__(\"compare\")\n        self._compare_fn = compare_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n        if not pending:\n            return\n\n        item = pending.pop(0)\n\n        # Find the actual ARCKG nodes\n        node_lookup = getattr(wm, \"node_lookup\", {})\n        node_a = node_lookup.get(item[\"id1\"])\n        node_b = node_lookup.get(item[\"id2\"])\n\n        if node_a is None or node_b is None:\n            wm.s1[\"pending-comparisons\"] = pending\n            return\n\n        # Execute comparison\n        fn = self._compare_fn or arckg_compare\n        result = fn(node_a, node_b)\n\n        # Store result keyed by type and pair index\n        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n        comparisons[key] = {\"spec\": item, \"result\": result}\n\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = comparisons\n\n\n# ======================================================================\n# ExtractPatternOperator -- cell-level transformation analysis\n# ======================================================================\n\nclass ExtractPatternOperator(Operator):\n    \"\"\"\n    Analyzes each example pair at the cell level to discover what changes\n    between input and output grids. Groups changed cells into connected\n    components and records color/position information for generalization.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"extract_pattern\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        patterns = {\n            \"grid_size_preserved\": True,\n            \"pair_analyses\": [],\n        }\n\n        for pair in task.example_pairs:\n            g0 = pair.input_grid\n            g1 = pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n\n            analysis = self._analyze_pair(g0, g1)\n            patterns[\"pair_analyses\"].append(analysis)\n\n            if g0.height != g1.height or g0.width != g1.width:\n                patterns[\"grid_size_preserved\"] = False\n\n        wm.s1[\"patterns\"] = patterns\n\n    # ---- internal helpers ------------------------------------------------\n\n    def _analyze_pair(self, g0, g1):\n        \"\"\"Cell-level diff between input and output grid.\"\"\"\n        raw_in = g0.raw\n        raw_out = g1.raw\n        h = min(len(raw_in), len(raw_out))\n        w = min(\n            len(raw_in[0]) if raw_in else 0,\n            len(raw_out[0]) if raw_out else 0,\n        )\n\n        changes = []\n        for r in range(h):\n            for c in range(w):\n                if raw_in[r][c] != raw_out[r][c]:\n                    changes.append({\n                        \"row\": r, \"col\": c,\n                        \"input_color\": raw_in[r][c],\n                        \"output_color\": raw_out[r][c],\n                    })\n\n        groups = self._group_changes(changes)\n\n        group_analyses = []\n        for group_cells in groups:\n            input_colors = set()\n            output_colors = set()\n            positions = []\n            for cell in group_cells:\n                input_colors.add(cell[\"input_color\"])\n                output_colors.add(cell[\"output_color\"])\n                positions.append((cell[\"row\"], cell[\"col\"]))\n\n            top_row = min(r for r, c in positions)\n            top_col = min(c for r, c in positions)\n\n            group_analyses.append({\n                \"input_colors\": sorted(input_colors),\n                \"output_colors\": sorted(output_colors),\n                \"top_row\": top_row,\n                \"top_col\": top_col,\n                \"cell_count\": len(group_cells),\n            })\n\n        return {\n            \"total_changes\": len(changes),\n            \"num_groups\": len(groups),\n            \"groups\": group_analyses,\n            \"size_match\": (\n                len(raw_in) == len(raw_out)\n                and (len(raw_in[0]) if raw_in else 0)\n                    == (len(raw_out[0]) if raw_out else 0)\n            ),\n        }\n\n    @staticmethod\n    def _group_changes(changes):\n        \"\"\"Group changed cells into 4-connected components.\"\"\"\n        if not changes:\n            return []\n\n        pos_to_change = {}\n        for c in changes:\n            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n\n        visited = set()\n        groups = []\n\n        for change in changes:\n            pos = (change[\"row\"], change[\"col\"])\n            if pos in visited:\n                continue\n\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_to_change:\n                    continue\n                visited.add(p)\n                group.append(pos_to_change[p])\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (p[0] + dr, p[1] + dc)\n                    if nb in pos_to_change and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# GeneralizeOperator -- rule creation from patterns\n# ======================================================================\n\nclass GeneralizeOperator(Operator):\n    \"\"\"\n    Reads extracted patterns and attempts to create a transformation rule.\n    Tries multiple strategies in priority order. If no strategy succeeds,\n    falls back to an identity rule so the pipeline can still complete.\n    \"\"\"\n\n    def __init__(self, generalize_fn=None, save_fn=None):\n        super().__init__(\"generalize\")\n        self._generalize_fn = generalize_fn\n        self._save_fn = save_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        patterns = wm.s1.get(\"patterns\")\n        if not patterns:\n            return\n\n        task = wm.task\n        example_pairs = self._collect_example_pairs(task)\n\n        rule = None\n\n        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n        rule = self._try_recolor_sequential(patterns)\n\n        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n        if rule is None:\n            rule = self._try_bbox_fill(example_pairs)\n\n        # Strategy 3: horizontal mirror recolor — recolor cells whose\n        #   horizontal-mirror partner has the same color\n        if rule is None:\n            rule = self._try_axis_mirror_recolor(example_pairs)\n\n        # Strategy 4: integer upscale — each input cell becomes a kxk block\n        if rule is None:\n            rule = self._try_integer_upscale(example_pairs)\n\n        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n        if rule is None:\n            rule = self._try_stack_with_mirror(example_pairs)\n\n        # Strategy 6: simple 1:1 color mapping\n        if rule is None:\n            rule = self._try_color_mapping(patterns)\n\n        # Fallback: identity (copy input as output)\n        if rule is None:\n            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n\n        wm.s1[\"active-rules\"] = [rule]\n\n    @staticmethod\n    def _collect_example_pairs(task):\n        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n        if task is None:\n            return []\n        out = []\n        for pair in task.example_pairs:\n            g0, g1 = pair.input_grid, pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n            out.append((g0.raw, g1.raw))\n        return out\n\n    # ---- strategy: sequential recoloring --------------------------------\n\n    def _try_recolor_sequential(self, patterns):\n        \"\"\"\n        Detect pattern: all changed-cell groups have one source color,\n        output colors are sequential (1,2,3,...), ordered by position.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # All pairs must have the same number of change groups\n        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n            return None\n\n        all_source_colors = set()\n\n        for analysis in pair_analyses:\n            for g in analysis[\"groups\"]:\n                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n                    return None\n                all_source_colors.add(g[\"input_colors\"][0])\n\n            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n            if out_colors != expected:\n                return None\n\n        # Try sorting by different position keys\n        for sort_key in [\"top_row\", \"top_col\"]:\n            if self._check_sort_key(pair_analyses, sort_key):\n                start_color = min(\n                    g[\"output_colors\"][0]\n                    for g in pair_analyses[0][\"groups\"]\n                )\n                return {\n                    \"type\": \"recolor_sequential\",\n                    \"sort_key\": sort_key,\n                    \"start_color\": start_color,\n                    \"source_colors\": sorted(all_source_colors),\n                    \"confidence\": 1.0,\n                }\n\n        return None\n\n    @staticmethod\n    def _check_sort_key(pair_analyses, sort_key):\n        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n        for analysis in pair_analyses:\n            groups = analysis[\"groups\"]\n            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n            if colors != list(range(colors[0], colors[0] + len(colors))):\n                return False\n        return True\n\n    # ---- strategy: simple color mapping ---------------------------------\n\n    def _try_color_mapping(self, patterns):\n        \"\"\"\n        Detect pattern: each input color consistently maps to one output color.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # Collect all observed color transitions\n        color_map = {}\n        for analysis in pair_analyses:\n            for group in analysis[\"groups\"]:\n                for ic in group[\"input_colors\"]:\n                    for oc in group[\"output_colors\"]:\n                        if ic not in color_map:\n                            color_map[ic] = set()\n                        color_map[ic].add(oc)\n\n        # Each input color must map to exactly one output color\n        simple_map = {}\n        for ic, ocs in color_map.items():\n            if len(ocs) != 1:\n                return None\n            simple_map[ic] = list(ocs)[0]\n\n        if simple_map:\n            return {\n                \"type\": \"color_mapping\",\n                \"mapping\": simple_map,\n                \"confidence\": 0.8,\n            }\n\n        return None\n\n    # ---- strategy: bounding-box fill ------------------------------------\n\n    def _try_bbox_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; output equals input except every background\n        cell within the bounding box of the foreground color has been\n        recolored to a single marker color (a color not present in input).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        marker = None\n        bg_color = None\n        fg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n                return None\n\n            in_colors = {c for row in raw_in for c in row}\n            out_colors = {c for row in raw_out for c in row}\n            new_colors = out_colors - in_colors\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            # Background = most-frequent color in input\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n\n            # Foreground = the other input color (must be exactly two)\n            fg_set = {c for c in in_colors if c != bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            # Compute bbox of foreground in input\n            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            if not rows:\n                return None\n            r0, r1 = min(rows), max(rows)\n            c0, c1 = min(cols), max(cols)\n\n            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n            for r in range(h):\n                for c in range(w):\n                    inside = r0 <= r <= r1 and c0 <= c <= c1\n                    if inside and raw_in[r][c] == bg:\n                        if raw_out[r][c] != m:\n                            return None\n                    else:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n\n            if marker is None:\n                marker, bg_color, fg_color = m, bg, fg\n            elif (m, bg, fg) != (marker, bg_color, fg_color):\n                return None\n\n        return {\n            \"type\": \"bbox_fill\",\n            \"marker\": marker,\n            \"background\": bg_color,\n            \"foreground\": fg_color,\n            \"confidence\": 1.0,\n        }\n\n    # ---- strategy: axis mirror recolor ----------------------------------\n\n    def _try_axis_mirror_recolor(self, example_pairs):\n        \"\"\"\n        Detect: same grid size, exactly one new color in output (marker).\n        For some axis (horizontal/vertical), every changed cell is the\n        original foreground color and its mirror partner along that axis\n        also has the original foreground color in the input.\n        Unchanged cells are those without a same-color mirror partner.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for axis in (\"horizontal\", \"vertical\"):\n            params = self._check_mirror_axis(example_pairs, axis)\n            if params is not None:\n                return {\n                    \"type\": \"axis_mirror_recolor\",\n                    \"axis\": axis,\n                    \"marker\": params[\"marker\"],\n                    \"foreground\": params[\"foreground\"],\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_mirror_axis(example_pairs, axis):\n        marker = None\n        fg = None\n        had_change = False\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or (w and w != len(raw_out[0])):\n                return None\n\n            new_colors = (\n                {c for row in raw_out for c in row}\n                - {c for row in raw_in for c in row}\n            )\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    in_v = raw_in[r][c]\n                    out_v = raw_out[r][c]\n                    mirror_v = raw_in[rr][cc]\n                    if out_v == in_v:\n                        # If this cell HAS a same-color mirror partner of\n                        # a non-bg color, the rule would have flipped it.\n                        # We require: not changed → no same-color partner\n                        # OR cell is on the axis and equals itself (trivial).\n                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n                            # only allow when in_v is the background\n                            # (but bg already excluded by != 0 check is rough);\n                            # we'll defer to fg check below.\n                            pass\n                        continue\n                    # Changed: must change FROM some fg TO marker, with mirror\n                    # partner also equal to fg in the input.\n                    if out_v != m:\n                        return None\n                    if in_v == 0:\n                        # background-cells turning into marker — not this rule\n                        return None\n                    if mirror_v != in_v:\n                        return None\n                    if fg is None:\n                        fg = in_v\n                    elif fg != in_v:\n                        return None\n                    had_change = True\n\n            if marker is None:\n                marker = m\n            elif marker != m:\n                return None\n\n        if not had_change or fg is None:\n            return None\n\n        # Final sanity: re-apply rule and confirm exact match.\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    expected = raw_in[r][c]\n                    if (raw_in[r][c] == fg\n                            and (r, c) != (rr, cc)\n                            and raw_in[rr][cc] == fg):\n                        expected = marker\n                    if raw_out[r][c] != expected:\n                        return None\n\n        return {\"marker\": marker, \"foreground\": fg}\n\n    # ---- strategy: integer upscale --------------------------------------\n\n    def _try_integer_upscale(self, example_pairs):\n        \"\"\"\n        Detect: output dimensions are k * input dimensions (same k for both\n        height and width, and the same k across all examples). Each input\n        cell at (r, c) becomes a kxk block at rows [k*r, k*r+k) and cols\n        [k*c, k*c+k) in the output, all filled with the same color.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        factor = None\n        for raw_in, raw_out in example_pairs:\n            ih = len(raw_in)\n            iw = len(raw_in[0]) if raw_in else 0\n            oh = len(raw_out)\n            ow = len(raw_out[0]) if raw_out else 0\n            if ih == 0 or iw == 0 or oh == 0 or ow == 0:\n                return None\n            if oh % ih != 0 or ow % iw != 0:\n                return None\n            kh, kw = oh // ih, ow // iw\n            if kh != kw or kh < 2:\n                return None\n            if factor is None:\n                factor = kh\n            elif factor != kh:\n                return None\n            for r in range(ih):\n                for c in range(iw):\n                    v = raw_in[r][c]\n                    for dr in range(factor):\n                        for dc in range(factor):\n                            if raw_out[r * factor + dr][c * factor + dc] != v:\n                                return None\n\n        if factor is None:\n            return None\n        return {\"type\": \"integer_upscale\", \"factor\": factor, \"confidence\": 1.0}\n\n    # ---- strategy: stack with mirror ------------------------------------\n\n    def _try_stack_with_mirror(self, example_pairs):\n        \"\"\"\n        Detect: output = concatenation of input and a flipped copy of input\n        along one axis. Tries four configurations:\n          - direction=vertical,   order=input_first  (rows: input, vflip(input))\n          - direction=vertical,   order=flip_first   (rows: vflip(input), input)\n          - direction=horizontal, order=input_first  (cols: input, hflip(input))\n          - direction=horizontal, order=flip_first   (cols: hflip(input), input)\n        The same configuration must hold across every example.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        configs = [\n            (\"vertical\", \"input_first\"),\n            (\"vertical\", \"flip_first\"),\n            (\"horizontal\", \"input_first\"),\n            (\"horizontal\", \"flip_first\"),\n        ]\n\n        for direction, order in configs:\n            ok = True\n            for raw_in, raw_out in example_pairs:\n                if not self._check_stack_mirror(raw_in, raw_out, direction, order):\n                    ok = False\n                    break\n            if ok:\n                return {\n                    \"type\": \"stack_with_mirror\",\n                    \"direction\": direction,\n                    \"order\": order,\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_stack_mirror(raw_in, raw_out, direction, order):\n        ih = len(raw_in)\n        iw = len(raw_in[0]) if raw_in else 0\n        oh = len(raw_out)\n        ow = len(raw_out[0]) if raw_out else 0\n        if ih == 0 or iw == 0:\n            return False\n\n        if direction == \"vertical\":\n            if ow != iw or oh != 2 * ih:\n                return False\n            flipped = list(reversed(raw_in))\n            top = raw_in if order == \"input_first\" else flipped\n            bot = flipped if order == \"input_first\" else raw_in\n            for r in range(ih):\n                if list(raw_out[r]) != list(top[r]):\n                    return False\n                if list(raw_out[ih + r]) != list(bot[r]):\n                    return False\n            return True\n        else:  # horizontal\n            if oh != ih or ow != 2 * iw:\n                return False\n            flipped = [list(reversed(row)) for row in raw_in]\n            left = raw_in if order == \"input_first\" else flipped\n            right = flipped if order == \"input_first\" else raw_in\n            for r in range(ih):\n                if list(raw_out[r][:iw]) != list(left[r]):\n                    return False\n                if list(raw_out[r][iw:]) != list(right[r]):\n                    return False\n            return True\n\n\n# ======================================================================\n# DescendOperator -- placeholder for deeper KG exploration\n# ======================================================================\n\nclass DescendOperator(Operator):\n    \"\"\"\n    Placeholder: moves focus to a deeper KG level when current-level\n    analysis is insufficient. Not yet needed for the basic pipeline.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"descend\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n\n\n# ======================================================================\n# PredictOperator -- apply rule to test input\n# ======================================================================\n\nclass PredictOperator(Operator):\n    \"\"\"\n    Reads the best rule from active-rules and applies it to each test\n    pair's input grid to produce a predicted output grid.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"predict\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        active_rules = wm.s1.get(\"active-rules\")\n        if not task or not active_rules:\n            return\n\n        rule = active_rules[0]\n        predictions = dict(wm.s1.get(\"predictions\") or {})\n\n        for i, test_pair in enumerate(task.test_pairs):\n            key = f\"test_{i}\"\n            if key in predictions:\n                continue\n            g0 = test_pair.input_grid\n            if g0 is None:\n                continue\n            predicted = self._apply_rule(rule, g0)\n            if predicted is not None:\n                predictions[key] = predicted\n\n        wm.s1[\"predictions\"] = predictions\n\n    # ---- rule application dispatchers ------------------------------------\n\n    def _apply_rule(self, rule, input_grid):\n        rule_type = rule.get(\"type\")\n        if rule_type == \"recolor_sequential\":\n            return self._apply_recolor_sequential(rule, input_grid)\n        if rule_type == \"color_mapping\":\n            return self._apply_color_mapping(rule, input_grid)\n        if rule_type == \"bbox_fill\":\n            return self._apply_bbox_fill(rule, input_grid)\n        if rule_type == \"axis_mirror_recolor\":\n            return self._apply_axis_mirror_recolor(rule, input_grid)\n        if rule_type == \"integer_upscale\":\n            return self._apply_integer_upscale(rule, input_grid)\n        if rule_type == \"stack_with_mirror\":\n            return self._apply_stack_with_mirror(rule, input_grid)\n        if rule_type == \"identity\":\n            return [row[:] for row in input_grid.raw]\n        return None\n\n    def _apply_recolor_sequential(self, rule, input_grid):\n        raw = input_grid.raw\n        height = len(raw)\n        width = len(raw[0]) if raw else 0\n        sort_key = rule[\"sort_key\"]\n        start_color = rule[\"start_color\"]\n        source_colors = set(rule.get(\"source_colors\", []))\n\n        # Find target cells\n        target_cells = []\n        for r in range(height):\n            for c in range(width):\n                if raw[r][c] in source_colors:\n                    target_cells.append((r, c))\n\n        if not target_cells:\n            return [row[:] for row in raw]\n\n        # Group into connected components\n        groups = self._group_positions(target_cells)\n\n        # Sort groups by the rule's sort key\n        def _sort_val(group):\n            if sort_key == \"top_row\":\n                return min(r for r, c in group)\n            if sort_key == \"top_col\":\n                return min(c for r, c in group)\n            return 0\n\n        sorted_groups = sorted(groups, key=_sort_val)\n\n        # Build output grid\n        output = [row[:] for row in raw]\n        for idx, group in enumerate(sorted_groups):\n            new_color = start_color + idx\n            for r, c in group:\n                output[r][c] = new_color\n\n        return output\n\n    def _apply_color_mapping(self, rule, input_grid):\n        raw = input_grid.raw\n        mapping = rule.get(\"mapping\", {})\n\n        output = []\n        for row in raw:\n            output.append([mapping.get(cell, cell) for cell in row])\n        return output\n\n    def _apply_bbox_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        bg = rule.get(\"background\")\n        if marker is None or fg is None or bg is None:\n            return None\n\n        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n        if not rows:\n            return [row[:] for row in raw]\n        r0, r1 = min(rows), max(rows)\n        c0, c1 = min(cols), max(cols)\n\n        out = [row[:] for row in raw]\n        for r in range(r0, r1 + 1):\n            for c in range(c0, c1 + 1):\n                if out[r][c] == bg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_axis_mirror_recolor(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        axis = rule.get(\"axis\", \"horizontal\")\n        if marker is None or fg is None:\n            return None\n\n        out = [row[:] for row in raw]\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != fg:\n                    continue\n                if axis == \"horizontal\":\n                    rr, cc = r, w - 1 - c\n                else:\n                    rr, cc = h - 1 - r, c\n                if (r, c) == (rr, cc):\n                    continue\n                if raw[rr][cc] == fg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_integer_upscale(self, rule, input_grid):\n        raw = input_grid.raw\n        k = rule.get(\"factor\")\n        if not isinstance(k, int) or k < 2:\n            return None\n        out = []\n        for row in raw:\n            new_row = []\n            for v in row:\n                new_row.extend([v] * k)\n            for _ in range(k):\n                out.append(new_row[:])\n        return out\n\n    def _apply_stack_with_mirror(self, rule, input_grid):\n        raw = input_grid.raw\n        direction = rule.get(\"direction\")\n        order = rule.get(\"order\")\n        if direction not in (\"vertical\", \"horizontal\"):\n            return None\n        if order not in (\"input_first\", \"flip_first\"):\n            return None\n\n        if direction == \"vertical\":\n            flipped = list(reversed([row[:] for row in raw]))\n            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [r[:] for r in top] + [r[:] for r in bot]\n        else:\n            flipped = [list(reversed(row)) for row in raw]\n            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n\n    # ---- helpers ---------------------------------------------------------\n\n    @staticmethod\n    def _group_positions(positions):\n        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n        pos_set = set(positions)\n        visited = set()\n        groups = []\n\n        for pos in positions:\n            if pos in visited:\n                continue\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_set:\n                    continue\n                visited.add(p)\n                group.append(p)\n                r, c = p\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (r + dr, c + dc)\n                    if nb in pos_set and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# SubmitOperator -- finalize and satisfy goal\n# ======================================================================\n\nclass SubmitOperator(Operator):\n    \"\"\"\n    Writes predicted grids to S1 output-link in the format expected by\n    run_task.py, and marks the goal as satisfied.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"submit\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        predictions = wm.s1.get(\"predictions\")\n        if not predictions:\n            return\n\n        task = wm.task\n        if not task:\n            return\n\n        predicted_grids = []\n        for i in range(len(task.test_pairs)):\n            grid = predictions.get(f\"test_{i}\")\n            if grid is not None:\n                predicted_grids.append(grid)\n\n        if not predicted_grids:\n            return\n\n        # Write to output-link (format expected by run_task.py)\n        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n\n        # Mark goal as satisfied\n        wm.s1[\"goal\"] = {\"subgoals\": {\n            f\"test_{i}\": {\"status\": \"solved\"}\n            for i in range(len(predicted_grids))\n        }}\n\n\nclass VerifyOperator(SubmitOperator):\n    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n\n    def __init__(self):\n        super().__init__()\n        self.name = \"verify\"\n","numLines":1017,"startLine":1,"totalLines":1017}}}
