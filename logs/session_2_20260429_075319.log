{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WVP5bTwqNJjeD32YzBd94A","type":"tool_result","content":"1\t\"\"\"\n2\tSingle task execution script — for inner loop success criteria evaluation.\n3\tpython run_task.py\n4\t\n5\tSuccess criteria: output contains \"CORRECT\"\n6\t\"\"\"\n7\t\n8\timport sys\n9\timport argparse\n10\timport traceback\n11\t\n12\t\n13\tMAX_STEPS = 500  # Allow enough iterations until goal is achieved\n14\t\n15\t\n16\tdef main():\n17\t    parser = argparse.ArgumentParser(description=\"Run SOAR pipeline on a single task\")\n18\t    parser.add_argument(\"task\", nargs=\"?\", default=\"08ed6ac7\",\n19\t                        help=\"Task ID (e.g. easy0001) or full filename without .json\")\n20\t    args = parser.parse_args()\n21\t    TASK_HEX = args.task.replace(\".json\", \"\")\n22\t\n23\t    print(f\"=== run_task: {TASK_HEX} ===\\n\")\n24\t\n25\t    # 1. Load task\n26\t    print(\"[*] Loading task...\")\n27\t    try:\n28\t        from basics.viz import show_task\n29\t        from managers.arc_manager import ARCManager\n30\t\n31\t        manager = ARCManager(data_root=\"data\", semantic_memory_root=\"semantic_memory\")\n32\t        task = manager.load_task(TASK_HEX)\n33\t        print(f\"    Task: {task}\")\n34\t        show_task(task)\n35\t\n36\t    except Exception:\n37\t        print(\"[!] Task loading failed:\")\n38\t        traceback.print_exc()\n39\t        sys.exit(1)\n40\t\n41\t    print(\"\\n[*] WM + SOAR cycle (Elaborate -> Propose -> Select -> Apply)...\")\n42\t    try:\n43\t        from agent.wm import WorkingMemory\n44\t        from agent.wm_logger import print_wm_triplets, reset_wm_snapshot\n45\t        from agent.io import inject_arc_task\n46\t        from agent.elaboration_rules import build_elaborator\n47\t        from agent.rules import build_proposer\n48\t        from agent.cycle import run_cycle\n49\t\n50\t        wm = WorkingMemory()\n51\t\n52\t        reset_wm_snapshot(wm)\n53\t        print_wm_triplets(wm, label=\"Initial WM (before input)\", step=0)\n54\t\n55\t        inject_arc_task(task, wm)\n56\t        print_wm_triplets(wm, label=\"After input-link injection (before cycle)\", step=0)\n57\t\n58\t        elaborator = build_elaborator()\n59\t        proposer = build_proposer()\n60\t\n61\t        out = run_cycle(\n62\t            wm,\n63\t            elaborator,\n64\t            proposer,\n65\t            max_steps=MAX_STEPS,\n66\t            stop_on_goal=True,\n67\t            log_wm=True,\n68\t        )\n69\t        print(f\"\\n[cycle] {out}\")\n70\t\n71\t    except Exception:\n72\t        print(\"[!] WM / cycle failed:\")\n73\t        traceback.print_exc()\n74\t        _print_result(False, error=True)\n75\t        sys.exit(1)\n76\t\n77\t    # 2. Result evaluation\n78\t    # Extract submitted answer from wm\n79\t    try:\n80\t        predicted = _extract_prediction(wm)\n81\t        answer = _load_answer(task)\n82\t        correct = _check_correct(predicted, answer)\n83\t        _show_output(task, predicted, answer, correct)\n84\t        _print_result(correct)\n85\t        sys.exit(0 if correct else 1)\n86\t\n87\t    except Exception:\n88\t        print(\"[!] Result evaluation failed:\")\n89\t        traceback.print_exc()\n90\t        _print_result(False, error=True)\n91\t        sys.exit(1)\n92\t\n93\t\n94\tdef _extract_prediction(wm):\n95\t    \"\"\"\n96\t    Extract the predicted grid from the WM output-link.\n97\t    SubmitOperator must write the result to the following slots:\n98\t      (S1 ^output-link O_out)\n99\t      (O_out ^predicted-grid [[...], [...], ...])\n100\t    Returns None until implemented.\n101\t    \"\"\"\n102\t    try:\n103\t        s1 = wm.get(\"S1\")\n104\t        output_link_id = s1.get(\"output-link\")\n105\t        if not output_link_id:\n106\t            return None\n107\t        output_node = wm.get(output_link_id)\n108\t        if not output_node:\n109\t            return None\n110\t        return output_node.get(\"predicted-grid\")\n111\t    except Exception:\n112\t        return None\n113\t\n114\t\n115\tdef _load_answer(task):\n116\t    \"\"\"\n117\t    Extract the correct output grid from the task object's test pairs.\n118\t    Returns a list if there are multiple test pairs.\n119\t    \"\"\"\n120\t    answers = []\n121\t    for pair in task.test_pairs:\n122\t        if hasattr(pair, \"output\") and pair.output is not None:\n123\t            answers.append(pair.output.contents)\n124\t    return answers if answers else None\n125\t\n126\t\n127\tdef _check_correct(predicted, answer):\n128\t    \"\"\"\n129\t    predicted: predicted grid (list[list[int]] or list of them)\n130\t    answer:    list of correct grids\n131\t    Returns True only on exact match.\n132\t    \"\"\"\n133\t    if predicted is None or answer is None:\n134\t        return False\n135\t    # Wrap in a list if a single grid was provided\n136\t    if predicted and not isinstance(predicted[0], list):\n137\t        predicted = [predicted]\n138\t    if len(predicted) != len(answer):\n139\t        return False\n140\t    for pred, ans in zip(predicted, answer):\n141\t        if pred != ans:\n142\t            return False\n143\t    return True\n144\t\n145\t\n146\tdef _show_output(task, predicted, answer, correct):\n147\t    \"\"\"Display predicted output vs expected answer side by side.\"\"\"\n148\t    from basics.viz import _print_side_by_side\n149\t\n150\t    if predicted is None:\n151\t        print(\"\\n[output] No prediction produced.\")\n152\t        return\n153\t\n154\t    # Normalize to list of grids\n155\t    pred_grids = predicted\n156\t    if pred_grids and not isinstance(pred_grids[0], list):\n157\t        pred_grids = [pred_grids]\n158\t\n159\t    ans_grids = answer if answer else []\n160\t\n161\t    print(\"\\n\" + \"-\" * 40)\n162\t    for i in range(max(len(pred_grids), len(ans_grids))):\n163\t        test_input = task.test_pairs[i].input_grid.raw if i < len(task.test_pairs) else None\n164\t        pred = pred_grids[i] if i < len(pred_grids) else None\n165\t        ans = ans_grids[i] if i < len(ans_grids) else None\n166\t\n167\t        label_parts = []\n168\t        grids = []\n169\t\n170\t        if test_input is not None:\n171\t            label_parts.append(\"input\")\n172\t            grids.append(test_input)\n173\t        if pred is not None:\n174\t            label_parts.append(\"predicted\")\n175\t            grids.append(pred)\n176\t        if ans is not None:\n177\t            label_parts.append(\"answer\")\n178\t            grids.append(ans)\n179\t\n180\t        match_str = \" << MATCH\" if pred == ans else \" << MISMATCH\"\n181\t        print(f\"  test_{i}:  {'  |  '.join(label_parts)}{match_str}\")\n182\t        if grids:\n183\t            _print_side_by_side(grids, gap=6)\n184\t    print(\"-\" * 40)\n185\t\n186\t\n187\tdef _print_result(correct: bool, error: bool = False):\n188\t    print(\"\\n\" + \"=\" * 40)\n189\t    if error:\n190\t        print(\"RESULT  : ERROR (unable to evaluate)\")\n191\t    elif correct:\n192\t        print(\"RESULT  : CORRECT\")\n193\t    else:\n194\t        print(\"RESULT  : INCORRECT\")\n195\t    print(\"=\" * 40)\n196\t\n197\t\n198\tif __name__ == \"__main__\":\n199\t    main()"}]},"parent_tool_use_id":null,"session_id":"7ce310b4-6aae-4681-86cb-d8313c221a2f","uuid":"fbbfcc14-e77d-41a8-8e90-e922198fa60c","timestamp":"2026-04-28T22:55:13.875Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/run_task.py","content":"\"\"\"\nSingle task execution script — for inner loop success criteria evaluation.\npython run_task.py\n\nSuccess criteria: output contains \"CORRECT\"\n\"\"\"\n\nimport sys\nimport argparse\nimport traceback\n\n\nMAX_STEPS = 500  # Allow enough iterations until goal is achieved\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Run SOAR pipeline on a single task\")\n    parser.add_argument(\"task\", nargs=\"?\", default=\"08ed6ac7\",\n                        help=\"Task ID (e.g. easy0001) or full filename without .json\")\n    args = parser.parse_args()\n    TASK_HEX = args.task.replace(\".json\", \"\")\n\n    print(f\"=== run_task: {TASK_HEX} ===\\n\")\n\n    # 1. Load task\n    print(\"[*] Loading task...\")\n    try:\n        from basics.viz import show_task\n        from managers.arc_manager import ARCManager\n\n        manager = ARCManager(data_root=\"data\", semantic_memory_root=\"semantic_memory\")\n        task = manager.load_task(TASK_HEX)\n        print(f\"    Task: {task}\")\n        show_task(task)\n\n    except Exception:\n        print(\"[!] Task loading failed:\")\n        traceback.print_exc()\n        sys.exit(1)\n\n    print(\"\\n[*] WM + SOAR cycle (Elaborate -> Propose -> Select -> Apply)...\")\n    try:\n        from agent.wm import WorkingMemory\n        from agent.wm_logger import print_wm_triplets, reset_wm_snapshot\n        from agent.io import inject_arc_task\n        from agent.elaboration_rules import build_elaborator\n        from agent.rules import build_proposer\n        from agent.cycle import run_cycle\n\n        wm = WorkingMemory()\n\n        reset_wm_snapshot(wm)\n        print_wm_triplets(wm, label=\"Initial WM (before input)\", step=0)\n\n        inject_arc_task(task, wm)\n        print_wm_triplets(wm, label=\"After input-link injection (before cycle)\", step=0)\n\n        elaborator = build_elaborator()\n        proposer = build_proposer()\n\n        out = run_cycle(\n            wm,\n            elaborator,\n            proposer,\n            max_steps=MAX_STEPS,\n            stop_on_goal=True,\n            log_wm=True,\n        )\n        print(f\"\\n[cycle] {out}\")\n\n    except Exception:\n        print(\"[!] WM / cycle failed:\")\n        traceback.print_exc()\n        _print_result(False, error=True)\n        sys.exit(1)\n\n    # 2. Result evaluation\n    # Extract submitted answer from wm\n    try:\n        predicted = _extract_prediction(wm)\n        answer = _load_answer(task)\n        correct = _check_correct(predicted, answer)\n        _show_output(task, predicted, answer, correct)\n        _print_result(correct)\n        sys.exit(0 if correct else 1)\n\n    except Exception:\n        print(\"[!] Result evaluation failed:\")\n        traceback.print_exc()\n        _print_result(False, error=True)\n        sys.exit(1)\n\n\ndef _extract_prediction(wm):\n    \"\"\"\n    Extract the predicted grid from the WM output-link.\n    SubmitOperator must write the result to the following slots:\n      (S1 ^output-link O_out)\n      (O_out ^predicted-grid [[...], [...], ...])\n    Returns None until implemented.\n    \"\"\"\n    try:\n        s1 = wm.get(\"S1\")\n        output_link_id = s1.get(\"output-link\")\n        if not output_link_id:\n            return None\n        output_node = wm.get(output_link_id)\n        if not output_node:\n            return None\n        return output_node.get(\"predicted-grid\")\n    except Exception:\n        return None\n\n\ndef _load_answer(task):\n    \"\"\"\n    Extract the correct output grid from the task object's test pairs.\n    Returns a list if there are multiple test pairs.\n    \"\"\"\n    answers = []\n    for pair in task.test_pairs:\n        if hasattr(pair, \"output\") and pair.output is not None:\n            answers.append(pair.output.contents)\n    return answers if answers else None\n\n\ndef _check_correct(predicted, answer):\n    \"\"\"\n    predicted: predicted grid (list[list[int]] or list of them)\n    answer:    list of correct grids\n    Returns True only on exact match.\n    \"\"\"\n    if predicted is None or answer is None:\n        return False\n    # Wrap in a list if a single grid was provided\n    if predicted and not isinstance(predicted[0], list):\n        predicted = [predicted]\n    if len(predicted) != len(answer):\n        return False\n    for pred, ans in zip(predicted, answer):\n        if pred != ans:\n            return False\n    return True\n\n\ndef _show_output(task, predicted, answer, correct):\n    \"\"\"Display predicted output vs expected answer side by side.\"\"\"\n    from basics.viz import _print_side_by_side\n\n    if predicted is None:\n        print(\"\\n[output] No prediction produced.\")\n        return\n\n    # Normalize to list of grids\n    pred_grids = predicted\n    if pred_grids and not isinstance(pred_grids[0], list):\n        pred_grids = [pred_grids]\n\n    ans_grids = answer if answer else []\n\n    print(\"\\n\" + \"-\" * 40)\n    for i in range(max(len(pred_grids), len(ans_grids))):\n        test_input = task.test_pairs[i].input_grid.raw if i < len(task.test_pairs) else None\n        pred = pred_grids[i] if i < len(pred_grids) else None\n        ans = ans_grids[i] if i < len(ans_grids) else None\n\n        label_parts = []\n        grids = []\n\n        if test_input is not None:\n            label_parts.append(\"input\")\n            grids.append(test_input)\n        if pred is not None:\n            label_parts.append(\"predicted\")\n            grids.append(pred)\n        if ans is not None:\n            label_parts.append(\"answer\")\n            grids.append(ans)\n\n        match_str = \" << MATCH\" if pred == ans else \" << MISMATCH\"\n        print(f\"  test_{i}:  {'  |  '.join(label_parts)}{match_str}\")\n        if grids:\n            _print_side_by_side(grids, gap=6)\n    print(\"-\" * 40)\n\n\ndef _print_result(correct: bool, error: bool = False):\n    print(\"\\n\" + \"=\" * 40)\n    if error:\n        print(\"RESULT  : ERROR (unable to evaluate)\")\n    elif correct:\n        print(\"RESULT  : CORRECT\")\n    else:\n        print(\"RESULT  : INCORRECT\")\n    print(\"=\" * 40)\n\n\nif __name__ == \"__main__\":\n    main()","numLines":199,"startLine":1,"totalLines":199}}}
