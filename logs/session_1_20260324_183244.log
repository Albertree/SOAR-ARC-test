  49Ôćĺ        print_wm_triplets(wm, label=\"After input-link injection (before cycle)\", step=0)\n    50Ôćĺ\n    51Ôćĺ        elaborator = build_elaborator()\n    52Ôćĺ        proposer = build_proposer()\n    53Ôćĺ\n    54Ôćĺ        out = run_cycle(\n    55Ôćĺ            wm,\n    56Ôćĺ            elaborator,\n    57Ôćĺ            proposer,\n    58Ôćĺ            max_steps=MAX_STEPS,\n    59Ôćĺ            stop_on_goal=True,\n    60Ôćĺ            log_wm=True,\n    61Ôćĺ        )\n    62Ôćĺ        print(f\"\\n[cycle] {out}\")\n    63Ôćĺ\n    64Ôćĺ    except Exception:\n    65Ôćĺ        print(\"[!] WM / cycle failed:\")\n    66Ôćĺ        traceback.print_exc()\n    67Ôćĺ        _print_result(False, error=True)\n    68Ôćĺ        sys.exit(1)\n    69Ôćĺ\n    70Ôćĺ    # 2. Result evaluation\n    71Ôćĺ    # Extract submitted answer from wm\n    72Ôćĺ    try:\n    73Ôćĺ        predicted = _extract_prediction(wm)\n    74Ôćĺ        answer = _load_answer(task)\n    75Ôćĺ        correct = _check_correct(predicted, answer)\n    76Ôćĺ        _print_result(correct)\n    77Ôćĺ        sys.exit(0 if correct else 1)\n    78Ôćĺ\n    79Ôćĺ    except Exception:\n    80Ôćĺ        print(\"[!] Result evaluation failed:\")\n    81Ôćĺ        traceback.print_exc()\n    82Ôćĺ        _print_result(False, error=True)\n    83Ôćĺ        sys.exit(1)\n    84Ôćĺ\n    85Ôćĺ\n    86Ôćĺdef _extract_prediction(wm):\n    87Ôćĺ    \"\"\"\n    88Ôćĺ    Extract the predicted grid from the WM output-link.\n    89Ôćĺ    SubmitOperator must write the result to the following slots:\n    90Ôćĺ      (S1 ^output-link O_out)\n    91Ôćĺ      (O_out ^predicted-grid [[...], [...], ...])\n    92Ôćĺ    Returns None until implemented.\n    93Ôćĺ    \"\"\"\n    94Ôćĺ    try:\n    95Ôćĺ        s1 = wm.get(\"S1\")\n    96Ôćĺ        output_link_id = s1.get(\"output-link\")\n    97Ôćĺ        if not output_link_id:\n    98Ôćĺ            return None\n    99Ôćĺ        output_node = wm.get(output_link_id)\n   100Ôćĺ        if not output_node:\n   101Ôćĺ            return None\n   102Ôćĺ        return output_node.get(\"predicted-grid\")\n   103Ôćĺ    except Exception:\n   104Ôćĺ        return None\n   105Ôćĺ\n   106Ôćĺ\n   107Ôćĺdef _load_answer(task):\n   108Ôćĺ    \"\"\"\n   109Ôćĺ    Extract the correct output grid from the task object's test pairs.\n   110Ôćĺ    Returns a list if there are multiple test pairs.\n   111Ôćĺ    \"\"\"\n   112Ôćĺ    answers = []\n   113Ôćĺ    for pair in task.test_pairs:\n   114Ôćĺ        if hasattr(pair, \"output\") and pair.output is not None:\n   115Ôćĺ            answers.append(pair.output.contents)\n   116Ôćĺ    return answers if answers else None\n   117Ôćĺ\n   118Ôćĺ\n   119Ôćĺdef _check_correct(predicted, answer):\n   120Ôćĺ    \"\"\"\n   121Ôćĺ    predicted: predicted grid (list[list[int]] or list of them)\n   122Ôćĺ    answer:    list of correct grids\n   123Ôćĺ    Returns True only on exact match.\n   124Ôćĺ    \"\"\"\n   125Ôćĺ    if predicted is None or answer is None:\n   126Ôćĺ        return False\n   127Ôćĺ    # Wrap in a list if a single grid was provided\n   128Ôćĺ    if predicted and not isinstance(predicted[0], list):\n   129Ôćĺ        predicted = [predicted]\n   130Ôćĺ    if len(predicted) != len(answer):\n   131Ôćĺ        return False\n   132Ôćĺ    for pred, ans in zip(predicted, answer):\n   133Ôćĺ        if pred != ans:\n   134Ôćĺ            return False\n   135Ôćĺ    return True\n   136Ôćĺ\n   137Ôćĺ\n   138Ôćĺdef _print_result(correct: bool, error: bool = False):\n   139Ôćĺ    print(\"\\n\" + \"=\" * 40)\n   140Ôćĺ    if error:\n   141Ôćĺ        print(\"RESULT  : ERROR (unable to evaluate)\")\n   142Ôćĺ    elif correct:\n   143Ôćĺ        print(\"RESULT  : CORRECT Ôťů\")\n   144Ôćĺ    else:\n   145Ôćĺ        print(\"RESULT  : INCORRECT ÔŁî\")\n   146Ôćĺ    print(\"=\" * 40)\n   147Ôćĺ\n   148Ôćĺ\n   149Ôćĺif __name__ == \"__main__\":\n   150Ôćĺ    main()"}]},"parent_tool_use_id":null,"session_id":"257de878-fc9d-48ea-9f06-060eecd20b6c","uui