{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NtJdqgFy7yK8ZFGrCVWYkP","type":"tool_result","content":"1\t\"\"\"\n2\tactive_operators -- SOAR Operator implementations.\n3\t\n4\tPipeline operators (all fire in S2, read/write S1):\n5\t  SelectTargetOperator  -> set up comparison agenda from example pairs\n6\t  CompareOperator       -> execute one comparison using ARCKG compare()\n7\t  ExtractPatternOperator-> cell-level analysis of input/output changes\n8\t  GeneralizeOperator    -> create transformation rule from patterns\n9\t  PredictOperator       -> apply rule to test input\n10\t  SubmitOperator        -> write prediction to output-link, satisfy goal\n11\t\"\"\"\n12\t\n13\tfrom agent.operators import Operator\n14\tfrom ARCKG.comparison import compare as arckg_compare\n15\t\n16\t\n17\t# ======================================================================\n18\t# SolveTaskOperator -- abstract top-level goal (S1)\n19\t# ======================================================================\n20\t\n21\tclass SolveTaskOperator(Operator):\n22\t    \"\"\"\n23\t    Abstract operator at S1. Intentionally makes no WM change so\n24\t    the cycle detects no-change and creates an S2 substate.\n25\t    \"\"\"\n26\t\n27\t    def __init__(self):\n28\t        super().__init__(\"solve-task\")\n29\t        self.proposal_preference = \"+\"\n30\t\n31\t    def precondition(self, wm) -> bool:\n32\t        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n33\t\n34\t    def effect(self, wm):\n35\t        # Intentionally empty -- triggers no-change impasse -> S2\n36\t        return\n37\t\n38\t\n39\t# ======================================================================\n40\t# SelectTargetOperator -- set up comparison agenda\n41\t# ======================================================================\n42\t\n43\tclass SelectTargetOperator(Operator):\n44\t    \"\"\"\n45\t    Reads wm.task to find example pairs and sets up comparison targets.\n46\t    For each example pair: compare input grid (G0) vs output grid (G1).\n47\t    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n48\t    \"\"\"\n49\t\n50\t    def __init__(self):\n51\t        super().__init__(\"select_target\")\n52\t\n53\t    def precondition(self, wm) -> bool:\n54\t        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n55\t\n56\t    def effect(self, wm):\n57\t        task = wm.task\n58\t        if task is None:\n59\t            return\n60\t\n61\t        agenda = []\n62\t        pending = []\n63\t\n64\t        for idx, pair in enumerate(task.example_pairs):\n65\t            if pair.input_grid is not None and pair.output_grid is not None:\n66\t                spec = {\n67\t                    \"type\": \"grid\",\n68\t                    \"pair_idx\": idx,\n69\t                    \"pair_type\": \"example\",\n70\t                    \"id1\": pair.input_grid.node_id,\n71\t                    \"id2\": pair.output_grid.node_id,\n72\t                }\n73\t                agenda.append(spec)\n74\t                pending.append(spec)\n75\t\n76\t        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n77\t        node_lookup = {}\n78\t        for pair in task.example_pairs + task.test_pairs:\n79\t            if pair.input_grid:\n80\t                node_lookup[pair.input_grid.node_id] = pair.input_grid\n81\t            if pair.output_grid:\n82\t                node_lookup[pair.output_grid.node_id] = pair.output_grid\n83\t        wm.node_lookup = node_lookup\n84\t\n85\t        wm.s1[\"comparison-agenda\"] = agenda\n86\t        wm.s1[\"pending-comparisons\"] = pending\n87\t        wm.s1[\"comparisons\"] = {}\n88\t\n89\t\n90\t# ======================================================================\n91\t# CompareOperator -- execute one comparison\n92\t# ======================================================================\n93\t\n94\tclass CompareOperator(Operator):\n95\t    \"\"\"\n96\t    Pops one item from pending-comparisons, calls ARCKG compare(),\n97\t    and stores the result in the comparisons dict on S1.\n98\t    \"\"\"\n99\t\n100\t    def __init__(self, compare_fn=None):\n101\t        super().__init__(\"compare\")\n102\t        self._compare_fn = compare_fn\n103\t\n104\t    def precondition(self, wm) -> bool:\n105\t        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n106\t\n107\t    def effect(self, wm):\n108\t        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n109\t        if not pending:\n110\t            return\n111\t\n112\t        item = pending.pop(0)\n113\t\n114\t        # Find the actual ARCKG nodes\n115\t        node_lookup = getattr(wm, \"node_lookup\", {})\n116\t        node_a = node_lookup.get(item[\"id1\"])\n117\t        node_b = node_lookup.get(item[\"id2\"])\n118\t\n119\t        if node_a is None or node_b is None:\n120\t            wm.s1[\"pending-comparisons\"] = pending\n121\t            return\n122\t\n123\t        # Execute comparison\n124\t        fn = self._compare_fn or arckg_compare\n125\t        result = fn(node_a, node_b)\n126\t\n127\t        # Store result keyed by type and pair index\n128\t        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n129\t        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n130\t        comparisons[key] = {\"spec\": item, \"result\": result}\n131\t\n132\t        wm.s1[\"pending-comparisons\"] = pending\n133\t        wm.s1[\"comparisons\"] = comparisons\n134\t\n135\t\n136\t# ======================================================================\n137\t# ExtractPatternOperator -- cell-level transformation analysis\n138\t# ======================================================================\n139\t\n140\tclass ExtractPatternOperator(Operator):\n141\t    \"\"\"\n142\t    Analyzes each example pair at the cell level to discover what changes\n143\t    between input and output grids. Groups changed cells into connected\n144\t    components and records color/position information for generalization.\n145\t    \"\"\"\n146\t\n147\t    def __init__(self):\n148\t        super().__init__(\"extract_pattern\")\n149\t\n150\t    def precondition(self, wm) -> bool:\n151\t        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n152\t\n153\t    def effect(self, wm):\n154\t        task = wm.task\n155\t        if task is None:\n156\t            return\n157\t\n158\t        patterns = {\n159\t            \"grid_size_preserved\": True,\n160\t            \"pair_analyses\": [],\n161\t        }\n162\t\n163\t        for pair in task.example_pairs:\n164\t            g0 = pair.input_grid\n165\t            g1 = pair.output_grid\n166\t            if g0 is None or g1 is None:\n167\t                continue\n168\t\n169\t            analysis = self._analyze_pair(g0, g1)\n170\t            patterns[\"pair_analyses\"].append(analysis)\n171\t\n172\t            if g0.height != g1.height or g0.width != g1.width:\n173\t                patterns[\"grid_size_preserved\"] = False\n174\t\n175\t        wm.s1[\"patterns\"] = patterns\n176\t\n177\t    # ---- internal helpers ------------------------------------------------\n178\t\n179\t    def _analyze_pair(self, g0, g1):\n180\t        \"\"\"Cell-level diff between input and output grid.\"\"\"\n181\t        raw_in = g0.raw\n182\t        raw_out = g1.raw\n183\t        h = min(len(raw_in), len(raw_out))\n184\t        w = min(\n185\t            len(raw_in[0]) if raw_in else 0,\n186\t            len(raw_out[0]) if raw_out else 0,\n187\t        )\n188\t\n189\t        changes = []\n190\t        for r in range(h):\n191\t            for c in range(w):\n192\t                if raw_in[r][c] != raw_out[r][c]:\n193\t                    changes.append({\n194\t                        \"row\": r, \"col\": c,\n195\t                        \"input_color\": raw_in[r][c],\n196\t                        \"output_color\": raw_out[r][c],\n197\t                    })\n198\t\n199\t        groups = self._group_changes(changes)\n200\t\n201\t        group_analyses = []\n202\t        for group_cells in groups:\n203\t            input_colors = set()\n204\t            output_colors = set()\n205\t            positions = []\n206\t            for cell in group_cells:\n207\t                input_colors.add(cell[\"input_color\"])\n208\t                output_colors.add(cell[\"output_color\"])\n209\t                positions.append((cell[\"row\"], cell[\"col\"]))\n210\t\n211\t            top_row = min(r for r, c in positions)\n212\t            top_col = min(c for r, c in positions)\n213\t\n214\t            group_analyses.append({\n215\t                \"input_colors\": sorted(input_colors),\n216\t                \"output_colors\": sorted(output_colors),\n217\t                \"top_row\": top_row,\n218\t                \"top_col\": top_col,\n219\t                \"cell_count\": len(group_cells),\n220\t            })\n221\t\n222\t        return {\n223\t            \"total_changes\": len(changes),\n224\t            \"num_groups\": len(groups),\n225\t            \"groups\": group_analyses,\n226\t            \"size_match\": (\n227\t                len(raw_in) == len(raw_out)\n228\t                and (len(raw_in[0]) if raw_in else 0)\n229\t                    == (len(raw_out[0]) if raw_out else 0)\n230\t            ),\n231\t        }\n232\t\n233\t    @staticmethod\n234\t    def _group_changes(changes):\n235\t        \"\"\"Group changed cells into 4-connected components.\"\"\"\n236\t        if not changes:\n237\t            return []\n238\t\n239\t        pos_to_change = {}\n240\t        for c in changes:\n241\t            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n242\t\n243\t        visited = set()\n244\t        groups = []\n245\t\n246\t        for change in changes:\n247\t            pos = (change[\"row\"], change[\"col\"])\n248\t            if pos in visited:\n249\t                continue\n250\t\n251\t            group = []\n252\t            queue = [pos]\n253\t            while queue:\n254\t                p = queue.pop(0)\n255\t                if p in visited or p not in pos_to_change:\n256\t                    continue\n257\t                visited.add(p)\n258\t                group.append(pos_to_change[p])\n259\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n260\t                    nb = (p[0] + dr, p[1] + dc)\n261\t                    if nb in pos_to_change and nb not in visited:\n262\t                        queue.append(nb)\n263\t            groups.append(group)\n264\t\n265\t        return groups\n266\t\n267\t\n268\t# ======================================================================\n269\t# GeneralizeOperator -- rule creation from patterns\n270\t# ======================================================================\n271\t\n272\tclass GeneralizeOperator(Operator):\n273\t    \"\"\"\n274\t    Reads extracted patterns and attempts to create a transformation rule.\n275\t    Tries multiple strategies in priority order. If no strategy succeeds,\n276\t    falls back to an identity rule so the pipeline can still complete.\n277\t    \"\"\"\n278\t\n279\t    def __init__(self, generalize_fn=None, save_fn=None):\n280\t        super().__init__(\"generalize\")\n281\t        self._generalize_fn = generalize_fn\n282\t        self._save_fn = save_fn\n283\t\n284\t    def precondition(self, wm) -> bool:\n285\t        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n286\t\n287\t    def effect(self, wm):\n288\t        patterns = wm.s1.get(\"patterns\")\n289\t        if not patterns:\n290\t            return\n291\t\n292\t        task = wm.task\n293\t        example_pairs = self._collect_example_pairs(task)\n294\t\n295\t        rule = None\n296\t\n297\t        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n298\t        rule = self._try_recolor_sequential(patterns)\n299\t\n300\t        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n301\t        if rule is None:\n302\t            rule = self._try_bbox_fill(example_pairs)\n303\t\n304\t        # Strategy 3: horizontal mirror recolor — recolor cells whose\n305\t        #   horizontal-mirror partner has the same color\n306\t        if rule is None:\n307\t            rule = self._try_axis_mirror_recolor(example_pairs)\n308\t\n309\t        # Strategy 4: integer upscale — each input cell becomes a kxk block\n310\t        if rule is None:\n311\t            rule = self._try_integer_upscale(example_pairs)\n312\t\n313\t        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n314\t        if rule is None:\n315\t            rule = self._try_stack_with_mirror(example_pairs)\n316\t\n317\t        # Strategy 6: rectangle interior fill — hollow rect borders get interior\n318\t        #   filled with a color determined by interior dimensions\n319\t        if rule is None:\n320\t            rule = self._try_rect_interior_fill(example_pairs)\n321\t\n322\t        # Strategy 7: staircase extend right — 1-row input becomes a triangular\n323\t        #   stack of rows where each row's prefix grows by one cell\n324\t        if rule is None:\n325\t            rule = self._try_staircase_extend_right(example_pairs)\n326\t\n327\t        # Strategy 8: corner quadrant fill — 4 single-cell corner markers\n328\t        #   surround a solid inner rectangle which is split into quadrants\n329\t        if rule is None:\n330\t            rule = self._try_corner_quadrant_fill(example_pairs)\n331\t\n332\t        # Strategy 9: diamond connector — collinear '+'-shaped 4-cell objects\n333\t        #   are joined by lines of a marker color\n334\t        if rule is None:\n335\t            rule = self._try_diamond_connector(example_pairs)\n336\t\n337\t        # Strategy 10: simple 1:1 color mapping\n338\t        if rule is None:\n339\t            rule = self._try_color_mapping(patterns)\n340\t\n341\t        # Fallback: identity (copy input as output)\n342\t        if rule is None:\n343\t            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n344\t\n345\t        wm.s1[\"active-rules\"] = [rule]\n346\t\n347\t    @staticmethod\n348\t    def _collect_example_pairs(task):\n349\t        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n350\t        if task is None:\n351\t            return []\n352\t        out = []\n353\t        for pair in task.example_pairs:\n354\t            g0, g1 = pair.input_grid, pair.output_grid\n355\t            if g0 is None or g1 is None:\n356\t                continue\n357\t            out.append((g0.raw, g1.raw))\n358\t        return out\n359\t\n360\t    # ---- strategy: sequential recoloring --------------------------------\n361\t\n362\t    def _try_recolor_sequential(self, patterns):\n363\t        \"\"\"\n364\t        Detect pattern: all changed-cell groups have one source color,\n365\t        output colors are sequential (1,2,3,...), ordered by position.\n366\t        \"\"\"\n367\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n368\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n369\t            return None\n370\t\n371\t        # All pairs must have the same number of change groups\n372\t        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n373\t        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n374\t            return None\n375\t\n376\t        all_source_colors = set()\n377\t\n378\t        for analysis in pair_analyses:\n379\t            for g in analysis[\"groups\"]:\n380\t                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n381\t                    return None\n382\t                all_source_colors.add(g[\"input_colors\"][0])\n383\t\n384\t            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n385\t            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n386\t            if out_colors != expected:\n387\t                return None\n388\t\n389\t        # Try sorting by different position keys\n390\t        for sort_key in [\"top_row\", \"top_col\"]:\n391\t            if self._check_sort_key(pair_analyses, sort_key):\n392\t                start_color = min(\n393\t                    g[\"output_colors\"][0]\n394\t                    for g in pair_analyses[0][\"groups\"]\n395\t                )\n396\t                return {\n397\t                    \"type\": \"recolor_sequential\",\n398\t                    \"sort_key\": sort_key,\n399\t                    \"start_color\": start_color,\n400\t                    \"source_colors\": sorted(all_source_colors),\n401\t                    \"confidence\": 1.0,\n402\t                }\n403\t\n404\t        return None\n405\t\n406\t    @staticmethod\n407\t    def _check_sort_key(pair_analyses, sort_key):\n408\t        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n409\t        for analysis in pair_analyses:\n410\t            groups = analysis[\"groups\"]\n411\t            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n412\t            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n413\t            if colors != list(range(colors[0], colors[0] + len(colors))):\n414\t                return False\n415\t        return True\n416\t\n417\t    # ---- strategy: simple color mapping ---------------------------------\n418\t\n419\t    def _try_color_mapping(self, patterns):\n420\t        \"\"\"\n421\t        Detect pattern: each input color consistently maps to one output color.\n422\t        \"\"\"\n423\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n424\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n425\t            return None\n426\t\n427\t        # Collect all observed color transitions\n428\t        color_map = {}\n429\t        for analysis in pair_analyses:\n430\t            for group in analysis[\"groups\"]:\n431\t                for ic in group[\"input_colors\"]:\n432\t                    for oc in group[\"output_colors\"]:\n433\t                        if ic not in color_map:\n434\t                            color_map[ic] = set()\n435\t                        color_map[ic].add(oc)\n436\t\n437\t        # Each input color must map to exactly one output color\n438\t        simple_map = {}\n439\t        for ic, ocs in color_map.items():\n440\t            if len(ocs) != 1:\n441\t                return None\n442\t            simple_map[ic] = list(ocs)[0]\n443\t\n444\t        if simple_map:\n445\t            return {\n446\t                \"type\": \"color_mapping\",\n447\t                \"mapping\": simple_map,\n448\t                \"confidence\": 0.8,\n449\t            }\n450\t\n451\t        return None\n452\t\n453\t    # ---- strategy: bounding-box fill ------------------------------------\n454\t\n455\t    def _try_bbox_fill(self, example_pairs):\n456\t        \"\"\"\n457\t        Detect: same grid size; output equals input except every background\n458\t        cell within the bounding box of the foreground color has been\n459\t        recolored to a single marker color (a color not present in input).\n460\t        \"\"\"\n461\t        if not example_pairs:\n462\t            return None\n463\t\n464\t        marker = None\n465\t        bg_color = None\n466\t        fg_color = None\n467\t\n468\t        for raw_in, raw_out in example_pairs:\n469\t            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n470\t            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n471\t                return None\n472\t\n473\t            in_colors = {c for row in raw_in for c in row}\n474\t            out_colors = {c for row in raw_out for c in row}\n475\t            new_colors = out_colors - in_colors\n476\t            if len(new_colors) != 1:\n477\t                return None\n478\t            m = next(iter(new_colors))\n479\t\n480\t            # Background = most-frequent color in input\n481\t            counts = {}\n482\t            for row in raw_in:\n483\t                for c in row:\n484\t                    counts[c] = counts.get(c, 0) + 1\n485\t            bg = max(counts, key=counts.get)\n486\t\n487\t            # Foreground = the other input color (must be exactly two)\n488\t            fg_set = {c for c in in_colors if c != bg}\n489\t            if len(fg_set) != 1:\n490\t                return None\n491\t            fg = next(iter(fg_set))\n492\t\n493\t            # Compute bbox of foreground in input\n494\t            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n495\t            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n496\t            if not rows:\n497\t                return None\n498\t            r0, r1 = min(rows), max(rows)\n499\t            c0, c1 = min(cols), max(cols)\n500\t\n501\t            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n502\t            for r in range(h):\n503\t                for c in range(w):\n504\t                    inside = r0 <= r <= r1 and c0 <= c <= c1\n505\t                    if inside and raw_in[r][c] == bg:\n506\t                        if raw_out[r][c] != m:\n507\t                            return None\n508\t                    else:\n509\t                        if raw_out[r][c] != raw_in[r][c]:\n510\t                            return None\n511\t\n512\t            if marker is None:\n513\t                marker, bg_color, fg_color = m, bg, fg\n514\t            elif (m, bg, fg) != (marker, bg_color, fg_color):\n515\t                return None\n516\t\n517\t        return {\n518\t            \"type\": \"bbox_fill\",\n519\t            \"marker\": marker,\n520\t            \"background\": bg_color,\n521\t            \"foreground\": fg_color,\n522\t            \"confidence\": 1.0,\n523\t        }\n524\t\n525\t    # ---- strategy: axis mirror recolor ----------------------------------\n526\t\n527\t    def _try_axis_mirror_recolor(self, example_pairs):\n528\t        \"\"\"\n529\t        Detect: same grid size, exactly one new color in output (marker).\n530\t        For some axis (horizontal/vertical), every changed cell is the\n531\t        original foreground color and its mirror partner along that axis\n532\t        also has the original foreground color in the input.\n533\t        Unchanged cells are those without a same-color mirror partner.\n534\t        \"\"\"\n535\t        if not example_pairs:\n536\t            return None\n537\t\n538\t        for axis in (\"horizontal\", \"vertical\"):\n539\t            params = self._check_mirror_axis(example_pairs, axis)\n540\t            if params is not None:\n541\t                return {\n542\t                    \"type\": \"axis_mirror_recolor\",\n543\t                    \"axis\": axis,\n544\t                    \"marker\": params[\"marker\"],\n545\t                    \"foreground\": params[\"foreground\"],\n546\t                    \"confidence\": 1.0,\n547\t                }\n548\t        return None\n549\t\n550\t    @staticmethod\n551\t    def _check_mirror_axis(example_pairs, axis):\n552\t        marker = None\n553\t        fg = None\n554\t        had_change = False\n555\t\n556\t        for raw_in, raw_out in example_pairs:\n557\t            h = len(raw_in)\n558\t            w = len(raw_in[0]) if raw_in else 0\n559\t            if h != len(raw_out) or (w and w != len(raw_out[0])):\n560\t                return None\n561\t\n562\t            new_colors = (\n563\t                {c for row in raw_out for c in row}\n564\t                - {c for row in raw_in for c in row}\n565\t            )\n566\t            if len(new_colors) != 1:\n567\t                return None\n568\t            m = next(iter(new_colors))\n569\t\n570\t            for r in range(h):\n571\t                for c in range(w):\n572\t                    if axis == \"horizontal\":\n573\t                        rr, cc = r, w - 1 - c\n574\t                    else:\n575\t                        rr, cc = h - 1 - r, c\n576\t                    in_v = raw_in[r][c]\n577\t                    out_v = raw_out[r][c]\n578\t                    mirror_v = raw_in[rr][cc]\n579\t                    if out_v == in_v:\n580\t                        # If this cell HAS a same-color mirror partner of\n581\t                        # a non-bg color, the rule would have flipped it.\n582\t                        # We require: not changed → no same-color partner\n583\t                        # OR cell is on the axis and equals itself (trivial).\n584\t                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n585\t                            # only allow when in_v is the background\n586\t                            # (but bg already excluded by != 0 check is rough);\n587\t                            # we'll defer to fg check below.\n588\t                            pass\n589\t                        continue\n590\t                    # Changed: must change FROM some fg TO marker, with mirror\n591\t                    # partner also equal to fg in the input.\n592\t                    if out_v != m:\n593\t                        return None\n594\t                    if in_v == 0:\n595\t                        # background-cells turning into marker — not this rule\n596\t                        return None\n597\t                    if mirror_v != in_v:\n598\t                        return None\n599\t                    if fg is None:\n600\t                        fg = in_v\n601\t                    elif fg != in_v:\n602\t                        return None\n603\t                    had_change = True\n604\t\n605\t            if marker is None:\n606\t                marker = m\n607\t            elif marker != m:\n608\t                return None\n609\t\n610\t        if not had_change or fg is None:\n611\t            return None\n612\t\n613\t        # Final sanity: re-apply rule and confirm exact match.\n614\t        for raw_in, raw_out in example_pairs:\n615\t            h = len(raw_in)\n616\t            w = len(raw_in[0]) if raw_in else 0\n617\t            for r in range(h):\n618\t                for c in range(w):\n619\t                    if axis == \"horizontal\":\n620\t                        rr, cc = r, w - 1 - c\n621\t                    else:\n622\t                        rr, cc = h - 1 - r, c\n623\t                    expected = raw_in[r][c]\n624\t                    if (raw_in[r][c] == fg\n625\t                            and (r, c) != (rr, cc)\n626\t                            and raw_in[rr][cc] == fg):\n627\t                        expected = marker\n628\t                    if raw_out[r][c] != expected:\n629\t                        return None\n630\t\n631\t        return {\"marker\": marker, \"foreground\": fg}\n632\t\n633\t    # ---- strategy: integer upscale --------------------------------------\n634\t\n635\t    def _try_integer_upscale(self, example_pairs):\n636\t        \"\"\"\n637\t        Detect: output dimensions are k * input dimensions (same k for both\n638\t        height and width, and the same k across all examples). Each input\n639\t        cell at (r, c) becomes a kxk block at rows [k*r, k*r+k) and cols\n640\t        [k*c, k*c+k) in the output, all filled with the same color.\n641\t        \"\"\"\n642\t        if not example_pairs:\n643\t            return None\n644\t\n645\t        factor = None\n646\t        for raw_in, raw_out in example_pairs:\n647\t            ih = len(raw_in)\n648\t            iw = len(raw_in[0]) if raw_in else 0\n649\t            oh = len(raw_out)\n650\t            ow = len(raw_out[0]) if raw_out else 0\n651\t            if ih == 0 or iw == 0 or oh == 0 or ow == 0:\n652\t                return None\n653\t            if oh % ih != 0 or ow % iw != 0:\n654\t                return None\n655\t            kh, kw = oh // ih, ow // iw\n656\t            if kh != kw or kh < 2:\n657\t                return None\n658\t            if factor is None:\n659\t                factor = kh\n660\t            elif factor != kh:\n661\t                return None\n662\t            for r in range(ih):\n663\t                for c in range(iw):\n664\t                    v = raw_in[r][c]\n665\t                    for dr in range(factor):\n666\t                        for dc in range(factor):\n667\t                            if raw_out[r * factor + dr][c * factor + dc] != v:\n668\t                                return None\n669\t\n670\t        if factor is None:\n671\t            return None\n672\t        return {\"type\": \"integer_upscale\", \"factor\": factor, \"confidence\": 1.0}\n673\t\n674\t    # ---- strategy: stack with mirror ------------------------------------\n675\t\n676\t    def _try_stack_with_mirror(self, example_pairs):\n677\t        \"\"\"\n678\t        Detect: output = concatenation of input and a flipped copy of input\n679\t        along one axis. Tries four configurations:\n680\t          - direction=vertical,   order=input_first  (rows: input, vflip(input))\n681\t          - direction=vertical,   order=flip_first   (rows: vflip(input), input)\n682\t          - direction=horizontal, order=input_first  (cols: input, hflip(input))\n683\t          - direction=horizontal, order=flip_first   (cols: hflip(input), input)\n684\t        The same configuration must hold across every example.\n685\t        \"\"\"\n686\t        if not example_pairs:\n687\t            return None\n688\t\n689\t        configs = [\n690\t            (\"vertical\", \"input_first\"),\n691\t            (\"vertical\", \"flip_first\"),\n692\t            (\"horizontal\", \"input_first\"),\n693\t            (\"horizontal\", \"flip_first\"),\n694\t        ]\n695\t\n696\t        for direction, order in configs:\n697\t            ok = True\n698\t            for raw_in, raw_out in example_pairs:\n699\t                if not self._check_stack_mirror(raw_in, raw_out, direction, order):\n700\t                    ok = False\n701\t                    break\n702\t            if ok:\n703\t                return {\n704\t                    \"type\": \"stack_with_mirror\",\n705\t                    \"direction\": direction,\n706\t                    \"order\": order,\n707\t                    \"confidence\": 1.0,\n708\t                }\n709\t        return None\n710\t\n711\t    @staticmethod\n712\t    def _check_stack_mirror(raw_in, raw_out, direction, order):\n713\t        ih = len(raw_in)\n714\t        iw = len(raw_in[0]) if raw_in else 0\n715\t        oh = len(raw_out)\n716\t        ow = len(raw_out[0]) if raw_out else 0\n717\t        if ih == 0 or iw == 0:\n718\t            return False\n719\t\n720\t        if direction == \"vertical\":\n721\t            if ow != iw or oh != 2 * ih:\n722\t                return False\n723\t            flipped = list(reversed(raw_in))\n724\t            top = raw_in if order == \"input_first\" else flipped\n725\t            bot = flipped if order == \"input_first\" else raw_in\n726\t            for r in range(ih):\n727\t                if list(raw_out[r]) != list(top[r]):\n728\t                    return False\n729\t                if list(raw_out[ih + r]) != list(bot[r]):\n730\t                    return False\n731\t            return True\n732\t        else:  # horizontal\n733\t            if oh != ih or ow != 2 * iw:\n734\t                return False\n735\t            flipped = [list(reversed(row)) for row in raw_in]\n736\t            left = raw_in if order == \"input_first\" else flipped\n737\t            right = flipped if order == \"input_first\" else raw_in\n738\t            for r in range(ih):\n739\t                if list(raw_out[r][:iw]) != list(left[r]):\n740\t                    return False\n741\t                if list(raw_out[r][iw:]) != list(right[r]):\n742\t                    return False\n743\t            return True\n744\t\n745\t    # ---- strategy: rectangle interior fill ------------------------------\n746\t\n747\t    def _try_rect_interior_fill(self, example_pairs):\n748\t        \"\"\"\n749\t        Detect: same grid size; input contains hollow rectangular borders of a\n750\t        single foreground color on a background; output equals input except\n751\t        each hollow rect's interior is filled with a color determined by the\n752\t        rect's interior dimensions. Map (interior_h, interior_w) -> fill_color\n753\t        is learned from training and applied to test rectangles.\n754\t        \"\"\"\n755\t        if not example_pairs:\n756\t            return None\n757\t\n758\t        size_to_fill = {}\n759\t        bg_color = None\n760\t        border_color = None\n761\t\n762\t        for raw_in, raw_out in example_pairs:\n763\t            h = len(raw_in)\n764\t            w = len(raw_in[0]) if raw_in else 0\n765\t            if h == 0 or w == 0:\n766\t                return None\n767\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n768\t                return None\n769\t\n770\t            # Background = most-frequent color in input\n771\t            counts = {}\n772\t            for row in raw_in:\n773\t                for c in row:\n774\t                    counts[c] = counts.get(c, 0) + 1\n775\t            bg = max(counts, key=counts.get)\n776\t\n777\t            # Foreground colors = everything else; require exactly one\n778\t            fg_set = {c for c in counts if c != bg}\n779\t            if len(fg_set) != 1:\n780\t                return None\n781\t            fg = next(iter(fg_set))\n782\t\n783\t            if bg_color is None:\n784\t                bg_color, border_color = bg, fg\n785\t            elif (bg_color, border_color) != (bg, fg):\n786\t                return None\n787\t\n788\t            rects = self._find_hollow_rects(raw_in, fg, bg)\n789\t            if not rects:\n790\t                return None\n791\t\n792\t            # Build expected output: copy input, fill each rect interior\n793\t            # with the color present in raw_out at the interior cells.\n794\t            for (r0, c0, r1, c1) in rects:\n795\t                ih_int = r1 - r0 - 1\n796\t                iw_int = c1 - c0 - 1\n797\t                if ih_int < 1 or iw_int < 1:\n798\t                    return None\n799\t                fill = raw_out[r0 + 1][c0 + 1]\n800\t                # Interior must be uniform fill color in output\n801\t                for r in range(r0 + 1, r1):\n802\t                    for c in range(c0 + 1, c1):\n803\t                        if raw_out[r][c] != fill:\n804\t                            return None\n805\t                key = (ih_int, iw_int)\n806\t                if key in size_to_fill and size_to_fill[key] != fill:\n807\t                    return None\n808\t                size_to_fill[key] = fill\n809\t\n810\t            # Verify all non-interior cells are unchanged\n811\t            interior_cells = set()\n812\t            for (r0, c0, r1, c1) in rects:\n813\t                for r in range(r0 + 1, r1):\n814\t                    for c in range(c0 + 1, c1):\n815\t                        interior_cells.add((r, c))\n816\t            for r in range(h):\n817\t                for c in range(w):\n818\t                    if (r, c) in interior_cells:\n819\t                        continue\n820\t                    if raw_in[r][c] != raw_out[r][c]:\n821\t                        return None\n822\t\n823\t        if not size_to_fill:\n824\t            return None\n825\t        return {\n826\t            \"type\": \"rect_interior_fill\",\n827\t            \"background\": bg_color,\n828\t            \"border\": border_color,\n829\t            \"size_to_fill\": {f\"{k[0]}x{k[1]}\": v for k, v in size_to_fill.items()},\n830\t            \"confidence\": 1.0,\n831\t        }\n832\t\n833\t    @staticmethod\n834\t    def _find_hollow_rects(raw, fg, bg):\n835\t        \"\"\"Find all hollow rectangles of color fg with interior color bg.\n836\t        Returns list of (r0, c0, r1, c1) bounding boxes.\"\"\"\n837\t        h = len(raw)\n838\t        w = len(raw[0]) if raw else 0\n839\t\n840\t        # Find connected components of fg cells (4-connected)\n841\t        visited = [[False] * w for _ in range(h)]\n842\t        rects = []\n843\t\n844\t        for r in range(h):\n845\t            for c in range(w):\n846\t                if raw[r][c] != fg or visited[r][c]:\n847\t                    continue\n848\t                # BFS\n849\t                comp = []\n850\t                queue = [(r, c)]\n851\t                while queue:\n852\t                    rr, cc = queue.pop(0)\n853\t                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n854\t                        continue\n855\t                    if visited[rr][cc] or raw[rr][cc] != fg:\n856\t                        continue\n857\t                    visited[rr][cc] = True\n858\t                    comp.append((rr, cc))\n859\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n860\t                        queue.append((rr + dr, cc + dc))\n861\t\n862\t                if not comp:\n863\t                    continue\n864\t                rs = [p[0] for p in comp]\n865\t                cs = [p[1] for p in comp]\n866\t                r0, r1 = min(rs), max(rs)\n867\t                c0, c1 = min(cs), max(cs)\n868\t                width = c1 - c0 + 1\n869\t                height = r1 - r0 + 1\n870\t                if width < 3 or height < 3:\n871\t                    continue\n872\t                # Check border is all fg\n873\t                comp_set = set(comp)\n874\t                ok = True\n875\t                for cc in range(c0, c1 + 1):\n876\t                    if (r0, cc) not in comp_set or (r1, cc) not in comp_set:\n877\t                        ok = False\n878\t                        break\n879\t                if ok:\n880\t                    for rr in range(r0, r1 + 1):\n881\t                        if (rr, c0) not in comp_set or (rr, c1) not in comp_set:\n882\t                            ok = False\n883\t                            break\n884\t                if not ok:\n885\t                    continue\n886\t                # Check interior is all bg\n887\t                for rr in range(r0 + 1, r1):\n888\t                    for cc in range(c0 + 1, c1):\n889\t                        if raw[rr][cc] != bg:\n890\t                            ok = False\n891\t                            break\n892\t                    if not ok:\n893\t                        break\n894\t                # Component must be exactly the border (no extra fg cells)\n895\t                expected_border_size = 2 * (height + width) - 4\n896\t                if ok and len(comp) == expected_border_size:\n897\t                    rects.append((r0, c0, r1, c1))\n898\t        return rects\n899\t\n900\t    # ---- strategy: staircase extend right -------------------------------\n901\t\n902\t    def _try_staircase_extend_right(self, example_pairs):\n903\t        \"\"\"\n904\t        Detect: every input is exactly one row of width w; output has\n905\t        oh = w // 2 rows and width w. Row 0 of the output equals the input;\n906\t        each subsequent row extends the colored prefix by one cell to the\n907\t        right (one more cell of the same fg color, rest background).\n908\t        \"\"\"\n909\t        if not example_pairs:\n910\t            return None\n911\t\n912\t        for raw_in, raw_out in example_pairs:\n913\t            if len(raw_in) != 1:\n914\t                return None\n915\t            w = len(raw_in[0])\n916\t            if w < 2:\n917\t                return None\n918\t            oh = len(raw_out)\n919\t            if oh != w // 2 or oh < 1:\n920\t                return None\n921\t            for row in raw_out:\n922\t                if len(row) != w:\n923\t                    return None\n924\t\n925\t            # The prefix color (fg) is the leftmost cell; the rest must be a\n926\t            # single different background color.\n927\t            row0 = list(raw_in[0])\n928\t            distinct = set(row0)\n929\t            if len(distinct) != 2:\n930\t                return None\n931\t            fg = row0[0]\n932\t            bg = next(v for v in distinct if v != fg)\n933\t\n934\t            n = 0\n935\t            while n < w and row0[n] == fg:\n936\t                n += 1\n937\t            if n == 0 or any(v != bg for v in row0[n:]):\n938\t                return None\n939\t\n940\t            # Verify each output row\n941\t            for i in range(oh):\n942\t                expected = [fg] * (n + i) + [bg] * (w - n - i)\n943\t                if list(raw_out[i]) != expected:\n944\t                    return None\n945\t\n946\t        return {\"type\": \"staircase_extend_right\", \"confidence\": 1.0}\n947\t\n948\t    # ---- strategy: corner quadrant fill ---------------------------------\n949\t\n950\t    def _try_corner_quadrant_fill(self, example_pairs):\n951\t        \"\"\"\n952\t        Detect: same grid size; input has 4 single-cell 'corner markers' of\n953\t        distinct non-background colors at the 4 corners of an axis-aligned\n954\t        rectangle, plus a solid block of one other 'inner' color filling the\n955\t        cells strictly inside that rectangle. The output replaces the corners\n956\t        with background and splits the inner block into four equal quadrants\n957\t        (TL/TR/BL/BR) recolored by the corresponding corner color.\n958\t        \"\"\"\n959\t        if not example_pairs:\n960\t            return None\n961\t\n962\t        inner_color = None\n963\t\n964\t        for raw_in, raw_out in example_pairs:\n965\t            params = self._check_corner_quadrant_fill(raw_in, raw_out)\n966\t            if params is None:\n967\t                return None\n968\t            if inner_color is None:\n969\t                inner_color = params[\"inner_color\"]\n970\t            elif inner_color != params[\"inner_color\"]:\n971\t                return None\n972\t\n973\t        if inner_color is None:\n974\t            return None\n975\t        return {\n976\t            \"type\": \"corner_quadrant_fill\",\n977\t            \"inner_color\": inner_color,\n978\t            \"confidence\": 1.0,\n979\t        }\n980\t\n981\t    @staticmethod\n982\t    def _check_corner_quadrant_fill(raw_in, raw_out):\n983\t        h = len(raw_in)\n984\t        w = len(raw_in[0]) if raw_in else 0\n985\t        if h == 0 or w == 0:\n986\t            return None\n987\t        if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n988\t            return None\n989\t\n990\t        counts = {}\n991\t        for row in raw_in:\n992\t            for c in row:\n993\t                counts[c] = counts.get(c, 0) + 1\n994\t        bg = max(counts, key=counts.get)\n995\t\n996\t        # Find inner color: must be one color forming one or more solid\n997\t        # rectangles, each of even side lengths >= 2, with 4 single-cell\n998\t        # 'corner markers' at the diagonal-adjacent positions.\n999\t        groups = GeneralizeOperator._find_corner_quadrant_groups(raw_in, bg)\n1000\t        if not groups:\n1001\t            return None\n1002\t        inner = groups[0][\"inner_color\"]\n1003\t        for g in groups:\n1004\t            if g[\"inner_color\"] != inner:\n1005\t                return None\n1006\t\n1007\t        expected = GeneralizeOperator._apply_quadrant_groups(raw_in, groups, bg)\n1008\t        for r in range(h):\n1009\t            for c in range(w):\n1010\t                if expected[r][c] != raw_out[r][c]:\n1011\t                    return None\n1012\t\n1013\t        return {\"inner_color\": inner}\n1014\t\n1015\t    @staticmethod\n1016\t    def _find_corner_quadrant_groups(raw, bg):\n1017\t        \"\"\"Find all (inner-rect + 4 corner-marker) groups in raw.\n1018\t\n1019\t        A group consists of: a solid rectangle filled with one non-bg color\n1020\t        (the 'inner color'), with side lengths >= 2 and even, surrounded by\n1021\t        4 single cells at the diagonal-adjacent positions, each a distinct\n1022\t        non-bg color (and distinct from the inner color). Returns a list of\n1023\t        dicts {r0,r1,c0,c1, inner_color, tl, tr, bl, br}, or empty list.\"\"\"\n1024\t        h = len(raw)\n1025\t        w = len(raw[0]) if raw else 0\n1026\t\n1027\t        # 4-connected components of every non-bg color\n1028\t        visited = [[False] * w for _ in range(h)]\n1029\t        groups = []\n1030\t        for r in range(h):\n1031\t            for c in range(w):\n1032\t                if raw[r][c] == bg or visited[r][c]:\n1033\t                    continue\n1034\t                color = raw[r][c]\n1035\t                comp = []\n1036\t                queue = [(r, c)]\n1037\t                while queue:\n1038\t                    rr, cc = queue.pop()\n1039\t                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n1040\t                        continue\n1041\t                    if visited[rr][cc] or raw[rr][cc] != color:\n1042\t                        continue\n1043\t                    visited[rr][cc] = True\n1044\t                    comp.append((rr, cc))\n1045\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1046\t                        queue.append((rr + dr, cc + dc))\n1047\t                if len(comp) < 4:\n1048\t                    continue  # skip tiny components\n1049\t                rs = [p[0] for p in comp]\n1050\t                cs = [p[1] for p in comp]\n1051\t                r0, r1 = min(rs), max(rs)\n1052\t                c0, c1 = min(cs), max(cs)\n1053\t                ih = r1 - r0 + 1\n1054\t                iw = c1 - c0 + 1\n1055\t                if ih < 2 or iw < 2:\n1056\t                    continue\n1057\t                if ih % 2 != 0 or iw % 2 != 0:\n1058\t                    continue\n1059\t                # Must be a solid rectangle\n1060\t                if len(comp) != ih * iw:\n1061\t                    continue\n1062\t                # Corner positions are diagonally adjacent to the rectangle\n1063\t                cr0, cc0 = r0 - 1, c0 - 1\n1064\t                cr1, cc1 = r0 - 1, c1 + 1\n1065\t                cr2, cc2 = r1 + 1, c0 - 1\n1066\t                cr3, cc3 = r1 + 1, c1 + 1\n1067\t                if (cr0 < 0 or cc0 < 0 or cr3 >= h or cc3 >= w):\n1068\t                    continue\n1069\t                tl_v = raw[cr0][cc0]\n1070\t                tr_v = raw[cr1][cc1]\n1071\t                bl_v = raw[cr2][cc2]\n1072\t                br_v = raw[cr3][cc3]\n1073\t                corner_vals = [tl_v, tr_v, bl_v, br_v]\n1074\t                if any(v == bg or v == color for v in corner_vals):\n1075\t                    continue\n1076\t                if len(set(corner_vals)) != 4:\n1077\t                    continue\n1078\t                # Each corner cell must be isolated: 4-neighbours all bg\n1079\t                ok = True\n1080\t                for (rr, cc) in [(cr0, cc0), (cr1, cc1), (cr2, cc2), (cr3, cc3)]:\n1081\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1082\t                        nr, nc = rr + dr, cc + dc\n1083\t                        if 0 <= nr < h and 0 <= nc < w:\n1084\t                            if raw[nr][nc] != bg:\n1085\t                                ok = False\n1086\t                                break\n1087\t                    if not ok:\n1088\t                        break\n1089\t                if not ok:\n1090\t                    continue\n1091\t                groups.append({\n1092\t                    \"r0\": r0, \"r1\": r1, \"c0\": c0, \"c1\": c1,\n1093\t                    \"inner_color\": color,\n1094\t                    \"tl\": tl_v, \"tr\": tr_v, \"bl\": bl_v, \"br\": br_v,\n1095\t                    \"tl_pos\": (cr0, cc0), \"tr_pos\": (cr1, cc1),\n1096\t                    \"bl_pos\": (cr2, cc2), \"br_pos\": (cr3, cc3),\n1097\t                })\n1098\t        return groups\n1099\t\n1100\t    @staticmethod\n1101\t    def _apply_quadrant_groups(raw, groups, bg):\n1102\t        out = [list(row) for row in raw]\n1103\t        for g in groups:\n1104\t            r0, r1, c0, c1 = g[\"r0\"], g[\"r1\"], g[\"c0\"], g[\"c1\"]\n1105\t            ih = r1 - r0 + 1\n1106\t            iw = c1 - c0 + 1\n1107\t            hh, ww = ih // 2, iw // 2\n1108\t            # Clear corner markers\n1109\t            for key in (\"tl_pos\", \"tr_pos\", \"bl_pos\", \"br_pos\"):\n1110\t                rr, cc = g[key]\n1111\t                out[rr][cc] = bg\n1112\t            # Fill quadrants of inner rect\n1113\t            for r in range(r0, r1 + 1):\n1114\t                for c in range(c0, c1 + 1):\n1115\t                    is_top = r < r0 + hh\n1116\t                    is_left = c < c0 + ww\n1117\t                    if is_top and is_left:\n1118\t                        out[r][c] = g[\"tl\"]\n1119\t                    elif is_top:\n1120\t                        out[r][c] = g[\"tr\"]\n1121\t                    elif is_left:\n1122\t                        out[r][c] = g[\"bl\"]\n1123\t                    else:\n1124\t                        out[r][c] = g[\"br\"]\n1125\t        return out\n1126\t\n1127\t    # ---- strategy: diamond connector ------------------------------------\n1128\t\n1129\t    def _try_diamond_connector(self, example_pairs):\n1130\t        \"\"\"\n1131\t        Detect: same grid size; input contains '+'-shaped 4-cell diamond\n1132\t        markers (one foreground cell at each of N/S/E/W around a background\n1133\t        center, with all 4 diagonal cells being background). Each pair of\n1134\t        adjacent collinear diamonds (sharing a row or column with no other\n1135\t        diamond between them on that line) is joined in the output by a\n1136\t        line of a single 'connector' color filling the cells strictly\n1137\t        between their inner '+' tips.\n1138\t        \"\"\"\n1139\t        if not example_pairs:\n1140\t            return None\n1141\t\n1142\t        connector = None\n1143\t        fg_color = None\n1144\t\n1145\t        for raw_in, raw_out in example_pairs:\n1146\t            h = len(raw_in)\n1147\t            w = len(raw_in[0]) if raw_in else 0\n1148\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n1149\t                return None\n1150\t\n1151\t            in_colors = {c for row in raw_in for c in row}\n1152\t            out_colors = {c for row in raw_out for c in row}\n1153\t            new_colors = out_colors - in_colors\n1154\t            if len(new_colors) != 1:\n1155\t                return None\n1156\t            marker = next(iter(new_colors))\n1157\t            if connector is None:\n1158\t                connector = marker\n1159\t            elif connector != marker:\n1160\t                return None\n1161\t\n1162\t            counts = {}\n1163\t            for row in raw_in:\n1164\t                for c in row:\n1165\t                    counts[c] = counts.get(c, 0) + 1\n1166\t            bg = max(counts, key=counts.get)\n1167\t            fg_set = in_colors - {bg}\n1168\t            if len(fg_set) != 1:\n1169\t                return None\n1170\t            fg = next(iter(fg_set))\n1171\t            if fg_color is None:\n1172\t                fg_color = fg\n1173\t            elif fg_color != fg:\n1174\t                return None\n1175\t\n1176\t            diamonds = self._find_diamonds(raw_in, fg, bg)\n1177\t            if len(diamonds) < 2:\n1178\t                return None\n1179\t\n1180\t            expected = [list(row) for row in raw_in]\n1181\t            self._draw_diamond_connectors(expected, diamonds, marker)\n1182\t\n1183\t            for r in range(h):\n1184\t                for c in range(w):\n1185\t                    if expected[r][c] != raw_out[r][c]:\n1186\t                        return None\n1187\t\n1188\t        if connector is None or fg_color is None:\n1189\t            return None\n1190\t        return {\n1191\t            \"type\": \"diamond_connector\",\n1192\t            \"connector\": connector,\n1193\t            \"foreground\": fg_color,\n1194\t            \"confidence\": 1.0,\n1195\t        }\n1196\t\n1197\t    @staticmethod\n1198\t    def _find_diamonds(raw, fg, bg):\n1199\t        h = len(raw)\n1200\t        w = len(raw[0]) if raw else 0\n1201\t        centers = []\n1202\t        for r in range(1, h - 1):\n1203\t            for c in range(1, w - 1):\n1204\t                if raw[r][c] != bg:\n1205\t                    continue\n1206\t                if (raw[r - 1][c] == fg and raw[r + 1][c] == fg\n1207\t                        and raw[r][c - 1] == fg and raw[r][c + 1] == fg\n1208\t                        and raw[r - 1][c - 1] == bg and raw[r - 1][c + 1] == bg\n1209\t                        and raw[r + 1][c - 1] == bg and raw[r + 1][c + 1] == bg):\n1210\t                    centers.append((r, c))\n1211\t        return centers\n1212\t\n1213\t    @staticmethod\n1214\t    def _draw_diamond_connectors(grid, diamonds, marker):\n1215\t        by_row = {}\n1216\t        by_col = {}\n1217\t        for r, c in diamonds:\n1218\t            by_row.setdefault(r, []).append(c)\n1219\t            by_col.setdefault(c, []).append(r)\n1220\t        for r, cols in by_row.items():\n1221\t            cols = sorted(cols)\n1222\t            for i in range(len(cols) - 1):\n1223\t                cl, cr = cols[i], cols[i + 1]\n1224\t                for cc in range(cl + 2, cr - 1):\n1225\t                    grid[r][cc] = marker\n1226\t        for c, rows in by_col.items():\n1227\t            rows = sorted(rows)\n1228\t            for i in range(len(rows) - 1):\n1229\t                rl, rr = rows[i], rows[i + 1]\n1230\t                for rr2 in range(rl + 2, rr - 1):\n1231\t                    grid[rr2][c] = marker\n1232\t\n1233\t\n1234\t# ======================================================================\n1235\t# DescendOperator -- placeholder for deeper KG exploration\n1236\t# ======================================================================\n1237\t\n1238\tclass DescendOperator(Operator):\n1239\t    \"\"\"\n1240\t    Placeholder: moves focus to a deeper KG level when current-level\n1241\t    analysis is insufficient. Not yet needed for the basic pipeline.\n1242\t    \"\"\"\n1243\t\n1244\t    def __init__(self):\n1245\t        super().__init__(\"descend\")\n1246\t\n1247\t    def precondition(self, wm) -> bool:\n1248\t        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n1249\t\n1250\t    def effect(self, wm):\n1251\t        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n1252\t\n1253\t\n1254\t# ======================================================================\n1255\t# PredictOperator -- apply rule to test input\n1256\t# ======================================================================\n1257\t\n1258\tclass PredictOperator(Operator):\n1259\t    \"\"\"\n1260\t    Reads the best rule from active-rules and applies it to each test\n1261\t    pair's input grid to produce a predicted output grid.\n1262\t    \"\"\"\n1263\t\n1264\t    def __init__(self):\n1265\t        super().__init__(\"predict\")\n1266\t\n1267\t    def precondition(self, wm) -> bool:\n1268\t        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n1269\t\n1270\t    def effect(self, wm):\n1271\t        task = wm.task\n1272\t        active_rules = wm.s1.get(\"active-rules\")\n1273\t        if not task or not active_rules:\n1274\t            return\n1275\t\n1276\t        rule = active_rules[0]\n1277\t        predictions = dict(wm.s1.get(\"predictions\") or {})\n1278\t\n1279\t        for i, test_pair in enumerate(task.test_pairs):\n1280\t            key = f\"test_{i}\"\n1281\t            if key in predictions:\n1282\t                continue\n1283\t            g0 = test_pair.input_grid\n1284\t            if g0 is None:\n1285\t                continue\n1286\t            predicted = self._apply_rule(rule, g0)\n1287\t            if predicted is not None:\n1288\t                predictions[key] = predicted\n1289\t\n1290\t        wm.s1[\"predictions\"] = predictions\n1291\t\n1292\t    # ---- rule application dispatchers ------------------------------------\n1293\t\n1294\t    def _apply_rule(self, rule, input_grid):\n1295\t        rule_type = rule.get(\"type\")\n1296\t        if rule_type == \"recolor_sequential\":\n1297\t            return self._apply_recolor_sequential(rule, input_grid)\n1298\t        if rule_type == \"color_mapping\":\n1299\t            return self._apply_color_mapping(rule, input_grid)\n1300\t        if rule_type == \"bbox_fill\":\n1301\t            return self._apply_bbox_fill(rule, input_grid)\n1302\t        if rule_type == \"axis_mirror_recolor\":\n1303\t            return self._apply_axis_mirror_recolor(rule, input_grid)\n1304\t        if rule_type == \"integer_upscale\":\n1305\t            return self._apply_integer_upscale(rule, input_grid)\n1306\t        if rule_type == \"stack_with_mirror\":\n1307\t            return self._apply_stack_with_mirror(rule, input_grid)\n1308\t        if rule_type == \"rect_interior_fill\":\n1309\t            return self._apply_rect_interior_fill(rule, input_grid)\n1310\t        if rule_type == \"staircase_extend_right\":\n1311\t            return self._apply_staircase_extend_right(rule, input_grid)\n1312\t        if rule_type == \"corner_quadrant_fill\":\n1313\t            return self._apply_corner_quadrant_fill(rule, input_grid)\n1314\t        if rule_type == \"diamond_connector\":\n1315\t            return self._apply_diamond_connector(rule, input_grid)\n1316\t        if rule_type == \"identity\":\n1317\t            return [row[:] for row in input_grid.raw]\n1318\t        return None\n1319\t\n1320\t    def _apply_recolor_sequential(self, rule, input_grid):\n1321\t        raw = input_grid.raw\n1322\t        height = len(raw)\n1323\t        width = len(raw[0]) if raw else 0\n1324\t        sort_key = rule[\"sort_key\"]\n1325\t        start_color = rule[\"start_color\"]\n1326\t        source_colors = set(rule.get(\"source_colors\", []))\n1327\t\n1328\t        # Find target cells\n1329\t        target_cells = []\n1330\t        for r in range(height):\n1331\t            for c in range(width):\n1332\t                if raw[r][c] in source_colors:\n1333\t                    target_cells.append((r, c))\n1334\t\n1335\t        if not target_cells:\n1336\t            return [row[:] for row in raw]\n1337\t\n1338\t        # Group into connected components\n1339\t        groups = self._group_positions(target_cells)\n1340\t\n1341\t        # Sort groups by the rule's sort key\n1342\t        def _sort_val(group):\n1343\t            if sort_key == \"top_row\":\n1344\t                return min(r for r, c in group)\n1345\t            if sort_key == \"top_col\":\n1346\t                return min(c for r, c in group)\n1347\t            return 0\n1348\t\n1349\t        sorted_groups = sorted(groups, key=_sort_val)\n1350\t\n1351\t        # Build output grid\n1352\t        output = [row[:] for row in raw]\n1353\t        for idx, group in enumerate(sorted_groups):\n1354\t            new_color = start_color + idx\n1355\t            for r, c in group:\n1356\t                output[r][c] = new_color\n1357\t\n1358\t        return output\n1359\t\n1360\t    def _apply_color_mapping(self, rule, input_grid):\n1361\t        raw = input_grid.raw\n1362\t        mapping = rule.get(\"mapping\", {})\n1363\t\n1364\t        output = []\n1365\t        for row in raw:\n1366\t            output.append([mapping.get(cell, cell) for cell in row])\n1367\t        return output\n1368\t\n1369\t    def _apply_bbox_fill(self, rule, input_grid):\n1370\t        raw = input_grid.raw\n1371\t        h = len(raw)\n1372\t        w = len(raw[0]) if raw else 0\n1373\t        marker = rule.get(\"marker\")\n1374\t        fg = rule.get(\"foreground\")\n1375\t        bg = rule.get(\"background\")\n1376\t        if marker is None or fg is None or bg is None:\n1377\t            return None\n1378\t\n1379\t        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n1380\t        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n1381\t        if not rows:\n1382\t            return [row[:] for row in raw]\n1383\t        r0, r1 = min(rows), max(rows)\n1384\t        c0, c1 = min(cols), max(cols)\n1385\t\n1386\t        out = [row[:] for row in raw]\n1387\t        for r in range(r0, r1 + 1):\n1388\t            for c in range(c0, c1 + 1):\n1389\t                if out[r][c] == bg:\n1390\t                    out[r][c] = marker\n1391\t        return out\n1392\t\n1393\t    def _apply_axis_mirror_recolor(self, rule, input_grid):\n1394\t        raw = input_grid.raw\n1395\t        h = len(raw)\n1396\t        w = len(raw[0]) if raw else 0\n1397\t        marker = rule.get(\"marker\")\n1398\t        fg = rule.get(\"foreground\")\n1399\t        axis = rule.get(\"axis\", \"horizontal\")\n1400\t        if marker is None or fg is None:\n1401\t            return None\n1402\t\n1403\t        out = [row[:] for row in raw]\n1404\t        for r in range(h):\n1405\t            for c in range(w):\n1406\t                if raw[r][c] != fg:\n1407\t                    continue\n1408\t                if axis == \"horizontal\":\n1409\t                    rr, cc = r, w - 1 - c\n1410\t                else:\n1411\t                    rr, cc = h - 1 - r, c\n1412\t                if (r, c) == (rr, cc):\n1413\t                    continue\n1414\t                if raw[rr][cc] == fg:\n1415\t                    out[r][c] = marker\n1416\t        return out\n1417\t\n1418\t    def _apply_integer_upscale(self, rule, input_grid):\n1419\t        raw = input_grid.raw\n1420\t        k = rule.get(\"factor\")\n1421\t        if not isinstance(k, int) or k < 2:\n1422\t            return None\n1423\t        out = []\n1424\t        for row in raw:\n1425\t            new_row = []\n1426\t            for v in row:\n1427\t                new_row.extend([v] * k)\n1428\t            for _ in range(k):\n1429\t                out.append(new_row[:])\n1430\t        return out\n1431\t\n1432\t    def _apply_stack_with_mirror(self, rule, input_grid):\n1433\t        raw = input_grid.raw\n1434\t        direction = rule.get(\"direction\")\n1435\t        order = rule.get(\"order\")\n1436\t        if direction not in (\"vertical\", \"horizontal\"):\n1437\t            return None\n1438\t        if order not in (\"input_first\", \"flip_first\"):\n1439\t            return None\n1440\t\n1441\t        if direction == \"vertical\":\n1442\t            flipped = list(reversed([row[:] for row in raw]))\n1443\t            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n1444\t            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n1445\t            return [r[:] for r in top] + [r[:] for r in bot]\n1446\t        else:\n1447\t            flipped = [list(reversed(row)) for row in raw]\n1448\t            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n1449\t            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n1450\t            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n1451\t\n1452\t    def _apply_rect_interior_fill(self, rule, input_grid):\n1453\t        raw = input_grid.raw\n1454\t        h = len(raw)\n1455\t        w = len(raw[0]) if raw else 0\n1456\t        bg = rule.get(\"background\")\n1457\t        fg = rule.get(\"border\")\n1458\t        size_to_fill_raw = rule.get(\"size_to_fill\") or {}\n1459\t        if bg is None or fg is None:\n1460\t            return None\n1461\t        size_to_fill = {}\n1462\t        for k, v in size_to_fill_raw.items():\n1463\t            try:\n1464\t                a, b = k.split(\"x\")\n1465\t                size_to_fill[(int(a), int(b))] = v\n1466\t            except ValueError:\n1467\t                continue\n1468\t\n1469\t        rects = GeneralizeOperator._find_hollow_rects(raw, fg, bg)\n1470\t        out = [row[:] for row in raw]\n1471\t        for (r0, c0, r1, c1) in rects:\n1472\t            ih = r1 - r0 - 1\n1473\t            iw = c1 - c0 - 1\n1474\t            fill = size_to_fill.get((ih, iw))\n1475\t            if fill is None:\n1476\t                continue\n1477\t            for r in range(r0 + 1, r1):\n1478\t                for c in range(c0 + 1, c1):\n1479\t                    out[r][c] = fill\n1480\t        return out\n1481\t\n1482\t    def _apply_staircase_extend_right(self, rule, input_grid):\n1483\t        raw = input_grid.raw\n1484\t        if len(raw) != 1:\n1485\t            return None\n1486\t        row0 = list(raw[0])\n1487\t        w = len(row0)\n1488\t        if w < 2:\n1489\t            return None\n1490\t        distinct = set(row0)\n1491\t        if len(distinct) != 2:\n1492\t            return None\n1493\t        fg = row0[0]\n1494\t        bg = next(v for v in distinct if v != fg)\n1495\t        n = 0\n1496\t        while n < w and row0[n] == fg:\n1497\t            n += 1\n1498\t        if n == 0 or any(v != bg for v in row0[n:]):\n1499\t            return None\n1500\t        oh = w // 2\n1501\t        out = []\n1502\t        for i in range(oh):\n1503\t            cells = [fg] * (n + i) + [bg] * (w - n - i)\n1504\t            out.append(cells)\n1505\t        return out\n1506\t\n1507\t    def _apply_corner_quadrant_fill(self, rule, input_grid):\n1508\t        raw = input_grid.raw\n1509\t        inner_color = rule.get(\"inner_color\")\n1510\t        if inner_color is None:\n1511\t            return None\n1512\t\n1513\t        counts = {}\n1514\t        for row in raw:\n1515\t            for c in row:\n1516\t                counts[c] = counts.get(c, 0) + 1\n1517\t        bg = max(counts, key=counts.get)\n1518\t\n1519\t        groups = GeneralizeOperator._find_corner_quadrant_groups(raw, bg)\n1520\t        groups = [g for g in groups if g[\"inner_color\"] == inner_color]\n1521\t        if not groups:\n1522\t            return None\n1523\t        return GeneralizeOperator._apply_quadrant_groups(raw, groups, bg)\n1524\t\n1525\t    def _apply_diamond_connector(self, rule, input_grid):\n1526\t        raw = input_grid.raw\n1527\t        h = len(raw)\n1528\t        w = len(raw[0]) if raw else 0\n1529\t        connector = rule.get(\"connector\")\n1530\t        if connector is None:\n1531\t            return None\n1532\t\n1533\t        counts = {}\n1534\t        for row in raw:\n1535\t            for c in row:\n1536\t                counts[c] = counts.get(c, 0) + 1\n1537\t        bg = max(counts, key=counts.get)\n1538\t\n1539\t        in_colors = {c for row in raw for c in row}\n1540\t        fg_set = in_colors - {bg}\n1541\t        if len(fg_set) != 1:\n1542\t            return None\n1543\t        fg = next(iter(fg_set))\n1544\t\n1545\t        diamonds = GeneralizeOperator._find_diamonds(raw, fg, bg)\n1546\t        out = [row[:] for row in raw]\n1547\t        GeneralizeOperator._draw_diamond_connectors(out, diamonds, connector)\n1548\t        return out\n1549\t\n1550\t    # ---- helpers ---------------------------------------------------------\n1551\t\n1552\t    @staticmethod\n1553\t    def _group_positions(positions):\n1554\t        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n1555\t        pos_set = set(positions)\n1556\t        visited = set()\n1557\t        groups = []\n1558\t\n1559\t        for pos in positions:\n1560\t            if pos in visited:\n1561\t                continue\n1562\t            group = []\n1563\t            queue = [pos]\n1564\t            while queue:\n1565\t                p = queue.pop(0)\n1566\t                if p in visited or p not in pos_set:\n1567\t                    continue\n1568\t                visited.add(p)\n1569\t                group.append(p)\n1570\t                r, c = p\n1571\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1572\t                    nb = (r + dr, c + dc)\n1573\t                    if nb in pos_set and nb not in visited:\n1574\t                        queue.append(nb)\n1575\t            groups.append(group)\n1576\t\n1577\t        return groups\n1578\t\n1579\t\n1580\t# ======================================================================\n1581\t# SubmitOperator -- finalize and satisfy goal\n1582\t# ======================================================================\n1583\t\n1584\tclass SubmitOperator(Operator):\n1585\t    \"\"\"\n1586\t    Writes predicted grids to S1 output-link in the format expected by\n1587\t    run_task.py, and marks the goal as satisfied.\n1588\t    \"\"\"\n1589\t\n1590\t    def __init__(self):\n1591\t        super().__init__(\"submit\")\n1592\t\n1593\t    def precondition(self, wm) -> bool:\n1594\t        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n1595\t\n1596\t    def effect(self, wm):\n1597\t        predictions = wm.s1.get(\"predictions\")\n1598\t        if not predictions:\n1599\t            return\n1600\t\n1601\t        task = wm.task\n1602\t        if not task:\n1603\t            return\n1604\t\n1605\t        predicted_grids = []\n1606\t        for i in range(len(task.test_pairs)):\n1607\t            grid = predictions.get(f\"test_{i}\")\n1608\t            if grid is not None:\n1609\t                predicted_grids.append(grid)\n1610\t\n1611\t        if not predicted_grids:\n1612\t            return\n1613\t\n1614\t        # Write to output-link (format expected by run_task.py)\n1615\t        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n1616\t        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n1617\t\n1618\t        # Mark goal as satisfied\n1619\t        wm.s1[\"goal\"] = {\"subgoals\": {\n1620\t            f\"test_{i}\": {\"status\": \"solved\"}\n1621\t            for i in range(len(predicted_grids))\n1622\t        }}\n1623\t\n1624\t\n1625\tclass VerifyOperator(SubmitOperator):\n1626\t    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n1627\t\n1628\t    def __init__(self):\n1629\t        super().__init__()\n1630\t        self.name = \"verify\"\n1631\t"}]},"parent_tool_use_id":null,"session_id":"6e965b3e-1124-42b1-9511-f4188c896242","uuid":"ab816b2a-3e5f-413e-bf62-deeb75ad21f7","timestamp":"2026-04-28T23:08:20.198Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"\"\"\"\nactive_operators -- SOAR Operator implementations.\n\nPipeline operators (all fire in S2, read/write S1):\n  SelectTargetOperator  -> set up comparison agenda from example pairs\n  CompareOperator       -> execute one comparison using ARCKG compare()\n  ExtractPatternOperator-> cell-level analysis of input/output changes\n  GeneralizeOperator    -> create transformation rule from patterns\n  PredictOperator       -> apply rule to test input\n  SubmitOperator        -> write prediction to output-link, satisfy goal\n\"\"\"\n\nfrom agent.operators import Operator\nfrom ARCKG.comparison import compare as arckg_compare\n\n\n# ======================================================================\n# SolveTaskOperator -- abstract top-level goal (S1)\n# ======================================================================\n\nclass SolveTaskOperator(Operator):\n    \"\"\"\n    Abstract operator at S1. Intentionally makes no WM change so\n    the cycle detects no-change and creates an S2 substate.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"solve-task\")\n        self.proposal_preference = \"+\"\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        # Intentionally empty -- triggers no-change impasse -> S2\n        return\n\n\n# ======================================================================\n# SelectTargetOperator -- set up comparison agenda\n# ======================================================================\n\nclass SelectTargetOperator(Operator):\n    \"\"\"\n    Reads wm.task to find example pairs and sets up comparison targets.\n    For each example pair: compare input grid (G0) vs output grid (G1).\n    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"select_target\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        agenda = []\n        pending = []\n\n        for idx, pair in enumerate(task.example_pairs):\n            if pair.input_grid is not None and pair.output_grid is not None:\n                spec = {\n                    \"type\": \"grid\",\n                    \"pair_idx\": idx,\n                    \"pair_type\": \"example\",\n                    \"id1\": pair.input_grid.node_id,\n                    \"id2\": pair.output_grid.node_id,\n                }\n                agenda.append(spec)\n                pending.append(spec)\n\n        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n        node_lookup = {}\n        for pair in task.example_pairs + task.test_pairs:\n            if pair.input_grid:\n                node_lookup[pair.input_grid.node_id] = pair.input_grid\n            if pair.output_grid:\n                node_lookup[pair.output_grid.node_id] = pair.output_grid\n        wm.node_lookup = node_lookup\n\n        wm.s1[\"comparison-agenda\"] = agenda\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = {}\n\n\n# ======================================================================\n# CompareOperator -- execute one comparison\n# ======================================================================\n\nclass CompareOperator(Operator):\n    \"\"\"\n    Pops one item from pending-comparisons, calls ARCKG compare(),\n    and stores the result in the comparisons dict on S1.\n    \"\"\"\n\n    def __init__(self, compare_fn=None):\n        super().__init__(\"compare\")\n        self._compare_fn = compare_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n        if not pending:\n            return\n\n        item = pending.pop(0)\n\n        # Find the actual ARCKG nodes\n        node_lookup = getattr(wm, \"node_lookup\", {})\n        node_a = node_lookup.get(item[\"id1\"])\n        node_b = node_lookup.get(item[\"id2\"])\n\n        if node_a is None or node_b is None:\n            wm.s1[\"pending-comparisons\"] = pending\n            return\n\n        # Execute comparison\n        fn = self._compare_fn or arckg_compare\n        result = fn(node_a, node_b)\n\n        # Store result keyed by type and pair index\n        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n        comparisons[key] = {\"spec\": item, \"result\": result}\n\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = comparisons\n\n\n# ======================================================================\n# ExtractPatternOperator -- cell-level transformation analysis\n# ======================================================================\n\nclass ExtractPatternOperator(Operator):\n    \"\"\"\n    Analyzes each example pair at the cell level to discover what changes\n    between input and output grids. Groups changed cells into connected\n    components and records color/position information for generalization.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"extract_pattern\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        patterns = {\n            \"grid_size_preserved\": True,\n            \"pair_analyses\": [],\n        }\n\n        for pair in task.example_pairs:\n            g0 = pair.input_grid\n            g1 = pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n\n            analysis = self._analyze_pair(g0, g1)\n            patterns[\"pair_analyses\"].append(analysis)\n\n            if g0.height != g1.height or g0.width != g1.width:\n                patterns[\"grid_size_preserved\"] = False\n\n        wm.s1[\"patterns\"] = patterns\n\n    # ---- internal helpers ------------------------------------------------\n\n    def _analyze_pair(self, g0, g1):\n        \"\"\"Cell-level diff between input and output grid.\"\"\"\n        raw_in = g0.raw\n        raw_out = g1.raw\n        h = min(len(raw_in), len(raw_out))\n        w = min(\n            len(raw_in[0]) if raw_in else 0,\n            len(raw_out[0]) if raw_out else 0,\n        )\n\n        changes = []\n        for r in range(h):\n            for c in range(w):\n                if raw_in[r][c] != raw_out[r][c]:\n                    changes.append({\n                        \"row\": r, \"col\": c,\n                        \"input_color\": raw_in[r][c],\n                        \"output_color\": raw_out[r][c],\n                    })\n\n        groups = self._group_changes(changes)\n\n        group_analyses = []\n        for group_cells in groups:\n            input_colors = set()\n            output_colors = set()\n            positions = []\n            for cell in group_cells:\n                input_colors.add(cell[\"input_color\"])\n                output_colors.add(cell[\"output_color\"])\n                positions.append((cell[\"row\"], cell[\"col\"]))\n\n            top_row = min(r for r, c in positions)\n            top_col = min(c for r, c in positions)\n\n            group_analyses.append({\n                \"input_colors\": sorted(input_colors),\n                \"output_colors\": sorted(output_colors),\n                \"top_row\": top_row,\n                \"top_col\": top_col,\n                \"cell_count\": len(group_cells),\n            })\n\n        return {\n            \"total_changes\": len(changes),\n            \"num_groups\": len(groups),\n            \"groups\": group_analyses,\n            \"size_match\": (\n                len(raw_in) == len(raw_out)\n                and (len(raw_in[0]) if raw_in else 0)\n                    == (len(raw_out[0]) if raw_out else 0)\n            ),\n        }\n\n    @staticmethod\n    def _group_changes(changes):\n        \"\"\"Group changed cells into 4-connected components.\"\"\"\n        if not changes:\n            return []\n\n        pos_to_change = {}\n        for c in changes:\n            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n\n        visited = set()\n        groups = []\n\n        for change in changes:\n            pos = (change[\"row\"], change[\"col\"])\n            if pos in visited:\n                continue\n\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_to_change:\n                    continue\n                visited.add(p)\n                group.append(pos_to_change[p])\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (p[0] + dr, p[1] + dc)\n                    if nb in pos_to_change and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# GeneralizeOperator -- rule creation from patterns\n# ======================================================================\n\nclass GeneralizeOperator(Operator):\n    \"\"\"\n    Reads extracted patterns and attempts to create a transformation rule.\n    Tries multiple strategies in priority order. If no strategy succeeds,\n    falls back to an identity rule so the pipeline can still complete.\n    \"\"\"\n\n    def __init__(self, generalize_fn=None, save_fn=None):\n        super().__init__(\"generalize\")\n        self._generalize_fn = generalize_fn\n        self._save_fn = save_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        patterns = wm.s1.get(\"patterns\")\n        if not patterns:\n            return\n\n        task = wm.task\n        example_pairs = self._collect_example_pairs(task)\n\n        rule = None\n\n        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n        rule = self._try_recolor_sequential(patterns)\n\n        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n        if rule is None:\n            rule = self._try_bbox_fill(example_pairs)\n\n        # Strategy 3: horizontal mirror recolor — recolor cells whose\n        #   horizontal-mirror partner has the same color\n        if rule is None:\n            rule = self._try_axis_mirror_recolor(example_pairs)\n\n        # Strategy 4: integer upscale — each input cell becomes a kxk block\n        if rule is None:\n            rule = self._try_integer_upscale(example_pairs)\n\n        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n        if rule is None:\n            rule = self._try_stack_with_mirror(example_pairs)\n\n        # Strategy 6: rectangle interior fill — hollow rect borders get interior\n        #   filled with a color determined by interior dimensions\n        if rule is None:\n            rule = self._try_rect_interior_fill(example_pairs)\n\n        # Strategy 7: staircase extend right — 1-row input becomes a triangular\n        #   stack of rows where each row's prefix grows by one cell\n        if rule is None:\n            rule = self._try_staircase_extend_right(example_pairs)\n\n        # Strategy 8: corner quadrant fill — 4 single-cell corner markers\n        #   surround a solid inner rectangle which is split into quadrants\n        if rule is None:\n            rule = self._try_corner_quadrant_fill(example_pairs)\n\n        # Strategy 9: diamond connector — collinear '+'-shaped 4-cell objects\n        #   are joined by lines of a marker color\n        if rule is None:\n            rule = self._try_diamond_connector(example_pairs)\n\n        # Strategy 10: simple 1:1 color mapping\n        if rule is None:\n            rule = self._try_color_mapping(patterns)\n\n        # Fallback: identity (copy input as output)\n        if rule is None:\n            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n\n        wm.s1[\"active-rules\"] = [rule]\n\n    @staticmethod\n    def _collect_example_pairs(task):\n        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n        if task is None:\n            return []\n        out = []\n        for pair in task.example_pairs:\n            g0, g1 = pair.input_grid, pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n            out.append((g0.raw, g1.raw))\n        return out\n\n    # ---- strategy: sequential recoloring --------------------------------\n\n    def _try_recolor_sequential(self, patterns):\n        \"\"\"\n        Detect pattern: all changed-cell groups have one source color,\n        output colors are sequential (1,2,3,...), ordered by position.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # All pairs must have the same number of change groups\n        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n            return None\n\n        all_source_colors = set()\n\n        for analysis in pair_analyses:\n            for g in analysis[\"groups\"]:\n                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n                    return None\n                all_source_colors.add(g[\"input_colors\"][0])\n\n            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n            if out_colors != expected:\n                return None\n\n        # Try sorting by different position keys\n        for sort_key in [\"top_row\", \"top_col\"]:\n            if self._check_sort_key(pair_analyses, sort_key):\n                start_color = min(\n                    g[\"output_colors\"][0]\n                    for g in pair_analyses[0][\"groups\"]\n                )\n                return {\n                    \"type\": \"recolor_sequential\",\n                    \"sort_key\": sort_key,\n                    \"start_color\": start_color,\n                    \"source_colors\": sorted(all_source_colors),\n                    \"confidence\": 1.0,\n                }\n\n        return None\n\n    @staticmethod\n    def _check_sort_key(pair_analyses, sort_key):\n        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n        for analysis in pair_analyses:\n            groups = analysis[\"groups\"]\n            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n            if colors != list(range(colors[0], colors[0] + len(colors))):\n                return False\n        return True\n\n    # ---- strategy: simple color mapping ---------------------------------\n\n    def _try_color_mapping(self, patterns):\n        \"\"\"\n        Detect pattern: each input color consistently maps to one output color.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # Collect all observed color transitions\n        color_map = {}\n        for analysis in pair_analyses:\n            for group in analysis[\"groups\"]:\n                for ic in group[\"input_colors\"]:\n                    for oc in group[\"output_colors\"]:\n                        if ic not in color_map:\n                            color_map[ic] = set()\n                        color_map[ic].add(oc)\n\n        # Each input color must map to exactly one output color\n        simple_map = {}\n        for ic, ocs in color_map.items():\n            if len(ocs) != 1:\n                return None\n            simple_map[ic] = list(ocs)[0]\n\n        if simple_map:\n            return {\n                \"type\": \"color_mapping\",\n                \"mapping\": simple_map,\n                \"confidence\": 0.8,\n            }\n\n        return None\n\n    # ---- strategy: bounding-box fill ------------------------------------\n\n    def _try_bbox_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; output equals input except every background\n        cell within the bounding box of the foreground color has been\n        recolored to a single marker color (a color not present in input).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        marker = None\n        bg_color = None\n        fg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n                return None\n\n            in_colors = {c for row in raw_in for c in row}\n            out_colors = {c for row in raw_out for c in row}\n            new_colors = out_colors - in_colors\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            # Background = most-frequent color in input\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n\n            # Foreground = the other input color (must be exactly two)\n            fg_set = {c for c in in_colors if c != bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            # Compute bbox of foreground in input\n            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            if not rows:\n                return None\n            r0, r1 = min(rows), max(rows)\n            c0, c1 = min(cols), max(cols)\n\n            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n            for r in range(h):\n                for c in range(w):\n                    inside = r0 <= r <= r1 and c0 <= c <= c1\n                    if inside and raw_in[r][c] == bg:\n                        if raw_out[r][c] != m:\n                            return None\n                    else:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n\n            if marker is None:\n                marker, bg_color, fg_color = m, bg, fg\n            elif (m, bg, fg) != (marker, bg_color, fg_color):\n                return None\n\n        return {\n            \"type\": \"bbox_fill\",\n            \"marker\": marker,\n            \"background\": bg_color,\n            \"foreground\": fg_color,\n            \"confidence\": 1.0,\n        }\n\n    # ---- strategy: axis mirror recolor ----------------------------------\n\n    def _try_axis_mirror_recolor(self, example_pairs):\n        \"\"\"\n        Detect: same grid size, exactly one new color in output (marker).\n        For some axis (horizontal/vertical), every changed cell is the\n        original foreground color and its mirror partner along that axis\n        also has the original foreground color in the input.\n        Unchanged cells are those without a same-color mirror partner.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for axis in (\"horizontal\", \"vertical\"):\n            params = self._check_mirror_axis(example_pairs, axis)\n            if params is not None:\n                return {\n                    \"type\": \"axis_mirror_recolor\",\n                    \"axis\": axis,\n                    \"marker\": params[\"marker\"],\n                    \"foreground\": params[\"foreground\"],\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_mirror_axis(example_pairs, axis):\n        marker = None\n        fg = None\n        had_change = False\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or (w and w != len(raw_out[0])):\n                return None\n\n            new_colors = (\n                {c for row in raw_out for c in row}\n                - {c for row in raw_in for c in row}\n            )\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    in_v = raw_in[r][c]\n                    out_v = raw_out[r][c]\n                    mirror_v = raw_in[rr][cc]\n                    if out_v == in_v:\n                        # If this cell HAS a same-color mirror partner of\n                        # a non-bg color, the rule would have flipped it.\n                        # We require: not changed → no same-color partner\n                        # OR cell is on the axis and equals itself (trivial).\n                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n                            # only allow when in_v is the background\n                            # (but bg already excluded by != 0 check is rough);\n                            # we'll defer to fg check below.\n                            pass\n                        continue\n                    # Changed: must change FROM some fg TO marker, with mirror\n                    # partner also equal to fg in the input.\n                    if out_v != m:\n                        return None\n                    if in_v == 0:\n                        # background-cells turning into marker — not this rule\n                        return None\n                    if mirror_v != in_v:\n                        return None\n                    if fg is None:\n                        fg = in_v\n                    elif fg != in_v:\n                        return None\n                    had_change = True\n\n            if marker is None:\n                marker = m\n            elif marker != m:\n                return None\n\n        if not had_change or fg is None:\n            return None\n\n        # Final sanity: re-apply rule and confirm exact match.\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    expected = raw_in[r][c]\n                    if (raw_in[r][c] == fg\n                            and (r, c) != (rr, cc)\n                            and raw_in[rr][cc] == fg):\n                        expected = marker\n                    if raw_out[r][c] != expected:\n                        return None\n\n        return {\"marker\": marker, \"foreground\": fg}\n\n    # ---- strategy: integer upscale --------------------------------------\n\n    def _try_integer_upscale(self, example_pairs):\n        \"\"\"\n        Detect: output dimensions are k * input dimensions (same k for both\n        height and width, and the same k across all examples). Each input\n        cell at (r, c) becomes a kxk block at rows [k*r, k*r+k) and cols\n        [k*c, k*c+k) in the output, all filled with the same color.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        factor = None\n        for raw_in, raw_out in example_pairs:\n            ih = len(raw_in)\n            iw = len(raw_in[0]) if raw_in else 0\n            oh = len(raw_out)\n            ow = len(raw_out[0]) if raw_out else 0\n            if ih == 0 or iw == 0 or oh == 0 or ow == 0:\n                return None\n            if oh % ih != 0 or ow % iw != 0:\n                return None\n            kh, kw = oh // ih, ow // iw\n            if kh != kw or kh < 2:\n                return None\n            if factor is None:\n                factor = kh\n            elif factor != kh:\n                return None\n            for r in range(ih):\n                for c in range(iw):\n                    v = raw_in[r][c]\n                    for dr in range(factor):\n                        for dc in range(factor):\n                            if raw_out[r * factor + dr][c * factor + dc] != v:\n                                return None\n\n        if factor is None:\n            return None\n        return {\"type\": \"integer_upscale\", \"factor\": factor, \"confidence\": 1.0}\n\n    # ---- strategy: stack with mirror ------------------------------------\n\n    def _try_stack_with_mirror(self, example_pairs):\n        \"\"\"\n        Detect: output = concatenation of input and a flipped copy of input\n        along one axis. Tries four configurations:\n          - direction=vertical,   order=input_first  (rows: input, vflip(input))\n          - direction=vertical,   order=flip_first   (rows: vflip(input), input)\n          - direction=horizontal, order=input_first  (cols: input, hflip(input))\n          - direction=horizontal, order=flip_first   (cols: hflip(input), input)\n        The same configuration must hold across every example.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        configs = [\n            (\"vertical\", \"input_first\"),\n            (\"vertical\", \"flip_first\"),\n            (\"horizontal\", \"input_first\"),\n            (\"horizontal\", \"flip_first\"),\n        ]\n\n        for direction, order in configs:\n            ok = True\n            for raw_in, raw_out in example_pairs:\n                if not self._check_stack_mirror(raw_in, raw_out, direction, order):\n                    ok = False\n                    break\n            if ok:\n                return {\n                    \"type\": \"stack_with_mirror\",\n                    \"direction\": direction,\n                    \"order\": order,\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_stack_mirror(raw_in, raw_out, direction, order):\n        ih = len(raw_in)\n        iw = len(raw_in[0]) if raw_in else 0\n        oh = len(raw_out)\n        ow = len(raw_out[0]) if raw_out else 0\n        if ih == 0 or iw == 0:\n            return False\n\n        if direction == \"vertical\":\n            if ow != iw or oh != 2 * ih:\n                return False\n            flipped = list(reversed(raw_in))\n            top = raw_in if order == \"input_first\" else flipped\n            bot = flipped if order == \"input_first\" else raw_in\n            for r in range(ih):\n                if list(raw_out[r]) != list(top[r]):\n                    return False\n                if list(raw_out[ih + r]) != list(bot[r]):\n                    return False\n            return True\n        else:  # horizontal\n            if oh != ih or ow != 2 * iw:\n                return False\n            flipped = [list(reversed(row)) for row in raw_in]\n            left = raw_in if order == \"input_first\" else flipped\n            right = flipped if order == \"input_first\" else raw_in\n            for r in range(ih):\n                if list(raw_out[r][:iw]) != list(left[r]):\n                    return False\n                if list(raw_out[r][iw:]) != list(right[r]):\n                    return False\n            return True\n\n    # ---- strategy: rectangle interior fill ------------------------------\n\n    def _try_rect_interior_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input contains hollow rectangular borders of a\n        single foreground color on a background; output equals input except\n        each hollow rect's interior is filled with a color determined by the\n        rect's interior dimensions. Map (interior_h, interior_w) -> fill_color\n        is learned from training and applied to test rectangles.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        size_to_fill = {}\n        bg_color = None\n        border_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h == 0 or w == 0:\n                return None\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            # Background = most-frequent color in input\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n\n            # Foreground colors = everything else; require exactly one\n            fg_set = {c for c in counts if c != bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            if bg_color is None:\n                bg_color, border_color = bg, fg\n            elif (bg_color, border_color) != (bg, fg):\n                return None\n\n            rects = self._find_hollow_rects(raw_in, fg, bg)\n            if not rects:\n                return None\n\n            # Build expected output: copy input, fill each rect interior\n            # with the color present in raw_out at the interior cells.\n            for (r0, c0, r1, c1) in rects:\n                ih_int = r1 - r0 - 1\n                iw_int = c1 - c0 - 1\n                if ih_int < 1 or iw_int < 1:\n                    return None\n                fill = raw_out[r0 + 1][c0 + 1]\n                # Interior must be uniform fill color in output\n                for r in range(r0 + 1, r1):\n                    for c in range(c0 + 1, c1):\n                        if raw_out[r][c] != fill:\n                            return None\n                key = (ih_int, iw_int)\n                if key in size_to_fill and size_to_fill[key] != fill:\n                    return None\n                size_to_fill[key] = fill\n\n            # Verify all non-interior cells are unchanged\n            interior_cells = set()\n            for (r0, c0, r1, c1) in rects:\n                for r in range(r0 + 1, r1):\n                    for c in range(c0 + 1, c1):\n                        interior_cells.add((r, c))\n            for r in range(h):\n                for c in range(w):\n                    if (r, c) in interior_cells:\n                        continue\n                    if raw_in[r][c] != raw_out[r][c]:\n                        return None\n\n        if not size_to_fill:\n            return None\n        return {\n            \"type\": \"rect_interior_fill\",\n            \"background\": bg_color,\n            \"border\": border_color,\n            \"size_to_fill\": {f\"{k[0]}x{k[1]}\": v for k, v in size_to_fill.items()},\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _find_hollow_rects(raw, fg, bg):\n        \"\"\"Find all hollow rectangles of color fg with interior color bg.\n        Returns list of (r0, c0, r1, c1) bounding boxes.\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n\n        # Find connected components of fg cells (4-connected)\n        visited = [[False] * w for _ in range(h)]\n        rects = []\n\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != fg or visited[r][c]:\n                    continue\n                # BFS\n                comp = []\n                queue = [(r, c)]\n                while queue:\n                    rr, cc = queue.pop(0)\n                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n                        continue\n                    if visited[rr][cc] or raw[rr][cc] != fg:\n                        continue\n                    visited[rr][cc] = True\n                    comp.append((rr, cc))\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        queue.append((rr + dr, cc + dc))\n\n                if not comp:\n                    continue\n                rs = [p[0] for p in comp]\n                cs = [p[1] for p in comp]\n                r0, r1 = min(rs), max(rs)\n                c0, c1 = min(cs), max(cs)\n                width = c1 - c0 + 1\n                height = r1 - r0 + 1\n                if width < 3 or height < 3:\n                    continue\n                # Check border is all fg\n                comp_set = set(comp)\n                ok = True\n                for cc in range(c0, c1 + 1):\n                    if (r0, cc) not in comp_set or (r1, cc) not in comp_set:\n                        ok = False\n                        break\n                if ok:\n                    for rr in range(r0, r1 + 1):\n                        if (rr, c0) not in comp_set or (rr, c1) not in comp_set:\n                            ok = False\n                            break\n                if not ok:\n                    continue\n                # Check interior is all bg\n                for rr in range(r0 + 1, r1):\n                    for cc in range(c0 + 1, c1):\n                        if raw[rr][cc] != bg:\n                            ok = False\n                            break\n                    if not ok:\n                        break\n                # Component must be exactly the border (no extra fg cells)\n                expected_border_size = 2 * (height + width) - 4\n                if ok and len(comp) == expected_border_size:\n                    rects.append((r0, c0, r1, c1))\n        return rects\n\n    # ---- strategy: staircase extend right -------------------------------\n\n    def _try_staircase_extend_right(self, example_pairs):\n        \"\"\"\n        Detect: every input is exactly one row of width w; output has\n        oh = w // 2 rows and width w. Row 0 of the output equals the input;\n        each subsequent row extends the colored prefix by one cell to the\n        right (one more cell of the same fg color, rest background).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for raw_in, raw_out in example_pairs:\n            if len(raw_in) != 1:\n                return None\n            w = len(raw_in[0])\n            if w < 2:\n                return None\n            oh = len(raw_out)\n            if oh != w // 2 or oh < 1:\n                return None\n            for row in raw_out:\n                if len(row) != w:\n                    return None\n\n            # The prefix color (fg) is the leftmost cell; the rest must be a\n            # single different background color.\n            row0 = list(raw_in[0])\n            distinct = set(row0)\n            if len(distinct) != 2:\n                return None\n            fg = row0[0]\n            bg = next(v for v in distinct if v != fg)\n\n            n = 0\n            while n < w and row0[n] == fg:\n                n += 1\n            if n == 0 or any(v != bg for v in row0[n:]):\n                return None\n\n            # Verify each output row\n            for i in range(oh):\n                expected = [fg] * (n + i) + [bg] * (w - n - i)\n                if list(raw_out[i]) != expected:\n                    return None\n\n        return {\"type\": \"staircase_extend_right\", \"confidence\": 1.0}\n\n    # ---- strategy: corner quadrant fill ---------------------------------\n\n    def _try_corner_quadrant_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input has 4 single-cell 'corner markers' of\n        distinct non-background colors at the 4 corners of an axis-aligned\n        rectangle, plus a solid block of one other 'inner' color filling the\n        cells strictly inside that rectangle. The output replaces the corners\n        with background and splits the inner block into four equal quadrants\n        (TL/TR/BL/BR) recolored by the corresponding corner color.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        inner_color = None\n\n        for raw_in, raw_out in example_pairs:\n            params = self._check_corner_quadrant_fill(raw_in, raw_out)\n            if params is None:\n                return None\n            if inner_color is None:\n                inner_color = params[\"inner_color\"]\n            elif inner_color != params[\"inner_color\"]:\n                return None\n\n        if inner_color is None:\n            return None\n        return {\n            \"type\": \"corner_quadrant_fill\",\n            \"inner_color\": inner_color,\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _check_corner_quadrant_fill(raw_in, raw_out):\n        h = len(raw_in)\n        w = len(raw_in[0]) if raw_in else 0\n        if h == 0 or w == 0:\n            return None\n        if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n            return None\n\n        counts = {}\n        for row in raw_in:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        # Find inner color: must be one color forming one or more solid\n        # rectangles, each of even side lengths >= 2, with 4 single-cell\n        # 'corner markers' at the diagonal-adjacent positions.\n        groups = GeneralizeOperator._find_corner_quadrant_groups(raw_in, bg)\n        if not groups:\n            return None\n        inner = groups[0][\"inner_color\"]\n        for g in groups:\n            if g[\"inner_color\"] != inner:\n                return None\n\n        expected = GeneralizeOperator._apply_quadrant_groups(raw_in, groups, bg)\n        for r in range(h):\n            for c in range(w):\n                if expected[r][c] != raw_out[r][c]:\n                    return None\n\n        return {\"inner_color\": inner}\n\n    @staticmethod\n    def _find_corner_quadrant_groups(raw, bg):\n        \"\"\"Find all (inner-rect + 4 corner-marker) groups in raw.\n\n        A group consists of: a solid rectangle filled with one non-bg color\n        (the 'inner color'), with side lengths >= 2 and even, surrounded by\n        4 single cells at the diagonal-adjacent positions, each a distinct\n        non-bg color (and distinct from the inner color). Returns a list of\n        dicts {r0,r1,c0,c1, inner_color, tl, tr, bl, br}, or empty list.\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n\n        # 4-connected components of every non-bg color\n        visited = [[False] * w for _ in range(h)]\n        groups = []\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] == bg or visited[r][c]:\n                    continue\n                color = raw[r][c]\n                comp = []\n                queue = [(r, c)]\n                while queue:\n                    rr, cc = queue.pop()\n                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n                        continue\n                    if visited[rr][cc] or raw[rr][cc] != color:\n                        continue\n                    visited[rr][cc] = True\n                    comp.append((rr, cc))\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        queue.append((rr + dr, cc + dc))\n                if len(comp) < 4:\n                    continue  # skip tiny components\n                rs = [p[0] for p in comp]\n                cs = [p[1] for p in comp]\n                r0, r1 = min(rs), max(rs)\n                c0, c1 = min(cs), max(cs)\n                ih = r1 - r0 + 1\n                iw = c1 - c0 + 1\n                if ih < 2 or iw < 2:\n                    continue\n                if ih % 2 != 0 or iw % 2 != 0:\n                    continue\n                # Must be a solid rectangle\n                if len(comp) != ih * iw:\n                    continue\n                # Corner positions are diagonally adjacent to the rectangle\n                cr0, cc0 = r0 - 1, c0 - 1\n                cr1, cc1 = r0 - 1, c1 + 1\n                cr2, cc2 = r1 + 1, c0 - 1\n                cr3, cc3 = r1 + 1, c1 + 1\n                if (cr0 < 0 or cc0 < 0 or cr3 >= h or cc3 >= w):\n                    continue\n                tl_v = raw[cr0][cc0]\n                tr_v = raw[cr1][cc1]\n                bl_v = raw[cr2][cc2]\n                br_v = raw[cr3][cc3]\n                corner_vals = [tl_v, tr_v, bl_v, br_v]\n                if any(v == bg or v == color for v in corner_vals):\n                    continue\n                if len(set(corner_vals)) != 4:\n                    continue\n                # Each corner cell must be isolated: 4-neighbours all bg\n                ok = True\n                for (rr, cc) in [(cr0, cc0), (cr1, cc1), (cr2, cc2), (cr3, cc3)]:\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        nr, nc = rr + dr, cc + dc\n                        if 0 <= nr < h and 0 <= nc < w:\n                            if raw[nr][nc] != bg:\n                                ok = False\n                                break\n                    if not ok:\n                        break\n                if not ok:\n                    continue\n                groups.append({\n                    \"r0\": r0, \"r1\": r1, \"c0\": c0, \"c1\": c1,\n                    \"inner_color\": color,\n                    \"tl\": tl_v, \"tr\": tr_v, \"bl\": bl_v, \"br\": br_v,\n                    \"tl_pos\": (cr0, cc0), \"tr_pos\": (cr1, cc1),\n                    \"bl_pos\": (cr2, cc2), \"br_pos\": (cr3, cc3),\n                })\n        return groups\n\n    @staticmethod\n    def _apply_quadrant_groups(raw, groups, bg):\n        out = [list(row) for row in raw]\n        for g in groups:\n            r0, r1, c0, c1 = g[\"r0\"], g[\"r1\"], g[\"c0\"], g[\"c1\"]\n            ih = r1 - r0 + 1\n            iw = c1 - c0 + 1\n            hh, ww = ih // 2, iw // 2\n            # Clear corner markers\n            for key in (\"tl_pos\", \"tr_pos\", \"bl_pos\", \"br_pos\"):\n                rr, cc = g[key]\n                out[rr][cc] = bg\n            # Fill quadrants of inner rect\n            for r in range(r0, r1 + 1):\n                for c in range(c0, c1 + 1):\n                    is_top = r < r0 + hh\n                    is_left = c < c0 + ww\n                    if is_top and is_left:\n                        out[r][c] = g[\"tl\"]\n                    elif is_top:\n                        out[r][c] = g[\"tr\"]\n                    elif is_left:\n                        out[r][c] = g[\"bl\"]\n                    else:\n                        out[r][c] = g[\"br\"]\n        return out\n\n    # ---- strategy: diamond connector ------------------------------------\n\n    def _try_diamond_connector(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input contains '+'-shaped 4-cell diamond\n        markers (one foreground cell at each of N/S/E/W around a background\n        center, with all 4 diagonal cells being background). Each pair of\n        adjacent collinear diamonds (sharing a row or column with no other\n        diamond between them on that line) is joined in the output by a\n        line of a single 'connector' color filling the cells strictly\n        between their inner '+' tips.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        connector = None\n        fg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            in_colors = {c for row in raw_in for c in row}\n            out_colors = {c for row in raw_out for c in row}\n            new_colors = out_colors - in_colors\n            if len(new_colors) != 1:\n                return None\n            marker = next(iter(new_colors))\n            if connector is None:\n                connector = marker\n            elif connector != marker:\n                return None\n\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n            fg_set = in_colors - {bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n            if fg_color is None:\n                fg_color = fg\n            elif fg_color != fg:\n                return None\n\n            diamonds = self._find_diamonds(raw_in, fg, bg)\n            if len(diamonds) < 2:\n                return None\n\n            expected = [list(row) for row in raw_in]\n            self._draw_diamond_connectors(expected, diamonds, marker)\n\n            for r in range(h):\n                for c in range(w):\n                    if expected[r][c] != raw_out[r][c]:\n                        return None\n\n        if connector is None or fg_color is None:\n            return None\n        return {\n            \"type\": \"diamond_connector\",\n            \"connector\": connector,\n            \"foreground\": fg_color,\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _find_diamonds(raw, fg, bg):\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        centers = []\n        for r in range(1, h - 1):\n            for c in range(1, w - 1):\n                if raw[r][c] != bg:\n                    continue\n                if (raw[r - 1][c] == fg and raw[r + 1][c] == fg\n                        and raw[r][c - 1] == fg and raw[r][c + 1] == fg\n                        and raw[r - 1][c - 1] == bg and raw[r - 1][c + 1] == bg\n                        and raw[r + 1][c - 1] == bg and raw[r + 1][c + 1] == bg):\n                    centers.append((r, c))\n        return centers\n\n    @staticmethod\n    def _draw_diamond_connectors(grid, diamonds, marker):\n        by_row = {}\n        by_col = {}\n        for r, c in diamonds:\n            by_row.setdefault(r, []).append(c)\n            by_col.setdefault(c, []).append(r)\n        for r, cols in by_row.items():\n            cols = sorted(cols)\n            for i in range(len(cols) - 1):\n                cl, cr = cols[i], cols[i + 1]\n                for cc in range(cl + 2, cr - 1):\n                    grid[r][cc] = marker\n        for c, rows in by_col.items():\n            rows = sorted(rows)\n            for i in range(len(rows) - 1):\n                rl, rr = rows[i], rows[i + 1]\n                for rr2 in range(rl + 2, rr - 1):\n                    grid[rr2][c] = marker\n\n\n# ======================================================================\n# DescendOperator -- placeholder for deeper KG exploration\n# ======================================================================\n\nclass DescendOperator(Operator):\n    \"\"\"\n    Placeholder: moves focus to a deeper KG level when current-level\n    analysis is insufficient. Not yet needed for the basic pipeline.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"descend\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n\n\n# ======================================================================\n# PredictOperator -- apply rule to test input\n# ======================================================================\n\nclass PredictOperator(Operator):\n    \"\"\"\n    Reads the best rule from active-rules and applies it to each test\n    pair's input grid to produce a predicted output grid.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"predict\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        active_rules = wm.s1.get(\"active-rules\")\n        if not task or not active_rules:\n            return\n\n        rule = active_rules[0]\n        predictions = dict(wm.s1.get(\"predictions\") or {})\n\n        for i, test_pair in enumerate(task.test_pairs):\n            key = f\"test_{i}\"\n            if key in predictions:\n                continue\n            g0 = test_pair.input_grid\n            if g0 is None:\n                continue\n            predicted = self._apply_rule(rule, g0)\n            if predicted is not None:\n                predictions[key] = predicted\n\n        wm.s1[\"predictions\"] = predictions\n\n    # ---- rule application dispatchers ------------------------------------\n\n    def _apply_rule(self, rule, input_grid):\n        rule_type = rule.get(\"type\")\n        if rule_type == \"recolor_sequential\":\n            return self._apply_recolor_sequential(rule, input_grid)\n        if rule_type == \"color_mapping\":\n            return self._apply_color_mapping(rule, input_grid)\n        if rule_type == \"bbox_fill\":\n            return self._apply_bbox_fill(rule, input_grid)\n        if rule_type == \"axis_mirror_recolor\":\n            return self._apply_axis_mirror_recolor(rule, input_grid)\n        if rule_type == \"integer_upscale\":\n            return self._apply_integer_upscale(rule, input_grid)\n        if rule_type == \"stack_with_mirror\":\n            return self._apply_stack_with_mirror(rule, input_grid)\n        if rule_type == \"rect_interior_fill\":\n            return self._apply_rect_interior_fill(rule, input_grid)\n        if rule_type == \"staircase_extend_right\":\n            return self._apply_staircase_extend_right(rule, input_grid)\n        if rule_type == \"corner_quadrant_fill\":\n            return self._apply_corner_quadrant_fill(rule, input_grid)\n        if rule_type == \"diamond_connector\":\n            return self._apply_diamond_connector(rule, input_grid)\n        if rule_type == \"identity\":\n            return [row[:] for row in input_grid.raw]\n        return None\n\n    def _apply_recolor_sequential(self, rule, input_grid):\n        raw = input_grid.raw\n        height = len(raw)\n        width = len(raw[0]) if raw else 0\n        sort_key = rule[\"sort_key\"]\n        start_color = rule[\"start_color\"]\n        source_colors = set(rule.get(\"source_colors\", []))\n\n        # Find target cells\n        target_cells = []\n        for r in range(height):\n            for c in range(width):\n                if raw[r][c] in source_colors:\n                    target_cells.append((r, c))\n\n        if not target_cells:\n            return [row[:] for row in raw]\n\n        # Group into connected components\n        groups = self._group_positions(target_cells)\n\n        # Sort groups by the rule's sort key\n        def _sort_val(group):\n            if sort_key == \"top_row\":\n                return min(r for r, c in group)\n            if sort_key == \"top_col\":\n                return min(c for r, c in group)\n            return 0\n\n        sorted_groups = sorted(groups, key=_sort_val)\n\n        # Build output grid\n        output = [row[:] for row in raw]\n        for idx, group in enumerate(sorted_groups):\n            new_color = start_color + idx\n            for r, c in group:\n                output[r][c] = new_color\n\n        return output\n\n    def _apply_color_mapping(self, rule, input_grid):\n        raw = input_grid.raw\n        mapping = rule.get(\"mapping\", {})\n\n        output = []\n        for row in raw:\n            output.append([mapping.get(cell, cell) for cell in row])\n        return output\n\n    def _apply_bbox_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        bg = rule.get(\"background\")\n        if marker is None or fg is None or bg is None:\n            return None\n\n        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n        if not rows:\n            return [row[:] for row in raw]\n        r0, r1 = min(rows), max(rows)\n        c0, c1 = min(cols), max(cols)\n\n        out = [row[:] for row in raw]\n        for r in range(r0, r1 + 1):\n            for c in range(c0, c1 + 1):\n                if out[r][c] == bg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_axis_mirror_recolor(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        axis = rule.get(\"axis\", \"horizontal\")\n        if marker is None or fg is None:\n            return None\n\n        out = [row[:] for row in raw]\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != fg:\n                    continue\n                if axis == \"horizontal\":\n                    rr, cc = r, w - 1 - c\n                else:\n                    rr, cc = h - 1 - r, c\n                if (r, c) == (rr, cc):\n                    continue\n                if raw[rr][cc] == fg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_integer_upscale(self, rule, input_grid):\n        raw = input_grid.raw\n        k = rule.get(\"factor\")\n        if not isinstance(k, int) or k < 2:\n            return None\n        out = []\n        for row in raw:\n            new_row = []\n            for v in row:\n                new_row.extend([v] * k)\n            for _ in range(k):\n                out.append(new_row[:])\n        return out\n\n    def _apply_stack_with_mirror(self, rule, input_grid):\n        raw = input_grid.raw\n        direction = rule.get(\"direction\")\n        order = rule.get(\"order\")\n        if direction not in (\"vertical\", \"horizontal\"):\n            return None\n        if order not in (\"input_first\", \"flip_first\"):\n            return None\n\n        if direction == \"vertical\":\n            flipped = list(reversed([row[:] for row in raw]))\n            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [r[:] for r in top] + [r[:] for r in bot]\n        else:\n            flipped = [list(reversed(row)) for row in raw]\n            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n\n    def _apply_rect_interior_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        bg = rule.get(\"background\")\n        fg = rule.get(\"border\")\n        size_to_fill_raw = rule.get(\"size_to_fill\") or {}\n        if bg is None or fg is None:\n            return None\n        size_to_fill = {}\n        for k, v in size_to_fill_raw.items():\n            try:\n                a, b = k.split(\"x\")\n                size_to_fill[(int(a), int(b))] = v\n            except ValueError:\n                continue\n\n        rects = GeneralizeOperator._find_hollow_rects(raw, fg, bg)\n        out = [row[:] for row in raw]\n        for (r0, c0, r1, c1) in rects:\n            ih = r1 - r0 - 1\n            iw = c1 - c0 - 1\n            fill = size_to_fill.get((ih, iw))\n            if fill is None:\n                continue\n            for r in range(r0 + 1, r1):\n                for c in range(c0 + 1, c1):\n                    out[r][c] = fill\n        return out\n\n    def _apply_staircase_extend_right(self, rule, input_grid):\n        raw = input_grid.raw\n        if len(raw) != 1:\n            return None\n        row0 = list(raw[0])\n        w = len(row0)\n        if w < 2:\n            return None\n        distinct = set(row0)\n        if len(distinct) != 2:\n            return None\n        fg = row0[0]\n        bg = next(v for v in distinct if v != fg)\n        n = 0\n        while n < w and row0[n] == fg:\n            n += 1\n        if n == 0 or any(v != bg for v in row0[n:]):\n            return None\n        oh = w // 2\n        out = []\n        for i in range(oh):\n            cells = [fg] * (n + i) + [bg] * (w - n - i)\n            out.append(cells)\n        return out\n\n    def _apply_corner_quadrant_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        inner_color = rule.get(\"inner_color\")\n        if inner_color is None:\n            return None\n\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        groups = GeneralizeOperator._find_corner_quadrant_groups(raw, bg)\n        groups = [g for g in groups if g[\"inner_color\"] == inner_color]\n        if not groups:\n            return None\n        return GeneralizeOperator._apply_quadrant_groups(raw, groups, bg)\n\n    def _apply_diamond_connector(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        connector = rule.get(\"connector\")\n        if connector is None:\n            return None\n\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        in_colors = {c for row in raw for c in row}\n        fg_set = in_colors - {bg}\n        if len(fg_set) != 1:\n            return None\n        fg = next(iter(fg_set))\n\n        diamonds = GeneralizeOperator._find_diamonds(raw, fg, bg)\n        out = [row[:] for row in raw]\n        GeneralizeOperator._draw_diamond_connectors(out, diamonds, connector)\n        return out\n\n    # ---- helpers ---------------------------------------------------------\n\n    @staticmethod\n    def _group_positions(positions):\n        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n        pos_set = set(positions)\n        visited = set()\n        groups = []\n\n        for pos in positions:\n            if pos in visited:\n                continue\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_set:\n                    continue\n                visited.add(p)\n                group.append(p)\n                r, c = p\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (r + dr, c + dc)\n                    if nb in pos_set and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# SubmitOperator -- finalize and satisfy goal\n# ======================================================================\n\nclass SubmitOperator(Operator):\n    \"\"\"\n    Writes predicted grids to S1 output-link in the format expected by\n    run_task.py, and marks the goal as satisfied.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"submit\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        predictions = wm.s1.get(\"predictions\")\n        if not predictions:\n            return\n\n        task = wm.task\n        if not task:\n            return\n\n        predicted_grids = []\n        for i in range(len(task.test_pairs)):\n            grid = predictions.get(f\"test_{i}\")\n            if grid is not None:\n                predicted_grids.append(grid)\n\n        if not predicted_grids:\n            return\n\n        # Write to output-link (format expected by run_task.py)\n        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n\n        # Mark goal as satisfied\n        wm.s1[\"goal\"] = {\"subgoals\": {\n            f\"test_{i}\": {\"status\": \"solved\"}\n            for i in range(len(predicted_grids))\n        }}\n\n\nclass VerifyOperator(SubmitOperator):\n    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n\n    def __init__(self):\n        super().__init__()\n        self.name = \"verify\"\n","numLines":1631,"startLine":1,"totalLines":1631}}}
