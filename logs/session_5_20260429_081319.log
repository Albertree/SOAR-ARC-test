{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K4LfvBiRrHk8WABmyf4noP","type":"tool_result","content":"1\t\"\"\"\n2\tactive_operators -- SOAR Operator implementations.\n3\t\n4\tPipeline operators (all fire in S2, read/write S1):\n5\t  SelectTargetOperator  -> set up comparison agenda from example pairs\n6\t  CompareOperator       -> execute one comparison using ARCKG compare()\n7\t  ExtractPatternOperator-> cell-level analysis of input/output changes\n8\t  GeneralizeOperator    -> create transformation rule from patterns\n9\t  PredictOperator       -> apply rule to test input\n10\t  SubmitOperator        -> write prediction to output-link, satisfy goal\n11\t\"\"\"\n12\t\n13\tfrom agent.operators import Operator\n14\tfrom ARCKG.comparison import compare as arckg_compare\n15\t\n16\t\n17\t# ======================================================================\n18\t# SolveTaskOperator -- abstract top-level goal (S1)\n19\t# ======================================================================\n20\t\n21\tclass SolveTaskOperator(Operator):\n22\t    \"\"\"\n23\t    Abstract operator at S1. Intentionally makes no WM change so\n24\t    the cycle detects no-change and creates an S2 substate.\n25\t    \"\"\"\n26\t\n27\t    def __init__(self):\n28\t        super().__init__(\"solve-task\")\n29\t        self.proposal_preference = \"+\"\n30\t\n31\t    def precondition(self, wm) -> bool:\n32\t        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n33\t\n34\t    def effect(self, wm):\n35\t        # Intentionally empty -- triggers no-change impasse -> S2\n36\t        return\n37\t\n38\t\n39\t# ======================================================================\n40\t# SelectTargetOperator -- set up comparison agenda\n41\t# ======================================================================\n42\t\n43\tclass SelectTargetOperator(Operator):\n44\t    \"\"\"\n45\t    Reads wm.task to find example pairs and sets up comparison targets.\n46\t    For each example pair: compare input grid (G0) vs output grid (G1).\n47\t    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n48\t    \"\"\"\n49\t\n50\t    def __init__(self):\n51\t        super().__init__(\"select_target\")\n52\t\n53\t    def precondition(self, wm) -> bool:\n54\t        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n55\t\n56\t    def effect(self, wm):\n57\t        task = wm.task\n58\t        if task is None:\n59\t            return\n60\t\n61\t        agenda = []\n62\t        pending = []\n63\t\n64\t        for idx, pair in enumerate(task.example_pairs):\n65\t            if pair.input_grid is not None and pair.output_grid is not None:\n66\t                spec = {\n67\t                    \"type\": \"grid\",\n68\t                    \"pair_idx\": idx,\n69\t                    \"pair_type\": \"example\",\n70\t                    \"id1\": pair.input_grid.node_id,\n71\t                    \"id2\": pair.output_grid.node_id,\n72\t                }\n73\t                agenda.append(spec)\n74\t                pending.append(spec)\n75\t\n76\t        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n77\t        node_lookup = {}\n78\t        for pair in task.example_pairs + task.test_pairs:\n79\t            if pair.input_grid:\n80\t                node_lookup[pair.input_grid.node_id] = pair.input_grid\n81\t            if pair.output_grid:\n82\t                node_lookup[pair.output_grid.node_id] = pair.output_grid\n83\t        wm.node_lookup = node_lookup\n84\t\n85\t        wm.s1[\"comparison-agenda\"] = agenda\n86\t        wm.s1[\"pending-comparisons\"] = pending\n87\t        wm.s1[\"comparisons\"] = {}\n88\t\n89\t\n90\t# ======================================================================\n91\t# CompareOperator -- execute one comparison\n92\t# ======================================================================\n93\t\n94\tclass CompareOperator(Operator):\n95\t    \"\"\"\n96\t    Pops one item from pending-comparisons, calls ARCKG compare(),\n97\t    and stores the result in the comparisons dict on S1.\n98\t    \"\"\"\n99\t\n100\t    def __init__(self, compare_fn=None):\n101\t        super().__init__(\"compare\")\n102\t        self._compare_fn = compare_fn\n103\t\n104\t    def precondition(self, wm) -> bool:\n105\t        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n106\t\n107\t    def effect(self, wm):\n108\t        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n109\t        if not pending:\n110\t            return\n111\t\n112\t        item = pending.pop(0)\n113\t\n114\t        # Find the actual ARCKG nodes\n115\t        node_lookup = getattr(wm, \"node_lookup\", {})\n116\t        node_a = node_lookup.get(item[\"id1\"])\n117\t        node_b = node_lookup.get(item[\"id2\"])\n118\t\n119\t        if node_a is None or node_b is None:\n120\t            wm.s1[\"pending-comparisons\"] = pending\n121\t            return\n122\t\n123\t        # Execute comparison\n124\t        fn = self._compare_fn or arckg_compare\n125\t        result = fn(node_a, node_b)\n126\t\n127\t        # Store result keyed by type and pair index\n128\t        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n129\t        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n130\t        comparisons[key] = {\"spec\": item, \"result\": result}\n131\t\n132\t        wm.s1[\"pending-comparisons\"] = pending\n133\t        wm.s1[\"comparisons\"] = comparisons\n134\t\n135\t\n136\t# ======================================================================\n137\t# ExtractPatternOperator -- cell-level transformation analysis\n138\t# ======================================================================\n139\t\n140\tclass ExtractPatternOperator(Operator):\n141\t    \"\"\"\n142\t    Analyzes each example pair at the cell level to discover what changes\n143\t    between input and output grids. Groups changed cells into connected\n144\t    components and records color/position information for generalization.\n145\t    \"\"\"\n146\t\n147\t    def __init__(self):\n148\t        super().__init__(\"extract_pattern\")\n149\t\n150\t    def precondition(self, wm) -> bool:\n151\t        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n152\t\n153\t    def effect(self, wm):\n154\t        task = wm.task\n155\t        if task is None:\n156\t            return\n157\t\n158\t        patterns = {\n159\t            \"grid_size_preserved\": True,\n160\t            \"pair_analyses\": [],\n161\t        }\n162\t\n163\t        for pair in task.example_pairs:\n164\t            g0 = pair.input_grid\n165\t            g1 = pair.output_grid\n166\t            if g0 is None or g1 is None:\n167\t                continue\n168\t\n169\t            analysis = self._analyze_pair(g0, g1)\n170\t            patterns[\"pair_analyses\"].append(analysis)\n171\t\n172\t            if g0.height != g1.height or g0.width != g1.width:\n173\t                patterns[\"grid_size_preserved\"] = False\n174\t\n175\t        wm.s1[\"patterns\"] = patterns\n176\t\n177\t    # ---- internal helpers ------------------------------------------------\n178\t\n179\t    def _analyze_pair(self, g0, g1):\n180\t        \"\"\"Cell-level diff between input and output grid.\"\"\"\n181\t        raw_in = g0.raw\n182\t        raw_out = g1.raw\n183\t        h = min(len(raw_in), len(raw_out))\n184\t        w = min(\n185\t            len(raw_in[0]) if raw_in else 0,\n186\t            len(raw_out[0]) if raw_out else 0,\n187\t        )\n188\t\n189\t        changes = []\n190\t        for r in range(h):\n191\t            for c in range(w):\n192\t                if raw_in[r][c] != raw_out[r][c]:\n193\t                    changes.append({\n194\t                        \"row\": r, \"col\": c,\n195\t                        \"input_color\": raw_in[r][c],\n196\t                        \"output_color\": raw_out[r][c],\n197\t                    })\n198\t\n199\t        groups = self._group_changes(changes)\n200\t\n201\t        group_analyses = []\n202\t        for group_cells in groups:\n203\t            input_colors = set()\n204\t            output_colors = set()\n205\t            positions = []\n206\t            for cell in group_cells:\n207\t                input_colors.add(cell[\"input_color\"])\n208\t                output_colors.add(cell[\"output_color\"])\n209\t                positions.append((cell[\"row\"], cell[\"col\"]))\n210\t\n211\t            top_row = min(r for r, c in positions)\n212\t            top_col = min(c for r, c in positions)\n213\t\n214\t            group_analyses.append({\n215\t                \"input_colors\": sorted(input_colors),\n216\t                \"output_colors\": sorted(output_colors),\n217\t                \"top_row\": top_row,\n218\t                \"top_col\": top_col,\n219\t                \"cell_count\": len(group_cells),\n220\t            })\n221\t\n222\t        return {\n223\t            \"total_changes\": len(changes),\n224\t            \"num_groups\": len(groups),\n225\t            \"groups\": group_analyses,\n226\t            \"size_match\": (\n227\t                len(raw_in) == len(raw_out)\n228\t                and (len(raw_in[0]) if raw_in else 0)\n229\t                    == (len(raw_out[0]) if raw_out else 0)\n230\t            ),\n231\t        }\n232\t\n233\t    @staticmethod\n234\t    def _group_changes(changes):\n235\t        \"\"\"Group changed cells into 4-connected components.\"\"\"\n236\t        if not changes:\n237\t            return []\n238\t\n239\t        pos_to_change = {}\n240\t        for c in changes:\n241\t            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n242\t\n243\t        visited = set()\n244\t        groups = []\n245\t\n246\t        for change in changes:\n247\t            pos = (change[\"row\"], change[\"col\"])\n248\t            if pos in visited:\n249\t                continue\n250\t\n251\t            group = []\n252\t            queue = [pos]\n253\t            while queue:\n254\t                p = queue.pop(0)\n255\t                if p in visited or p not in pos_to_change:\n256\t                    continue\n257\t                visited.add(p)\n258\t                group.append(pos_to_change[p])\n259\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n260\t                    nb = (p[0] + dr, p[1] + dc)\n261\t                    if nb in pos_to_change and nb not in visited:\n262\t                        queue.append(nb)\n263\t            groups.append(group)\n264\t\n265\t        return groups\n266\t\n267\t\n268\t# ======================================================================\n269\t# GeneralizeOperator -- rule creation from patterns\n270\t# ======================================================================\n271\t\n272\tclass GeneralizeOperator(Operator):\n273\t    \"\"\"\n274\t    Reads extracted patterns and attempts to create a transformation rule.\n275\t    Tries multiple strategies in priority order. If no strategy succeeds,\n276\t    falls back to an identity rule so the pipeline can still complete.\n277\t    \"\"\"\n278\t\n279\t    def __init__(self, generalize_fn=None, save_fn=None):\n280\t        super().__init__(\"generalize\")\n281\t        self._generalize_fn = generalize_fn\n282\t        self._save_fn = save_fn\n283\t\n284\t    def precondition(self, wm) -> bool:\n285\t        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n286\t\n287\t    def effect(self, wm):\n288\t        patterns = wm.s1.get(\"patterns\")\n289\t        if not patterns:\n290\t            return\n291\t\n292\t        task = wm.task\n293\t        example_pairs = self._collect_example_pairs(task)\n294\t\n295\t        rule = None\n296\t\n297\t        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n298\t        rule = self._try_recolor_sequential(patterns)\n299\t\n300\t        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n301\t        if rule is None:\n302\t            rule = self._try_bbox_fill(example_pairs)\n303\t\n304\t        # Strategy 3: horizontal mirror recolor — recolor cells whose\n305\t        #   horizontal-mirror partner has the same color\n306\t        if rule is None:\n307\t            rule = self._try_axis_mirror_recolor(example_pairs)\n308\t\n309\t        # Strategy 4: integer upscale — each input cell becomes a kxk block\n310\t        if rule is None:\n311\t            rule = self._try_integer_upscale(example_pairs)\n312\t\n313\t        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n314\t        if rule is None:\n315\t            rule = self._try_stack_with_mirror(example_pairs)\n316\t\n317\t        # Strategy 6: rectangle interior fill — hollow rect borders get interior\n318\t        #   filled with a color determined by interior dimensions\n319\t        if rule is None:\n320\t            rule = self._try_rect_interior_fill(example_pairs)\n321\t\n322\t        # Strategy 7: staircase extend right — 1-row input becomes a triangular\n323\t        #   stack of rows where each row's prefix grows by one cell\n324\t        if rule is None:\n325\t            rule = self._try_staircase_extend_right(example_pairs)\n326\t\n327\t        # Strategy 8: corner quadrant fill — 4 single-cell corner markers\n328\t        #   surround a solid inner rectangle which is split into quadrants\n329\t        if rule is None:\n330\t            rule = self._try_corner_quadrant_fill(example_pairs)\n331\t\n332\t        # Strategy 9: diamond connector — collinear '+'-shaped 4-cell objects\n333\t        #   are joined by lines of a marker color\n334\t        if rule is None:\n335\t            rule = self._try_diamond_connector(example_pairs)\n336\t\n337\t        # Strategy 10: axis line keep — output preserves a single row or\n338\t        #   column of the input; everything else collapses to background\n339\t        if rule is None:\n340\t            rule = self._try_axis_line_keep(example_pairs)\n341\t\n342\t        # Strategy 11: recolor by component size — single fg color split into\n343\t        #   connected components, each recolored by cell count\n344\t        if rule is None:\n345\t            rule = self._try_recolor_by_size(example_pairs)\n346\t\n347\t        # Strategy 12: simple 1:1 color mapping\n348\t        if rule is None:\n349\t            rule = self._try_color_mapping(patterns)\n350\t\n351\t        # Fallback: identity (copy input as output)\n352\t        if rule is None:\n353\t            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n354\t\n355\t        wm.s1[\"active-rules\"] = [rule]\n356\t\n357\t    @staticmethod\n358\t    def _collect_example_pairs(task):\n359\t        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n360\t        if task is None:\n361\t            return []\n362\t        out = []\n363\t        for pair in task.example_pairs:\n364\t            g0, g1 = pair.input_grid, pair.output_grid\n365\t            if g0 is None or g1 is None:\n366\t                continue\n367\t            out.append((g0.raw, g1.raw))\n368\t        return out\n369\t\n370\t    # ---- strategy: sequential recoloring --------------------------------\n371\t\n372\t    def _try_recolor_sequential(self, patterns):\n373\t        \"\"\"\n374\t        Detect pattern: all changed-cell groups have one source color,\n375\t        output colors are sequential (1,2,3,...), ordered by position.\n376\t        \"\"\"\n377\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n378\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n379\t            return None\n380\t\n381\t        # All pairs must have the same number of change groups\n382\t        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n383\t        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n384\t            return None\n385\t\n386\t        all_source_colors = set()\n387\t\n388\t        for analysis in pair_analyses:\n389\t            for g in analysis[\"groups\"]:\n390\t                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n391\t                    return None\n392\t                all_source_colors.add(g[\"input_colors\"][0])\n393\t\n394\t            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n395\t            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n396\t            if out_colors != expected:\n397\t                return None\n398\t\n399\t        # Try sorting by different position keys\n400\t        for sort_key in [\"top_row\", \"top_col\"]:\n401\t            if self._check_sort_key(pair_analyses, sort_key):\n402\t                start_color = min(\n403\t                    g[\"output_colors\"][0]\n404\t                    for g in pair_analyses[0][\"groups\"]\n405\t                )\n406\t                return {\n407\t                    \"type\": \"recolor_sequential\",\n408\t                    \"sort_key\": sort_key,\n409\t                    \"start_color\": start_color,\n410\t                    \"source_colors\": sorted(all_source_colors),\n411\t                    \"confidence\": 1.0,\n412\t                }\n413\t\n414\t        return None\n415\t\n416\t    @staticmethod\n417\t    def _check_sort_key(pair_analyses, sort_key):\n418\t        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n419\t        for analysis in pair_analyses:\n420\t            groups = analysis[\"groups\"]\n421\t            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n422\t            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n423\t            if colors != list(range(colors[0], colors[0] + len(colors))):\n424\t                return False\n425\t        return True\n426\t\n427\t    # ---- strategy: simple color mapping ---------------------------------\n428\t\n429\t    def _try_color_mapping(self, patterns):\n430\t        \"\"\"\n431\t        Detect pattern: each input color consistently maps to one output color.\n432\t        \"\"\"\n433\t        pair_analyses = patterns.get(\"pair_analyses\", [])\n434\t        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n435\t            return None\n436\t\n437\t        # Collect all observed color transitions\n438\t        color_map = {}\n439\t        for analysis in pair_analyses:\n440\t            for group in analysis[\"groups\"]:\n441\t                for ic in group[\"input_colors\"]:\n442\t                    for oc in group[\"output_colors\"]:\n443\t                        if ic not in color_map:\n444\t                            color_map[ic] = set()\n445\t                        color_map[ic].add(oc)\n446\t\n447\t        # Each input color must map to exactly one output color\n448\t        simple_map = {}\n449\t        for ic, ocs in color_map.items():\n450\t            if len(ocs) != 1:\n451\t                return None\n452\t            simple_map[ic] = list(ocs)[0]\n453\t\n454\t        if simple_map:\n455\t            return {\n456\t                \"type\": \"color_mapping\",\n457\t                \"mapping\": simple_map,\n458\t                \"confidence\": 0.8,\n459\t            }\n460\t\n461\t        return None\n462\t\n463\t    # ---- strategy: bounding-box fill ------------------------------------\n464\t\n465\t    def _try_bbox_fill(self, example_pairs):\n466\t        \"\"\"\n467\t        Detect: same grid size; output equals input except every background\n468\t        cell within the bounding box of the foreground color has been\n469\t        recolored to a single marker color (a color not present in input).\n470\t        \"\"\"\n471\t        if not example_pairs:\n472\t            return None\n473\t\n474\t        marker = None\n475\t        bg_color = None\n476\t        fg_color = None\n477\t\n478\t        for raw_in, raw_out in example_pairs:\n479\t            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n480\t            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n481\t                return None\n482\t\n483\t            in_colors = {c for row in raw_in for c in row}\n484\t            out_colors = {c for row in raw_out for c in row}\n485\t            new_colors = out_colors - in_colors\n486\t            if len(new_colors) != 1:\n487\t                return None\n488\t            m = next(iter(new_colors))\n489\t\n490\t            # Background = most-frequent color in input\n491\t            counts = {}\n492\t            for row in raw_in:\n493\t                for c in row:\n494\t                    counts[c] = counts.get(c, 0) + 1\n495\t            bg = max(counts, key=counts.get)\n496\t\n497\t            # Foreground = the other input color (must be exactly two)\n498\t            fg_set = {c for c in in_colors if c != bg}\n499\t            if len(fg_set) != 1:\n500\t                return None\n501\t            fg = next(iter(fg_set))\n502\t\n503\t            # Compute bbox of foreground in input\n504\t            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n505\t            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n506\t            if not rows:\n507\t                return None\n508\t            r0, r1 = min(rows), max(rows)\n509\t            c0, c1 = min(cols), max(cols)\n510\t\n511\t            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n512\t            for r in range(h):\n513\t                for c in range(w):\n514\t                    inside = r0 <= r <= r1 and c0 <= c <= c1\n515\t                    if inside and raw_in[r][c] == bg:\n516\t                        if raw_out[r][c] != m:\n517\t                            return None\n518\t                    else:\n519\t                        if raw_out[r][c] != raw_in[r][c]:\n520\t                            return None\n521\t\n522\t            if marker is None:\n523\t                marker, bg_color, fg_color = m, bg, fg\n524\t            elif (m, bg, fg) != (marker, bg_color, fg_color):\n525\t                return None\n526\t\n527\t        return {\n528\t            \"type\": \"bbox_fill\",\n529\t            \"marker\": marker,\n530\t            \"background\": bg_color,\n531\t            \"foreground\": fg_color,\n532\t            \"confidence\": 1.0,\n533\t        }\n534\t\n535\t    # ---- strategy: axis mirror recolor ----------------------------------\n536\t\n537\t    def _try_axis_mirror_recolor(self, example_pairs):\n538\t        \"\"\"\n539\t        Detect: same grid size, exactly one new color in output (marker).\n540\t        For some axis (horizontal/vertical), every changed cell is the\n541\t        original foreground color and its mirror partner along that axis\n542\t        also has the original foreground color in the input.\n543\t        Unchanged cells are those without a same-color mirror partner.\n544\t        \"\"\"\n545\t        if not example_pairs:\n546\t            return None\n547\t\n548\t        for axis in (\"horizontal\", \"vertical\"):\n549\t            params = self._check_mirror_axis(example_pairs, axis)\n550\t            if params is not None:\n551\t                return {\n552\t                    \"type\": \"axis_mirror_recolor\",\n553\t                    \"axis\": axis,\n554\t                    \"marker\": params[\"marker\"],\n555\t                    \"foreground\": params[\"foreground\"],\n556\t                    \"confidence\": 1.0,\n557\t                }\n558\t        return None\n559\t\n560\t    @staticmethod\n561\t    def _check_mirror_axis(example_pairs, axis):\n562\t        marker = None\n563\t        fg = None\n564\t        had_change = False\n565\t\n566\t        for raw_in, raw_out in example_pairs:\n567\t            h = len(raw_in)\n568\t            w = len(raw_in[0]) if raw_in else 0\n569\t            if h != len(raw_out) or (w and w != len(raw_out[0])):\n570\t                return None\n571\t\n572\t            new_colors = (\n573\t                {c for row in raw_out for c in row}\n574\t                - {c for row in raw_in for c in row}\n575\t            )\n576\t            if len(new_colors) != 1:\n577\t                return None\n578\t            m = next(iter(new_colors))\n579\t\n580\t            for r in range(h):\n581\t                for c in range(w):\n582\t                    if axis == \"horizontal\":\n583\t                        rr, cc = r, w - 1 - c\n584\t                    else:\n585\t                        rr, cc = h - 1 - r, c\n586\t                    in_v = raw_in[r][c]\n587\t                    out_v = raw_out[r][c]\n588\t                    mirror_v = raw_in[rr][cc]\n589\t                    if out_v == in_v:\n590\t                        # If this cell HAS a same-color mirror partner of\n591\t                        # a non-bg color, the rule would have flipped it.\n592\t                        # We require: not changed → no same-color partner\n593\t                        # OR cell is on the axis and equals itself (trivial).\n594\t                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n595\t                            # only allow when in_v is the background\n596\t                            # (but bg already excluded by != 0 check is rough);\n597\t                            # we'll defer to fg check below.\n598\t                            pass\n599\t                        continue\n600\t                    # Changed: must change FROM some fg TO marker, with mirror\n601\t                    # partner also equal to fg in the input.\n602\t                    if out_v != m:\n603\t                        return None\n604\t                    if in_v == 0:\n605\t                        # background-cells turning into marker — not this rule\n606\t                        return None\n607\t                    if mirror_v != in_v:\n608\t                        return None\n609\t                    if fg is None:\n610\t                        fg = in_v\n611\t                    elif fg != in_v:\n612\t                        return None\n613\t                    had_change = True\n614\t\n615\t            if marker is None:\n616\t                marker = m\n617\t            elif marker != m:\n618\t                return None\n619\t\n620\t        if not had_change or fg is None:\n621\t            return None\n622\t\n623\t        # Final sanity: re-apply rule and confirm exact match.\n624\t        for raw_in, raw_out in example_pairs:\n625\t            h = len(raw_in)\n626\t            w = len(raw_in[0]) if raw_in else 0\n627\t            for r in range(h):\n628\t                for c in range(w):\n629\t                    if axis == \"horizontal\":\n630\t                        rr, cc = r, w - 1 - c\n631\t                    else:\n632\t                        rr, cc = h - 1 - r, c\n633\t                    expected = raw_in[r][c]\n634\t                    if (raw_in[r][c] == fg\n635\t                            and (r, c) != (rr, cc)\n636\t                            and raw_in[rr][cc] == fg):\n637\t                        expected = marker\n638\t                    if raw_out[r][c] != expected:\n639\t                        return None\n640\t\n641\t        return {\"marker\": marker, \"foreground\": fg}\n642\t\n643\t    # ---- strategy: integer upscale --------------------------------------\n644\t\n645\t    def _try_integer_upscale(self, example_pairs):\n646\t        \"\"\"\n647\t        Detect: output dimensions are k * input dimensions (same k for both\n648\t        height and width, and the same k across all examples). Each input\n649\t        cell at (r, c) becomes a kxk block at rows [k*r, k*r+k) and cols\n650\t        [k*c, k*c+k) in the output, all filled with the same color.\n651\t        \"\"\"\n652\t        if not example_pairs:\n653\t            return None\n654\t\n655\t        factor = None\n656\t        for raw_in, raw_out in example_pairs:\n657\t            ih = len(raw_in)\n658\t            iw = len(raw_in[0]) if raw_in else 0\n659\t            oh = len(raw_out)\n660\t            ow = len(raw_out[0]) if raw_out else 0\n661\t            if ih == 0 or iw == 0 or oh == 0 or ow == 0:\n662\t                return None\n663\t            if oh % ih != 0 or ow % iw != 0:\n664\t                return None\n665\t            kh, kw = oh // ih, ow // iw\n666\t            if kh != kw or kh < 2:\n667\t                return None\n668\t            if factor is None:\n669\t                factor = kh\n670\t            elif factor != kh:\n671\t                return None\n672\t            for r in range(ih):\n673\t                for c in range(iw):\n674\t                    v = raw_in[r][c]\n675\t                    for dr in range(factor):\n676\t                        for dc in range(factor):\n677\t                            if raw_out[r * factor + dr][c * factor + dc] != v:\n678\t                                return None\n679\t\n680\t        if factor is None:\n681\t            return None\n682\t        return {\"type\": \"integer_upscale\", \"factor\": factor, \"confidence\": 1.0}\n683\t\n684\t    # ---- strategy: stack with mirror ------------------------------------\n685\t\n686\t    def _try_stack_with_mirror(self, example_pairs):\n687\t        \"\"\"\n688\t        Detect: output = concatenation of input and a flipped copy of input\n689\t        along one axis. Tries four configurations:\n690\t          - direction=vertical,   order=input_first  (rows: input, vflip(input))\n691\t          - direction=vertical,   order=flip_first   (rows: vflip(input), input)\n692\t          - direction=horizontal, order=input_first  (cols: input, hflip(input))\n693\t          - direction=horizontal, order=flip_first   (cols: hflip(input), input)\n694\t        The same configuration must hold across every example.\n695\t        \"\"\"\n696\t        if not example_pairs:\n697\t            return None\n698\t\n699\t        configs = [\n700\t            (\"vertical\", \"input_first\"),\n701\t            (\"vertical\", \"flip_first\"),\n702\t            (\"horizontal\", \"input_first\"),\n703\t            (\"horizontal\", \"flip_first\"),\n704\t        ]\n705\t\n706\t        for direction, order in configs:\n707\t            ok = True\n708\t            for raw_in, raw_out in example_pairs:\n709\t                if not self._check_stack_mirror(raw_in, raw_out, direction, order):\n710\t                    ok = False\n711\t                    break\n712\t            if ok:\n713\t                return {\n714\t                    \"type\": \"stack_with_mirror\",\n715\t                    \"direction\": direction,\n716\t                    \"order\": order,\n717\t                    \"confidence\": 1.0,\n718\t                }\n719\t        return None\n720\t\n721\t    @staticmethod\n722\t    def _check_stack_mirror(raw_in, raw_out, direction, order):\n723\t        ih = len(raw_in)\n724\t        iw = len(raw_in[0]) if raw_in else 0\n725\t        oh = len(raw_out)\n726\t        ow = len(raw_out[0]) if raw_out else 0\n727\t        if ih == 0 or iw == 0:\n728\t            return False\n729\t\n730\t        if direction == \"vertical\":\n731\t            if ow != iw or oh != 2 * ih:\n732\t                return False\n733\t            flipped = list(reversed(raw_in))\n734\t            top = raw_in if order == \"input_first\" else flipped\n735\t            bot = flipped if order == \"input_first\" else raw_in\n736\t            for r in range(ih):\n737\t                if list(raw_out[r]) != list(top[r]):\n738\t                    return False\n739\t                if list(raw_out[ih + r]) != list(bot[r]):\n740\t                    return False\n741\t            return True\n742\t        else:  # horizontal\n743\t            if oh != ih or ow != 2 * iw:\n744\t                return False\n745\t            flipped = [list(reversed(row)) for row in raw_in]\n746\t            left = raw_in if order == \"input_first\" else flipped\n747\t            right = flipped if order == \"input_first\" else raw_in\n748\t            for r in range(ih):\n749\t                if list(raw_out[r][:iw]) != list(left[r]):\n750\t                    return False\n751\t                if list(raw_out[r][iw:]) != list(right[r]):\n752\t                    return False\n753\t            return True\n754\t\n755\t    # ---- strategy: rectangle interior fill ------------------------------\n756\t\n757\t    def _try_rect_interior_fill(self, example_pairs):\n758\t        \"\"\"\n759\t        Detect: same grid size; input contains hollow rectangular borders of a\n760\t        single foreground color on a background; output equals input except\n761\t        each hollow rect's interior is filled with a color determined by the\n762\t        rect's interior dimensions. Map (interior_h, interior_w) -> fill_color\n763\t        is learned from training and applied to test rectangles.\n764\t        \"\"\"\n765\t        if not example_pairs:\n766\t            return None\n767\t\n768\t        size_to_fill = {}\n769\t        bg_color = None\n770\t        border_color = None\n771\t\n772\t        for raw_in, raw_out in example_pairs:\n773\t            h = len(raw_in)\n774\t            w = len(raw_in[0]) if raw_in else 0\n775\t            if h == 0 or w == 0:\n776\t                return None\n777\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n778\t                return None\n779\t\n780\t            # Background = most-frequent color in input\n781\t            counts = {}\n782\t            for row in raw_in:\n783\t                for c in row:\n784\t                    counts[c] = counts.get(c, 0) + 1\n785\t            bg = max(counts, key=counts.get)\n786\t\n787\t            # Foreground colors = everything else; require exactly one\n788\t            fg_set = {c for c in counts if c != bg}\n789\t            if len(fg_set) != 1:\n790\t                return None\n791\t            fg = next(iter(fg_set))\n792\t\n793\t            if bg_color is None:\n794\t                bg_color, border_color = bg, fg\n795\t            elif (bg_color, border_color) != (bg, fg):\n796\t                return None\n797\t\n798\t            rects = self._find_hollow_rects(raw_in, fg, bg)\n799\t            if not rects:\n800\t                return None\n801\t\n802\t            # Build expected output: copy input, fill each rect interior\n803\t            # with the color present in raw_out at the interior cells.\n804\t            for (r0, c0, r1, c1) in rects:\n805\t                ih_int = r1 - r0 - 1\n806\t                iw_int = c1 - c0 - 1\n807\t                if ih_int < 1 or iw_int < 1:\n808\t                    return None\n809\t                fill = raw_out[r0 + 1][c0 + 1]\n810\t                # Interior must be uniform fill color in output\n811\t                for r in range(r0 + 1, r1):\n812\t                    for c in range(c0 + 1, c1):\n813\t                        if raw_out[r][c] != fill:\n814\t                            return None\n815\t                key = (ih_int, iw_int)\n816\t                if key in size_to_fill and size_to_fill[key] != fill:\n817\t                    return None\n818\t                size_to_fill[key] = fill\n819\t\n820\t            # Verify all non-interior cells are unchanged\n821\t            interior_cells = set()\n822\t            for (r0, c0, r1, c1) in rects:\n823\t                for r in range(r0 + 1, r1):\n824\t                    for c in range(c0 + 1, c1):\n825\t                        interior_cells.add((r, c))\n826\t            for r in range(h):\n827\t                for c in range(w):\n828\t                    if (r, c) in interior_cells:\n829\t                        continue\n830\t                    if raw_in[r][c] != raw_out[r][c]:\n831\t                        return None\n832\t\n833\t        if not size_to_fill:\n834\t            return None\n835\t        return {\n836\t            \"type\": \"rect_interior_fill\",\n837\t            \"background\": bg_color,\n838\t            \"border\": border_color,\n839\t            \"size_to_fill\": {f\"{k[0]}x{k[1]}\": v for k, v in size_to_fill.items()},\n840\t            \"confidence\": 1.0,\n841\t        }\n842\t\n843\t    @staticmethod\n844\t    def _find_hollow_rects(raw, fg, bg):\n845\t        \"\"\"Find all hollow rectangles of color fg with interior color bg.\n846\t        Returns list of (r0, c0, r1, c1) bounding boxes.\"\"\"\n847\t        h = len(raw)\n848\t        w = len(raw[0]) if raw else 0\n849\t\n850\t        # Find connected components of fg cells (4-connected)\n851\t        visited = [[False] * w for _ in range(h)]\n852\t        rects = []\n853\t\n854\t        for r in range(h):\n855\t            for c in range(w):\n856\t                if raw[r][c] != fg or visited[r][c]:\n857\t                    continue\n858\t                # BFS\n859\t                comp = []\n860\t                queue = [(r, c)]\n861\t                while queue:\n862\t                    rr, cc = queue.pop(0)\n863\t                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n864\t                        continue\n865\t                    if visited[rr][cc] or raw[rr][cc] != fg:\n866\t                        continue\n867\t                    visited[rr][cc] = True\n868\t                    comp.append((rr, cc))\n869\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n870\t                        queue.append((rr + dr, cc + dc))\n871\t\n872\t                if not comp:\n873\t                    continue\n874\t                rs = [p[0] for p in comp]\n875\t                cs = [p[1] for p in comp]\n876\t                r0, r1 = min(rs), max(rs)\n877\t                c0, c1 = min(cs), max(cs)\n878\t                width = c1 - c0 + 1\n879\t                height = r1 - r0 + 1\n880\t                if width < 3 or height < 3:\n881\t                    continue\n882\t                # Check border is all fg\n883\t                comp_set = set(comp)\n884\t                ok = True\n885\t                for cc in range(c0, c1 + 1):\n886\t                    if (r0, cc) not in comp_set or (r1, cc) not in comp_set:\n887\t                        ok = False\n888\t                        break\n889\t                if ok:\n890\t                    for rr in range(r0, r1 + 1):\n891\t                        if (rr, c0) not in comp_set or (rr, c1) not in comp_set:\n892\t                            ok = False\n893\t                            break\n894\t                if not ok:\n895\t                    continue\n896\t                # Check interior is all bg\n897\t                for rr in range(r0 + 1, r1):\n898\t                    for cc in range(c0 + 1, c1):\n899\t                        if raw[rr][cc] != bg:\n900\t                            ok = False\n901\t                            break\n902\t                    if not ok:\n903\t                        break\n904\t                # Component must be exactly the border (no extra fg cells)\n905\t                expected_border_size = 2 * (height + width) - 4\n906\t                if ok and len(comp) == expected_border_size:\n907\t                    rects.append((r0, c0, r1, c1))\n908\t        return rects\n909\t\n910\t    # ---- strategy: staircase extend right -------------------------------\n911\t\n912\t    def _try_staircase_extend_right(self, example_pairs):\n913\t        \"\"\"\n914\t        Detect: every input is exactly one row of width w; output has\n915\t        oh = w // 2 rows and width w. Row 0 of the output equals the input;\n916\t        each subsequent row extends the colored prefix by one cell to the\n917\t        right (one more cell of the same fg color, rest background).\n918\t        \"\"\"\n919\t        if not example_pairs:\n920\t            return None\n921\t\n922\t        for raw_in, raw_out in example_pairs:\n923\t            if len(raw_in) != 1:\n924\t                return None\n925\t            w = len(raw_in[0])\n926\t            if w < 2:\n927\t                return None\n928\t            oh = len(raw_out)\n929\t            if oh != w // 2 or oh < 1:\n930\t                return None\n931\t            for row in raw_out:\n932\t                if len(row) != w:\n933\t                    return None\n934\t\n935\t            # The prefix color (fg) is the leftmost cell; the rest must be a\n936\t            # single different background color.\n937\t            row0 = list(raw_in[0])\n938\t            distinct = set(row0)\n939\t            if len(distinct) != 2:\n940\t                return None\n941\t            fg = row0[0]\n942\t            bg = next(v for v in distinct if v != fg)\n943\t\n944\t            n = 0\n945\t            while n < w and row0[n] == fg:\n946\t                n += 1\n947\t            if n == 0 or any(v != bg for v in row0[n:]):\n948\t                return None\n949\t\n950\t            # Verify each output row\n951\t            for i in range(oh):\n952\t                expected = [fg] * (n + i) + [bg] * (w - n - i)\n953\t                if list(raw_out[i]) != expected:\n954\t                    return None\n955\t\n956\t        return {\"type\": \"staircase_extend_right\", \"confidence\": 1.0}\n957\t\n958\t    # ---- strategy: corner quadrant fill ---------------------------------\n959\t\n960\t    def _try_corner_quadrant_fill(self, example_pairs):\n961\t        \"\"\"\n962\t        Detect: same grid size; input has 4 single-cell 'corner markers' of\n963\t        distinct non-background colors at the 4 corners of an axis-aligned\n964\t        rectangle, plus a solid block of one other 'inner' color filling the\n965\t        cells strictly inside that rectangle. The output replaces the corners\n966\t        with background and splits the inner block into four equal quadrants\n967\t        (TL/TR/BL/BR) recolored by the corresponding corner color.\n968\t        \"\"\"\n969\t        if not example_pairs:\n970\t            return None\n971\t\n972\t        inner_color = None\n973\t\n974\t        for raw_in, raw_out in example_pairs:\n975\t            params = self._check_corner_quadrant_fill(raw_in, raw_out)\n976\t            if params is None:\n977\t                return None\n978\t            if inner_color is None:\n979\t                inner_color = params[\"inner_color\"]\n980\t            elif inner_color != params[\"inner_color\"]:\n981\t                return None\n982\t\n983\t        if inner_color is None:\n984\t            return None\n985\t        return {\n986\t            \"type\": \"corner_quadrant_fill\",\n987\t            \"inner_color\": inner_color,\n988\t            \"confidence\": 1.0,\n989\t        }\n990\t\n991\t    @staticmethod\n992\t    def _check_corner_quadrant_fill(raw_in, raw_out):\n993\t        h = len(raw_in)\n994\t        w = len(raw_in[0]) if raw_in else 0\n995\t        if h == 0 or w == 0:\n996\t            return None\n997\t        if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n998\t            return None\n999\t\n1000\t        counts = {}\n1001\t        for row in raw_in:\n1002\t            for c in row:\n1003\t                counts[c] = counts.get(c, 0) + 1\n1004\t        bg = max(counts, key=counts.get)\n1005\t\n1006\t        # Find inner color: must be one color forming one or more solid\n1007\t        # rectangles, each of even side lengths >= 2, with 4 single-cell\n1008\t        # 'corner markers' at the diagonal-adjacent positions.\n1009\t        groups = GeneralizeOperator._find_corner_quadrant_groups(raw_in, bg)\n1010\t        if not groups:\n1011\t            return None\n1012\t        inner = groups[0][\"inner_color\"]\n1013\t        for g in groups:\n1014\t            if g[\"inner_color\"] != inner:\n1015\t                return None\n1016\t\n1017\t        expected = GeneralizeOperator._apply_quadrant_groups(raw_in, groups, bg)\n1018\t        for r in range(h):\n1019\t            for c in range(w):\n1020\t                if expected[r][c] != raw_out[r][c]:\n1021\t                    return None\n1022\t\n1023\t        return {\"inner_color\": inner}\n1024\t\n1025\t    @staticmethod\n1026\t    def _find_corner_quadrant_groups(raw, bg):\n1027\t        \"\"\"Find all (inner-rect + 4 corner-marker) groups in raw.\n1028\t\n1029\t        A group consists of: a solid rectangle filled with one non-bg color\n1030\t        (the 'inner color'), with side lengths >= 2 and even, surrounded by\n1031\t        4 single cells at the diagonal-adjacent positions, each a distinct\n1032\t        non-bg color (and distinct from the inner color). Returns a list of\n1033\t        dicts {r0,r1,c0,c1, inner_color, tl, tr, bl, br}, or empty list.\"\"\"\n1034\t        h = len(raw)\n1035\t        w = len(raw[0]) if raw else 0\n1036\t\n1037\t        # 4-connected components of every non-bg color\n1038\t        visited = [[False] * w for _ in range(h)]\n1039\t        groups = []\n1040\t        for r in range(h):\n1041\t            for c in range(w):\n1042\t                if raw[r][c] == bg or visited[r][c]:\n1043\t                    continue\n1044\t                color = raw[r][c]\n1045\t                comp = []\n1046\t                queue = [(r, c)]\n1047\t                while queue:\n1048\t                    rr, cc = queue.pop()\n1049\t                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n1050\t                        continue\n1051\t                    if visited[rr][cc] or raw[rr][cc] != color:\n1052\t                        continue\n1053\t                    visited[rr][cc] = True\n1054\t                    comp.append((rr, cc))\n1055\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1056\t                        queue.append((rr + dr, cc + dc))\n1057\t                if len(comp) < 4:\n1058\t                    continue  # skip tiny components\n1059\t                rs = [p[0] for p in comp]\n1060\t                cs = [p[1] for p in comp]\n1061\t                r0, r1 = min(rs), max(rs)\n1062\t                c0, c1 = min(cs), max(cs)\n1063\t                ih = r1 - r0 + 1\n1064\t                iw = c1 - c0 + 1\n1065\t                if ih < 2 or iw < 2:\n1066\t                    continue\n1067\t                if ih % 2 != 0 or iw % 2 != 0:\n1068\t                    continue\n1069\t                # Must be a solid rectangle\n1070\t                if len(comp) != ih * iw:\n1071\t                    continue\n1072\t                # Corner positions are diagonally adjacent to the rectangle\n1073\t                cr0, cc0 = r0 - 1, c0 - 1\n1074\t                cr1, cc1 = r0 - 1, c1 + 1\n1075\t                cr2, cc2 = r1 + 1, c0 - 1\n1076\t                cr3, cc3 = r1 + 1, c1 + 1\n1077\t                if (cr0 < 0 or cc0 < 0 or cr3 >= h or cc3 >= w):\n1078\t                    continue\n1079\t                tl_v = raw[cr0][cc0]\n1080\t                tr_v = raw[cr1][cc1]\n1081\t                bl_v = raw[cr2][cc2]\n1082\t                br_v = raw[cr3][cc3]\n1083\t                corner_vals = [tl_v, tr_v, bl_v, br_v]\n1084\t                if any(v == bg or v == color for v in corner_vals):\n1085\t                    continue\n1086\t                if len(set(corner_vals)) != 4:\n1087\t                    continue\n1088\t                # Each corner cell must be isolated: 4-neighbours all bg\n1089\t                ok = True\n1090\t                for (rr, cc) in [(cr0, cc0), (cr1, cc1), (cr2, cc2), (cr3, cc3)]:\n1091\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1092\t                        nr, nc = rr + dr, cc + dc\n1093\t                        if 0 <= nr < h and 0 <= nc < w:\n1094\t                            if raw[nr][nc] != bg:\n1095\t                                ok = False\n1096\t                                break\n1097\t                    if not ok:\n1098\t                        break\n1099\t                if not ok:\n1100\t                    continue\n1101\t                groups.append({\n1102\t                    \"r0\": r0, \"r1\": r1, \"c0\": c0, \"c1\": c1,\n1103\t                    \"inner_color\": color,\n1104\t                    \"tl\": tl_v, \"tr\": tr_v, \"bl\": bl_v, \"br\": br_v,\n1105\t                    \"tl_pos\": (cr0, cc0), \"tr_pos\": (cr1, cc1),\n1106\t                    \"bl_pos\": (cr2, cc2), \"br_pos\": (cr3, cc3),\n1107\t                })\n1108\t        return groups\n1109\t\n1110\t    @staticmethod\n1111\t    def _apply_quadrant_groups(raw, groups, bg):\n1112\t        out = [list(row) for row in raw]\n1113\t        for g in groups:\n1114\t            r0, r1, c0, c1 = g[\"r0\"], g[\"r1\"], g[\"c0\"], g[\"c1\"]\n1115\t            ih = r1 - r0 + 1\n1116\t            iw = c1 - c0 + 1\n1117\t            hh, ww = ih // 2, iw // 2\n1118\t            # Clear corner markers\n1119\t            for key in (\"tl_pos\", \"tr_pos\", \"bl_pos\", \"br_pos\"):\n1120\t                rr, cc = g[key]\n1121\t                out[rr][cc] = bg\n1122\t            # Fill quadrants of inner rect\n1123\t            for r in range(r0, r1 + 1):\n1124\t                for c in range(c0, c1 + 1):\n1125\t                    is_top = r < r0 + hh\n1126\t                    is_left = c < c0 + ww\n1127\t                    if is_top and is_left:\n1128\t                        out[r][c] = g[\"tl\"]\n1129\t                    elif is_top:\n1130\t                        out[r][c] = g[\"tr\"]\n1131\t                    elif is_left:\n1132\t                        out[r][c] = g[\"bl\"]\n1133\t                    else:\n1134\t                        out[r][c] = g[\"br\"]\n1135\t        return out\n1136\t\n1137\t    # ---- strategy: diamond connector ------------------------------------\n1138\t\n1139\t    def _try_diamond_connector(self, example_pairs):\n1140\t        \"\"\"\n1141\t        Detect: same grid size; input contains '+'-shaped 4-cell diamond\n1142\t        markers (one foreground cell at each of N/S/E/W around a background\n1143\t        center, with all 4 diagonal cells being background). Each pair of\n1144\t        adjacent collinear diamonds (sharing a row or column with no other\n1145\t        diamond between them on that line) is joined in the output by a\n1146\t        line of a single 'connector' color filling the cells strictly\n1147\t        between their inner '+' tips.\n1148\t        \"\"\"\n1149\t        if not example_pairs:\n1150\t            return None\n1151\t\n1152\t        connector = None\n1153\t        fg_color = None\n1154\t\n1155\t        for raw_in, raw_out in example_pairs:\n1156\t            h = len(raw_in)\n1157\t            w = len(raw_in[0]) if raw_in else 0\n1158\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n1159\t                return None\n1160\t\n1161\t            in_colors = {c for row in raw_in for c in row}\n1162\t            out_colors = {c for row in raw_out for c in row}\n1163\t            new_colors = out_colors - in_colors\n1164\t            if len(new_colors) != 1:\n1165\t                return None\n1166\t            marker = next(iter(new_colors))\n1167\t            if connector is None:\n1168\t                connector = marker\n1169\t            elif connector != marker:\n1170\t                return None\n1171\t\n1172\t            counts = {}\n1173\t            for row in raw_in:\n1174\t                for c in row:\n1175\t                    counts[c] = counts.get(c, 0) + 1\n1176\t            bg = max(counts, key=counts.get)\n1177\t            fg_set = in_colors - {bg}\n1178\t            if len(fg_set) != 1:\n1179\t                return None\n1180\t            fg = next(iter(fg_set))\n1181\t            if fg_color is None:\n1182\t                fg_color = fg\n1183\t            elif fg_color != fg:\n1184\t                return None\n1185\t\n1186\t            diamonds = self._find_diamonds(raw_in, fg, bg)\n1187\t            if len(diamonds) < 2:\n1188\t                return None\n1189\t\n1190\t            expected = [list(row) for row in raw_in]\n1191\t            self._draw_diamond_connectors(expected, diamonds, marker)\n1192\t\n1193\t            for r in range(h):\n1194\t                for c in range(w):\n1195\t                    if expected[r][c] != raw_out[r][c]:\n1196\t                        return None\n1197\t\n1198\t        if connector is None or fg_color is None:\n1199\t            return None\n1200\t        return {\n1201\t            \"type\": \"diamond_connector\",\n1202\t            \"connector\": connector,\n1203\t            \"foreground\": fg_color,\n1204\t            \"confidence\": 1.0,\n1205\t        }\n1206\t\n1207\t    @staticmethod\n1208\t    def _find_diamonds(raw, fg, bg):\n1209\t        h = len(raw)\n1210\t        w = len(raw[0]) if raw else 0\n1211\t        centers = []\n1212\t        for r in range(1, h - 1):\n1213\t            for c in range(1, w - 1):\n1214\t                if raw[r][c] != bg:\n1215\t                    continue\n1216\t                if (raw[r - 1][c] == fg and raw[r + 1][c] == fg\n1217\t                        and raw[r][c - 1] == fg and raw[r][c + 1] == fg\n1218\t                        and raw[r - 1][c - 1] == bg and raw[r - 1][c + 1] == bg\n1219\t                        and raw[r + 1][c - 1] == bg and raw[r + 1][c + 1] == bg):\n1220\t                    centers.append((r, c))\n1221\t        return centers\n1222\t\n1223\t    @staticmethod\n1224\t    def _draw_diamond_connectors(grid, diamonds, marker):\n1225\t        by_row = {}\n1226\t        by_col = {}\n1227\t        for r, c in diamonds:\n1228\t            by_row.setdefault(r, []).append(c)\n1229\t            by_col.setdefault(c, []).append(r)\n1230\t        for r, cols in by_row.items():\n1231\t            cols = sorted(cols)\n1232\t            for i in range(len(cols) - 1):\n1233\t                cl, cr = cols[i], cols[i + 1]\n1234\t                for cc in range(cl + 2, cr - 1):\n1235\t                    grid[r][cc] = marker\n1236\t        for c, rows in by_col.items():\n1237\t            rows = sorted(rows)\n1238\t            for i in range(len(rows) - 1):\n1239\t                rl, rr = rows[i], rows[i + 1]\n1240\t                for rr2 in range(rl + 2, rr - 1):\n1241\t                    grid[rr2][c] = marker\n1242\t\n1243\t    # ---- strategy: axis line keep ---------------------------------------\n1244\t\n1245\t    def _try_axis_line_keep(self, example_pairs):\n1246\t        \"\"\"\n1247\t        Detect: same grid size; output equals input on a single 'kept' line\n1248\t        (one row or one column) and equals a single background color\n1249\t        everywhere else. The line position must be derivable consistently\n1250\t        across all examples (e.g., always the middle row/column).\n1251\t        \"\"\"\n1252\t        if not example_pairs:\n1253\t            return None\n1254\t\n1255\t        for axis, pos_kind in ((\"col\", \"middle\"), (\"row\", \"middle\")):\n1256\t            params = self._check_axis_line_keep(example_pairs, axis, pos_kind)\n1257\t            if params is not None:\n1258\t                return {\n1259\t                    \"type\": \"axis_line_keep\",\n1260\t                    \"axis\": axis,\n1261\t                    \"position\": pos_kind,\n1262\t                    \"background\": params[\"background\"],\n1263\t                    \"confidence\": 1.0,\n1264\t                }\n1265\t        return None\n1266\t\n1267\t    @staticmethod\n1268\t    def _check_axis_line_keep(example_pairs, axis, pos_kind):\n1269\t        bg_color = None\n1270\t        for raw_in, raw_out in example_pairs:\n1271\t            h = len(raw_in)\n1272\t            w = len(raw_in[0]) if raw_in else 0\n1273\t            if h == 0 or w == 0:\n1274\t                return None\n1275\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n1276\t                return None\n1277\t            if pos_kind == \"middle\":\n1278\t                k = (w // 2) if axis == \"col\" else (h // 2)\n1279\t            else:\n1280\t                return None\n1281\t\n1282\t            local_bg = None\n1283\t            for r in range(h):\n1284\t                for c in range(w):\n1285\t                    on_line = (axis == \"col\" and c == k) or (axis == \"row\" and r == k)\n1286\t                    if on_line:\n1287\t                        if raw_out[r][c] != raw_in[r][c]:\n1288\t                            return None\n1289\t                    else:\n1290\t                        if local_bg is None:\n1291\t                            local_bg = raw_out[r][c]\n1292\t                        elif raw_out[r][c] != local_bg:\n1293\t                            return None\n1294\t            if local_bg is None:\n1295\t                return None\n1296\t            if bg_color is None:\n1297\t                bg_color = local_bg\n1298\t            elif bg_color != local_bg:\n1299\t                return None\n1300\t        if bg_color is None:\n1301\t            return None\n1302\t        return {\"background\": bg_color}\n1303\t\n1304\t    # ---- strategy: recolor by component size ----------------------------\n1305\t\n1306\t    def _try_recolor_by_size(self, example_pairs):\n1307\t        \"\"\"\n1308\t        Detect: same grid size; input has one background color and one\n1309\t        foreground color; connected components of foreground cells in the\n1310\t        input are each recolored uniformly in the output to a color that\n1311\t        depends solely on the component's cell count. A consistent\n1312\t        size -> color mapping must hold across all examples. Non-foreground\n1313\t        cells are unchanged.\n1314\t        \"\"\"\n1315\t        if not example_pairs:\n1316\t            return None\n1317\t\n1318\t        size_to_color = {}\n1319\t        fg_color = None\n1320\t        bg_color = None\n1321\t\n1322\t        for raw_in, raw_out in example_pairs:\n1323\t            h = len(raw_in)\n1324\t            w = len(raw_in[0]) if raw_in else 0\n1325\t            if h == 0 or w == 0:\n1326\t                return None\n1327\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n1328\t                return None\n1329\t\n1330\t            counts = {}\n1331\t            for row in raw_in:\n1332\t                for c in row:\n1333\t                    counts[c] = counts.get(c, 0) + 1\n1334\t            bg_local = max(counts, key=counts.get)\n1335\t            in_colors = set(counts.keys())\n1336\t            fg_set = in_colors - {bg_local}\n1337\t            if len(fg_set) != 1:\n1338\t                return None\n1339\t            fg_local = next(iter(fg_set))\n1340\t\n1341\t            if bg_color is None:\n1342\t                bg_color, fg_color = bg_local, fg_local\n1343\t            elif (bg_color, fg_color) != (bg_local, fg_local):\n1344\t                return None\n1345\t\n1346\t            comps = self._find_components(raw_in, fg_local)\n1347\t            if not comps:\n1348\t                return None\n1349\t            for comp in comps:\n1350\t                out_colors = {raw_out[r][c] for (r, c) in comp}\n1351\t                if len(out_colors) != 1:\n1352\t                    return None\n1353\t                out_c = next(iter(out_colors))\n1354\t                size = len(comp)\n1355\t                if size in size_to_color and size_to_color[size] != out_c:\n1356\t                    return None\n1357\t                size_to_color[size] = out_c\n1358\t\n1359\t            # Non-foreground cells must be unchanged\n1360\t            for r in range(h):\n1361\t                for c in range(w):\n1362\t                    if raw_in[r][c] != fg_local and raw_out[r][c] != raw_in[r][c]:\n1363\t                        return None\n1364\t\n1365\t        if not size_to_color or fg_color is None:\n1366\t            return None\n1367\t        return {\n1368\t            \"type\": \"recolor_by_size\",\n1369\t            \"foreground\": fg_color,\n1370\t            \"background\": bg_color,\n1371\t            \"size_to_color\": {str(k): v for k, v in size_to_color.items()},\n1372\t            \"confidence\": 1.0,\n1373\t        }\n1374\t\n1375\t    @staticmethod\n1376\t    def _find_components(raw, color):\n1377\t        \"\"\"Return 4-connected components of `color` in `raw` as lists of (r, c).\"\"\"\n1378\t        h = len(raw)\n1379\t        w = len(raw[0]) if raw else 0\n1380\t        visited = [[False] * w for _ in range(h)]\n1381\t        comps = []\n1382\t        for r in range(h):\n1383\t            for c in range(w):\n1384\t                if raw[r][c] != color or visited[r][c]:\n1385\t                    continue\n1386\t                comp = []\n1387\t                queue = [(r, c)]\n1388\t                while queue:\n1389\t                    rr, cc = queue.pop()\n1390\t                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n1391\t                        continue\n1392\t                    if visited[rr][cc] or raw[rr][cc] != color:\n1393\t                        continue\n1394\t                    visited[rr][cc] = True\n1395\t                    comp.append((rr, cc))\n1396\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1397\t                        queue.append((rr + dr, cc + dc))\n1398\t                comps.append(comp)\n1399\t        return comps\n1400\t\n1401\t\n1402\t# ======================================================================\n1403\t# DescendOperator -- placeholder for deeper KG exploration\n1404\t# ======================================================================\n1405\t\n1406\tclass DescendOperator(Operator):\n1407\t    \"\"\"\n1408\t    Placeholder: moves focus to a deeper KG level when current-level\n1409\t    analysis is insufficient. Not yet needed for the basic pipeline.\n1410\t    \"\"\"\n1411\t\n1412\t    def __init__(self):\n1413\t        super().__init__(\"descend\")\n1414\t\n1415\t    def precondition(self, wm) -> bool:\n1416\t        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n1417\t\n1418\t    def effect(self, wm):\n1419\t        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n1420\t\n1421\t\n1422\t# ======================================================================\n1423\t# PredictOperator -- apply rule to test input\n1424\t# ======================================================================\n1425\t\n1426\tclass PredictOperator(Operator):\n1427\t    \"\"\"\n1428\t    Reads the best rule from active-rules and applies it to each test\n1429\t    pair's input grid to produce a predicted output grid.\n1430\t    \"\"\"\n1431\t\n1432\t    def __init__(self):\n1433\t        super().__init__(\"predict\")\n1434\t\n1435\t    def precondition(self, wm) -> bool:\n1436\t        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n1437\t\n1438\t    def effect(self, wm):\n1439\t        task = wm.task\n1440\t        active_rules = wm.s1.get(\"active-rules\")\n1441\t        if not task or not active_rules:\n1442\t            return\n1443\t\n1444\t        rule = active_rules[0]\n1445\t        predictions = dict(wm.s1.get(\"predictions\") or {})\n1446\t\n1447\t        for i, test_pair in enumerate(task.test_pairs):\n1448\t            key = f\"test_{i}\"\n1449\t            if key in predictions:\n1450\t                continue\n1451\t            g0 = test_pair.input_grid\n1452\t            if g0 is None:\n1453\t                continue\n1454\t            predicted = self._apply_rule(rule, g0)\n1455\t            if predicted is not None:\n1456\t                predictions[key] = predicted\n1457\t\n1458\t        wm.s1[\"predictions\"] = predictions\n1459\t\n1460\t    # ---- rule application dispatchers ------------------------------------\n1461\t\n1462\t    def _apply_rule(self, rule, input_grid):\n1463\t        rule_type = rule.get(\"type\")\n1464\t        if rule_type == \"recolor_sequential\":\n1465\t            return self._apply_recolor_sequential(rule, input_grid)\n1466\t        if rule_type == \"color_mapping\":\n1467\t            return self._apply_color_mapping(rule, input_grid)\n1468\t        if rule_type == \"bbox_fill\":\n1469\t            return self._apply_bbox_fill(rule, input_grid)\n1470\t        if rule_type == \"axis_mirror_recolor\":\n1471\t            return self._apply_axis_mirror_recolor(rule, input_grid)\n1472\t        if rule_type == \"integer_upscale\":\n1473\t            return self._apply_integer_upscale(rule, input_grid)\n1474\t        if rule_type == \"stack_with_mirror\":\n1475\t            return self._apply_stack_with_mirror(rule, input_grid)\n1476\t        if rule_type == \"rect_interior_fill\":\n1477\t            return self._apply_rect_interior_fill(rule, input_grid)\n1478\t        if rule_type == \"staircase_extend_right\":\n1479\t            return self._apply_staircase_extend_right(rule, input_grid)\n1480\t        if rule_type == \"corner_quadrant_fill\":\n1481\t            return self._apply_corner_quadrant_fill(rule, input_grid)\n1482\t        if rule_type == \"diamond_connector\":\n1483\t            return self._apply_diamond_connector(rule, input_grid)\n1484\t        if rule_type == \"axis_line_keep\":\n1485\t            return self._apply_axis_line_keep(rule, input_grid)\n1486\t        if rule_type == \"recolor_by_size\":\n1487\t            return self._apply_recolor_by_size(rule, input_grid)\n1488\t        if rule_type == \"identity\":\n1489\t            return [row[:] for row in input_grid.raw]\n1490\t        return None\n1491\t\n1492\t    def _apply_recolor_sequential(self, rule, input_grid):\n1493\t        raw = input_grid.raw\n1494\t        height = len(raw)\n1495\t        width = len(raw[0]) if raw else 0\n1496\t        sort_key = rule[\"sort_key\"]\n1497\t        start_color = rule[\"start_color\"]\n1498\t        source_colors = set(rule.get(\"source_colors\", []))\n1499\t\n1500\t        # Find target cells\n1501\t        target_cells = []\n1502\t        for r in range(height):\n1503\t            for c in range(width):\n1504\t                if raw[r][c] in source_colors:\n1505\t                    target_cells.append((r, c))\n1506\t\n1507\t        if not target_cells:\n1508\t            return [row[:] for row in raw]\n1509\t\n1510\t        # Group into connected components\n1511\t        groups = self._group_positions(target_cells)\n1512\t\n1513\t        # Sort groups by the rule's sort key\n1514\t        def _sort_val(group):\n1515\t            if sort_key == \"top_row\":\n1516\t                return min(r for r, c in group)\n1517\t            if sort_key == \"top_col\":\n1518\t                return min(c for r, c in group)\n1519\t            return 0\n1520\t\n1521\t        sorted_groups = sorted(groups, key=_sort_val)\n1522\t\n1523\t        # Build output grid\n1524\t        output = [row[:] for row in raw]\n1525\t        for idx, group in enumerate(sorted_groups):\n1526\t            new_color = start_color + idx\n1527\t            for r, c in group:\n1528\t                output[r][c] = new_color\n1529\t\n1530\t        return output\n1531\t\n1532\t    def _apply_color_mapping(self, rule, input_grid):\n1533\t        raw = input_grid.raw\n1534\t        mapping = rule.get(\"mapping\", {})\n1535\t\n1536\t        output = []\n1537\t        for row in raw:\n1538\t            output.append([mapping.get(cell, cell) for cell in row])\n1539\t        return output\n1540\t\n1541\t    def _apply_bbox_fill(self, rule, input_grid):\n1542\t        raw = input_grid.raw\n1543\t        h = len(raw)\n1544\t        w = len(raw[0]) if raw else 0\n1545\t        marker = rule.get(\"marker\")\n1546\t        fg = rule.get(\"foreground\")\n1547\t        bg = rule.get(\"background\")\n1548\t        if marker is None or fg is None or bg is None:\n1549\t            return None\n1550\t\n1551\t        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n1552\t        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n1553\t        if not rows:\n1554\t            return [row[:] for row in raw]\n1555\t        r0, r1 = min(rows), max(rows)\n1556\t        c0, c1 = min(cols), max(cols)\n1557\t\n1558\t        out = [row[:] for row in raw]\n1559\t        for r in range(r0, r1 + 1):\n1560\t            for c in range(c0, c1 + 1):\n1561\t                if out[r][c] == bg:\n1562\t                    out[r][c] = marker\n1563\t        return out\n1564\t\n1565\t    def _apply_axis_mirror_recolor(self, rule, input_grid):\n1566\t        raw = input_grid.raw\n1567\t        h = len(raw)\n1568\t        w = len(raw[0]) if raw else 0\n1569\t        marker = rule.get(\"marker\")\n1570\t        fg = rule.get(\"foreground\")\n1571\t        axis = rule.get(\"axis\", \"horizontal\")\n1572\t        if marker is None or fg is None:\n1573\t            return None\n1574\t\n1575\t        out = [row[:] for row in raw]\n1576\t        for r in range(h):\n1577\t            for c in range(w):\n1578\t                if raw[r][c] != fg:\n1579\t                    continue\n1580\t                if axis == \"horizontal\":\n1581\t                    rr, cc = r, w - 1 - c\n1582\t                else:\n1583\t                    rr, cc = h - 1 - r, c\n1584\t                if (r, c) == (rr, cc):\n1585\t                    continue\n1586\t                if raw[rr][cc] == fg:\n1587\t                    out[r][c] = marker\n1588\t        return out\n1589\t\n1590\t    def _apply_integer_upscale(self, rule, input_grid):\n1591\t        raw = input_grid.raw\n1592\t        k = rule.get(\"factor\")\n1593\t        if not isinstance(k, int) or k < 2:\n1594\t            return None\n1595\t        out = []\n1596\t        for row in raw:\n1597\t            new_row = []\n1598\t            for v in row:\n1599\t                new_row.extend([v] * k)\n1600\t            for _ in range(k):\n1601\t                out.append(new_row[:])\n1602\t        return out\n1603\t\n1604\t    def _apply_stack_with_mirror(self, rule, input_grid):\n1605\t        raw = input_grid.raw\n1606\t        direction = rule.get(\"direction\")\n1607\t        order = rule.get(\"order\")\n1608\t        if direction not in (\"vertical\", \"horizontal\"):\n1609\t            return None\n1610\t        if order not in (\"input_first\", \"flip_first\"):\n1611\t            return None\n1612\t\n1613\t        if direction == \"vertical\":\n1614\t            flipped = list(reversed([row[:] for row in raw]))\n1615\t            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n1616\t            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n1617\t            return [r[:] for r in top] + [r[:] for r in bot]\n1618\t        else:\n1619\t            flipped = [list(reversed(row)) for row in raw]\n1620\t            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n1621\t            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n1622\t            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n1623\t\n1624\t    def _apply_rect_interior_fill(self, rule, input_grid):\n1625\t        raw = input_grid.raw\n1626\t        h = len(raw)\n1627\t        w = len(raw[0]) if raw else 0\n1628\t        bg = rule.get(\"background\")\n1629\t        fg = rule.get(\"border\")\n1630\t        size_to_fill_raw = rule.get(\"size_to_fill\") or {}\n1631\t        if bg is None or fg is None:\n1632\t            return None\n1633\t        size_to_fill = {}\n1634\t        for k, v in size_to_fill_raw.items():\n1635\t            try:\n1636\t                a, b = k.split(\"x\")\n1637\t                size_to_fill[(int(a), int(b))] = v\n1638\t            except ValueError:\n1639\t                continue\n1640\t\n1641\t        rects = GeneralizeOperator._find_hollow_rects(raw, fg, bg)\n1642\t        out = [row[:] for row in raw]\n1643\t        for (r0, c0, r1, c1) in rects:\n1644\t            ih = r1 - r0 - 1\n1645\t            iw = c1 - c0 - 1\n1646\t            fill = size_to_fill.get((ih, iw))\n1647\t            if fill is None:\n1648\t                continue\n1649\t            for r in range(r0 + 1, r1):\n1650\t                for c in range(c0 + 1, c1):\n1651\t                    out[r][c] = fill\n1652\t        return out\n1653\t\n1654\t    def _apply_staircase_extend_right(self, rule, input_grid):\n1655\t        raw = input_grid.raw\n1656\t        if len(raw) != 1:\n1657\t            return None\n1658\t        row0 = list(raw[0])\n1659\t        w = len(row0)\n1660\t        if w < 2:\n1661\t            return None\n1662\t        distinct = set(row0)\n1663\t        if len(distinct) != 2:\n1664\t            return None\n1665\t        fg = row0[0]\n1666\t        bg = next(v for v in distinct if v != fg)\n1667\t        n = 0\n1668\t        while n < w and row0[n] == fg:\n1669\t            n += 1\n1670\t        if n == 0 or any(v != bg for v in row0[n:]):\n1671\t            return None\n1672\t        oh = w // 2\n1673\t        out = []\n1674\t        for i in range(oh):\n1675\t            cells = [fg] * (n + i) + [bg] * (w - n - i)\n1676\t            out.append(cells)\n1677\t        return out\n1678\t\n1679\t    def _apply_corner_quadrant_fill(self, rule, input_grid):\n1680\t        raw = input_grid.raw\n1681\t        inner_color = rule.get(\"inner_color\")\n1682\t        if inner_color is None:\n1683\t            return None\n1684\t\n1685\t        counts = {}\n1686\t        for row in raw:\n1687\t            for c in row:\n1688\t                counts[c] = counts.get(c, 0) + 1\n1689\t        bg = max(counts, key=counts.get)\n1690\t\n1691\t        groups = GeneralizeOperator._find_corner_quadrant_groups(raw, bg)\n1692\t        groups = [g for g in groups if g[\"inner_color\"] == inner_color]\n1693\t        if not groups:\n1694\t            return None\n1695\t        return GeneralizeOperator._apply_quadrant_groups(raw, groups, bg)\n1696\t\n1697\t    def _apply_axis_line_keep(self, rule, input_grid):\n1698\t        raw = input_grid.raw\n1699\t        h = len(raw)\n1700\t        w = len(raw[0]) if raw else 0\n1701\t        axis = rule.get(\"axis\")\n1702\t        pos = rule.get(\"position\")\n1703\t        bg = rule.get(\"background\")\n1704\t        if axis not in (\"col\", \"row\") or pos != \"middle\" or bg is None:\n1705\t            return None\n1706\t        k = (w // 2) if axis == \"col\" else (h // 2)\n1707\t        out = [[bg] * w for _ in range(h)]\n1708\t        for r in range(h):\n1709\t            for c in range(w):\n1710\t                on_line = (axis == \"col\" and c == k) or (axis == \"row\" and r == k)\n1711\t                if on_line:\n1712\t                    out[r][c] = raw[r][c]\n1713\t        return out\n1714\t\n1715\t    def _apply_recolor_by_size(self, rule, input_grid):\n1716\t        raw = input_grid.raw\n1717\t        h = len(raw)\n1718\t        w = len(raw[0]) if raw else 0\n1719\t        fg = rule.get(\"foreground\")\n1720\t        if fg is None:\n1721\t            return None\n1722\t        size_to_color_raw = rule.get(\"size_to_color\") or {}\n1723\t        size_to_color = {}\n1724\t        for k, v in size_to_color_raw.items():\n1725\t            try:\n1726\t                size_to_color[int(k)] = v\n1727\t            except (TypeError, ValueError):\n1728\t                continue\n1729\t        out = [row[:] for row in raw]\n1730\t        for comp in GeneralizeOperator._find_components(raw, fg):\n1731\t            new_color = size_to_color.get(len(comp))\n1732\t            if new_color is None:\n1733\t                continue\n1734\t            for (rr, cc) in comp:\n1735\t                out[rr][cc] = new_color\n1736\t        return out\n1737\t\n1738\t    def _apply_diamond_connector(self, rule, input_grid):\n1739\t        raw = input_grid.raw\n1740\t        h = len(raw)\n1741\t        w = len(raw[0]) if raw else 0\n1742\t        connector = rule.get(\"connector\")\n1743\t        if connector is None:\n1744\t            return None\n1745\t\n1746\t        counts = {}\n1747\t        for row in raw:\n1748\t            for c in row:\n1749\t                counts[c] = counts.get(c, 0) + 1\n1750\t        bg = max(counts, key=counts.get)\n1751\t\n1752\t        in_colors = {c for row in raw for c in row}\n1753\t        fg_set = in_colors - {bg}\n1754\t        if len(fg_set) != 1:\n1755\t            return None\n1756\t        fg = next(iter(fg_set))\n1757\t\n1758\t        diamonds = GeneralizeOperator._find_diamonds(raw, fg, bg)\n1759\t        out = [row[:] for row in raw]\n1760\t        GeneralizeOperator._draw_diamond_connectors(out, diamonds, connector)\n1761\t        return out\n1762\t\n1763\t    # ---- helpers ---------------------------------------------------------\n1764\t\n1765\t    @staticmethod\n1766\t    def _group_positions(positions):\n1767\t        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n1768\t        pos_set = set(positions)\n1769\t        visited = set()\n1770\t        groups = []\n1771\t\n1772\t        for pos in positions:\n1773\t            if pos in visited:\n1774\t                continue\n1775\t            group = []\n1776\t            queue = [pos]\n1777\t            while queue:\n1778\t                p = queue.pop(0)\n1779\t                if p in visited or p not in pos_set:\n1780\t                    continue\n1781\t                visited.add(p)\n1782\t                group.append(p)\n1783\t                r, c = p\n1784\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1785\t                    nb = (r + dr, c + dc)\n1786\t                    if nb in pos_set and nb not in visited:\n1787\t                        queue.append(nb)\n1788\t            groups.append(group)\n1789\t\n1790\t        return groups\n1791\t\n1792\t\n1793\t# ======================================================================\n1794\t# SubmitOperator -- finalize and satisfy goal\n1795\t# ======================================================================\n1796\t\n1797\tclass SubmitOperator(Operator):\n1798\t    \"\"\"\n1799\t    Writes predicted grids to S1 output-link in the format expected by\n1800\t    run_task.py, and marks the goal as satisfied.\n1801\t    \"\"\"\n1802\t\n1803\t    def __init__(self):\n1804\t        super().__init__(\"submit\")\n1805\t\n1806\t    def precondition(self, wm) -> bool:\n1807\t        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n1808\t\n1809\t    def effect(self, wm):\n1810\t        predictions = wm.s1.get(\"predictions\")\n1811\t        if not predictions:\n1812\t            return\n1813\t\n1814\t        task = wm.task\n1815\t        if not task:\n1816\t            return\n1817\t\n1818\t        predicted_grids = []\n1819\t        for i in range(len(task.test_pairs)):\n1820\t            grid = predictions.get(f\"test_{i}\")\n1821\t            if grid is not None:\n1822\t                predicted_grids.append(grid)\n1823\t\n1824\t        if not predicted_grids:\n1825\t            return\n1826\t\n1827\t        # Write to output-link (format expected by run_task.py)\n1828\t        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n1829\t        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n1830\t\n1831\t        # Mark goal as satisfied\n1832\t        wm.s1[\"goal\"] = {\"subgoals\": {\n1833\t            f\"test_{i}\": {\"status\": \"solved\"}\n1834\t            for i in range(len(predicted_grids))\n1835\t        }}\n1836\t\n1837\t\n1838\tclass VerifyOperator(SubmitOperator):\n1839\t    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n1840\t\n1841\t    def __init__(self):\n1842\t        super().__init__()\n1843\t        self.name = \"verify\"\n1844\t"}]},"parent_tool_use_id":null,"session_id":"96b1c6ff-849e-4c9e-9314-e9f16fa27ceb","uuid":"ae128255-a5e1-4e1b-a6f3-e381b251d52b","timestamp":"2026-04-28T23:13:47.063Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"\"\"\"\nactive_operators -- SOAR Operator implementations.\n\nPipeline operators (all fire in S2, read/write S1):\n  SelectTargetOperator  -> set up comparison agenda from example pairs\n  CompareOperator       -> execute one comparison using ARCKG compare()\n  ExtractPatternOperator-> cell-level analysis of input/output changes\n  GeneralizeOperator    -> create transformation rule from patterns\n  PredictOperator       -> apply rule to test input\n  SubmitOperator        -> write prediction to output-link, satisfy goal\n\"\"\"\n\nfrom agent.operators import Operator\nfrom ARCKG.comparison import compare as arckg_compare\n\n\n# ======================================================================\n# SolveTaskOperator -- abstract top-level goal (S1)\n# ======================================================================\n\nclass SolveTaskOperator(Operator):\n    \"\"\"\n    Abstract operator at S1. Intentionally makes no WM change so\n    the cycle detects no-change and creates an S2 substate.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"solve-task\")\n        self.proposal_preference = \"+\"\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SolveTaskOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        # Intentionally empty -- triggers no-change impasse -> S2\n        return\n\n\n# ======================================================================\n# SelectTargetOperator -- set up comparison agenda\n# ======================================================================\n\nclass SelectTargetOperator(Operator):\n    \"\"\"\n    Reads wm.task to find example pairs and sets up comparison targets.\n    For each example pair: compare input grid (G0) vs output grid (G1).\n    Writes comparison-agenda, pending-comparisons, and empty comparisons to S1.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"select_target\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SelectTargetOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        agenda = []\n        pending = []\n\n        for idx, pair in enumerate(task.example_pairs):\n            if pair.input_grid is not None and pair.output_grid is not None:\n                spec = {\n                    \"type\": \"grid\",\n                    \"pair_idx\": idx,\n                    \"pair_type\": \"example\",\n                    \"id1\": pair.input_grid.node_id,\n                    \"id2\": pair.output_grid.node_id,\n                }\n                agenda.append(spec)\n                pending.append(spec)\n\n        # Build node lookup so CompareOperator can find ARCKG nodes by ID\n        node_lookup = {}\n        for pair in task.example_pairs + task.test_pairs:\n            if pair.input_grid:\n                node_lookup[pair.input_grid.node_id] = pair.input_grid\n            if pair.output_grid:\n                node_lookup[pair.output_grid.node_id] = pair.output_grid\n        wm.node_lookup = node_lookup\n\n        wm.s1[\"comparison-agenda\"] = agenda\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = {}\n\n\n# ======================================================================\n# CompareOperator -- execute one comparison\n# ======================================================================\n\nclass CompareOperator(Operator):\n    \"\"\"\n    Pops one item from pending-comparisons, calls ARCKG compare(),\n    and stores the result in the comparisons dict on S1.\n    \"\"\"\n\n    def __init__(self, compare_fn=None):\n        super().__init__(\"compare\")\n        self._compare_fn = compare_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"CompareOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        pending = list(wm.s1.get(\"pending-comparisons\") or [])\n        if not pending:\n            return\n\n        item = pending.pop(0)\n\n        # Find the actual ARCKG nodes\n        node_lookup = getattr(wm, \"node_lookup\", {})\n        node_a = node_lookup.get(item[\"id1\"])\n        node_b = node_lookup.get(item[\"id2\"])\n\n        if node_a is None or node_b is None:\n            wm.s1[\"pending-comparisons\"] = pending\n            return\n\n        # Execute comparison\n        fn = self._compare_fn or arckg_compare\n        result = fn(node_a, node_b)\n\n        # Store result keyed by type and pair index\n        key = f\"{item['type']}_{item.get('pair_idx', 0)}\"\n        comparisons = dict(wm.s1.get(\"comparisons\") or {})\n        comparisons[key] = {\"spec\": item, \"result\": result}\n\n        wm.s1[\"pending-comparisons\"] = pending\n        wm.s1[\"comparisons\"] = comparisons\n\n\n# ======================================================================\n# ExtractPatternOperator -- cell-level transformation analysis\n# ======================================================================\n\nclass ExtractPatternOperator(Operator):\n    \"\"\"\n    Analyzes each example pair at the cell level to discover what changes\n    between input and output grids. Groups changed cells into connected\n    components and records color/position information for generalization.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"extract_pattern\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"ExtractPatternOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        if task is None:\n            return\n\n        patterns = {\n            \"grid_size_preserved\": True,\n            \"pair_analyses\": [],\n        }\n\n        for pair in task.example_pairs:\n            g0 = pair.input_grid\n            g1 = pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n\n            analysis = self._analyze_pair(g0, g1)\n            patterns[\"pair_analyses\"].append(analysis)\n\n            if g0.height != g1.height or g0.width != g1.width:\n                patterns[\"grid_size_preserved\"] = False\n\n        wm.s1[\"patterns\"] = patterns\n\n    # ---- internal helpers ------------------------------------------------\n\n    def _analyze_pair(self, g0, g1):\n        \"\"\"Cell-level diff between input and output grid.\"\"\"\n        raw_in = g0.raw\n        raw_out = g1.raw\n        h = min(len(raw_in), len(raw_out))\n        w = min(\n            len(raw_in[0]) if raw_in else 0,\n            len(raw_out[0]) if raw_out else 0,\n        )\n\n        changes = []\n        for r in range(h):\n            for c in range(w):\n                if raw_in[r][c] != raw_out[r][c]:\n                    changes.append({\n                        \"row\": r, \"col\": c,\n                        \"input_color\": raw_in[r][c],\n                        \"output_color\": raw_out[r][c],\n                    })\n\n        groups = self._group_changes(changes)\n\n        group_analyses = []\n        for group_cells in groups:\n            input_colors = set()\n            output_colors = set()\n            positions = []\n            for cell in group_cells:\n                input_colors.add(cell[\"input_color\"])\n                output_colors.add(cell[\"output_color\"])\n                positions.append((cell[\"row\"], cell[\"col\"]))\n\n            top_row = min(r for r, c in positions)\n            top_col = min(c for r, c in positions)\n\n            group_analyses.append({\n                \"input_colors\": sorted(input_colors),\n                \"output_colors\": sorted(output_colors),\n                \"top_row\": top_row,\n                \"top_col\": top_col,\n                \"cell_count\": len(group_cells),\n            })\n\n        return {\n            \"total_changes\": len(changes),\n            \"num_groups\": len(groups),\n            \"groups\": group_analyses,\n            \"size_match\": (\n                len(raw_in) == len(raw_out)\n                and (len(raw_in[0]) if raw_in else 0)\n                    == (len(raw_out[0]) if raw_out else 0)\n            ),\n        }\n\n    @staticmethod\n    def _group_changes(changes):\n        \"\"\"Group changed cells into 4-connected components.\"\"\"\n        if not changes:\n            return []\n\n        pos_to_change = {}\n        for c in changes:\n            pos_to_change[(c[\"row\"], c[\"col\"])] = c\n\n        visited = set()\n        groups = []\n\n        for change in changes:\n            pos = (change[\"row\"], change[\"col\"])\n            if pos in visited:\n                continue\n\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_to_change:\n                    continue\n                visited.add(p)\n                group.append(pos_to_change[p])\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (p[0] + dr, p[1] + dc)\n                    if nb in pos_to_change and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# GeneralizeOperator -- rule creation from patterns\n# ======================================================================\n\nclass GeneralizeOperator(Operator):\n    \"\"\"\n    Reads extracted patterns and attempts to create a transformation rule.\n    Tries multiple strategies in priority order. If no strategy succeeds,\n    falls back to an identity rule so the pipeline can still complete.\n    \"\"\"\n\n    def __init__(self, generalize_fn=None, save_fn=None):\n        super().__init__(\"generalize\")\n        self._generalize_fn = generalize_fn\n        self._save_fn = save_fn\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"GeneralizeOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        patterns = wm.s1.get(\"patterns\")\n        if not patterns:\n            return\n\n        task = wm.task\n        example_pairs = self._collect_example_pairs(task)\n\n        rule = None\n\n        # Strategy 1: sequential recoloring (e.g., color objects 1, 2, 3, ...)\n        rule = self._try_recolor_sequential(patterns)\n\n        # Strategy 2: bounding-box fill — fill bg cells within bbox of fg color\n        if rule is None:\n            rule = self._try_bbox_fill(example_pairs)\n\n        # Strategy 3: horizontal mirror recolor — recolor cells whose\n        #   horizontal-mirror partner has the same color\n        if rule is None:\n            rule = self._try_axis_mirror_recolor(example_pairs)\n\n        # Strategy 4: integer upscale — each input cell becomes a kxk block\n        if rule is None:\n            rule = self._try_integer_upscale(example_pairs)\n\n        # Strategy 5: stack with mirror — output = concat(input, flip(input))\n        if rule is None:\n            rule = self._try_stack_with_mirror(example_pairs)\n\n        # Strategy 6: rectangle interior fill — hollow rect borders get interior\n        #   filled with a color determined by interior dimensions\n        if rule is None:\n            rule = self._try_rect_interior_fill(example_pairs)\n\n        # Strategy 7: staircase extend right — 1-row input becomes a triangular\n        #   stack of rows where each row's prefix grows by one cell\n        if rule is None:\n            rule = self._try_staircase_extend_right(example_pairs)\n\n        # Strategy 8: corner quadrant fill — 4 single-cell corner markers\n        #   surround a solid inner rectangle which is split into quadrants\n        if rule is None:\n            rule = self._try_corner_quadrant_fill(example_pairs)\n\n        # Strategy 9: diamond connector — collinear '+'-shaped 4-cell objects\n        #   are joined by lines of a marker color\n        if rule is None:\n            rule = self._try_diamond_connector(example_pairs)\n\n        # Strategy 10: axis line keep — output preserves a single row or\n        #   column of the input; everything else collapses to background\n        if rule is None:\n            rule = self._try_axis_line_keep(example_pairs)\n\n        # Strategy 11: recolor by component size — single fg color split into\n        #   connected components, each recolored by cell count\n        if rule is None:\n            rule = self._try_recolor_by_size(example_pairs)\n\n        # Strategy 12: simple 1:1 color mapping\n        if rule is None:\n            rule = self._try_color_mapping(patterns)\n\n        # Fallback: identity (copy input as output)\n        if rule is None:\n            rule = {\"type\": \"identity\", \"confidence\": 0.0}\n\n        wm.s1[\"active-rules\"] = [rule]\n\n    @staticmethod\n    def _collect_example_pairs(task):\n        \"\"\"Return list of (raw_input, raw_output) tuples for example pairs.\"\"\"\n        if task is None:\n            return []\n        out = []\n        for pair in task.example_pairs:\n            g0, g1 = pair.input_grid, pair.output_grid\n            if g0 is None or g1 is None:\n                continue\n            out.append((g0.raw, g1.raw))\n        return out\n\n    # ---- strategy: sequential recoloring --------------------------------\n\n    def _try_recolor_sequential(self, patterns):\n        \"\"\"\n        Detect pattern: all changed-cell groups have one source color,\n        output colors are sequential (1,2,3,...), ordered by position.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # All pairs must have the same number of change groups\n        group_counts = [a[\"num_groups\"] for a in pair_analyses]\n        if len(set(group_counts)) != 1 or group_counts[0] == 0:\n            return None\n\n        all_source_colors = set()\n\n        for analysis in pair_analyses:\n            for g in analysis[\"groups\"]:\n                if len(g[\"input_colors\"]) != 1 or len(g[\"output_colors\"]) != 1:\n                    return None\n                all_source_colors.add(g[\"input_colors\"][0])\n\n            out_colors = sorted(set(g[\"output_colors\"][0] for g in analysis[\"groups\"]))\n            expected = list(range(min(out_colors), min(out_colors) + len(out_colors)))\n            if out_colors != expected:\n                return None\n\n        # Try sorting by different position keys\n        for sort_key in [\"top_row\", \"top_col\"]:\n            if self._check_sort_key(pair_analyses, sort_key):\n                start_color = min(\n                    g[\"output_colors\"][0]\n                    for g in pair_analyses[0][\"groups\"]\n                )\n                return {\n                    \"type\": \"recolor_sequential\",\n                    \"sort_key\": sort_key,\n                    \"start_color\": start_color,\n                    \"source_colors\": sorted(all_source_colors),\n                    \"confidence\": 1.0,\n                }\n\n        return None\n\n    @staticmethod\n    def _check_sort_key(pair_analyses, sort_key):\n        \"\"\"Verify that sorting groups by sort_key produces sequential output colors.\"\"\"\n        for analysis in pair_analyses:\n            groups = analysis[\"groups\"]\n            sorted_groups = sorted(groups, key=lambda g: g[sort_key])\n            colors = [g[\"output_colors\"][0] for g in sorted_groups]\n            if colors != list(range(colors[0], colors[0] + len(colors))):\n                return False\n        return True\n\n    # ---- strategy: simple color mapping ---------------------------------\n\n    def _try_color_mapping(self, patterns):\n        \"\"\"\n        Detect pattern: each input color consistently maps to one output color.\n        \"\"\"\n        pair_analyses = patterns.get(\"pair_analyses\", [])\n        if not pair_analyses or not patterns.get(\"grid_size_preserved\"):\n            return None\n\n        # Collect all observed color transitions\n        color_map = {}\n        for analysis in pair_analyses:\n            for group in analysis[\"groups\"]:\n                for ic in group[\"input_colors\"]:\n                    for oc in group[\"output_colors\"]:\n                        if ic not in color_map:\n                            color_map[ic] = set()\n                        color_map[ic].add(oc)\n\n        # Each input color must map to exactly one output color\n        simple_map = {}\n        for ic, ocs in color_map.items():\n            if len(ocs) != 1:\n                return None\n            simple_map[ic] = list(ocs)[0]\n\n        if simple_map:\n            return {\n                \"type\": \"color_mapping\",\n                \"mapping\": simple_map,\n                \"confidence\": 0.8,\n            }\n\n        return None\n\n    # ---- strategy: bounding-box fill ------------------------------------\n\n    def _try_bbox_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; output equals input except every background\n        cell within the bounding box of the foreground color has been\n        recolored to a single marker color (a color not present in input).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        marker = None\n        bg_color = None\n        fg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h, w = len(raw_in), len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or w != len(raw_out[0] if raw_out else []):\n                return None\n\n            in_colors = {c for row in raw_in for c in row}\n            out_colors = {c for row in raw_out for c in row}\n            new_colors = out_colors - in_colors\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            # Background = most-frequent color in input\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n\n            # Foreground = the other input color (must be exactly two)\n            fg_set = {c for c in in_colors if c != bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            # Compute bbox of foreground in input\n            rows = [r for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            cols = [c for r in range(h) for c in range(w) if raw_in[r][c] == fg]\n            if not rows:\n                return None\n            r0, r1 = min(rows), max(rows)\n            c0, c1 = min(cols), max(cols)\n\n            # Verify: inside bbox, bg→marker, fg→fg; outside bbox unchanged\n            for r in range(h):\n                for c in range(w):\n                    inside = r0 <= r <= r1 and c0 <= c <= c1\n                    if inside and raw_in[r][c] == bg:\n                        if raw_out[r][c] != m:\n                            return None\n                    else:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n\n            if marker is None:\n                marker, bg_color, fg_color = m, bg, fg\n            elif (m, bg, fg) != (marker, bg_color, fg_color):\n                return None\n\n        return {\n            \"type\": \"bbox_fill\",\n            \"marker\": marker,\n            \"background\": bg_color,\n            \"foreground\": fg_color,\n            \"confidence\": 1.0,\n        }\n\n    # ---- strategy: axis mirror recolor ----------------------------------\n\n    def _try_axis_mirror_recolor(self, example_pairs):\n        \"\"\"\n        Detect: same grid size, exactly one new color in output (marker).\n        For some axis (horizontal/vertical), every changed cell is the\n        original foreground color and its mirror partner along that axis\n        also has the original foreground color in the input.\n        Unchanged cells are those without a same-color mirror partner.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for axis in (\"horizontal\", \"vertical\"):\n            params = self._check_mirror_axis(example_pairs, axis)\n            if params is not None:\n                return {\n                    \"type\": \"axis_mirror_recolor\",\n                    \"axis\": axis,\n                    \"marker\": params[\"marker\"],\n                    \"foreground\": params[\"foreground\"],\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_mirror_axis(example_pairs, axis):\n        marker = None\n        fg = None\n        had_change = False\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or (w and w != len(raw_out[0])):\n                return None\n\n            new_colors = (\n                {c for row in raw_out for c in row}\n                - {c for row in raw_in for c in row}\n            )\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    in_v = raw_in[r][c]\n                    out_v = raw_out[r][c]\n                    mirror_v = raw_in[rr][cc]\n                    if out_v == in_v:\n                        # If this cell HAS a same-color mirror partner of\n                        # a non-bg color, the rule would have flipped it.\n                        # We require: not changed → no same-color partner\n                        # OR cell is on the axis and equals itself (trivial).\n                        if (r, c) != (rr, cc) and in_v == mirror_v and in_v != 0:\n                            # only allow when in_v is the background\n                            # (but bg already excluded by != 0 check is rough);\n                            # we'll defer to fg check below.\n                            pass\n                        continue\n                    # Changed: must change FROM some fg TO marker, with mirror\n                    # partner also equal to fg in the input.\n                    if out_v != m:\n                        return None\n                    if in_v == 0:\n                        # background-cells turning into marker — not this rule\n                        return None\n                    if mirror_v != in_v:\n                        return None\n                    if fg is None:\n                        fg = in_v\n                    elif fg != in_v:\n                        return None\n                    had_change = True\n\n            if marker is None:\n                marker = m\n            elif marker != m:\n                return None\n\n        if not had_change or fg is None:\n            return None\n\n        # Final sanity: re-apply rule and confirm exact match.\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            for r in range(h):\n                for c in range(w):\n                    if axis == \"horizontal\":\n                        rr, cc = r, w - 1 - c\n                    else:\n                        rr, cc = h - 1 - r, c\n                    expected = raw_in[r][c]\n                    if (raw_in[r][c] == fg\n                            and (r, c) != (rr, cc)\n                            and raw_in[rr][cc] == fg):\n                        expected = marker\n                    if raw_out[r][c] != expected:\n                        return None\n\n        return {\"marker\": marker, \"foreground\": fg}\n\n    # ---- strategy: integer upscale --------------------------------------\n\n    def _try_integer_upscale(self, example_pairs):\n        \"\"\"\n        Detect: output dimensions are k * input dimensions (same k for both\n        height and width, and the same k across all examples). Each input\n        cell at (r, c) becomes a kxk block at rows [k*r, k*r+k) and cols\n        [k*c, k*c+k) in the output, all filled with the same color.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        factor = None\n        for raw_in, raw_out in example_pairs:\n            ih = len(raw_in)\n            iw = len(raw_in[0]) if raw_in else 0\n            oh = len(raw_out)\n            ow = len(raw_out[0]) if raw_out else 0\n            if ih == 0 or iw == 0 or oh == 0 or ow == 0:\n                return None\n            if oh % ih != 0 or ow % iw != 0:\n                return None\n            kh, kw = oh // ih, ow // iw\n            if kh != kw or kh < 2:\n                return None\n            if factor is None:\n                factor = kh\n            elif factor != kh:\n                return None\n            for r in range(ih):\n                for c in range(iw):\n                    v = raw_in[r][c]\n                    for dr in range(factor):\n                        for dc in range(factor):\n                            if raw_out[r * factor + dr][c * factor + dc] != v:\n                                return None\n\n        if factor is None:\n            return None\n        return {\"type\": \"integer_upscale\", \"factor\": factor, \"confidence\": 1.0}\n\n    # ---- strategy: stack with mirror ------------------------------------\n\n    def _try_stack_with_mirror(self, example_pairs):\n        \"\"\"\n        Detect: output = concatenation of input and a flipped copy of input\n        along one axis. Tries four configurations:\n          - direction=vertical,   order=input_first  (rows: input, vflip(input))\n          - direction=vertical,   order=flip_first   (rows: vflip(input), input)\n          - direction=horizontal, order=input_first  (cols: input, hflip(input))\n          - direction=horizontal, order=flip_first   (cols: hflip(input), input)\n        The same configuration must hold across every example.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        configs = [\n            (\"vertical\", \"input_first\"),\n            (\"vertical\", \"flip_first\"),\n            (\"horizontal\", \"input_first\"),\n            (\"horizontal\", \"flip_first\"),\n        ]\n\n        for direction, order in configs:\n            ok = True\n            for raw_in, raw_out in example_pairs:\n                if not self._check_stack_mirror(raw_in, raw_out, direction, order):\n                    ok = False\n                    break\n            if ok:\n                return {\n                    \"type\": \"stack_with_mirror\",\n                    \"direction\": direction,\n                    \"order\": order,\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_stack_mirror(raw_in, raw_out, direction, order):\n        ih = len(raw_in)\n        iw = len(raw_in[0]) if raw_in else 0\n        oh = len(raw_out)\n        ow = len(raw_out[0]) if raw_out else 0\n        if ih == 0 or iw == 0:\n            return False\n\n        if direction == \"vertical\":\n            if ow != iw or oh != 2 * ih:\n                return False\n            flipped = list(reversed(raw_in))\n            top = raw_in if order == \"input_first\" else flipped\n            bot = flipped if order == \"input_first\" else raw_in\n            for r in range(ih):\n                if list(raw_out[r]) != list(top[r]):\n                    return False\n                if list(raw_out[ih + r]) != list(bot[r]):\n                    return False\n            return True\n        else:  # horizontal\n            if oh != ih or ow != 2 * iw:\n                return False\n            flipped = [list(reversed(row)) for row in raw_in]\n            left = raw_in if order == \"input_first\" else flipped\n            right = flipped if order == \"input_first\" else raw_in\n            for r in range(ih):\n                if list(raw_out[r][:iw]) != list(left[r]):\n                    return False\n                if list(raw_out[r][iw:]) != list(right[r]):\n                    return False\n            return True\n\n    # ---- strategy: rectangle interior fill ------------------------------\n\n    def _try_rect_interior_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input contains hollow rectangular borders of a\n        single foreground color on a background; output equals input except\n        each hollow rect's interior is filled with a color determined by the\n        rect's interior dimensions. Map (interior_h, interior_w) -> fill_color\n        is learned from training and applied to test rectangles.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        size_to_fill = {}\n        bg_color = None\n        border_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h == 0 or w == 0:\n                return None\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            # Background = most-frequent color in input\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n\n            # Foreground colors = everything else; require exactly one\n            fg_set = {c for c in counts if c != bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            if bg_color is None:\n                bg_color, border_color = bg, fg\n            elif (bg_color, border_color) != (bg, fg):\n                return None\n\n            rects = self._find_hollow_rects(raw_in, fg, bg)\n            if not rects:\n                return None\n\n            # Build expected output: copy input, fill each rect interior\n            # with the color present in raw_out at the interior cells.\n            for (r0, c0, r1, c1) in rects:\n                ih_int = r1 - r0 - 1\n                iw_int = c1 - c0 - 1\n                if ih_int < 1 or iw_int < 1:\n                    return None\n                fill = raw_out[r0 + 1][c0 + 1]\n                # Interior must be uniform fill color in output\n                for r in range(r0 + 1, r1):\n                    for c in range(c0 + 1, c1):\n                        if raw_out[r][c] != fill:\n                            return None\n                key = (ih_int, iw_int)\n                if key in size_to_fill and size_to_fill[key] != fill:\n                    return None\n                size_to_fill[key] = fill\n\n            # Verify all non-interior cells are unchanged\n            interior_cells = set()\n            for (r0, c0, r1, c1) in rects:\n                for r in range(r0 + 1, r1):\n                    for c in range(c0 + 1, c1):\n                        interior_cells.add((r, c))\n            for r in range(h):\n                for c in range(w):\n                    if (r, c) in interior_cells:\n                        continue\n                    if raw_in[r][c] != raw_out[r][c]:\n                        return None\n\n        if not size_to_fill:\n            return None\n        return {\n            \"type\": \"rect_interior_fill\",\n            \"background\": bg_color,\n            \"border\": border_color,\n            \"size_to_fill\": {f\"{k[0]}x{k[1]}\": v for k, v in size_to_fill.items()},\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _find_hollow_rects(raw, fg, bg):\n        \"\"\"Find all hollow rectangles of color fg with interior color bg.\n        Returns list of (r0, c0, r1, c1) bounding boxes.\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n\n        # Find connected components of fg cells (4-connected)\n        visited = [[False] * w for _ in range(h)]\n        rects = []\n\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != fg or visited[r][c]:\n                    continue\n                # BFS\n                comp = []\n                queue = [(r, c)]\n                while queue:\n                    rr, cc = queue.pop(0)\n                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n                        continue\n                    if visited[rr][cc] or raw[rr][cc] != fg:\n                        continue\n                    visited[rr][cc] = True\n                    comp.append((rr, cc))\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        queue.append((rr + dr, cc + dc))\n\n                if not comp:\n                    continue\n                rs = [p[0] for p in comp]\n                cs = [p[1] for p in comp]\n                r0, r1 = min(rs), max(rs)\n                c0, c1 = min(cs), max(cs)\n                width = c1 - c0 + 1\n                height = r1 - r0 + 1\n                if width < 3 or height < 3:\n                    continue\n                # Check border is all fg\n                comp_set = set(comp)\n                ok = True\n                for cc in range(c0, c1 + 1):\n                    if (r0, cc) not in comp_set or (r1, cc) not in comp_set:\n                        ok = False\n                        break\n                if ok:\n                    for rr in range(r0, r1 + 1):\n                        if (rr, c0) not in comp_set or (rr, c1) not in comp_set:\n                            ok = False\n                            break\n                if not ok:\n                    continue\n                # Check interior is all bg\n                for rr in range(r0 + 1, r1):\n                    for cc in range(c0 + 1, c1):\n                        if raw[rr][cc] != bg:\n                            ok = False\n                            break\n                    if not ok:\n                        break\n                # Component must be exactly the border (no extra fg cells)\n                expected_border_size = 2 * (height + width) - 4\n                if ok and len(comp) == expected_border_size:\n                    rects.append((r0, c0, r1, c1))\n        return rects\n\n    # ---- strategy: staircase extend right -------------------------------\n\n    def _try_staircase_extend_right(self, example_pairs):\n        \"\"\"\n        Detect: every input is exactly one row of width w; output has\n        oh = w // 2 rows and width w. Row 0 of the output equals the input;\n        each subsequent row extends the colored prefix by one cell to the\n        right (one more cell of the same fg color, rest background).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for raw_in, raw_out in example_pairs:\n            if len(raw_in) != 1:\n                return None\n            w = len(raw_in[0])\n            if w < 2:\n                return None\n            oh = len(raw_out)\n            if oh != w // 2 or oh < 1:\n                return None\n            for row in raw_out:\n                if len(row) != w:\n                    return None\n\n            # The prefix color (fg) is the leftmost cell; the rest must be a\n            # single different background color.\n            row0 = list(raw_in[0])\n            distinct = set(row0)\n            if len(distinct) != 2:\n                return None\n            fg = row0[0]\n            bg = next(v for v in distinct if v != fg)\n\n            n = 0\n            while n < w and row0[n] == fg:\n                n += 1\n            if n == 0 or any(v != bg for v in row0[n:]):\n                return None\n\n            # Verify each output row\n            for i in range(oh):\n                expected = [fg] * (n + i) + [bg] * (w - n - i)\n                if list(raw_out[i]) != expected:\n                    return None\n\n        return {\"type\": \"staircase_extend_right\", \"confidence\": 1.0}\n\n    # ---- strategy: corner quadrant fill ---------------------------------\n\n    def _try_corner_quadrant_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input has 4 single-cell 'corner markers' of\n        distinct non-background colors at the 4 corners of an axis-aligned\n        rectangle, plus a solid block of one other 'inner' color filling the\n        cells strictly inside that rectangle. The output replaces the corners\n        with background and splits the inner block into four equal quadrants\n        (TL/TR/BL/BR) recolored by the corresponding corner color.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        inner_color = None\n\n        for raw_in, raw_out in example_pairs:\n            params = self._check_corner_quadrant_fill(raw_in, raw_out)\n            if params is None:\n                return None\n            if inner_color is None:\n                inner_color = params[\"inner_color\"]\n            elif inner_color != params[\"inner_color\"]:\n                return None\n\n        if inner_color is None:\n            return None\n        return {\n            \"type\": \"corner_quadrant_fill\",\n            \"inner_color\": inner_color,\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _check_corner_quadrant_fill(raw_in, raw_out):\n        h = len(raw_in)\n        w = len(raw_in[0]) if raw_in else 0\n        if h == 0 or w == 0:\n            return None\n        if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n            return None\n\n        counts = {}\n        for row in raw_in:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        # Find inner color: must be one color forming one or more solid\n        # rectangles, each of even side lengths >= 2, with 4 single-cell\n        # 'corner markers' at the diagonal-adjacent positions.\n        groups = GeneralizeOperator._find_corner_quadrant_groups(raw_in, bg)\n        if not groups:\n            return None\n        inner = groups[0][\"inner_color\"]\n        for g in groups:\n            if g[\"inner_color\"] != inner:\n                return None\n\n        expected = GeneralizeOperator._apply_quadrant_groups(raw_in, groups, bg)\n        for r in range(h):\n            for c in range(w):\n                if expected[r][c] != raw_out[r][c]:\n                    return None\n\n        return {\"inner_color\": inner}\n\n    @staticmethod\n    def _find_corner_quadrant_groups(raw, bg):\n        \"\"\"Find all (inner-rect + 4 corner-marker) groups in raw.\n\n        A group consists of: a solid rectangle filled with one non-bg color\n        (the 'inner color'), with side lengths >= 2 and even, surrounded by\n        4 single cells at the diagonal-adjacent positions, each a distinct\n        non-bg color (and distinct from the inner color). Returns a list of\n        dicts {r0,r1,c0,c1, inner_color, tl, tr, bl, br}, or empty list.\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n\n        # 4-connected components of every non-bg color\n        visited = [[False] * w for _ in range(h)]\n        groups = []\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] == bg or visited[r][c]:\n                    continue\n                color = raw[r][c]\n                comp = []\n                queue = [(r, c)]\n                while queue:\n                    rr, cc = queue.pop()\n                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n                        continue\n                    if visited[rr][cc] or raw[rr][cc] != color:\n                        continue\n                    visited[rr][cc] = True\n                    comp.append((rr, cc))\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        queue.append((rr + dr, cc + dc))\n                if len(comp) < 4:\n                    continue  # skip tiny components\n                rs = [p[0] for p in comp]\n                cs = [p[1] for p in comp]\n                r0, r1 = min(rs), max(rs)\n                c0, c1 = min(cs), max(cs)\n                ih = r1 - r0 + 1\n                iw = c1 - c0 + 1\n                if ih < 2 or iw < 2:\n                    continue\n                if ih % 2 != 0 or iw % 2 != 0:\n                    continue\n                # Must be a solid rectangle\n                if len(comp) != ih * iw:\n                    continue\n                # Corner positions are diagonally adjacent to the rectangle\n                cr0, cc0 = r0 - 1, c0 - 1\n                cr1, cc1 = r0 - 1, c1 + 1\n                cr2, cc2 = r1 + 1, c0 - 1\n                cr3, cc3 = r1 + 1, c1 + 1\n                if (cr0 < 0 or cc0 < 0 or cr3 >= h or cc3 >= w):\n                    continue\n                tl_v = raw[cr0][cc0]\n                tr_v = raw[cr1][cc1]\n                bl_v = raw[cr2][cc2]\n                br_v = raw[cr3][cc3]\n                corner_vals = [tl_v, tr_v, bl_v, br_v]\n                if any(v == bg or v == color for v in corner_vals):\n                    continue\n                if len(set(corner_vals)) != 4:\n                    continue\n                # Each corner cell must be isolated: 4-neighbours all bg\n                ok = True\n                for (rr, cc) in [(cr0, cc0), (cr1, cc1), (cr2, cc2), (cr3, cc3)]:\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        nr, nc = rr + dr, cc + dc\n                        if 0 <= nr < h and 0 <= nc < w:\n                            if raw[nr][nc] != bg:\n                                ok = False\n                                break\n                    if not ok:\n                        break\n                if not ok:\n                    continue\n                groups.append({\n                    \"r0\": r0, \"r1\": r1, \"c0\": c0, \"c1\": c1,\n                    \"inner_color\": color,\n                    \"tl\": tl_v, \"tr\": tr_v, \"bl\": bl_v, \"br\": br_v,\n                    \"tl_pos\": (cr0, cc0), \"tr_pos\": (cr1, cc1),\n                    \"bl_pos\": (cr2, cc2), \"br_pos\": (cr3, cc3),\n                })\n        return groups\n\n    @staticmethod\n    def _apply_quadrant_groups(raw, groups, bg):\n        out = [list(row) for row in raw]\n        for g in groups:\n            r0, r1, c0, c1 = g[\"r0\"], g[\"r1\"], g[\"c0\"], g[\"c1\"]\n            ih = r1 - r0 + 1\n            iw = c1 - c0 + 1\n            hh, ww = ih // 2, iw // 2\n            # Clear corner markers\n            for key in (\"tl_pos\", \"tr_pos\", \"bl_pos\", \"br_pos\"):\n                rr, cc = g[key]\n                out[rr][cc] = bg\n            # Fill quadrants of inner rect\n            for r in range(r0, r1 + 1):\n                for c in range(c0, c1 + 1):\n                    is_top = r < r0 + hh\n                    is_left = c < c0 + ww\n                    if is_top and is_left:\n                        out[r][c] = g[\"tl\"]\n                    elif is_top:\n                        out[r][c] = g[\"tr\"]\n                    elif is_left:\n                        out[r][c] = g[\"bl\"]\n                    else:\n                        out[r][c] = g[\"br\"]\n        return out\n\n    # ---- strategy: diamond connector ------------------------------------\n\n    def _try_diamond_connector(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input contains '+'-shaped 4-cell diamond\n        markers (one foreground cell at each of N/S/E/W around a background\n        center, with all 4 diagonal cells being background). Each pair of\n        adjacent collinear diamonds (sharing a row or column with no other\n        diamond between them on that line) is joined in the output by a\n        line of a single 'connector' color filling the cells strictly\n        between their inner '+' tips.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        connector = None\n        fg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            in_colors = {c for row in raw_in for c in row}\n            out_colors = {c for row in raw_out for c in row}\n            new_colors = out_colors - in_colors\n            if len(new_colors) != 1:\n                return None\n            marker = next(iter(new_colors))\n            if connector is None:\n                connector = marker\n            elif connector != marker:\n                return None\n\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n            fg_set = in_colors - {bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n            if fg_color is None:\n                fg_color = fg\n            elif fg_color != fg:\n                return None\n\n            diamonds = self._find_diamonds(raw_in, fg, bg)\n            if len(diamonds) < 2:\n                return None\n\n            expected = [list(row) for row in raw_in]\n            self._draw_diamond_connectors(expected, diamonds, marker)\n\n            for r in range(h):\n                for c in range(w):\n                    if expected[r][c] != raw_out[r][c]:\n                        return None\n\n        if connector is None or fg_color is None:\n            return None\n        return {\n            \"type\": \"diamond_connector\",\n            \"connector\": connector,\n            \"foreground\": fg_color,\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _find_diamonds(raw, fg, bg):\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        centers = []\n        for r in range(1, h - 1):\n            for c in range(1, w - 1):\n                if raw[r][c] != bg:\n                    continue\n                if (raw[r - 1][c] == fg and raw[r + 1][c] == fg\n                        and raw[r][c - 1] == fg and raw[r][c + 1] == fg\n                        and raw[r - 1][c - 1] == bg and raw[r - 1][c + 1] == bg\n                        and raw[r + 1][c - 1] == bg and raw[r + 1][c + 1] == bg):\n                    centers.append((r, c))\n        return centers\n\n    @staticmethod\n    def _draw_diamond_connectors(grid, diamonds, marker):\n        by_row = {}\n        by_col = {}\n        for r, c in diamonds:\n            by_row.setdefault(r, []).append(c)\n            by_col.setdefault(c, []).append(r)\n        for r, cols in by_row.items():\n            cols = sorted(cols)\n            for i in range(len(cols) - 1):\n                cl, cr = cols[i], cols[i + 1]\n                for cc in range(cl + 2, cr - 1):\n                    grid[r][cc] = marker\n        for c, rows in by_col.items():\n            rows = sorted(rows)\n            for i in range(len(rows) - 1):\n                rl, rr = rows[i], rows[i + 1]\n                for rr2 in range(rl + 2, rr - 1):\n                    grid[rr2][c] = marker\n\n    # ---- strategy: axis line keep ---------------------------------------\n\n    def _try_axis_line_keep(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; output equals input on a single 'kept' line\n        (one row or one column) and equals a single background color\n        everywhere else. The line position must be derivable consistently\n        across all examples (e.g., always the middle row/column).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for axis, pos_kind in ((\"col\", \"middle\"), (\"row\", \"middle\")):\n            params = self._check_axis_line_keep(example_pairs, axis, pos_kind)\n            if params is not None:\n                return {\n                    \"type\": \"axis_line_keep\",\n                    \"axis\": axis,\n                    \"position\": pos_kind,\n                    \"background\": params[\"background\"],\n                    \"confidence\": 1.0,\n                }\n        return None\n\n    @staticmethod\n    def _check_axis_line_keep(example_pairs, axis, pos_kind):\n        bg_color = None\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h == 0 or w == 0:\n                return None\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n            if pos_kind == \"middle\":\n                k = (w // 2) if axis == \"col\" else (h // 2)\n            else:\n                return None\n\n            local_bg = None\n            for r in range(h):\n                for c in range(w):\n                    on_line = (axis == \"col\" and c == k) or (axis == \"row\" and r == k)\n                    if on_line:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n                    else:\n                        if local_bg is None:\n                            local_bg = raw_out[r][c]\n                        elif raw_out[r][c] != local_bg:\n                            return None\n            if local_bg is None:\n                return None\n            if bg_color is None:\n                bg_color = local_bg\n            elif bg_color != local_bg:\n                return None\n        if bg_color is None:\n            return None\n        return {\"background\": bg_color}\n\n    # ---- strategy: recolor by component size ----------------------------\n\n    def _try_recolor_by_size(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input has one background color and one\n        foreground color; connected components of foreground cells in the\n        input are each recolored uniformly in the output to a color that\n        depends solely on the component's cell count. A consistent\n        size -> color mapping must hold across all examples. Non-foreground\n        cells are unchanged.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        size_to_color = {}\n        fg_color = None\n        bg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h == 0 or w == 0:\n                return None\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg_local = max(counts, key=counts.get)\n            in_colors = set(counts.keys())\n            fg_set = in_colors - {bg_local}\n            if len(fg_set) != 1:\n                return None\n            fg_local = next(iter(fg_set))\n\n            if bg_color is None:\n                bg_color, fg_color = bg_local, fg_local\n            elif (bg_color, fg_color) != (bg_local, fg_local):\n                return None\n\n            comps = self._find_components(raw_in, fg_local)\n            if not comps:\n                return None\n            for comp in comps:\n                out_colors = {raw_out[r][c] for (r, c) in comp}\n                if len(out_colors) != 1:\n                    return None\n                out_c = next(iter(out_colors))\n                size = len(comp)\n                if size in size_to_color and size_to_color[size] != out_c:\n                    return None\n                size_to_color[size] = out_c\n\n            # Non-foreground cells must be unchanged\n            for r in range(h):\n                for c in range(w):\n                    if raw_in[r][c] != fg_local and raw_out[r][c] != raw_in[r][c]:\n                        return None\n\n        if not size_to_color or fg_color is None:\n            return None\n        return {\n            \"type\": \"recolor_by_size\",\n            \"foreground\": fg_color,\n            \"background\": bg_color,\n            \"size_to_color\": {str(k): v for k, v in size_to_color.items()},\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _find_components(raw, color):\n        \"\"\"Return 4-connected components of `color` in `raw` as lists of (r, c).\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        visited = [[False] * w for _ in range(h)]\n        comps = []\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != color or visited[r][c]:\n                    continue\n                comp = []\n                queue = [(r, c)]\n                while queue:\n                    rr, cc = queue.pop()\n                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n                        continue\n                    if visited[rr][cc] or raw[rr][cc] != color:\n                        continue\n                    visited[rr][cc] = True\n                    comp.append((rr, cc))\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        queue.append((rr + dr, cc + dc))\n                comps.append(comp)\n        return comps\n\n\n# ======================================================================\n# DescendOperator -- placeholder for deeper KG exploration\n# ======================================================================\n\nclass DescendOperator(Operator):\n    \"\"\"\n    Placeholder: moves focus to a deeper KG level when current-level\n    analysis is insufficient. Not yet needed for the basic pipeline.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"descend\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n\n\n# ======================================================================\n# PredictOperator -- apply rule to test input\n# ======================================================================\n\nclass PredictOperator(Operator):\n    \"\"\"\n    Reads the best rule from active-rules and applies it to each test\n    pair's input grid to produce a predicted output grid.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"predict\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        active_rules = wm.s1.get(\"active-rules\")\n        if not task or not active_rules:\n            return\n\n        rule = active_rules[0]\n        predictions = dict(wm.s1.get(\"predictions\") or {})\n\n        for i, test_pair in enumerate(task.test_pairs):\n            key = f\"test_{i}\"\n            if key in predictions:\n                continue\n            g0 = test_pair.input_grid\n            if g0 is None:\n                continue\n            predicted = self._apply_rule(rule, g0)\n            if predicted is not None:\n                predictions[key] = predicted\n\n        wm.s1[\"predictions\"] = predictions\n\n    # ---- rule application dispatchers ------------------------------------\n\n    def _apply_rule(self, rule, input_grid):\n        rule_type = rule.get(\"type\")\n        if rule_type == \"recolor_sequential\":\n            return self._apply_recolor_sequential(rule, input_grid)\n        if rule_type == \"color_mapping\":\n            return self._apply_color_mapping(rule, input_grid)\n        if rule_type == \"bbox_fill\":\n            return self._apply_bbox_fill(rule, input_grid)\n        if rule_type == \"axis_mirror_recolor\":\n            return self._apply_axis_mirror_recolor(rule, input_grid)\n        if rule_type == \"integer_upscale\":\n            return self._apply_integer_upscale(rule, input_grid)\n        if rule_type == \"stack_with_mirror\":\n            return self._apply_stack_with_mirror(rule, input_grid)\n        if rule_type == \"rect_interior_fill\":\n            return self._apply_rect_interior_fill(rule, input_grid)\n        if rule_type == \"staircase_extend_right\":\n            return self._apply_staircase_extend_right(rule, input_grid)\n        if rule_type == \"corner_quadrant_fill\":\n            return self._apply_corner_quadrant_fill(rule, input_grid)\n        if rule_type == \"diamond_connector\":\n            return self._apply_diamond_connector(rule, input_grid)\n        if rule_type == \"axis_line_keep\":\n            return self._apply_axis_line_keep(rule, input_grid)\n        if rule_type == \"recolor_by_size\":\n            return self._apply_recolor_by_size(rule, input_grid)\n        if rule_type == \"identity\":\n            return [row[:] for row in input_grid.raw]\n        return None\n\n    def _apply_recolor_sequential(self, rule, input_grid):\n        raw = input_grid.raw\n        height = len(raw)\n        width = len(raw[0]) if raw else 0\n        sort_key = rule[\"sort_key\"]\n        start_color = rule[\"start_color\"]\n        source_colors = set(rule.get(\"source_colors\", []))\n\n        # Find target cells\n        target_cells = []\n        for r in range(height):\n            for c in range(width):\n                if raw[r][c] in source_colors:\n                    target_cells.append((r, c))\n\n        if not target_cells:\n            return [row[:] for row in raw]\n\n        # Group into connected components\n        groups = self._group_positions(target_cells)\n\n        # Sort groups by the rule's sort key\n        def _sort_val(group):\n            if sort_key == \"top_row\":\n                return min(r for r, c in group)\n            if sort_key == \"top_col\":\n                return min(c for r, c in group)\n            return 0\n\n        sorted_groups = sorted(groups, key=_sort_val)\n\n        # Build output grid\n        output = [row[:] for row in raw]\n        for idx, group in enumerate(sorted_groups):\n            new_color = start_color + idx\n            for r, c in group:\n                output[r][c] = new_color\n\n        return output\n\n    def _apply_color_mapping(self, rule, input_grid):\n        raw = input_grid.raw\n        mapping = rule.get(\"mapping\", {})\n\n        output = []\n        for row in raw:\n            output.append([mapping.get(cell, cell) for cell in row])\n        return output\n\n    def _apply_bbox_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        bg = rule.get(\"background\")\n        if marker is None or fg is None or bg is None:\n            return None\n\n        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n        if not rows:\n            return [row[:] for row in raw]\n        r0, r1 = min(rows), max(rows)\n        c0, c1 = min(cols), max(cols)\n\n        out = [row[:] for row in raw]\n        for r in range(r0, r1 + 1):\n            for c in range(c0, c1 + 1):\n                if out[r][c] == bg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_axis_mirror_recolor(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        axis = rule.get(\"axis\", \"horizontal\")\n        if marker is None or fg is None:\n            return None\n\n        out = [row[:] for row in raw]\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != fg:\n                    continue\n                if axis == \"horizontal\":\n                    rr, cc = r, w - 1 - c\n                else:\n                    rr, cc = h - 1 - r, c\n                if (r, c) == (rr, cc):\n                    continue\n                if raw[rr][cc] == fg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_integer_upscale(self, rule, input_grid):\n        raw = input_grid.raw\n        k = rule.get(\"factor\")\n        if not isinstance(k, int) or k < 2:\n            return None\n        out = []\n        for row in raw:\n            new_row = []\n            for v in row:\n                new_row.extend([v] * k)\n            for _ in range(k):\n                out.append(new_row[:])\n        return out\n\n    def _apply_stack_with_mirror(self, rule, input_grid):\n        raw = input_grid.raw\n        direction = rule.get(\"direction\")\n        order = rule.get(\"order\")\n        if direction not in (\"vertical\", \"horizontal\"):\n            return None\n        if order not in (\"input_first\", \"flip_first\"):\n            return None\n\n        if direction == \"vertical\":\n            flipped = list(reversed([row[:] for row in raw]))\n            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [r[:] for r in top] + [r[:] for r in bot]\n        else:\n            flipped = [list(reversed(row)) for row in raw]\n            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n\n    def _apply_rect_interior_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        bg = rule.get(\"background\")\n        fg = rule.get(\"border\")\n        size_to_fill_raw = rule.get(\"size_to_fill\") or {}\n        if bg is None or fg is None:\n            return None\n        size_to_fill = {}\n        for k, v in size_to_fill_raw.items():\n            try:\n                a, b = k.split(\"x\")\n                size_to_fill[(int(a), int(b))] = v\n            except ValueError:\n                continue\n\n        rects = GeneralizeOperator._find_hollow_rects(raw, fg, bg)\n        out = [row[:] for row in raw]\n        for (r0, c0, r1, c1) in rects:\n            ih = r1 - r0 - 1\n            iw = c1 - c0 - 1\n            fill = size_to_fill.get((ih, iw))\n            if fill is None:\n                continue\n            for r in range(r0 + 1, r1):\n                for c in range(c0 + 1, c1):\n                    out[r][c] = fill\n        return out\n\n    def _apply_staircase_extend_right(self, rule, input_grid):\n        raw = input_grid.raw\n        if len(raw) != 1:\n            return None\n        row0 = list(raw[0])\n        w = len(row0)\n        if w < 2:\n            return None\n        distinct = set(row0)\n        if len(distinct) != 2:\n            return None\n        fg = row0[0]\n        bg = next(v for v in distinct if v != fg)\n        n = 0\n        while n < w and row0[n] == fg:\n            n += 1\n        if n == 0 or any(v != bg for v in row0[n:]):\n            return None\n        oh = w // 2\n        out = []\n        for i in range(oh):\n            cells = [fg] * (n + i) + [bg] * (w - n - i)\n            out.append(cells)\n        return out\n\n    def _apply_corner_quadrant_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        inner_color = rule.get(\"inner_color\")\n        if inner_color is None:\n            return None\n\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        groups = GeneralizeOperator._find_corner_quadrant_groups(raw, bg)\n        groups = [g for g in groups if g[\"inner_color\"] == inner_color]\n        if not groups:\n            return None\n        return GeneralizeOperator._apply_quadrant_groups(raw, groups, bg)\n\n    def _apply_axis_line_keep(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        axis = rule.get(\"axis\")\n        pos = rule.get(\"position\")\n        bg = rule.get(\"background\")\n        if axis not in (\"col\", \"row\") or pos != \"middle\" or bg is None:\n            return None\n        k = (w // 2) if axis == \"col\" else (h // 2)\n        out = [[bg] * w for _ in range(h)]\n        for r in range(h):\n            for c in range(w):\n                on_line = (axis == \"col\" and c == k) or (axis == \"row\" and r == k)\n                if on_line:\n                    out[r][c] = raw[r][c]\n        return out\n\n    def _apply_recolor_by_size(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        fg = rule.get(\"foreground\")\n        if fg is None:\n            return None\n        size_to_color_raw = rule.get(\"size_to_color\") or {}\n        size_to_color = {}\n        for k, v in size_to_color_raw.items():\n            try:\n                size_to_color[int(k)] = v\n            except (TypeError, ValueError):\n                continue\n        out = [row[:] for row in raw]\n        for comp in GeneralizeOperator._find_components(raw, fg):\n            new_color = size_to_color.get(len(comp))\n            if new_color is None:\n                continue\n            for (rr, cc) in comp:\n                out[rr][cc] = new_color\n        return out\n\n    def _apply_diamond_connector(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        connector = rule.get(\"connector\")\n        if connector is None:\n            return None\n\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        in_colors = {c for row in raw for c in row}\n        fg_set = in_colors - {bg}\n        if len(fg_set) != 1:\n            return None\n        fg = next(iter(fg_set))\n\n        diamonds = GeneralizeOperator._find_diamonds(raw, fg, bg)\n        out = [row[:] for row in raw]\n        GeneralizeOperator._draw_diamond_connectors(out, diamonds, connector)\n        return out\n\n    # ---- helpers ---------------------------------------------------------\n\n    @staticmethod\n    def _group_positions(positions):\n        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n        pos_set = set(positions)\n        visited = set()\n        groups = []\n\n        for pos in positions:\n            if pos in visited:\n                continue\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_set:\n                    continue\n                visited.add(p)\n                group.append(p)\n                r, c = p\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (r + dr, c + dc)\n                    if nb in pos_set and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# SubmitOperator -- finalize and satisfy goal\n# ======================================================================\n\nclass SubmitOperator(Operator):\n    \"\"\"\n    Writes predicted grids to S1 output-link in the format expected by\n    run_task.py, and marks the goal as satisfied.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"submit\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        predictions = wm.s1.get(\"predictions\")\n        if not predictions:\n            return\n\n        task = wm.task\n        if not task:\n            return\n\n        predicted_grids = []\n        for i in range(len(task.test_pairs)):\n            grid = predictions.get(f\"test_{i}\")\n            if grid is not None:\n                predicted_grids.append(grid)\n\n        if not predicted_grids:\n            return\n\n        # Write to output-link (format expected by run_task.py)\n        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n\n        # Mark goal as satisfied\n        wm.s1[\"goal\"] = {\"subgoals\": {\n            f\"test_{i}\": {\"status\": \"solved\"}\n            for i in range(len(predicted_grids))\n        }}\n\n\nclass VerifyOperator(SubmitOperator):\n    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n\n    def __init__(self):\n        super().__init__()\n        self.name = \"verify\"\n","numLines":1844,"startLine":1,"totalLines":1844}}}
