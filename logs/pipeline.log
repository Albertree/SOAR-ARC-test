{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SAedHS13T2kwiu3QbVwHRh","type":"tool_result","content":"     1→\"\"\"\n     2→wm_logger — Utility for printing WorkingMemory state in SOAR triplet format.\n     3→\n     4→━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n     5→SOAR Working Memory Element (WME) format:\n     6→    (identifier ^attribute value)\n     7→\n     8→    identifier : S1=root, S2/S3...=substates, I1/I2...=auto-generated child nodes\n     9→    attribute  : field name\n    10→    value      : primitive or child node identifier\n    11→\n    12→diff colors (git diff style):\n    13→    Green background + white text  →  WME added/changed compared to previous call\n    14→    Red background + white text    →  WME removed compared to previous call\n    15→    Normal                         →  Unchanged WME\n    16→\n    17→    Comparison is based on path_key (e.g., S1/relations/pair_0/type) rather than\n    18→    auto-id (I1, I2...), so the semantic diff is computed accurately even if\n    19→    identifiers change.\n    20→\n    21→Usage:\n    22→    from agent.wm_logger import print_wm_triplets, reset_wm_snapshot\n    23→    reset_wm_snapshot()                                 # Reset snapshot before task starts\n    24→    print_wm_triplets(wm, label=\"After: elaborate\", step=3)\n    25→━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    26→\"\"\"\n    27→\n    28→from __future__ import annotations\n    29→\n    30→import itertools\n    31→from dataclasses import dataclass\n    32→from typing import Any\n    33→\n    34→\n    35→# ── ANSI colors ────────────────────────────────────────────────────────── #\n    36→\n    37→_GREEN_BG = \"\\033[42;37m\"   # Green background, white text (added/changed)\n    38→_RED_BG   = \"\\033[41;37m\"   # Red background, white text (removed)\n    39→_RESET    = \"\\033[0m\"\n    40→\n    41→# Output width: pad color background to match divider width.\n    42→_LINE_WIDTH = 62\n    43→\n    44→\n    45→# ── Output constants ────────────────────────────────────────────────────── #\n    46→\n    47→_L1      = \"  \"       # depth 0 (root identifier S1/S2/WM) line indentation\n    48→_L2      = \"    \"     # depth 1 (direct children: I1, etc.) indentation\n    49→_L3      = \"      \"   # depth 2+ (grandchildren and below: I2, I3, etc.) indentation\n    50→_DIVIDER = \"═\" * _LINE_WIDTH\n    51→\n    52→# S1/WM family identifier detection\n    53→_ROOT_IDS = {\"S1\", \"S2\", \"S3\", \"S4\", \"WM\"}\n    54→\n    55→# Maximum display length for string values\n    56→_MAX_STR_LEN = 80\n    57→\n    58→\n    59→# ── WME data model ──────────────────────────────────────────────────── #\n    60→\n    61→@dataclass(frozen=True)\n    62→class _WME:\n    63→    \"\"\"\n    64→    A single Working Memory Element.\n    65→\n    66→    identifier : display node ID (S1, I1, ...)\n    67→    attribute  : field name\n    68→    value      : formatted value string\n    69→    path_key   : canonical path for diff comparison (e.g., \"S1/relations/pair_0/type\")\n    70→    is_root    : True if identifier is S1/WM family → L1 indentation\n    71→    \"\"\"\n    72→    identifier: str\n    73→    attribute:  str\n    74→    value:      str\n    75→    path_key:   str\n    76→    is_root:    bool\n    77→    depth:      int   # Depth relative to S1 (0=S1, 1=child, 2=grandchild...)\n    78→\n    79→\n    80→# ── Module-level diff state ──────────────────────────────────────────── #\n    81→\n    82→# {path_key: _WME} — Snapshot from the previous print_wm_triplets call\n    83→_prev_snap: dict[str, _WME] = {}\n    84→\n    85→\n    86→def reset_wm_snapshot(wm=None) -> None:\n    87→    \"\"\"\n    88→    Resets the diff snapshot.\n    89→\n    90→    wm=None  : Reset to empty snapshot → next print_wm_triplets call shows everything in green\n    91→    wm=<WM>  : Pre-fill snapshot with current WM state\n    92→               → next print_wm_triplets call shows no changes, all in normal color\n    93→\n    94→    Recommended usage pattern:\n    95→        # run_task.py — Start diff from initial WM state\n    96→        build_wm_from_task(task, wm)\n    97→        reset_wm_snapshot(wm)              # Set initial state as baseline\n    98→        print_wm_triplets(wm, \"Initial WM state\")  # Print current state without colors\n    99→\n   100→        # active_agent.solve() — Prevent previous state from mixing between tasks\n   101→        reset_wm_snapshot()                # Reset to empty state before task starts\n   102→    \"\"\"\n   103→    global _prev_snap\n   104→    if wm is not None:\n   105→        entries    = _wm_as_entries(wm)\n   106→        _prev_snap = {e.path_key: e for e in entries}\n   107→    else:\n   108→        _prev_snap = {}\n   109→\n   110→\n   111→# ── Value formatting ────────────────────────────────────────────────────── #\n   112→\n   113→def _fmt(value: Any) -> str:\n   114→    \"\"\"Converts a primitive value to a SOAR display string.\"\"\"\n   115→    if value is None:\n   116→        return \"nil\"\n   117→    if isinstance(value, bool):\n   118→        return \"true\" if value else \"false\"\n   119→    if isinstance(value, str):\n   120→        # Preference symbols etc. — single characters used bare in Soar\n   121→        if len(value) == 1 and value in \"+-!~<>\":\n   122→            return value\n   123→        # SOAR style: symbols without spaces/special chars are kept as-is; others are quoted.\n   124→        s = value if len(value) <= _MAX_STR_LEN else value[:_MAX_STR_LEN] + \"…\"\n   125→        if s and all(ch.isalnum() or ch in (\"_\", \"-\", \".\") for ch in s):\n   126→            return s\n   127→        return f'\"{s}\"'\n   128→    return str(value)\n   129→\n   130→\n   131→def _is_grid(lst: list) -> bool:\n   132→    \"\"\"Determines whether the list looks like a 2D grid (array of integers or array of integer arrays).\"\"\"\n   133→    return bool(lst) and isinstance(lst[0], (int, list, tuple))\n   134→\n   135→\n   136→# ── WME collection (recursive) ──────────────────────────────────────── #\n   137→\n   138→def _collect(\n   139→    identifier:  str,\n   140→    attribute:   str,\n   141→    value:       Any,\n   142→    id_gen,\n   143→    out:         list[_WME],\n   144→    path_prefix: str,\n   145→    depth:       int,\n   146→    list_index:  int | None = None,\n   147→) -> None:\n   148→    \"\"\"\n   149→    Recursively expands a single (identifier, attribute, value) and appends _WME entries to out.\n   150→\n   151→    path_key generation rules:\n   152→        Normal dict field: \"{path_prefix}/{attribute}\"\n   153→        List item: \"{path_prefix}/{attribute}[{list_index}]\"\n   154→    \"\"\"\n   155→    if list_index is not None:\n   156→        path_key = f\"{path_prefix}/{attribute}[{list_index}]\"\n   157→    else:\n   158→        path_key = f\"{path_prefix}/{attribute}\"\n   159→\n   160→    is_root = identifier in _ROOT_IDS\n   161→\n   162→    if isinstance(value, dict):\n   163→        if not value:\n   164→            # Empty dict also gets a separate identifier (Ix) with just the link.\n   165→            # e.g., (I1 ^output-link I3) where I3 has no attributes yet.\n   166→            child_id = next(id_gen)\n   167→            out.append(_WME(identifier, attribute, child_id, path_key, is_root, depth))\n   168→            return\n   169→        child_id = next(id_gen)\n   170→        out.append(_WME(identifier, attribute, child_id, path_key, is_root, depth))\n   171→        for child_attr, child_val in value.items():\n   172→            _collect(child_id, child_attr, child_val, id_gen, out, path_key, depth + 1)\n   173→\n   174→    elif isinstance(value, list):\n   175→        if not value:\n   176→            out.append(_WME(identifier, attribute, \"[]\", path_key, is_root, depth))\n   177→            return\n   178→        if _is_grid(value):\n   179→            first = value[0]\n   180→            ncols = len(first) if isinstance(first, (list, tuple)) else 1\n   181→            out.append(_WME(\n   182→                identifier, attribute, f\"<grid {len(value)}x{ncols}>\",\n   183→                path_key, is_root, depth,\n   184→            ))\n   185→            return\n   186→        # Normal list: recursively collect each item with index-based path_key\n   187→        for idx, item in enumerate(value):\n   188→            _collect(identifier, attribute, item, id_gen, out, path_prefix, depth, list_index=idx)\n   189→\n   190→    else:\n   191→        out.append(_WME(identifier, attribute, _fmt(value), path_key, is_root, depth))\n   192→\n   193→\n   194→# ── WM → WME list conversion ───────────────────────────────────────── #\n   195→\n   196→def _wm_as_entries(wm) -> list[_WME]:\n   197→    \"\"\"Converts the entire WorkingMemory to a list of _WME entries.\"\"\"\n   198→    id_gen = (f\"I{n}\" for n in itertools.count(1))\n   199→    out: list[_WME] = []\n   200→\n   201→    # S1 (root state)\n   202→    root = \"S1\"\n   203→    for attr, val in wm.s1.items():\n   204→        # Operator nodes and similar separate identifier nodes are treated as\n   205→        # independent identifiers rather than S1 attributes (e.g., O1).\n   206→        if isinstance(val, dict) and attr[:1].isalpha() and attr[0].isupper():\n   207→            for child_attr, child_val in val.items():\n   208→                _collect(attr, child_attr, child_val, id_gen, out, attr, depth=0)\n   209→            continue\n   210→        _collect(root, attr, val, id_gen, out, root, depth=0)\n   211→\n   212→    # task is an external reference outside WM (Python level), so only a summary is printed.\n   213→    # In SOAR style, environment input should go under io/input-link,\n   214→    # so this value is kept for debug purposes only.\n   215→    if getattr(wm, \"task\", None) is not None:\n   216→        summary = getattr(wm.task, \"task_hex\", repr(wm.task))\n   217→        out.append(_WME(root, \"task_ref\", f\"<task {summary}>\", f\"{root}/task_ref\", True, 0))\n   218→\n   219→    # S2, S3, ... (substate stack) — Each substate is represented only as an independent Sx identifier.\n   220→    for depth, substate in enumerate(wm._substate_stack, start=2):\n   221→        sub = f\"S{depth}\"\n   222→        for attr, val in substate.items():\n   223→            # Same as S1: O* operator nodes are expanded as independent identifiers.\n   224→            if isinstance(val, dict) and attr[:1].isalpha() and attr[0].isupper():\n   225→                for child_attr, child_val in val.items():\n   226→                    _collect(attr, child_attr, child_val, id_gen, out, attr, depth=0)\n   227→                continue\n   228→            _collect(sub, attr, val, id_gen, out, sub, depth=0)\n   229→\n   230→    return out\n   231→\n   232→\n   233→# ── Line formatting + colors ─────────────────────────────────────────── #\n   234→\n   235→def _indent_for_depth(depth: int) -> str:\n   236→    \"\"\"Returns the indentation string for the given depth value.\"\"\"\n   237→    if depth <= 0:\n   238→        return _L1\n   239→    if depth == 1:\n   240→        return _L2\n   241→    return _L3\n   242→\n   243→\n   244→def _render(entry: _WME) -> str:\n   245→    \"\"\"Converts a single _WME to a string in `  (S1 ^attr val)` format.\"\"\"\n   246→    indent = _L1 if entry.is_root else _L2\n   247→    return f\"{indent}({entry.identifier} ^{entry.attribute} {entry.value})\"\n   248→\n   249→\n   250→def _op_preference_map_current(current_entries: list[_WME]) -> dict[str, str]:\n   251→    \"\"\"Returns op-preference of O* nodes that exist only in the current WM (must not mix with removed WME list).\"\"\"\n   252→    d: dict[str, str] = {}\n   253→    for e in current_entries:\n   254→        if (\n   255→            len(e.identifier) >= 2\n   256→            and e.identifier[0] == \"O\"\n   257→            and e.identifier[1:].isdigit()\n   258→            and e.attribute == \"op-preference\"\n   259→        ):\n   260→            d[e.identifier] = e.value.strip()\n   261→    return d\n   262→\n   263→\n   264→def _grouped_lines(\n   265→    entries: list[_WME],\n   266→    *,\n   267→    op_preference_map: dict[str, str],\n   268→) -> list[tuple[str, str | None]]:\n   269→    \"\"\"\n   270→    Groups WMEs with the same identifier into a single block, similar to SOAR debug output style.\n   271→\n   272→    op_preference_map: Computed from current WM only (prevents contamination even if display_entries contains removed items).\n   273→    \"\"\"\n   274→    if not entries:\n   275→        return []\n   276→\n   277→    op_preference = op_preference_map\n   278→\n   279→    # Collect all WMEs by identifier (regardless of contiguity).\n   280→    by_id: dict[str, list[_WME]] = {}\n   281→    order: list[str] = []\n   282→    for e in entries:\n   283→        if e.identifier not in by_id:\n   284→            by_id[e.identifier] = []\n   285→            order.append(e.identifier)\n   286→        by_id[e.identifier].append(e)\n   287→\n   288→    # In O* blocks, ^op-preference is merged into the S1 line, so omit it as a separate line\n   289→    for oid, group in list(by_id.items()):\n   290→        if oid.startswith(\"O\") and len(oid) >= 2 and oid[1:].isdigit():\n   291→            by_id[oid] = [w for w in group if w.attribute != \"op-preference\"]\n   292→\n   293→    # Output order: S1, operators (O*), S2/S3/S4, WM, then remaining identifiers.\n   294→    def id_priority(ident: str) -> tuple[int, str]:\n   295→        if ident == \"S1\":\n   296→            return (0, ident)\n   297→        if ident.startswith(\"O\"):\n   298→            return (1, ident)\n   299→        if ident in {\"S2\", \"S3\", \"S4\"}:\n   300→            return (2, ident)\n   301→        if ident == \"WM\":\n   302→            return (3, ident)\n   303→        return (4, ident)\n   304→\n   305→    sorted_ids = sorted(order, key=id_priority)\n   306→\n   307→    # S1: proposal ^operator O* + followed by official ^operator O* (operator-application)\n   308→    _S1_ORDER = (\n   309→        \"type\",\n   310→        \"superstate\",\n   311→        \"io\",\n   312→        \"smem\",\n   313→        \"epmem\",\n   314→        \"current-task\",\n   315→        \"operator\",\n   316→        \"operator-application\",\n   317→    )\n   318→\n   319→    # S2, S3, ... (substate) — smem → epmem fixed order\n   320→    _SUBSTATE_ORDER = (\n   321→        \"type\",\n   322→        \"superstate\",\n   323→        \"impasse\",\n   324→        \"choices\",\n   325→        \"attribute\",\n   326→        \"quiescence\",\n   327→        \"operator\",\n   328→        \"operator-application\",\n   329→        \"smem\",\n   330→        \"epmem\",\n   331→        \"item\",\n   332→        \"item-count\",\n   333→        \"non-numeric\",\n   334→        \"non-numeric-count\",\n   335→    )\n   336→\n   337→    def _s1_sort_key(e: _WME) -> tuple[int, str]:\n   338→        try:\n   339→            return (_S1_ORDER.index(e.attribute), e.attribute)\n   340→        except ValueError:\n   341→            return (len(_S1_ORDER), e.attribute)\n   342→\n   343→    def _substate_sort_key(e: _WME) -> tuple[int, str]:\n   344→        try:\n   345→            return (_SUBSTATE_ORDER.index(e.attribute), e.path_key)\n   346→        except ValueError:\n   347→            return (len(_SUBSTATE_ORDER), e.path_key)\n   348→\n   349→    def _is_substate_ident(ident: str) -> bool:\n   350→        return (\n   351→            len(ident) >= 2\n   352→            and ident[0] == \"S\"\n   353→            and ident != \"S1\"\n   354→            and ident[1:].isdigit()\n   355→        )\n   356→\n   357→    def _s1_show_attr(attr: str) -> str:\n   358→        return \"operator\" if attr == \"operator-application\" else attr\n   359→\n   360→    lines: list[tuple[str, str | None]] = []\n   361→\n   362→    for ident in sorted_ids:\n   363→        group = by_id[ident]\n   364→        if not group:\n   365→            continue\n   366→        if ident == \"S1\":\n   367→            group = sorted(group, key=_s1_sort_key)\n   368→        elif _is_substate_ident(ident):\n   369→            group = sorted(group, key=_substate_sort_key)\n   370→\n   371→        first = group[0]\n   372→        base_indent = _indent_for_depth(first.depth)\n   373→        cont_indent = base_indent + (\" \" * (len(ident) + 2))\n   374→\n   375→        def _proposal_suffix(e: _WME) -> str:\n   376→            if ident != \"S1\" or e.attribute != \"operator\":\n   377→                return \"\"\n   378→            sym = op_preference.get(e.value)\n   379→            return f\" {sym}\" if sym else \"\"\n   380→\n   381→        if ident == \"S1\":\n   382→            if len(group) == 1:\n   383→                e0 = group[0]\n   384→                a = _s1_show_attr(e0.attribute)\n   385→                text = f\"{base_indent}({ident} ^{a} {e0.value}{_proposal_suffix(e0)})\"\n   386→                lines.append((text, e0.path_key))\n   387→            else:\n   388→                e0 = group[0]\n   389→                a0 = _s1_show_attr(e0.attribute)\n   390→                first_text = f\"{base_indent}({ident} ^{a0} {e0.value}{_proposal_suffix(e0)}\"\n   391→                lines.append((first_text, e0.path_key))\n   392→                for k in range(1, len(group) - 1):\n   393→                    e = group[k]\n   394→                    a = _s1_show_attr(e.attribute)\n   395→                    mid = f\"{cont_indent}^{a} {e.value}{_proposal_suffix(e)}\"\n   396→                    lines.append((mid, e.path_key))\n   397→                el = group[-1]\n   398→                al = _s1_show_attr(el.attribute)\n   399→                last_text = f\"{cont_indent}^{al} {el.value}{_proposal_suffix(el)})\"\n   400→                lines.append((last_text, el.path_key))\n   401→            continue\n   402→\n   403→        if len(group) == 1:\n   404→            text = f\"{base_indent}({ident} ^{first.attribute} {first.value})\"\n   405→            lines.append((text, first.path_key))\n   406→        else:\n   407→            first_text = f\"{base_indent}({ident} ^{first.attribute} {first.value}\"\n   408→            lines.append((first_text, first.path_key))\n   409→            for k in range(1, len(group) - 1):\n   410→                e = group[k]\n   411→                lines.append((f\"{cont_indent}^{e.attribute} {e.value}\", e.path_key))\n   412→            last = group[-1]\n   413→            lines.append((f\"{cont_indent}^{last.attribute} {last.value})\", last.path_key))\n   414→\n   415→    return lines\n   416→\n   417→def _render_removed(entry: _WME) -> str:\n   418→    \"\"\"\n   419→    Displays a removed WME with path_key-based identifier.\n   420→\n   421→    Uses entry.identifier / attribute / depth information to\n   422→    maintain the same indentation as normal output.\n   423→    \"\"\"\n   424→    base_indent = _indent_for_depth(entry.depth)\n   425→    return f\"{base_indent}({entry.identifier} ^{entry.attribute} {entry.value})\"\n   426→\n   427→\n   428→def _colorize(text: str, ansi: str) -> str:\n   429→    \"\"\"Pads text to _LINE_WIDTH and wraps it with ANSI background color.\"\"\"\n   430→    padded = text.ljust(_LINE_WIDTH)\n   431→    return f\"{ansi}{padded}{_RESET}\"\n   432→\n   433→\n   434→# ── Public output function ───────────────────────────────────────────── #\n   435→\n   436→def print_wm_triplets(wm, label: str = \"\", step: int = 0) -> None:\n   437→    \"\"\"\n   438→    Prints the entire WorkingMemory state in SOAR triplet format + git diff style colors.\n   439→\n   440→    Output rules:\n   441→        Green background  → WME newly added or value changed compared to previous snapshot\n   442→        Red background    → WME that existed in previous snapshot but is now absent (removed section)\n   443→        Normal text       → Unchanged WME\n   444→\n   445→    On the first call, _prev_snap is empty so all items are shown in green.\n   446→    When the task changes, reset_wm_snapshot() must be called to reset the snapshot.\n   447→    \"\"\"\n   448→    global _prev_snap\n   449→\n   450→    entries   = _wm_as_entries(wm)\n   451→    curr_snap = {e.path_key: e for e in entries}\n   452→\n   453→    # ── Diff computation ─────────────────────────────────────────── #\n   454→    added_keys = {\n   455→        k for k, e in curr_snap.items()\n   456→        if k not in _prev_snap or _prev_snap[k].value != e.value\n   457→    }\n   458→    removed = {\n   459→        k: e for k, e in _prev_snap.items()\n   460→        if k not in curr_snap\n   461→    }\n   462→\n   463→    # ── Header ──────────────────────────────────────────────────── #\n   464→    header = f\"[Step {step}] {label}\" if label else f\"[Step {step}]\"\n   465→    print(_DIVIDER)\n   466→    print(f\"{_L1}{header}\")\n   467→    print(_DIVIDER)\n   468→\n   469→    # ── Print current state + removed items together (grouped by identifier) ── #\n   470→    # Display entries: current entries + removed entries (current takes priority for duplicate path_keys)\n   471→    display_entries: list[_WME] = list(entries)\n   472→    for k, e in removed.items():\n   473→        if k not in curr_snap:\n   474→            display_entries.append(e)\n   475→\n   476→    op_pref = _op_preference_map_current(entries)\n   477→    for text, path_key in _grouped_lines(display_entries, op_preference_map=op_pref):\n   478→        if path_key is not None:\n   479→            if path_key in removed:\n   480→                print(_colorize(text, _RED_BG))\n   481→                continue\n   482→            if path_key in added_keys:\n   483→                print(_colorize(text, _GREEN_BG))\n   484→                continue\n   485→        print(text)\n   486→\n   487→    # ── Footer ──────────────────────────────────────────────────── #\n   488→    print(_DIVIDER)\n   489→    print()\n   490→\n   491→    # ── Update snapshot ───────────────────────────────────────────── #\n   492→    _prev_snap = curr_snap\n   493→"}]},"parent_tool_use_id":null,"session_id":"257de878-fc9d-48ea-9f06-060eecd20b6c","uuid":"228fd0fe-02da-4052-a2b4-e74389bf7110","timestamp":"2026-03-24T09:33:16.648Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\Sir_K\\Desktop\\SOAR-ARC-test\\agent\\wm_logger.py","content":"\"\"\"\nwm_logger — Utility for printing WorkingMemory state in SOAR triplet format.\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nSOAR Working Memory Element (WME) format:\n    (identifier ^attribute value)\n\n    identifier : S1=root, S2/S3...=substates, I1/I2...=auto-generated child nodes\n    attribute  : field name\n    value      : primitive or child node identifier\n\ndiff colors (git diff style):\n    Green background + white text  →  WME added/changed compared to previous call\n    Red background + white text    →  WME removed compared to previous call\n    Normal                         →  Unchanged WME\n\n    Comparison is based on path_key (e.g., S1/relations/pair_0/type) rather than\n    auto-id (I1, I2...), so the semantic diff is computed accurately even if\n    identifiers change.\n\nUsage:\n    from agent.wm_logger import print_wm_triplets, reset_wm_snapshot\n    reset_wm_snapshot()                                 # Reset snapshot before task starts\n    print_wm_triplets(wm, label=\"After: elaborate\", step=3)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\"\"\"\n\nfrom __future__ import annotations\n\nimport itertools\nfrom dataclasses import dataclass\nfrom typing import Any\n\n\n# ── ANSI colors ────────────────────────────────────────────────────────── #\n\n_GREEN_BG = \"\\033[42;37m\"   # Green background, white text (added/changed)\n_RED_BG   = \"\\033[41;37m\"   # Red background, white text (removed)\n_RESET    = \"\\033[0m\"\n\n# Output width: pad color background to match divider width.\n_LINE_WIDTH = 62\n\n\n# ── Output constants ────────────────────────────────────────────────────── #\n\n_L1      = \"  \"       # depth 0 (root identifier S1/S2/WM) line indentation\n_L2      = \"    \"     # depth 1 (direct children: I1, etc.) indentation\n_L3      = \"      \"   # depth 2+ (grandchildren and below: I2, I3, etc.) indentation\n_DIVIDER = \"═\" * _LINE_WIDTH\n\n# S1/WM family identifier detection\n_ROOT_IDS = {\"S1\", \"S2\", \"S3\", \"S4\", \"WM\"}\n\n# Maximum display length for string values\n_MAX_STR_LEN = 80\n\n\n# ── WME data model ──────────────────────────────────────────────────── #\n\n@dataclass(frozen=True)\nclass _WME:\n    \"\"\"\n    A single Working Memory Element.\n\n    identifier : display node ID (S1, I1, ...)\n    attribute  : field name\n    value      : formatted value string\n    path_key   : canonical path for diff comparison (e.g., \"S1/relations/pair_0/type\")\n    is_root    : True if identifier is S1/WM family → L1 indentation\n    \"\"\"\n    identifier: str\n    attribute:  str\n    value:      str\n    path_key:   str\n    is_root:    bool\n    depth:      int   # Depth relative to S1 (0=S1, 1=child, 2=grandchild...)\n\n\n# ── Module-level diff state ──────────────────────────────────────────── #\n\n# {path_key: _WME} — Snapshot from the previous print_wm_triplets call\n_prev_snap: dict[str, _WME] = {}\n\n\ndef reset_wm_snapshot(wm=None) -> None:\n    \"\"\"\n    Resets the diff snapshot.\n\n    wm=None  : Reset to empty snapshot → next print_wm_triplets call shows everything in green\n    wm=<WM>  : Pre-fill snapshot with current WM state\n               → next print_wm_triplets call shows no changes, all in normal color\n\n    Recommended usage pattern:\n        # run_task.py — Start diff from initial WM state\n        build_wm_from_task(task, wm)\n        reset_wm_snapshot(wm)              # Set initial state as baseline\n        print_wm_triplets(wm, \"Initial WM state\")  # Print current state without colors\n\n        # active_agent.solve() — Prevent previous state from mixing between tasks\n        reset_wm_snapshot()                # Reset to empty state before task starts\n    \"\"\"\n    global _prev_snap\n    if wm is not None:\n        entries    = _wm_as_entries(wm)\n        _prev_snap = {e.path_key: e for e in entries}\n    else:\n        _prev_snap = {}\n\n\n# ── Value formatting ────────────────────────────────────────────────────── #\n\ndef _fmt(value: Any) -> str:\n    \"\"\"Converts a primitive value to a SOAR display string.\"\"\"\n    if value is None:\n        return \"nil\"\n    if isinstance(value, bool):\n        return \"true\" if value else \"false\"\n    if isinstance(value, str):\n        # Preference symbols etc. — single characters used bare in Soar\n        if len(value) == 1 and value in \"+-!~<>\":\n            return value\n        # SOAR style: symbols without spaces/special chars are kept as-is; others are quoted.\n        s = value if len(value) <= _MAX_STR_LEN else value[:_MAX_STR_LEN] + \"…\"\n        if s and all(ch.isalnum() or ch in (\"_\", \"-\", \".\") for ch in s):\n            return s\n        return f'\"{s}\"'\n    return str(value)\n\n\ndef _is_grid(lst: list) -> bool:\n    \"\"\"Determines whether the list looks like a 2D grid (array of integers or array of integer arrays).\"\"\"\n    return bool(lst) and isinstance(lst[0], (int, list, tuple))\n\n\n# ── WME collection (recursive) ──────────────────────────────────────── #\n\ndef _collect(\n    identifier:  str,\n    attribute:   str,\n    value:       Any,\n    id_gen,\n    out:         list[_WME],\n    path_prefix: str,\n    depth:       int,\n    list_index:  int | None = None,\n) -> None:\n    \"\"\"\n    Recursively expands a single (identifier, attribute, value) and appends _WME entries to out.\n\n    path_key generation rules:\n        Normal dict field: \"{path_prefix}/{attribute}\"\n        List item: \"{path_prefix}/{attribute}[{list_index}]\"\n    \"\"\"\n    if list_index is not None:\n        path_key = f\"{path_prefix}/{attribute}[{list_index}]\"\n    else:\n        path_key = f\"{path_prefix}/{attribute}\"\n\n    is_root = identifier in _ROOT_IDS\n\n    if isinstance(value, dict):\n        if not value:\n            # Empty dict also gets a separate identifier (Ix) with just the link.\n            # e.g., (I1 ^output-link I3) where I3 has no attributes yet.\n            child_id = next(id_gen)\n            out.append(_WME(identifier, attribute, child_id, path_key, is_root, depth))\n            return\n        child_id = next(id_gen)\n        out.append(_WME(identifier, attribute, child_id, path_key, is_root, depth))\n        for child_attr, child_val in value.items():\n            _collect(child_id, child_attr, child_val, id_gen, out, path_key, depth + 1)\n\n    elif isinstance(value, list):\n        if not value:\n            out.append(_WME(identifier, attribute, \"[]\", path_key, is_root, depth))\n            return\n        if _is_grid(value):\n            first = value[0]\n            ncols = len(first) if isinstance(first, (list, tuple)) else 1\n            out.append(_WME(\n                identifier, attribute, f\"<grid {len(value)}x{ncols}>\",\n                path_key, is_root, depth,\n            ))\n            return\n        # Normal list: recursively collect each item with index-based path_key\n        for idx, item in enumerate(value):\n            _collect(identifier, attribute, item, id_gen, out, path_prefix, depth, list_index=idx)\n\n    else:\n        out.append(_WME(identifier, attribute, _fmt(value), path_key, is_root, depth))\n\n\n# ── WM → WME list conversion ───────────────────────────────────────── #\n\ndef _wm_as_entries(wm) -> list[_WME]:\n    \"\"\"Converts the entire WorkingMemory to a list of _WME entries.\"\"\"\n    id_gen = (f\"I{n}\" for n in itertools.count(1))\n    out: list[_WME] = []\n\n    # S1 (root state)\n    root = \"S1\"\n    for attr, val in wm.s1.items():\n        # Operator nodes and similar separate identifier nodes are treated as\n        # independent identifiers rather than S1 attributes (e.g., O1).\n        if isinstance(val, dict) and attr[:1].isalpha() and attr[0].isupper():\n            for child_attr, child_val in val.items():\n                _collect(attr, child_attr, child_val, id_gen, out, attr, depth=0)\n            continue\n        _collect(root, attr, val, id_gen, out, root, depth=0)\n\n    # task is an external reference outside WM (Python level), so only a summary is printed.\n    # In SOAR style, environment input should go under io/input-link,\n    # so this value is kept for debug purposes only.\n    if getattr(wm, \"task\", None) is not None:\n        summary = getattr(wm.task, \"task_hex\", repr(wm.task))\n        out.append(_WME(root, \"task_ref\", f\"<task {summary}>\", f\"{root}/task_ref\", True, 0))\n\n    # S2, S3, ... (substate stack) — Each substate is represented only as an independent Sx identifier.\n    for depth, substate in enumerate(wm._substate_stack, start=2):\n        sub = f\"S{depth}\"\n        for attr, val in substate.items():\n            # Same as S1: O* operator nodes are expanded as independent identifiers.\n            if isinstance(val, dict) and attr[:1].isalpha() and attr[0].isupper():\n                for child_attr, child_val in val.items():\n                    _collect(attr, child_attr, child_val, id_gen, out, attr, depth=0)\n                continue\n            _collect(sub, attr, val, id_gen, out, sub, depth=0)\n\n    return out\n\n\n# ── Line formatting + colors ─────────────────────────────────────────── #\n\ndef _indent_for_depth(depth: int) -> str:\n    \"\"\"Returns the indentation string for the given depth value.\"\"\"\n    if depth <= 0:\n        return _L1\n    if depth == 1:\n        return _L2\n    return _L3\n\n\ndef _render(entry: _WME) -> str:\n    \"\"\"Converts a single _WME to a string in `  (S1 ^attr val)` format.\"\"\"\n    indent = _L1 if entry.is_root else _L2\n    return f\"{indent}({entry.identifier} ^{entry.attribute} {entry.value})\"\n\n\ndef _op_preference_map_current(current_entries: list[_WME]) -> dict[str, str]:\n    \"\"\"Returns op-preference of O* nodes that exist only in the current WM (must not mix with removed WME list).\"\"\"\n    d: dict[str, str] = {}\n    for e in current_entries:\n        if (\n            len(e.identifier) >= 2\n            and e.identifier[0] == \"O\"\n            and e.identifier[1:].isdigit()\n            and e.attribute == \"op-preference\"\n        ):\n            d[e.identifier] = e.value.strip()\n    return d\n\n\ndef _grouped_lines(\n    entries: list[_WME],\n    *,\n    op_preference_map: dict[str, str],\n) -> list[tuple[str, str | None]]:\n    \"\"\"\n    Groups WMEs with the same identifier into a single block, similar to SOAR debug output style.\n\n    op_preference_map: Computed from current WM only (prevents contamination even if display_entries contains removed items).\n    \"\"\"\n    if not entries:\n        return []\n\n    op_preference = op_preference_map\n\n    # Collect all WMEs by identifier (regardless of contiguity).\n    by_id: dict[str, list[_WME]] = {}\n    order: list[str] = []\n    for e in entries:\n        if e.identifier not in by_id:\n            by_id[e.identifier] = []\n            order.append(e.identifier)\n        by_id[e.identifier].append(e)\n\n    # In O* blocks, ^op-preference is merged into the S1 line, so omit it as a separate line\n    for oid, group in list(by_id.items()):\n        if oid.startswith(\"O\") and len(oid) >= 2 and oid[1:].isdigit():\n            by_id[oid] = [w for w in group if w.attribute != \"op-preference\"]\n\n    # Output order: S1, operators (O*), S2/S3/S4, WM, then remaining identifiers.\n    def id_priority(ident: str) -> tuple[int, str]:\n        if ident == \"S1\":\n            return (0, ident)\n        if ident.startswith(\"O\"):\n            return (1, ident)\n        if ident in {\"S2\", \"S3\", \"S4\"}:\n            return (2, ident)\n        if ident == \"WM\":\n            return (3, ident)\n        return (4, ident)\n\n    sorted_ids = sorted(order, key=id_priority)\n\n    # S1: proposal ^operator O* + followed by official ^operator O* (operator-application)\n    _S1_ORDER = (\n        \"type\",\n        \"superstate\",\n        \"io\",\n        \"smem\",\n        \"epmem\",\n        \"current-task\",\n        \"operator\",\n        \"operator-application\",\n    )\n\n    # S2, S3, ... (substate) — smem → epmem fixed order\n    _SUBSTATE_ORDER = (\n        \"type\",\n        \"superstate\",\n        \"impasse\",\n        \"choices\",\n        \"attribute\",\n        \"quiescence\",\n        \"operator\",\n        \"operator-application\",\n        \"smem\",\n        \"epmem\",\n        \"item\",\n        \"item-count\",\n        \"non-numeric\",\n        \"non-numeric-count\",\n    )\n\n    def _s1_sort_key(e: _WME) -> tuple[int, str]:\n        try:\n            return (_S1_ORDER.index(e.attribute), e.attribute)\n        except ValueError:\n            return (len(_S1_ORDER), e.attribute)\n\n    def _substate_sort_key(e: _WME) -> tuple[int, str]:\n        try:\n            return (_SUBSTATE_ORDER.index(e.attribute), e.path_key)\n        except ValueError:\n            return (len(_SUBSTATE_ORDER), e.path_key)\n\n    def _is_substate_ident(ident: str) -> bool:\n        return (\n            len(ident) >= 2\n            and ident[0] == \"S\"\n            and ident != \"S1\"\n            and ident[1:].isdigit()\n        )\n\n    def _s1_show_attr(attr: str) -> str:\n        return \"operator\" if attr == \"operator-application\" else attr\n\n    lines: list[tuple[str, str | None]] = []\n\n    for ident in sorted_ids:\n        group = by_id[ident]\n        if not group:\n            continue\n        if ident == \"S1\":\n            group = sorted(group, key=_s1_sort_key)\n        elif _is_substate_ident(ident):\n            group = sorted(group, key=_substate_sort_key)\n\n        first = group[0]\n        base_indent = _indent_for_depth(first.depth)\n        cont_indent = base_indent + (\" \" * (len(ident) + 2))\n\n        def _proposal_suffix(e: _WME) -> str:\n            if ident != \"S1\" or e.attribute != \"operator\":\n                return \"\"\n            sym = op_preference.get(e.value)\n            return f\" {sym}\" if sym else \"\"\n\n        if ident == \"S1\":\n            if len(group) == 1:\n                e0 = group[0]\n                a = _s1_show_attr(e0.attribute)\n                text = f\"{base_indent}({ident} ^{a} {e0.value}{_proposal_suffix(e0)})\"\n                lines.append((text, e0.path_key))\n            else:\n                e0 = group[0]\n                a0 = _s1_show_attr(e0.attribute)\n                first_text = f\"{base_indent}({ident} ^{a0} {e0.value}{_proposal_suffix(e0)}\"\n                lines.append((first_text, e0.path_key))\n                for k in range(1, len(group) - 1):\n                    e = group[k]\n                    a = _s1_show_attr(e.attribute)\n                    mid = f\"{cont_indent}^{a} {e.value}{_proposal_suffix(e)}\"\n                    lines.append((mid, e.path_key))\n                el = group[-1]\n                al = _s1_show_attr(el.attribute)\n                last_text = f\"{cont_indent}^{al} {el.value}{_proposal_suffix(el)})\"\n                lines.append((last_text, el.path_key))\n            continue\n\n        if len(group) == 1:\n            text = f\"{base_indent}({ident} ^{first.attribute} {first.value})\"\n            lines.append((text, first.path_key))\n        else:\n            first_text = f\"{base_indent}({ident} ^{first.attribute} {first.value}\"\n            lines.append((first_text, first.path_key))\n            for k in range(1, len(group) - 1):\n                e = group[k]\n                lines.append((f\"{cont_indent}^{e.attribute} {e.value}\", e.path_key))\n            last = group[-1]\n            lines.append((f\"{cont_indent}^{last.attribute} {last.value})\", last.path_key))\n\n    return lines\n\ndef _render_removed(entry: _WME) -> str:\n    \"\"\"\n    Displays a removed WME with path_key-based identifier.\n\n    Uses entry.identifier / attribute / depth information to\n    maintain the same indentation as normal output.\n    \"\"\"\n    base_indent = _indent_for_depth(entry.depth)\n    return f\"{base_indent}({entry.identifier} ^{entry.attribute} {entry.value})\"\n\n\ndef _colorize(text: str, ansi: str) -> str:\n    \"\"\"Pads text to _LINE_WIDTH and wraps it with ANSI background color.\"\"\"\n    padded = text.ljust(_LINE_WIDTH)\n    return f\"{ansi}{padded}{_RESET}\"\n\n\n# ── Public output function ───────────────────────────────────────────── #\n\ndef print_wm_triplets(wm, label: str = \"\", step: int = 0) -> None:\n    \"\"\"\n    Prints the entire WorkingMemory state in SOAR triplet format + git diff style colors.\n\n    Output rules:\n        Green background  → WME newly added or value changed compared to previous snapshot\n        Red background    → WME that existed in previous snapshot but is now absent (removed section)\n        Normal text       → Unchanged WME\n\n    On the first call, _prev_snap is empty so all items are shown in green.\n    When the task changes, reset_wm_snapshot() must be called to reset the snapshot.\n    \"\"\"\n    global _prev_snap\n\n    entries   = _wm_as_entries(wm)\n    curr_snap = {e.path_key: e for e in entries}\n\n    # ── Diff computation ─────────────────────────────────────────── #\n    added_keys = {\n        k for k, e in curr_snap.items()\n        if k not in _prev_snap or _prev_snap[k].value != e.value\n    }\n    removed = {\n        k: e for k, e in _prev_snap.items()\n        if k not in curr_snap\n    }\n\n    # ── Header ──────────────────────────────────────────────────── #\n    header = f\"[Step {step}] {label}\" if label else f\"[Step {step}]\"\n    print(_DIVIDER)\n    print(f\"{_L1}{header}\")\n    print(_DIVIDER)\n\n    # ── Print current state + removed items together (grouped by identifier) ── #\n    # Display entries: current entries + removed entries (current takes priority for duplicate path_keys)\n    display_entries: list[_WME] = list(entries)\n    for k, e in removed.items():\n        if k not in curr_snap:\n            display_entries.append(e)\n\n    op_pref = _op_preference_map_current(entries)\n    for text, path_key in _grouped_lines(display_entries, op_preference_map=op_pref):\n        if path_key is not None:\n            if path_key in removed:\n                print(_colorize(text, _RED_BG))\n                continue\n            if path_key in added_keys:\n                print(_colorize(text, _GREEN_BG))\n                continue\n        print(text)\n\n    # ── Footer ──────────────────────────────────────────────────── #\n    print(_DIVIDER)\n    print()\n\n    # ── Update snapshot ───────────────────────────────────────────── #\n    _prev_snap = curr_snap\n","numLines":493,"startLine":1,"totalLines":493}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Y2g2ZgR5nbjFQKQqDE4xUr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013X7e9bL8G3vAQwzYN8eeQc","name":"Read","input":{"file_path":"C:\\Users\\Sir_K\\Desktop\\SOAR-ARC-test\\agent\\wm.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":12150,"cache_read_input_tokens":28085,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":12150},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"257de878-fc9d-48ea-9f06-060eecd20b6c","uuid":"c51d0a2b-22d5-4881-8a1c-d268fe1b6315"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013X7e9bL8G3vAQwzYN8eeQc","type":"tool_result","content":"     1→\"\"\"\n     2→WorkingMemory — SOAR Working Memory.\n     3→\n     4→One of SOAR's four components.\n     5→  WM              ← The entire current problem state (this file)\n     6→  Production Memory ← elaboration_rules.py + rules.py\n     7→  Operators         ← operators.py + active_operators.py\n     8→  Cycle             ← cycle.py\n     9→\n    10→━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    11→[SOAR MANDATORY] WM must exist.\n    12→                 All content is represented as (identifier, attribute, value) triplets.\n    13→                 Has an S1 (root) / S2 (substate) hierarchical structure.\n    14→\n    15→Dedicated dict slots such as comparison queue, relations, elaborated and WM helpers\n    16→that fill them are not provided.\n    17→Knowledge is extended only by triplets/operators adding directly.\n    18→━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    19→\n    20→────────────────────────────────────────────────────────────────\n    21→[Design note — Soar WM vs this class's fields]  (Reference for future cleanup)\n    22→\n    23→Conceptually, Soar WM is only a **set of WMEs**, and wme_records (+ timetag) correspond to that data.\n    24→In the Python implementation, **manager-role** fields are attached to operate on the set.\n    25→\n    26→• Recommended to keep (nearly essential for engine/cycle)\n    27→  - _timetag_seq : Issues a unique, monotonically increasing timetag per WME (Soar 4 components)\n    28→  - _substate_stack : Substate stack on impasse — rule evaluation order (superstate → most recent substate)\n    29→  - wme_timetags : Slot-level latest timetag index, since iterating the set alone can be slow\n    30→\n    31→• Can be considered for removal/replacement during refactoring (convenience/cache)\n    32→  - s1 : S1 is merely an identifier in the WME graph, but keeping it as a \"root pointer\" simplifies implementation.\n    33→         Can be replaced with entry point search if using a pure graph.\n    34→  - task : Cache outside WM. In pure Soar, could be eliminated by accessing only through graph traversal like input-link.\n    35→\n    36→This class serves dual roles: \"WM data set\" + \"managing that set and driving the cycle\".\n    37→────────────────────────────────────────────────────────────────\n    38→\"\"\"\n    39→\n    40→from __future__ import annotations\n    41→\n    42→import copy\n    43→import itertools\n    44→from typing import Any\n    45→\n    46→MAX_SUBSTATE_DEPTH: int = 2\n    47→\n    48→# Top-level slots to protect by default in SOAR style\n    49→_RESERVED_TOP_KEYS = frozenset({\"io\"})\n    50→\n    51→\n    52→def _is_operator_id(key: str) -> bool:\n    53→    return bool(key) and key[0] == \"O\" and key[1:].isdigit()\n    54→\n    55→\n    56→class _TrackedS1(dict):\n    57→    \"\"\"\n    58→    Records timetag when a top-level key is assigned to S1.\n    59→    When an operator node dict (O1/O2...) is inserted as a whole, records each sub-key separately.\n    60→    \"\"\"\n    61→\n    62→    __slots__ = (\"_wm\",)\n    63→\n    64→    def __init__(self, wm: \"WorkingMemory\", *args, **kwargs):\n    65→        super().__init__(*args, **kwargs)\n    66→        self._wm = wm\n    67→\n    68→    def __setitem__(self, key: str, value: Any) -> None:\n    69→        super().__setitem__(key, value)\n    70→        self._wm._record_wme(\"S1\", key, value)\n    71→        if isinstance(value, dict) and _is_operator_id(key):\n    72→            for sk, sv in value.items():\n    73→                self._wm._record_wme(key, sk, sv)\n    74→\n    75→\n    76→class WorkingMemory:\n    77→    \"\"\"\n    78→    [SOAR MANDATORY] WM class must exist.\n    79→                     S1/S2 hierarchy and triplet access interface (get/set) are SOAR protocol.\n    80→    \"\"\"\n    81→\n    82→    def __init__(self):\n    83→        # Soar timetag: integer that increases in WME creation order (not printed in logger)\n    84→        self._timetag_seq = itertools.count(1)\n    85→        # Full history (for debugger/print(wm.wme_records))\n    86→        self.wme_records: list[dict[str, Any]] = []\n    87→        # (identifier, attribute) -> latest timetag\n    88→        self.wme_timetags: dict[str, int] = {}\n    89→\n    90→        self.s1 = _TrackedS1(self)\n    91→        self.s1[\"type\"] = \"state\"\n    92→        self.s1[\"superstate\"] = None\n    93→        self.s1[\"io\"] = {\n    94→            \"input-link\": {},\n    95→            \"output-link\": {},\n    96→        }\n    97→        # States can be connected to semantic memory/episodic memory modules.\n    98→        # The detailed protocol is not yet defined, so only id is kept as placeholder.\n    99→        self.s1[\"smem\"] = {\"id\": \"SM1\"}\n   100→        self.s1[\"epmem\"] = {\"id\": \"E1\"}\n   101→\n   102→        self.task = None\n   103→        self._substate_stack: list = []\n   104→\n   105→    def _record_wme(self, identifier: str, attribute: str, value: Any) -> int:\n   106→        \"\"\"Internal: assigns a timetag to a triplet (output is not done by wm_logger).\"\"\"\n   107→        tt = next(self._timetag_seq)\n   108→        key = f\"{identifier}^{attribute}\"\n   109→        self.wme_timetags[key] = tt\n   110→        self.wme_records.append(\n   111→            {\n   112→                \"timetag\": tt,\n   113→                \"identifier\": identifier,\n   114→                \"attribute\": attribute,\n   115→                \"value\": value,\n   116→            }\n   117→        )\n   118→        return tt\n   119→\n   120→    def register_wme(self, identifier: str, attribute: str, value: Any) -> int:\n   121→        \"\"\"\n   122→        Used to manually record a timetag for paths other than S1 (e.g., input-link.task).\n   123→        \"\"\"\n   124→        return self._record_wme(identifier, attribute, value)\n   125→\n   126→    @property\n   127→    def active(self) -> dict:\n   128→        return self._substate_stack[-1] if self._substate_stack else self.s1\n   129→\n   130→    @property\n   131→    def depth(self) -> int:\n   132→        return len(self._substate_stack)\n   133→\n   134→    def get(self, key: str):\n   135→        return self.active.get(key)\n   136→\n   137→    def set(self, key: str, value):\n   138→        if key in _RESERVED_TOP_KEYS:\n   139→            raise ValueError(\n   140→                f\"WorkingMemory.set: Do not directly set '{key}'.\"\n   141→            )\n   142→        self.active[key] = value\n   143→\n   144→    def get_list(self, key: str) -> list:\n   145→        v = self.active.get(key)\n   146→        return v if isinstance(v, list) else []\n   147→\n   148→    def push_substate(\n   149→        self,\n   150→        impasse_type: str,\n   151→        attribute: str,\n   152→        *,\n   153→        items: list[str] | None = None,\n   154→        non_numeric_items: list[str] | None = None,\n   155→    ) -> bool:\n   156→        \"\"\"\n   157→        Creates a substate for impasse resolution.\n   158→\n   159→        impasse_type:\n   160→            - \"tie\"\n   161→            - \"no-change\"\n   162→            - \"conflict\"\n   163→            - \"constraint-failure\"\n   164→\n   165→        Follows a simplified Soar structure:\n   166→            (Sx ^type state\n   167→                ^impasse <type>\n   168→                ^choices <...>\n   169→                ^attribute <attribute>\n   170→                ^superstate Sy\n   171→                ^item ...              ; optional\n   172→                ^item-count N          ; optional\n   173→                ^non-numeric ...       ; optional for tie\n   174→                ^non-numeric-count M\n   175→                ^quiescence t\n   176→                ^reward-link Rk\n   177→                ^smem SMk\n   178→                ^epmem Ek\n   179→                ^svs SVk)\n   180→        \"\"\"\n   181→        if len(self._substate_stack) >= MAX_SUBSTATE_DEPTH:\n   182→            return False\n   183→\n   184→        depth = len(self._substate_stack) + 2  # Starts from S2\n   185→        super_id = \"S1\" if depth == 2 else f\"S{depth-1}\"\n   186→\n   187→        # Default ^choices value by impasse type\n   188→        if impasse_type == \"tie\":\n   189→            choices = \"multiple\"\n   190→        elif impasse_type == \"conflict\":\n   191→            choices = \"multiple\"\n   192→        elif impasse_type == \"constraint-failure\":\n   193→            choices = \"constraint-failure\"\n   194→        else:\n   195→            # Default: includes no-change\n   196→            choices = \"none\"\n   197→\n   198→        sub: dict[str, Any] = {\n   199→            \"type\": \"state\",\n   200→            \"superstate\": super_id,\n   201→            \"impasse\": impasse_type,\n   202→            \"choices\": choices,\n   203→            \"attribute\": attribute,\n   204→            \"quiescence\": True,\n   205→            # Module links: keep only smem/epmem, omit reward-link and svs.\n   206→            \"smem\": {\"id\": f\"SM{depth}\"},\n   207→            \"epmem\": {\"id\": f\"E{depth}\"},\n   208→        }\n   209→\n   210→        if items:\n   211→            sub[\"item\"] = list(items)\n   212→            sub[\"item-count\"] = len(items)\n   213→\n   214→        if non_numeric_items:\n   215→            sub[\"non-numeric\"] = list(non_numeric_items)\n   216→            sub[\"non-numeric-count\"] = len(non_numeric_items)\n   217→\n   218→        self._substate_stack.append(sub)\n   219→        return True\n   220→\n   221→    def pop_substate(self, result: Any = None) -> None:\n   222→        if not self._substate_stack:\n   223→            return\n   224→        self._substate_stack.pop()\n   225→"}]},"parent_tool_use_id":null,"session_id":"257de878-fc9d-48ea-9f06-060eecd20b6c","uuid":"4a07245e-4fe0-4616-958b-786788acba94","timestamp":"2026-03-24T09:33:16.657Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\Sir_K\\Desktop\\SOAR-ARC-test\\agent\\wm.py","content":"\"\"\"\nWorkingMemory — SOAR Working Memory.\n\nOne of SOAR's four components.\n  WM              ← The entire current problem state (this file)\n  Production Memory ← elaboration_rules.py + rules.py\n  Operators         ← operators.py + active_operators.py\n  Cycle             ← cycle.py\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n[SOAR MANDATORY] WM must exist.\n                 All content is represented as (identifier, attribute, value) triplets.\n                 Has an S1 (root) / S2 (substate) hierarchical structure.\n\nDedicated dict slots such as comparison queue, relations, elaborated and WM helpers\nthat fill them are not provided.\nKnowledge is extended only by triplets/operators adding directly.\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n────────────────────────────────────────────────────────────────\n[Design note — Soar WM vs this class's fields]  (Reference for future cleanup)\n\nConceptually, Soar WM is only a **set of WMEs**, and wme_records (+ timetag) correspond to that data.\nIn the Python implementation, **manager-role** fields are attached to operate on the set.\n\n• Recommended to keep (nearly essential for engine/cycle)\n  - _timetag_seq : Issues a unique, monotonically increasing timetag per WME (Soar 4 components)\n  - _substate_stack : Substate stack on impasse — rule evaluation order (superstate → most recent substate)\n  - wme_timetags : Slot-level latest timetag index, since iterating the set alone can be slow\n\n• Can be considered for removal/replacement during refactoring (convenience/cache)\n  - s1 : S1 is merely an identifier in the WME graph, but keeping it as a \"root pointer\" simplifies implementation.\n         Can be replaced with entry point search if using a pure graph.\n  - task : Cache outside WM. In pure Soar, could be eliminated by accessing only through graph traversal like input-link.\n\nThis class serves dual roles: \"WM data set\" + \"managing that set and driving the cycle\".\n────────────────────────────────────────────────────────────────\n\"\"\"\n\nfrom __future__ import annotations\n\nimport copy\nimport itertools\nfrom typing import Any\n\nMAX_SUBSTATE_DEPTH: int = 2\n\n# Top-level slots to protect by default in SOAR style\n_RESERVED_TOP_KEYS = frozenset({\"io\"})\n\n\ndef _is_operator_id(key: str) -> bool:\n    return bool(key) and key[0] == \"O\" and key[1:].isdigit()\n\n\nclass _TrackedS1(dict):\n    \"\"\"\n    Records timetag when a top-level key is assigned to S1.\n    When an operator node dict (O1/O2...) is inserted as a whole, records each sub-key separately.\n    \"\"\"\n\n    __slots__ = (\"_wm\",)\n\n    def __init__(self, wm: \"WorkingMemory\", *args, **kwargs):\n        super().__init__(*args, **kwargs)\n        self._wm = wm\n\n    def __setitem__(self, key: str, value: Any) -> None:\n        super().__setitem__(key, value)\n        self._wm._record_wme(\"S1\", key, value)\n        if isinstance(value, dict) and _is_operator_id(key):\n            for sk, sv in value.items():\n                self._wm._record_wme(key, sk, sv)\n\n\nclass WorkingMemory:\n    \"\"\"\n    [SOAR MANDATORY] WM class must exist.\n                     S1/S2 hierarchy and triplet access interface (get/set) are SOAR protocol.\n    \"\"\"\n\n    def __init__(self):\n        # Soar timetag: integer that increases in WME creation order (not printed in logger)\n        self._timetag_seq = itertools.count(1)\n        # Full history (for debugger/print(wm.wme_records))\n        self.wme_records: list[dict[str, Any]] = []\n        # (identifier, attribute) -> latest timetag\n        self.wme_timetags: dict[str, int] = {}\n\n        self.s1 = _TrackedS1(self)\n        self.s1[\"type\"] = \"state\"\n        self.s1[\"superstate\"] = None\n        self.s1[\"io\"] = {\n            \"input-link\": {},\n            \"output-link\": {},\n        }\n        # States can be connected to semantic memory/episodic memory modules.\n        # The detailed protocol is not yet defined, so only id is kept as placeholder.\n        self.s1[\"smem\"] = {\"id\": \"SM1\"}\n        self.s1[\"epmem\"] = {\"id\": \"E1\"}\n\n        self.task = None\n        self._substate_stack: list = []\n\n    def _record_wme(self, identifier: str, attribute: str, value: Any) -> int:\n        \"\"\"Internal: assigns a timetag to a triplet (output is not done by wm_logger).\"\"\"\n        tt = next(self._timetag_seq)\n        key = f\"{identifier}^{attribute}\"\n        self.wme_timetags[key] = tt\n        self.wme_records.append(\n            {\n                \"timetag\": tt,\n                \"identifier\": identifier,\n                \"attribute\": attribute,\n                \"value\": value,\n            }\n        )\n        return tt\n\n    def register_wme(self, identifier: str, attribute: str, value: Any) -> int:\n        \"\"\"\n        Used to manually record a timetag for paths other than S1 (e.g., input-link.task).\n        \"\"\"\n        return self._record_wme(identifier, attribute, value)\n\n    @property\n    def active(self) -> dict:\n        return self._substate_stack[-1] if self._substate_stack else self.s1\n\n    @property\n    def depth(self) -> int:\n        return len(self._substate_stack)\n\n    def get(self, key: str):\n        return self.active.get(key)\n\n    def set(self, key: str, value):\n        if key in _RESERVED_TOP_KEYS:\n            raise ValueError(\n                f\"WorkingMemory.set: Do not directly set '{key}'.\"\n            )\n        self.active[key] = value\n\n    def get_list(self, key: str) -> list:\n        v = self.active.get(key)\n        return v if isinstance(v, list) else []\n\n    def push_substate(\n        self,\n        impasse_type: str,\n        attribute: str,\n        *,\n        items: list[str] | None = None,\n        non_numeric_items: list[str] | None = None,\n    ) -> bool:\n        \"\"\"\n        Creates a substate for impasse resolution.\n\n        impasse_type:\n            - \"tie\"\n            - \"no-change\"\n            - \"conflict\"\n            - \"constraint-failure\"\n\n        Follows a simplified Soar structure:\n            (Sx ^type state\n                ^impasse <type>\n                ^choices <...>\n                ^attribute <attribute>\n                ^superstate Sy\n                ^item ...              ; optional\n                ^item-count N          ; optional\n                ^non-numeric ...       ; optional for tie\n                ^non-numeric-count M\n                ^quiescence t\n                ^reward-link Rk\n                ^smem SMk\n                ^epmem Ek\n                ^svs SVk)\n        \"\"\"\n        if len(self._substate_stack) >= MAX_SUBSTATE_DEPTH:\n            return False\n\n        depth = len(self._substate_stack) + 2  # Starts from S2\n        super_id = \"S1\" if depth == 2 else f\"S{depth-1}\"\n\n        # Default ^choices value by impasse type\n        if impasse_type == \"tie\":\n            choices = \"multiple\"\n        elif impasse_type == \"conflict\":\n            choices = \"multiple\"\n        elif impasse_type == \"constraint-failure\":\n            choices = \"constraint-failure\"\n        else:\n            # Default: includes no-change\n            choices = \"none\"\n\n        sub: dict[str, Any] = {\n            \"type\": \"state\",\n            \"superstate\": super_id,\n            \"impasse\": impasse_type,\n            \"choices\": choices,\n            \"attribute\": attribute,\n            \"quiescence\": True,\n            # Module links: keep only smem/epmem, omit reward-link and svs.\n            \"smem\": {\"id\": f\"SM{depth}\"},\n            \"epmem\": {\"id\": f\"E{depth}\"},\n        }\n\n        if items:\n            sub[\"item\"] = list(items)\n            sub[\"item-count\"] = len(items)\n\n        if non_numeric_items:\n            sub[\"non-numeric\"] = list(non_numeric_items)\n            sub[\"non-numeric-count\"] = len(non_numeric_items)\n\n        self._substate_stack.append(sub)\n        return True\n\n    def pop_substate(self, result: Any = None) -> None:\n        if not self._substate_stack:\n            return\n        self._substate_stack.pop()\n","numLines":225,"startLine":1,"totalLines":225}}}
