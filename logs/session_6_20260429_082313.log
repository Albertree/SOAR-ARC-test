_in)\n1342\t            w = len(raw_in[0]) if raw_in else 0\n1343\t            if h == 0 or w == 0:\n1344\t                return None\n1345\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n1346\t                return None\n1347\t\n1348\t            counts = {}\n1349\t            for row in raw_in:\n1350\t                for c in row:\n1351\t                    counts[c] = counts.get(c, 0) + 1\n1352\t            bg_local = max(counts, key=counts.get)\n1353\t            in_colors = set(counts.keys())\n1354\t            fg_set = in_colors - {bg_local}\n1355\t            if len(fg_set) != 1:\n1356\t                return None\n1357\t            fg_local = next(iter(fg_set))\n1358\t\n1359\t            if bg_color is None:\n1360\t                bg_color, fg_color = bg_local, fg_local\n1361\t            elif (bg_color, fg_color) != (bg_local, fg_local):\n1362\t                return None\n1363\t\n1364\t            comps = self._find_components(raw_in, fg_local)\n1365\t            if not comps:\n1366\t                return None\n1367\t            for comp in comps:\n1368\t                out_colors = {raw_out[r][c] for (r, c) in comp}\n1369\t                if len(out_colors) != 1:\n1370\t                    return None\n1371\t                out_c = next(iter(out_colors))\n1372\t                size = len(comp)\n1373\t                if size in size_to_color and size_to_color[size] != out_c:\n1374\t                    return None\n1375\t                size_to_color[size] = out_c\n1376\t\n1377\t            # Non-foreground cells must be unchanged\n1378\t            for r in range(h):\n1379\t                for c in range(w):\n1380\t                    if raw_in[r][c] != fg_local and raw_out[r][c] != raw_in[r][c]:\n1381\t                        return None\n1382\t\n1383\t        if not size_to_color or fg_color is None:\n1384\t            return None\n1385\t        return {\n1386\t            \"type\": \"recolor_by_size\",\n1387\t            \"foreground\": fg_color,\n1388\t            \"background\": bg_color,\n1389\t            \"size_to_color\": {str(k): v for k, v in size_to_color.items()},\n1390\t            \"confidence\": 1.0,\n1391\t        }\n1392\t\n1393\t    # ---- strategy: rect interior marker fill ----------------------------\n1394\t\n1395\t    def _try_rect_interior_marker_fill(self, example_pairs):\n1396\t        \"\"\"\n1397\t        Detect: same grid size; one bg + one fg in input; one new color in\n1398\t        output (the marker, consistent across pairs). Input contains one or\n1399\t        more axis-aligned rectangles whose 4 borders are entirely fg (size\n1400\t        >= 3x3). Output equals input except interior bg cells of every such\n1401\t        rectangle become the marker color (existing interior fg cells stay).\n1402\t        \"\"\"\n1403\t        if not example_pairs:\n1404\t            return None\n1405\t\n1406\t        marker = None\n1407\t        fg_color = None\n1408\t        bg_color = None\n1409\t\n1410\t        for raw_in, raw_out in example_pairs:\n1411\t            h = len(raw_in)\n1412\t            w = len(raw_in[0]) if raw_in else 0\n1413\t            if h == 0 or w == 0:\n1414\t                return None\n1415\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n1416\t                return None\n1417\t\n1418\t            counts = {}\n1419\t            for row in raw_in:\n1420\t                for c in row:\n1421\t                    counts[c] = counts.get(c, 0) + 1\n1422\t            bg = max(counts, key=counts.get)\n1423\t            in_colors = set(counts.keys())\n1424\t            fg_set = in_colors - {bg}\n1425\t            if len(fg_set) != 1:\n1426\t                return None\n1427\t            fg = next(iter(fg_set))\n1428\t\n1429\t            new_colors = (\n1430\t                {c for row in raw_out for c in row} - in_colors\n1431\t            )\n1432\t            if len(new_colors) != 1:\n1433\t                return None\n1434\t            m = next(iter(new_colors))\n1435\t\n1436\t            if marker is None:\n1437\t                marker, fg_color, bg_color = m, fg, bg\n1438\t            elif (m, fg, bg) != (marker, fg_color, bg_color):\n1439\t                return None\n1440\t\n1441\t            rects = self._find_rect_borders(raw_in, fg, min_h=3, min_w=3)\n1442\t            if not rects:\n1443\t                return None\n1444\t\n1445\t            interior_cells = set()\n1446\t            for (r0, c0, r1, c1) in rects:\n1447\t                for r in range(r0 + 1, r1):\n1448\t                    for c in range(c0 + 1, c1):\n1449\t                        interior_cells.add((r, c))\n1450\t\n1451\t            for r in range(h):\n1452\t                for c in range(w):\n1453\t                    if (r, c) in interior_cells and raw_in[r][c] == bg:\n1454\t                        if raw_out[r][c] != m:\n1455\t                            return None\n1456\t                    else:\n1457\t                        if raw_out[r][c] != raw_in[r][c]:\n1458\t                            return None\n1459\t\n1460\t        if marker is None:\n1461\t            return None\n1462\t        return {\n1463\t            \"type\": \"rect_interior_marker_fill\",\n1464\t            \"marker\": marker,\n1465\t            \"foreground\": fg_color,\n1466\t            \"background\": bg_color,\n1467\t            \"confidence\": 1.0,\n1468\t        }\n1469\t\n1470\t    @staticmethod\n1471\t    def _find_rect_borders(raw, fg, min_h=3, min_w=3):\n1472\t        \"\"\"Find all axis-aligned rectangles whose 4 borders are entirely fg.\n1473\t        Returns a list of (r0, c0, r1, c1).\"\"\"\n1474\t        h = len(raw)\n1475\t        w = len(raw[0]) if raw else 0\n1476\t        rects = []\n1477\t        for r0 in range(h):\n1478\t            for r1 in range(r0 + min_h - 1, h):\n1479\t                for c0 in range(w):\n1480\t                    if raw[r0][c0] != fg or raw[r1][c0] != fg:\n1481\t                        continue\n1482\t                    for c1 in range(c0 + min_w - 1, w):\n1483\t                        if raw[r0][c1] != fg or raw[r1][c1] != fg:\n1484\t                            continue\n1485\t                        if any(raw[r0][c] != fg for c in range(c0, c1 + 1)):\n1486\t                            continue\n1487\t                        if any(raw[r1][c] != fg for c in range(c0, c1 + 1)):\n1488\t                            continue\n1489\t                        if any(raw[r][c0] != fg for r in range(r0, r1 + 1)):\n1490\t                            continue\n1491\t                        if any(raw[r][c1] != fg for r in range(r0, r1 + 1)):\n1492\t                            continue\n1493\t                        rects.append((r0, c0, r1, c1))\n1494\t        return rects\n1495\t\n1496\t    # ---- strategy: object extract + color swap --------------------------\n1497\t\n1498\t    def _try_object_extract_swap(self, example_pairs):\n1499\t        \"\"\"\n1500\t        Detect: input has one bg color and exactly two non-bg colors A and B\n1501\t        forming a single bounded object; output equals the object's bbox\n1502\t        region with A and B swapped (bg cells inside the bbox stay bg). The\n1503\t        specific A/B colors may differ per pair, but the swap rule is the\n1504\t        same: output = swap(input bbox, A<->B).\n1505\t        \"\"\"\n1506\t        if not example_pairs:\n1507\t            return None\n1508\t\n1509\t        for raw_in, raw_out in example_pairs:\n1510\t            h_in = len(raw_in)\n1511\t            w_in = len(raw_in[0]) if raw_in else 0\n1512\t            h_out = len(raw_out)\n1513\t            w_out = len(raw_out[0]) if raw_out else 0\n1514\t            if h_in == 0 or w_in == 0 or h_out == 0 or w_out == 0:\n1515\t                return None\n1516\t\n1517\t            counts = {}\n1518\t            for row in raw_in:\n1519\t                for c in row:\n1520\t                    counts[c] = counts.get(c, 0) + 1\n1521\t            bg = max(counts, key=counts.get)\n1522\t            non_bg = [c for c in counts if c != bg]\n1523\t            if len(non_bg) != 2:\n1524\t                return None\n1525\t\n1526\t            rows = [r for r in range(h_in)\n1527\t                    for c in range(w_in) if raw_in[r][c] != bg]\n1528\t            cols = [c for r in range(h_in)\n1529\t                    for c in range(w_in) if raw_in[r][c] != bg]\n1530\t            if not rows:\n1531\t                return None\n1532\t            r0, r1 = min(rows), max(rows)\n1533\t            c0, c1 = min(cols), max(cols)\n1534\t            obj_h = r1 - r0 + 1\n1535\t            obj_w = c1 - c0 + 1\n1536\t\n1537\t            if h_out != obj_h or w_out != obj_w:\n1538\t                return None\n1539\t\n1540\t            a, b = non_bg\n1541\t            for r in range(obj_h):\n1542\t                for c in range(obj_w):\n1543\t                    v = raw_in[r0 + r][c0 + c]\n1544\t                    if v == a:\n1545\t                        expected = b\n1546\t                    elif v == b:\n1547\t                        expected = a\n1548\t                    else:\n1549\t                        expected = v\n1550\t                    if raw_out[r][c] != expected:\n1551\t                        return None\n1552\t\n1553\t        return {\n1554\t            \"type\": \"object_extract_swap\",\n1555\t            \"confidence\": 1.0,\n1556\t        }\n1557\t\n1558\t    # ---- strategy: keep solid rectangles --------------------------------\n1559\t\n1560\t    def _try_keep_solid_rectangles(self, example_pairs):\n1561\t        \"\"\"\n1562\t        Detect: same grid size; one bg + one fg in input; output equals input\n1563\t        except foreground cells that do NOT belong to any solid 2x2+ block of\n1564\t        fg cells are erased to background. A foreground cell is kept iff at\n1565\t        least one of the four 2x2 windows containing it is entirely fg.\n1566\t        \"\"\"\n1567\t        if not example_pairs:\n1568\t            return None\n1569\t\n1570\t        any_kept = False\n1571\t        any_erased = False\n1572\t\n1573\t        for raw_in, raw_out in example_pairs:\n1574\t            h = len(raw_in)\n1575\t            w = len(raw_in[0]) if raw_in else 0\n1576\t            if h == 0 or w == 0:\n1577\t                return None\n1578\t            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n1579\t                return None\n1580\t\n1581\t            counts = {}\n1582\t            for row in raw_in:\n1583\t                for c in row:\n1584\t                    counts[c] = counts.get(c, 0) + 1\n1585\t            bg = max(counts, key=counts.get)\n1586\t            fg_set = set(counts.keys()) - {bg}\n1587\t            if len(fg_set) != 1:\n1588\t                return None\n1589\t            fg = next(iter(fg_set))\n1590\t\n1591\t            keep_cells = self._compute_solid_block_keep(raw_in, fg)\n1592\t\n1593\t            for r in range(h):\n1594\t                for c in range(w):\n1595\t                    if raw_in[r][c] == fg and (r, c) not in keep_cells:\n1596\t                        if raw_out[r][c] != bg:\n1597\t                            return None\n1598\t                        any_erased = True\n1599\t                    else:\n1600\t                        if raw_out[r][c] != raw_in[r][c]:\n1601\t                            return None\n1602\t                        if raw_in[r][c] == fg:\n1603\t                            any_kept = True\n1604\t\n1605\t        if not any_kept or not any_erased:\n1606\t            return None\n1607\t        return {\n1608\t            \"type\": \"keep_solid_rectangles\",\n1609\t            \"confidence\": 1.0,\n1610\t        }\n1611\t\n1612\t    @staticmethod\n1613\t    def _compute_solid_block_keep(raw, fg):\n1614\t        \"\"\"Cells of color fg that lie in some 2x2 all-fg window.\"\"\"\n1615\t        h = len(raw)\n1616\t        w = len(raw[0]) if raw else 0\n1617\t        keep = set()\n1618\t        for r in range(h - 1):\n1619\t            for c in range(w - 1):\n1620\t                if (raw[r][c] == fg and raw[r][c + 1] == fg\n1621\t                        and raw[r + 1][c] == fg and raw[r + 1][c + 1] == fg):\n1622\t                    keep.add((r, c))\n1623\t                    keep.add((r, c + 1))\n1624\t                    keep.add((r + 1, c))\n1625\t                    keep.add((r + 1, c + 1))\n1626\t        return keep\n1627\t\n1628\t    @staticmethod\n1629\t    def _find_components(raw, color):\n1630\t        \"\"\"Return 4-connected components of `color` in `raw` as lists of (r, c).\"\"\"\n1631\t        h = len(raw)\n1632\t        w = len(raw[0]) if raw else 0\n1633\t        visited = [[False] * w for _ in range(h)]\n1634\t        comps = []\n1635\t        for r in range(h):\n1636\t            for c in range(w):\n1637\t                if raw[r][c] != color or visited[r][c]:\n1638\t                    continue\n1639\t                comp = []\n1640\t                queue = [(r, c)]\n1641\t                while queue:\n1642\t                    rr, cc = queue.pop()\n1643\t                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n1644\t                        continue\n1645\t                    if visited[rr][cc] or raw[rr][cc] != color:\n1646\t                        continue\n1647\t                    visited[rr][cc] = True\n1648\t                    comp.append((rr, cc))\n1649\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n1650\t                        queue.append((rr + dr, cc + dc))\n1651\t                comps.append(comp)\n1652\t        return comps\n1653\t\n1654\t\n1655\t# ======================================================================\n1656\t# DescendOperator -- placeholder for deeper KG exploration\n1657\t# ======================================================================\n1658\t\n1659\tclass DescendOperator(Operator):\n1660\t    \"\"\"\n1661\t    Placeholder: moves focus to a deeper KG level when current-level\n1662\t    analysis is insufficient. Not yet needed for the basic pipeline.\n1663\t    \"\"\"\n1664\t\n1665\t    def __init__(self):\n1666\t        super().__init__(\"descend\")\n1667\t\n1668\t    def precondition(self, wm) -> bool:\n1669\t        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n1670\t\n1671\t    def effect(self, wm):\n1672\t        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n1673\t\n1674\t\n1675\t# ======================================================================\n1676\t# PredictOperator -- apply rule to test input\n1677\t# ======================================================================\n1678\t\n1679\tclass PredictOperator(Operator):\n1680\t    \"\"\"\n1681\t    Reads the best rule from active-rules and applies it to each test\n1682\t    pair's input grid to produce a predicted output grid.\n1683\t    \"\"\"\n1684\t\n1685\t    def __init__(self):\n1686\t        super().__init__(\"predict\")\n1687\t\n1688\t    def precondition(self, wm) -> bool:\n1689\t        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n1690\t\n1691\t    def effect(self, wm):\n1692\t        task = wm.task\n1693\t        active_rules = wm.s1.get(\"active-rules\")\n1694\t        if not task or not active_rules:\n1695\t            return\n1696\t\n1697\t        rule = active_rules[0]\n1698\t        predictions = dict(wm.s1.get(\"predictions\") or {})\n1699\t\n1700\t        for i, test_pair in enumerate(task.test_pairs):\n1701\t            key = f\"test_{i}\"\n1702\t            if key in predictions:\n1703\t                continue\n1704\t            g0 = test_pair.input_grid\n1705\t            if g0 is None:\n1706\t                continue\n1707\t            predicted = self._apply_rule(rule, g0)\n1708\t            if predicted is not None:\n1709\t                predictions[key] = predicted\n1710\t\n1711\t        wm.s1[\"predictions\"] = predictions\n1712\t\n1713\t    # ---- rule application dispatchers ------------------------------------\n1714\t\n1715\t    def _apply_rule(self, rule, input_grid):\n1716\t        rule_type = rule.get(\"type\")\n1717\t        if rule_type == \"recolor_sequential\":\n1718\t            return self._apply_recolor_sequential(rule, input_grid)\n1719\t        if rule_type == \"color_mapping\":\n1720\t            return self._apply_color_mapping(rule, input_grid)\n1721\t        if rule_type == \"bbox_fill\":\n1722\t            return self._apply_bbox_fill(rule, input_grid)\n1723\t        if rule_type == \"axis_mirror_recolor\":\n1724\t            return self._apply_axis_mirror_recolor(rule, input_grid)\n1725\t        if rule_type == \"integer_upscale\":\n1726\t            return self._apply_integer_upscale(rule, input_grid)\n1727\t        if rule_type == \"stack_with_mirror\":\n1728\t            return self._apply_stack_with_mirror(rule, input_grid)\n1729\t        if rule_type == \"rect_interior_fill\":\n1730\t            return self._apply_rect_interior_fill(rule, input_grid)\n1731\t        if rule_type == \"staircase_extend_right\":\n1732\t            return self._apply_staircase_extend_right(rule, input_grid)\n1733\t        if rule_type == \"corner_quadrant_fill\":\n1734\t            return self._apply_corner_quadrant_fill(rule, input_grid)\n1735\t        if rule_type == \"diamond_connector\":\n1736\t            return self._apply_diamond_connector(rule, input_grid)\n1737\t        if rule_type == \"axis_line_keep\":\n1738\t            return self._apply_axis_line_keep(rule, input_grid)\n1739\t        if rule_type == \"recolor_by_size\":\n1740\t            return self._apply_recolor_by_size(rule, input_grid)\n1741\t        if rule_type == \"rect_interior_marker_fill\":\n1742\t            return self._apply_rect_interior_marker_fill(rule, input_grid)\n1743\t        if rule_type == \"object_extract_swap\":\n1744\t            return self._apply_object_extract_swap(rule, input_grid)\n1745\t        if rule_type == \"keep_solid_rectangles\":\n1746\t            return self._apply_keep_solid_rectangles(rule, input_grid)\n1747\t        if rule_type == \"identity\":\n1748\t            return [row[:] for row in input_grid.raw]\n1749\t        return None\n1750\t\n1751\t    def _apply_recolor_sequential(self, rule, input_grid):\n1752\t        raw = input_grid.raw\n1753\t        height = len(raw)\n1754\t        width = len(raw[0]) if raw else 0\n1755\t        sort_key = rule[\"sort_key\"]\n1756\t        start_color = rule[\"start_color\"]\n1757\t        source_colors = set(rule.get(\"source_colors\", []))\n1758\t\n1759\t        # Find target cells\n1760\t        target_cells = []\n1761\t        for r in range(height):\n1762\t            for c in range(width):\n1763\t                if raw[r][c] in source_colors:\n1764\t                    target_cells.append((r, c))\n1765\t\n1766\t        if not target_cells:\n1767\t            return [row[:] for row in raw]\n1768\t\n1769\t        # Group into connected components\n1770\t        groups = self._group_positions(target_cells)\n1771\t\n1772\t        # Sort groups by the rule's sort key\n1773\t        def _sort_val(group):\n1774\t            if sort_key == \"top_row\":\n1775\t                return min(r for r, c in group)\n1776\t            if sort_key == \"top_col\":\n1777\t                return min(c for r, c in group)\n1778\t            return 0\n1779\t\n1780\t        sorted_groups = sorted(groups, key=_sort_val)\n1781\t\n1782\t        # Build output grid\n1783\t        output = [row[:] for row in raw]\n1784\t        for idx, group in enumerate(sorted_groups):\n1785\t            new_color = start_color + idx\n1786\t            for r, c in group:\n1787\t                output[r][c] = new_color\n1788\t\n1789\t        return output\n1790\t\n1791\t    def _apply_color_mapping(self, rule, input_grid):\n1792\t        raw = input_grid.raw\n1793\t        mapping = rule.get(\"mapping\", {})\n1794\t\n1795\t        output = []\n1796\t        for row in raw:\n1797\t            output.append([mapping.get(cell, cell) for cell in row])\n1798\t        return output\n1799\t"}]},"parent_tool_use_id":null,"session_id":"70d6b18b-76ec-4353-8d1e-b6a3c04aff21","uuid":"ed234d7f-0c45-4d31-ac96-c5fe3346edc4","timestamp":"2026-04-28T23:24:03.650Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"            local_bg = None\n            for r in range(h):\n                for c in range(w):\n                    on_line = (axis == \"col\" and c == k) or (axis == \"row\" and r == k)\n                    if on_line:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n                    else:\n                        if local_bg is None:\n                            local_bg = raw_out[r][c]\n                        elif raw_out[r][c] != local_bg:\n                            return None\n            if local_bg is None:\n                return None\n            if bg_color is None:\n                bg_color = local_bg\n            elif bg_color != local_bg:\n                return None\n        if bg_color is None:\n            return None\n        return {\"background\": bg_color}\n\n    # ---- strategy: recolor by component size ----------------------------\n\n    def _try_recolor_by_size(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; input has one background color and one\n        foreground color; connected components of foreground cells in the\n        input are each recolored uniformly in the output to a color that\n        depends solely on the component's cell count. A consistent\n        size -> color mapping must hold across all examples. Non-foreground\n        cells are unchanged.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        size_to_color = {}\n        fg_color = None\n        bg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h == 0 or w == 0:\n                return None\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg_local = max(counts, key=counts.get)\n            in_colors = set(counts.keys())\n            fg_set = in_colors - {bg_local}\n            if len(fg_set) != 1:\n                return None\n            fg_local = next(iter(fg_set))\n\n            if bg_color is None:\n                bg_color, fg_color = bg_local, fg_local\n            elif (bg_color, fg_color) != (bg_local, fg_local):\n                return None\n\n            comps = self._find_components(raw_in, fg_local)\n            if not comps:\n                return None\n            for comp in comps:\n                out_colors = {raw_out[r][c] for (r, c) in comp}\n                if len(out_colors) != 1:\n                    return None\n                out_c = next(iter(out_colors))\n                size = len(comp)\n                if size in size_to_color and size_to_color[size] != out_c:\n                    return None\n                size_to_color[size] = out_c\n\n            # Non-foreground cells must be unchanged\n            for r in range(h):\n                for c in range(w):\n                    if raw_in[r][c] != fg_local and raw_out[r][c] != raw_in[r][c]:\n                        return None\n\n        if not size_to_color or fg_color is None:\n            return None\n        return {\n            \"type\": \"recolor_by_size\",\n            \"foreground\": fg_color,\n            \"background\": bg_color,\n            \"size_to_color\": {str(k): v for k, v in size_to_color.items()},\n            \"confidence\": 1.0,\n        }\n\n    # ---- strategy: rect interior marker fill ----------------------------\n\n    def _try_rect_interior_marker_fill(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; one bg + one fg in input; one new color in\n        output (the marker, consistent across pairs). Input contains one or\n        more axis-aligned rectangles whose 4 borders are entirely fg (size\n        >= 3x3). Output equals input except interior bg cells of every such\n        rectangle become the marker color (existing interior fg cells stay).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        marker = None\n        fg_color = None\n        bg_color = None\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h == 0 or w == 0:\n                return None\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n            in_colors = set(counts.keys())\n            fg_set = in_colors - {bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            new_colors = (\n                {c for row in raw_out for c in row} - in_colors\n            )\n            if len(new_colors) != 1:\n                return None\n            m = next(iter(new_colors))\n\n            if marker is None:\n                marker, fg_color, bg_color = m, fg, bg\n            elif (m, fg, bg) != (marker, fg_color, bg_color):\n                return None\n\n            rects = self._find_rect_borders(raw_in, fg, min_h=3, min_w=3)\n            if not rects:\n                return None\n\n            interior_cells = set()\n            for (r0, c0, r1, c1) in rects:\n                for r in range(r0 + 1, r1):\n                    for c in range(c0 + 1, c1):\n                        interior_cells.add((r, c))\n\n            for r in range(h):\n                for c in range(w):\n                    if (r, c) in interior_cells and raw_in[r][c] == bg:\n                        if raw_out[r][c] != m:\n                            return None\n                    else:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n\n        if marker is None:\n            return None\n        return {\n            \"type\": \"rect_interior_marker_fill\",\n            \"marker\": marker,\n            \"foreground\": fg_color,\n            \"background\": bg_color,\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _find_rect_borders(raw, fg, min_h=3, min_w=3):\n        \"\"\"Find all axis-aligned rectangles whose 4 borders are entirely fg.\n        Returns a list of (r0, c0, r1, c1).\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        rects = []\n        for r0 in range(h):\n            for r1 in range(r0 + min_h - 1, h):\n                for c0 in range(w):\n                    if raw[r0][c0] != fg or raw[r1][c0] != fg:\n                        continue\n                    for c1 in range(c0 + min_w - 1, w):\n                        if raw[r0][c1] != fg or raw[r1][c1] != fg:\n                            continue\n                        if any(raw[r0][c] != fg for c in range(c0, c1 + 1)):\n                            continue\n                        if any(raw[r1][c] != fg for c in range(c0, c1 + 1)):\n                            continue\n                        if any(raw[r][c0] != fg for r in range(r0, r1 + 1)):\n                            continue\n                        if any(raw[r][c1] != fg for r in range(r0, r1 + 1)):\n                            continue\n                        rects.append((r0, c0, r1, c1))\n        return rects\n\n    # ---- strategy: object extract + color swap --------------------------\n\n    def _try_object_extract_swap(self, example_pairs):\n        \"\"\"\n        Detect: input has one bg color and exactly two non-bg colors A and B\n        forming a single bounded object; output equals the object's bbox\n        region with A and B swapped (bg cells inside the bbox stay bg). The\n        specific A/B colors may differ per pair, but the swap rule is the\n        same: output = swap(input bbox, A<->B).\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        for raw_in, raw_out in example_pairs:\n            h_in = len(raw_in)\n            w_in = len(raw_in[0]) if raw_in else 0\n            h_out = len(raw_out)\n            w_out = len(raw_out[0]) if raw_out else 0\n            if h_in == 0 or w_in == 0 or h_out == 0 or w_out == 0:\n                return None\n\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n            non_bg = [c for c in counts if c != bg]\n            if len(non_bg) != 2:\n                return None\n\n            rows = [r for r in range(h_in)\n                    for c in range(w_in) if raw_in[r][c] != bg]\n            cols = [c for r in range(h_in)\n                    for c in range(w_in) if raw_in[r][c] != bg]\n            if not rows:\n                return None\n            r0, r1 = min(rows), max(rows)\n            c0, c1 = min(cols), max(cols)\n            obj_h = r1 - r0 + 1\n            obj_w = c1 - c0 + 1\n\n            if h_out != obj_h or w_out != obj_w:\n                return None\n\n            a, b = non_bg\n            for r in range(obj_h):\n                for c in range(obj_w):\n                    v = raw_in[r0 + r][c0 + c]\n                    if v == a:\n                        expected = b\n                    elif v == b:\n                        expected = a\n                    else:\n                        expected = v\n                    if raw_out[r][c] != expected:\n                        return None\n\n        return {\n            \"type\": \"object_extract_swap\",\n            \"confidence\": 1.0,\n        }\n\n    # ---- strategy: keep solid rectangles --------------------------------\n\n    def _try_keep_solid_rectangles(self, example_pairs):\n        \"\"\"\n        Detect: same grid size; one bg + one fg in input; output equals input\n        except foreground cells that do NOT belong to any solid 2x2+ block of\n        fg cells are erased to background. A foreground cell is kept iff at\n        least one of the four 2x2 windows containing it is entirely fg.\n        \"\"\"\n        if not example_pairs:\n            return None\n\n        any_kept = False\n        any_erased = False\n\n        for raw_in, raw_out in example_pairs:\n            h = len(raw_in)\n            w = len(raw_in[0]) if raw_in else 0\n            if h == 0 or w == 0:\n                return None\n            if h != len(raw_out) or w != (len(raw_out[0]) if raw_out else 0):\n                return None\n\n            counts = {}\n            for row in raw_in:\n                for c in row:\n                    counts[c] = counts.get(c, 0) + 1\n            bg = max(counts, key=counts.get)\n            fg_set = set(counts.keys()) - {bg}\n            if len(fg_set) != 1:\n                return None\n            fg = next(iter(fg_set))\n\n            keep_cells = self._compute_solid_block_keep(raw_in, fg)\n\n            for r in range(h):\n                for c in range(w):\n                    if raw_in[r][c] == fg and (r, c) not in keep_cells:\n                        if raw_out[r][c] != bg:\n                            return None\n                        any_erased = True\n                    else:\n                        if raw_out[r][c] != raw_in[r][c]:\n                            return None\n                        if raw_in[r][c] == fg:\n                            any_kept = True\n\n        if not any_kept or not any_erased:\n            return None\n        return {\n            \"type\": \"keep_solid_rectangles\",\n            \"confidence\": 1.0,\n        }\n\n    @staticmethod\n    def _compute_solid_block_keep(raw, fg):\n        \"\"\"Cells of color fg that lie in some 2x2 all-fg window.\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        keep = set()\n        for r in range(h - 1):\n            for c in range(w - 1):\n                if (raw[r][c] == fg and raw[r][c + 1] == fg\n                        and raw[r + 1][c] == fg and raw[r + 1][c + 1] == fg):\n                    keep.add((r, c))\n                    keep.add((r, c + 1))\n                    keep.add((r + 1, c))\n                    keep.add((r + 1, c + 1))\n        return keep\n\n    @staticmethod\n    def _find_components(raw, color):\n        \"\"\"Return 4-connected components of `color` in `raw` as lists of (r, c).\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        visited = [[False] * w for _ in range(h)]\n        comps = []\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != color or visited[r][c]:\n                    continue\n                comp = []\n                queue = [(r, c)]\n                while queue:\n                    rr, cc = queue.pop()\n                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n                        continue\n                    if visited[rr][cc] or raw[rr][cc] != color:\n                        continue\n                    visited[rr][cc] = True\n                    comp.append((rr, cc))\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        queue.append((rr + dr, cc + dc))\n                comps.append(comp)\n        return comps\n\n\n# ======================================================================\n# DescendOperator -- placeholder for deeper KG exploration\n# ======================================================================\n\nclass DescendOperator(Operator):\n    \"\"\"\n    Placeholder: moves focus to a deeper KG level when current-level\n    analysis is insufficient. Not yet needed for the basic pipeline.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"descend\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n\n\n# ======================================================================\n# PredictOperator -- apply rule to test input\n# ======================================================================\n\nclass PredictOperator(Operator):\n    \"\"\"\n    Reads the best rule from active-rules and applies it to each test\n    pair's input grid to produce a predicted output grid.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"predict\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"PredictOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        task = wm.task\n        active_rules = wm.s1.get(\"active-rules\")\n        if not task or not active_rules:\n            return\n\n        rule = active_rules[0]\n        predictions = dict(wm.s1.get(\"predictions\") or {})\n\n        for i, test_pair in enumerate(task.test_pairs):\n            key = f\"test_{i}\"\n            if key in predictions:\n                continue\n            g0 = test_pair.input_grid\n            if g0 is None:\n                continue\n            predicted = self._apply_rule(rule, g0)\n            if predicted is not None:\n                predictions[key] = predicted\n\n        wm.s1[\"predictions\"] = predictions\n\n    # ---- rule application dispatchers ------------------------------------\n\n    def _apply_rule(self, rule, input_grid):\n        rule_type = rule.get(\"type\")\n        if rule_type == \"recolor_sequential\":\n            return self._apply_recolor_sequential(rule, input_grid)\n        if rule_type == \"color_mapping\":\n            return self._apply_color_mapping(rule, input_grid)\n        if rule_type == \"bbox_fill\":\n            return self._apply_bbox_fill(rule, input_grid)\n        if rule_type == \"axis_mirror_recolor\":\n            return self._apply_axis_mirror_recolor(rule, input_grid)\n        if rule_type == \"integer_upscale\":\n            return self._apply_integer_upscale(rule, input_grid)\n        if rule_type == \"stack_with_mirror\":\n            return self._apply_stack_with_mirror(rule, input_grid)\n        if rule_type == \"rect_interior_fill\":\n            return self._apply_rect_interior_fill(rule, input_grid)\n        if rule_type == \"staircase_extend_right\":\n            return self._apply_staircase_extend_right(rule, input_grid)\n        if rule_type == \"corner_quadrant_fill\":\n            return self._apply_corner_quadrant_fill(rule, input_grid)\n        if rule_type == \"diamond_connector\":\n            return self._apply_diamond_connector(rule, input_grid)\n        if rule_type == \"axis_line_keep\":\n            return self._apply_axis_line_keep(rule, input_grid)\n        if rule_type == \"recolor_by_size\":\n            return self._apply_recolor_by_size(rule, input_grid)\n        if rule_type == \"rect_interior_marker_fill\":\n            return self._apply_rect_interior_marker_fill(rule, input_grid)\n        if rule_type == \"object_extract_swap\":\n            return self._apply_object_extract_swap(rule, input_grid)\n        if rule_type == \"keep_solid_rectangles\":\n            return self._apply_keep_solid_rectangles(rule, input_grid)\n        if rule_type == \"identity\":\n            return [row[:] for row in input_grid.raw]\n        return None\n\n    def _apply_recolor_sequential(self, rule, input_grid):\n        raw = input_grid.raw\n        height = len(raw)\n        width = len(raw[0]) if raw else 0\n        sort_key = rule[\"sort_key\"]\n        start_color = rule[\"start_color\"]\n        source_colors = set(rule.get(\"source_colors\", []))\n\n        # Find target cells\n        target_cells = []\n        for r in range(height):\n            for c in range(width):\n                if raw[r][c] in source_colors:\n                    target_cells.append((r, c))\n\n        if not target_cells:\n            return [row[:] for row in raw]\n\n        # Group into connected components\n        groups = self._group_positions(target_cells)\n\n        # Sort groups by the rule's sort key\n        def _sort_val(group):\n            if sort_key == \"top_row\":\n                return min(r for r, c in group)\n            if sort_key == \"top_col\":\n                return min(c for r, c in group)\n            return 0\n\n        sorted_groups = sorted(groups, key=_sort_val)\n\n        # Build output grid\n        output = [row[:] for row in raw]\n        for idx, group in enumerate(sorted_groups):\n            new_color = start_color + idx\n            for r, c in group:\n                output[r][c] = new_color\n\n        return output\n\n    def _apply_color_mapping(self, rule, input_grid):\n        raw = input_grid.raw\n        mapping = rule.get(\"mapping\", {})\n\n        output = []\n        for row in raw:\n            output.append([mapping.get(cell, cell) for cell in row])\n        return output\n","numLines":500,"startLine":1300,"totalLines":2179}}}
