{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014yn5W4btwcmuWB5nAkvM3R","type":"tool_result","content":"1800\t    def _apply_bbox_fill(self, rule, input_grid):\n1801\t        raw = input_grid.raw\n1802\t        h = len(raw)\n1803\t        w = len(raw[0]) if raw else 0\n1804\t        marker = rule.get(\"marker\")\n1805\t        fg = rule.get(\"foreground\")\n1806\t        bg = rule.get(\"background\")\n1807\t        if marker is None or fg is None or bg is None:\n1808\t            return None\n1809\t\n1810\t        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n1811\t        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n1812\t        if not rows:\n1813\t            return [row[:] for row in raw]\n1814\t        r0, r1 = min(rows), max(rows)\n1815\t        c0, c1 = min(cols), max(cols)\n1816\t\n1817\t        out = [row[:] for row in raw]\n1818\t        for r in range(r0, r1 + 1):\n1819\t            for c in range(c0, c1 + 1):\n1820\t                if out[r][c] == bg:\n1821\t                    out[r][c] = marker\n1822\t        return out\n1823\t\n1824\t    def _apply_axis_mirror_recolor(self, rule, input_grid):\n1825\t        raw = input_grid.raw\n1826\t        h = len(raw)\n1827\t        w = len(raw[0]) if raw else 0\n1828\t        marker = rule.get(\"marker\")\n1829\t        fg = rule.get(\"foreground\")\n1830\t        axis = rule.get(\"axis\", \"horizontal\")\n1831\t        if marker is None or fg is None:\n1832\t            return None\n1833\t\n1834\t        out = [row[:] for row in raw]\n1835\t        for r in range(h):\n1836\t            for c in range(w):\n1837\t                if raw[r][c] != fg:\n1838\t                    continue\n1839\t                if axis == \"horizontal\":\n1840\t                    rr, cc = r, w - 1 - c\n1841\t                else:\n1842\t                    rr, cc = h - 1 - r, c\n1843\t                if (r, c) == (rr, cc):\n1844\t                    continue\n1845\t                if raw[rr][cc] == fg:\n1846\t                    out[r][c] = marker\n1847\t        return out\n1848\t\n1849\t    def _apply_integer_upscale(self, rule, input_grid):\n1850\t        raw = input_grid.raw\n1851\t        k = rule.get(\"factor\")\n1852\t        if not isinstance(k, int) or k < 2:\n1853\t            return None\n1854\t        out = []\n1855\t        for row in raw:\n1856\t            new_row = []\n1857\t            for v in row:\n1858\t                new_row.extend([v] * k)\n1859\t            for _ in range(k):\n1860\t                out.append(new_row[:])\n1861\t        return out\n1862\t\n1863\t    def _apply_stack_with_mirror(self, rule, input_grid):\n1864\t        raw = input_grid.raw\n1865\t        direction = rule.get(\"direction\")\n1866\t        order = rule.get(\"order\")\n1867\t        if direction not in (\"vertical\", \"horizontal\"):\n1868\t            return None\n1869\t        if order not in (\"input_first\", \"flip_first\"):\n1870\t            return None\n1871\t\n1872\t        if direction == \"vertical\":\n1873\t            flipped = list(reversed([row[:] for row in raw]))\n1874\t            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n1875\t            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n1876\t            return [r[:] for r in top] + [r[:] for r in bot]\n1877\t        else:\n1878\t            flipped = [list(reversed(row)) for row in raw]\n1879\t            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n1880\t            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n1881\t            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n1882\t\n1883\t    def _apply_rect_interior_fill(self, rule, input_grid):\n1884\t        raw = input_grid.raw\n1885\t        h = len(raw)\n1886\t        w = len(raw[0]) if raw else 0\n1887\t        bg = rule.get(\"background\")\n1888\t        fg = rule.get(\"border\")\n1889\t        size_to_fill_raw = rule.get(\"size_to_fill\") or {}\n1890\t        if bg is None or fg is None:\n1891\t            return None\n1892\t        size_to_fill = {}\n1893\t        for k, v in size_to_fill_raw.items():\n1894\t            try:\n1895\t                a, b = k.split(\"x\")\n1896\t                size_to_fill[(int(a), int(b))] = v\n1897\t            except ValueError:\n1898\t                continue\n1899\t\n1900\t        rects = GeneralizeOperator._find_hollow_rects(raw, fg, bg)\n1901\t        out = [row[:] for row in raw]\n1902\t        for (r0, c0, r1, c1) in rects:\n1903\t            ih = r1 - r0 - 1\n1904\t            iw = c1 - c0 - 1\n1905\t            fill = size_to_fill.get((ih, iw))\n1906\t            if fill is None:\n1907\t                continue\n1908\t            for r in range(r0 + 1, r1):\n1909\t                for c in range(c0 + 1, c1):\n1910\t                    out[r][c] = fill\n1911\t        return out\n1912\t\n1913\t    def _apply_staircase_extend_right(self, rule, input_grid):\n1914\t        raw = input_grid.raw\n1915\t        if len(raw) != 1:\n1916\t            return None\n1917\t        row0 = list(raw[0])\n1918\t        w = len(row0)\n1919\t        if w < 2:\n1920\t            return None\n1921\t        distinct = set(row0)\n1922\t        if len(distinct) != 2:\n1923\t            return None\n1924\t        fg = row0[0]\n1925\t        bg = next(v for v in distinct if v != fg)\n1926\t        n = 0\n1927\t        while n < w and row0[n] == fg:\n1928\t            n += 1\n1929\t        if n == 0 or any(v != bg for v in row0[n:]):\n1930\t            return None\n1931\t        oh = w // 2\n1932\t        out = []\n1933\t        for i in range(oh):\n1934\t            cells = [fg] * (n + i) + [bg] * (w - n - i)\n1935\t            out.append(cells)\n1936\t        return out\n1937\t\n1938\t    def _apply_corner_quadrant_fill(self, rule, input_grid):\n1939\t        raw = input_grid.raw\n1940\t        inner_color = rule.get(\"inner_color\")\n1941\t        if inner_color is None:\n1942\t            return None\n1943\t\n1944\t        counts = {}\n1945\t        for row in raw:\n1946\t            for c in row:\n1947\t                counts[c] = counts.get(c, 0) + 1\n1948\t        bg = max(counts, key=counts.get)\n1949\t\n1950\t        groups = GeneralizeOperator._find_corner_quadrant_groups(raw, bg)\n1951\t        groups = [g for g in groups if g[\"inner_color\"] == inner_color]\n1952\t        if not groups:\n1953\t            return None\n1954\t        return GeneralizeOperator._apply_quadrant_groups(raw, groups, bg)\n1955\t\n1956\t    def _apply_axis_line_keep(self, rule, input_grid):\n1957\t        raw = input_grid.raw\n1958\t        h = len(raw)\n1959\t        w = len(raw[0]) if raw else 0\n1960\t        axis = rule.get(\"axis\")\n1961\t        pos = rule.get(\"position\")\n1962\t        bg = rule.get(\"background\")\n1963\t        if axis not in (\"col\", \"row\") or pos != \"middle\" or bg is None:\n1964\t            return None\n1965\t        k = (w // 2) if axis == \"col\" else (h // 2)\n1966\t        out = [[bg] * w for _ in range(h)]\n1967\t        for r in range(h):\n1968\t            for c in range(w):\n1969\t                on_line = (axis == \"col\" and c == k) or (axis == \"row\" and r == k)\n1970\t                if on_line:\n1971\t                    out[r][c] = raw[r][c]\n1972\t        return out\n1973\t\n1974\t    def _apply_recolor_by_size(self, rule, input_grid):\n1975\t        raw = input_grid.raw\n1976\t        h = len(raw)\n1977\t        w = len(raw[0]) if raw else 0\n1978\t        fg = rule.get(\"foreground\")\n1979\t        if fg is None:\n1980\t            return None\n1981\t        size_to_color_raw = rule.get(\"size_to_color\") or {}\n1982\t        size_to_color = {}\n1983\t        for k, v in size_to_color_raw.items():\n1984\t            try:\n1985\t                size_to_color[int(k)] = v\n1986\t            except (TypeError, ValueError):\n1987\t                continue\n1988\t        out = [row[:] for row in raw]\n1989\t        for comp in GeneralizeOperator._find_components(raw, fg):\n1990\t            new_color = size_to_color.get(len(comp))\n1991\t            if new_color is None:\n1992\t                continue\n1993\t            for (rr, cc) in comp:\n1994\t                out[rr][cc] = new_color\n1995\t        return out\n1996\t\n1997\t    def _apply_rect_interior_marker_fill(self, rule, input_grid):\n1998\t        raw = input_grid.raw\n1999\t        h = len(raw)\n2000\t        w = len(raw[0]) if raw else 0\n2001\t        marker = rule.get(\"marker\")\n2002\t        fg = rule.get(\"foreground\")\n2003\t        bg = rule.get(\"background\")\n2004\t        if marker is None or fg is None or bg is None:\n2005\t            return None\n2006\t        rects = GeneralizeOperator._find_rect_borders(raw, fg, min_h=3, min_w=3)\n2007\t        out = [row[:] for row in raw]\n2008\t        for (r0, c0, r1, c1) in rects:\n2009\t            for r in range(r0 + 1, r1):\n2010\t                for c in range(c0 + 1, c1):\n2011\t                    if raw[r][c] == bg:\n2012\t                        out[r][c] = marker\n2013\t        return out\n2014\t\n2015\t    def _apply_object_extract_swap(self, rule, input_grid):\n2016\t        raw = input_grid.raw\n2017\t        h = len(raw)\n2018\t        w = len(raw[0]) if raw else 0\n2019\t        if h == 0 or w == 0:\n2020\t            return None\n2021\t        counts = {}\n2022\t        for row in raw:\n2023\t            for c in row:\n2024\t                counts[c] = counts.get(c, 0) + 1\n2025\t        bg = max(counts, key=counts.get)\n2026\t        non_bg = [c for c in counts if c != bg]\n2027\t        if len(non_bg) != 2:\n2028\t            return None\n2029\t        rows = [r for r in range(h) for c in range(w) if raw[r][c] != bg]\n2030\t        cols = [c for r in range(h) for c in range(w) if raw[r][c] != bg]\n2031\t        if not rows:\n2032\t            return None\n2033\t        r0, r1 = min(rows), max(rows)\n2034\t        c0, c1 = min(cols), max(cols)\n2035\t        a, b = non_bg\n2036\t        out = []\n2037\t        for r in range(r0, r1 + 1):\n2038\t            new_row = []\n2039\t            for c in range(c0, c1 + 1):\n2040\t                v = raw[r][c]\n2041\t                if v == a:\n2042\t                    new_row.append(b)\n2043\t                elif v == b:\n2044\t                    new_row.append(a)\n2045\t                else:\n2046\t                    new_row.append(v)\n2047\t            out.append(new_row)\n2048\t        return out\n2049\t\n2050\t    def _apply_keep_solid_rectangles(self, rule, input_grid):\n2051\t        raw = input_grid.raw\n2052\t        h = len(raw)\n2053\t        w = len(raw[0]) if raw else 0\n2054\t        if h == 0 or w == 0:\n2055\t            return None\n2056\t        counts = {}\n2057\t        for row in raw:\n2058\t            for c in row:\n2059\t                counts[c] = counts.get(c, 0) + 1\n2060\t        bg = max(counts, key=counts.get)\n2061\t        fg_set = set(counts.keys()) - {bg}\n2062\t        if len(fg_set) != 1:\n2063\t            return None\n2064\t        fg = next(iter(fg_set))\n2065\t        keep = GeneralizeOperator._compute_solid_block_keep(raw, fg)\n2066\t        out = [row[:] for row in raw]\n2067\t        for r in range(h):\n2068\t            for c in range(w):\n2069\t                if raw[r][c] == fg and (r, c) not in keep:\n2070\t                    out[r][c] = bg\n2071\t        return out\n2072\t\n2073\t    def _apply_diamond_connector(self, rule, input_grid):\n2074\t        raw = input_grid.raw\n2075\t        h = len(raw)\n2076\t        w = len(raw[0]) if raw else 0\n2077\t        connector = rule.get(\"connector\")\n2078\t        if connector is None:\n2079\t            return None\n2080\t\n2081\t        counts = {}\n2082\t        for row in raw:\n2083\t            for c in row:\n2084\t                counts[c] = counts.get(c, 0) + 1\n2085\t        bg = max(counts, key=counts.get)\n2086\t\n2087\t        in_colors = {c for row in raw for c in row}\n2088\t        fg_set = in_colors - {bg}\n2089\t        if len(fg_set) != 1:\n2090\t            return None\n2091\t        fg = next(iter(fg_set))\n2092\t\n2093\t        diamonds = GeneralizeOperator._find_diamonds(raw, fg, bg)\n2094\t        out = [row[:] for row in raw]\n2095\t        GeneralizeOperator._draw_diamond_connectors(out, diamonds, connector)\n2096\t        return out\n2097\t\n2098\t    # ---- helpers ---------------------------------------------------------\n2099\t\n2100\t    @staticmethod\n2101\t    def _group_positions(positions):\n2102\t        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n2103\t        pos_set = set(positions)\n2104\t        visited = set()\n2105\t        groups = []\n2106\t\n2107\t        for pos in positions:\n2108\t            if pos in visited:\n2109\t                continue\n2110\t            group = []\n2111\t            queue = [pos]\n2112\t            while queue:\n2113\t                p = queue.pop(0)\n2114\t                if p in visited or p not in pos_set:\n2115\t                    continue\n2116\t                visited.add(p)\n2117\t                group.append(p)\n2118\t                r, c = p\n2119\t                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n2120\t                    nb = (r + dr, c + dc)\n2121\t                    if nb in pos_set and nb not in visited:\n2122\t                        queue.append(nb)\n2123\t            groups.append(group)\n2124\t\n2125\t        return groups\n2126\t\n2127\t\n2128\t# ======================================================================\n2129\t# SubmitOperator -- finalize and satisfy goal\n2130\t# ======================================================================\n2131\t\n2132\tclass SubmitOperator(Operator):\n2133\t    \"\"\"\n2134\t    Writes predicted grids to S1 output-link in the format expected by\n2135\t    run_task.py, and marks the goal as satisfied.\n2136\t    \"\"\"\n2137\t\n2138\t    def __init__(self):\n2139\t        super().__init__(\"submit\")\n2140\t\n2141\t    def precondition(self, wm) -> bool:\n2142\t        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n2143\t\n2144\t    def effect(self, wm):\n2145\t        predictions = wm.s1.get(\"predictions\")\n2146\t        if not predictions:\n2147\t            return\n2148\t\n2149\t        task = wm.task\n2150\t        if not task:\n2151\t            return\n2152\t\n2153\t        predicted_grids = []\n2154\t        for i in range(len(task.test_pairs)):\n2155\t            grid = predictions.get(f\"test_{i}\")\n2156\t            if grid is not None:\n2157\t                predicted_grids.append(grid)\n2158\t\n2159\t        if not predicted_grids:\n2160\t            return\n2161\t\n2162\t        # Write to output-link (format expected by run_task.py)\n2163\t        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n2164\t        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n2165\t\n2166\t        # Mark goal as satisfied\n2167\t        wm.s1[\"goal\"] = {\"subgoals\": {\n2168\t            f\"test_{i}\": {\"status\": \"solved\"}\n2169\t            for i in range(len(predicted_grids))\n2170\t        }}\n2171\t\n2172\t\n2173\tclass VerifyOperator(SubmitOperator):\n2174\t    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n2175\t\n2176\t    def __init__(self):\n2177\t        super().__init__()\n2178\t        self.name = \"verify\"\n2179\t"}]},"parent_tool_use_id":null,"session_id":"70d6b18b-76ec-4353-8d1e-b6a3c04aff21","uuid":"9f7d93ad-c14c-4cc7-b6cb-3140eab8675d","timestamp":"2026-04-28T23:24:07.074Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"    def _apply_bbox_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        bg = rule.get(\"background\")\n        if marker is None or fg is None or bg is None:\n            return None\n\n        rows = [r for r in range(h) for c in range(w) if raw[r][c] == fg]\n        cols = [c for r in range(h) for c in range(w) if raw[r][c] == fg]\n        if not rows:\n            return [row[:] for row in raw]\n        r0, r1 = min(rows), max(rows)\n        c0, c1 = min(cols), max(cols)\n\n        out = [row[:] for row in raw]\n        for r in range(r0, r1 + 1):\n            for c in range(c0, c1 + 1):\n                if out[r][c] == bg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_axis_mirror_recolor(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        axis = rule.get(\"axis\", \"horizontal\")\n        if marker is None or fg is None:\n            return None\n\n        out = [row[:] for row in raw]\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != fg:\n                    continue\n                if axis == \"horizontal\":\n                    rr, cc = r, w - 1 - c\n                else:\n                    rr, cc = h - 1 - r, c\n                if (r, c) == (rr, cc):\n                    continue\n                if raw[rr][cc] == fg:\n                    out[r][c] = marker\n        return out\n\n    def _apply_integer_upscale(self, rule, input_grid):\n        raw = input_grid.raw\n        k = rule.get(\"factor\")\n        if not isinstance(k, int) or k < 2:\n            return None\n        out = []\n        for row in raw:\n            new_row = []\n            for v in row:\n                new_row.extend([v] * k)\n            for _ in range(k):\n                out.append(new_row[:])\n        return out\n\n    def _apply_stack_with_mirror(self, rule, input_grid):\n        raw = input_grid.raw\n        direction = rule.get(\"direction\")\n        order = rule.get(\"order\")\n        if direction not in (\"vertical\", \"horizontal\"):\n            return None\n        if order not in (\"input_first\", \"flip_first\"):\n            return None\n\n        if direction == \"vertical\":\n            flipped = list(reversed([row[:] for row in raw]))\n            top = [row[:] for row in raw] if order == \"input_first\" else flipped\n            bot = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [r[:] for r in top] + [r[:] for r in bot]\n        else:\n            flipped = [list(reversed(row)) for row in raw]\n            left = [row[:] for row in raw] if order == \"input_first\" else flipped\n            right = flipped if order == \"input_first\" else [row[:] for row in raw]\n            return [list(left[r]) + list(right[r]) for r in range(len(raw))]\n\n    def _apply_rect_interior_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        bg = rule.get(\"background\")\n        fg = rule.get(\"border\")\n        size_to_fill_raw = rule.get(\"size_to_fill\") or {}\n        if bg is None or fg is None:\n            return None\n        size_to_fill = {}\n        for k, v in size_to_fill_raw.items():\n            try:\n                a, b = k.split(\"x\")\n                size_to_fill[(int(a), int(b))] = v\n            except ValueError:\n                continue\n\n        rects = GeneralizeOperator._find_hollow_rects(raw, fg, bg)\n        out = [row[:] for row in raw]\n        for (r0, c0, r1, c1) in rects:\n            ih = r1 - r0 - 1\n            iw = c1 - c0 - 1\n            fill = size_to_fill.get((ih, iw))\n            if fill is None:\n                continue\n            for r in range(r0 + 1, r1):\n                for c in range(c0 + 1, c1):\n                    out[r][c] = fill\n        return out\n\n    def _apply_staircase_extend_right(self, rule, input_grid):\n        raw = input_grid.raw\n        if len(raw) != 1:\n            return None\n        row0 = list(raw[0])\n        w = len(row0)\n        if w < 2:\n            return None\n        distinct = set(row0)\n        if len(distinct) != 2:\n            return None\n        fg = row0[0]\n        bg = next(v for v in distinct if v != fg)\n        n = 0\n        while n < w and row0[n] == fg:\n            n += 1\n        if n == 0 or any(v != bg for v in row0[n:]):\n            return None\n        oh = w // 2\n        out = []\n        for i in range(oh):\n            cells = [fg] * (n + i) + [bg] * (w - n - i)\n            out.append(cells)\n        return out\n\n    def _apply_corner_quadrant_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        inner_color = rule.get(\"inner_color\")\n        if inner_color is None:\n            return None\n\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        groups = GeneralizeOperator._find_corner_quadrant_groups(raw, bg)\n        groups = [g for g in groups if g[\"inner_color\"] == inner_color]\n        if not groups:\n            return None\n        return GeneralizeOperator._apply_quadrant_groups(raw, groups, bg)\n\n    def _apply_axis_line_keep(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        axis = rule.get(\"axis\")\n        pos = rule.get(\"position\")\n        bg = rule.get(\"background\")\n        if axis not in (\"col\", \"row\") or pos != \"middle\" or bg is None:\n            return None\n        k = (w // 2) if axis == \"col\" else (h // 2)\n        out = [[bg] * w for _ in range(h)]\n        for r in range(h):\n            for c in range(w):\n                on_line = (axis == \"col\" and c == k) or (axis == \"row\" and r == k)\n                if on_line:\n                    out[r][c] = raw[r][c]\n        return out\n\n    def _apply_recolor_by_size(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        fg = rule.get(\"foreground\")\n        if fg is None:\n            return None\n        size_to_color_raw = rule.get(\"size_to_color\") or {}\n        size_to_color = {}\n        for k, v in size_to_color_raw.items():\n            try:\n                size_to_color[int(k)] = v\n            except (TypeError, ValueError):\n                continue\n        out = [row[:] for row in raw]\n        for comp in GeneralizeOperator._find_components(raw, fg):\n            new_color = size_to_color.get(len(comp))\n            if new_color is None:\n                continue\n            for (rr, cc) in comp:\n                out[rr][cc] = new_color\n        return out\n\n    def _apply_rect_interior_marker_fill(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        marker = rule.get(\"marker\")\n        fg = rule.get(\"foreground\")\n        bg = rule.get(\"background\")\n        if marker is None or fg is None or bg is None:\n            return None\n        rects = GeneralizeOperator._find_rect_borders(raw, fg, min_h=3, min_w=3)\n        out = [row[:] for row in raw]\n        for (r0, c0, r1, c1) in rects:\n            for r in range(r0 + 1, r1):\n                for c in range(c0 + 1, c1):\n                    if raw[r][c] == bg:\n                        out[r][c] = marker\n        return out\n\n    def _apply_object_extract_swap(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        if h == 0 or w == 0:\n            return None\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n        non_bg = [c for c in counts if c != bg]\n        if len(non_bg) != 2:\n            return None\n        rows = [r for r in range(h) for c in range(w) if raw[r][c] != bg]\n        cols = [c for r in range(h) for c in range(w) if raw[r][c] != bg]\n        if not rows:\n            return None\n        r0, r1 = min(rows), max(rows)\n        c0, c1 = min(cols), max(cols)\n        a, b = non_bg\n        out = []\n        for r in range(r0, r1 + 1):\n            new_row = []\n            for c in range(c0, c1 + 1):\n                v = raw[r][c]\n                if v == a:\n                    new_row.append(b)\n                elif v == b:\n                    new_row.append(a)\n                else:\n                    new_row.append(v)\n            out.append(new_row)\n        return out\n\n    def _apply_keep_solid_rectangles(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        if h == 0 or w == 0:\n            return None\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n        fg_set = set(counts.keys()) - {bg}\n        if len(fg_set) != 1:\n            return None\n        fg = next(iter(fg_set))\n        keep = GeneralizeOperator._compute_solid_block_keep(raw, fg)\n        out = [row[:] for row in raw]\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] == fg and (r, c) not in keep:\n                    out[r][c] = bg\n        return out\n\n    def _apply_diamond_connector(self, rule, input_grid):\n        raw = input_grid.raw\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        connector = rule.get(\"connector\")\n        if connector is None:\n            return None\n\n        counts = {}\n        for row in raw:\n            for c in row:\n                counts[c] = counts.get(c, 0) + 1\n        bg = max(counts, key=counts.get)\n\n        in_colors = {c for row in raw for c in row}\n        fg_set = in_colors - {bg}\n        if len(fg_set) != 1:\n            return None\n        fg = next(iter(fg_set))\n\n        diamonds = GeneralizeOperator._find_diamonds(raw, fg, bg)\n        out = [row[:] for row in raw]\n        GeneralizeOperator._draw_diamond_connectors(out, diamonds, connector)\n        return out\n\n    # ---- helpers ---------------------------------------------------------\n\n    @staticmethod\n    def _group_positions(positions):\n        \"\"\"Group (row, col) positions into 4-connected components.\"\"\"\n        pos_set = set(positions)\n        visited = set()\n        groups = []\n\n        for pos in positions:\n            if pos in visited:\n                continue\n            group = []\n            queue = [pos]\n            while queue:\n                p = queue.pop(0)\n                if p in visited or p not in pos_set:\n                    continue\n                visited.add(p)\n                group.append(p)\n                r, c = p\n                for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                    nb = (r + dr, c + dc)\n                    if nb in pos_set and nb not in visited:\n                        queue.append(nb)\n            groups.append(group)\n\n        return groups\n\n\n# ======================================================================\n# SubmitOperator -- finalize and satisfy goal\n# ======================================================================\n\nclass SubmitOperator(Operator):\n    \"\"\"\n    Writes predicted grids to S1 output-link in the format expected by\n    run_task.py, and marks the goal as satisfied.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"submit\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"SubmitOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        predictions = wm.s1.get(\"predictions\")\n        if not predictions:\n            return\n\n        task = wm.task\n        if not task:\n            return\n\n        predicted_grids = []\n        for i in range(len(task.test_pairs)):\n            grid = predictions.get(f\"test_{i}\")\n            if grid is not None:\n                predicted_grids.append(grid)\n\n        if not predicted_grids:\n            return\n\n        # Write to output-link (format expected by run_task.py)\n        wm.s1[\"S1\"] = {\"output-link\": \"O_out\"}\n        wm.s1[\"O_out\"] = {\"predicted-grid\": predicted_grids}\n\n        # Mark goal as satisfied\n        wm.s1[\"goal\"] = {\"subgoals\": {\n            f\"test_{i}\": {\"status\": \"solved\"}\n            for i in range(len(predicted_grids))\n        }}\n\n\nclass VerifyOperator(SubmitOperator):\n    \"\"\"Alias for the verify operation (same mechanism as submit).\"\"\"\n\n    def __init__(self):\n        super().__init__()\n        self.name = \"verify\"\n","numLines":380,"startLine":1800,"totalLines":2179}}}
