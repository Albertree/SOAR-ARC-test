2), tl),  # BR direction","+        ]","+        for (dr, dc), color in specs:","+            br0 = r0 + dr","+            bc0 = c0 + dc","+            for rr in range(br0, br0 + 2):","+                for cc in range(bc0, bc0 + 2):","+                    if 0 <= rr < h and 0 <= cc < w:","+                        grid[rr][cc] = color","+","+    @staticmethod","     def _find_components(raw, color):","         \"\"\"Return 4-connected components of `color` in `raw` as lists of (r, c).\"\"\"","         h = len(raw)"]}],"userModified":false,"replaceAll":false}}
