,  # TR direction\n2782\t            ((+2, -2), tr),  # BL direction\n2783\t            ((+2, +2), tl),  # BR direction\n2784\t        ]\n2785\t        for (dr, dc), color in specs:\n2786\t            br0 = r0 + dr\n2787\t            bc0 = c0 + dc\n2788\t            for rr in range(br0, br0 + 2):\n2789\t                for cc in range(bc0, bc0 + 2):\n2790\t                    if 0 <= rr < h and 0 <= cc < w:\n2791\t                        grid[rr][cc] = color\n2792\t\n2793\t    @staticmethod\n2794\t    def _find_components(raw, color):\n2795\t        \"\"\"Return 4-connected components of `color` in `raw` as lists of (r, c).\"\"\"\n2796\t        h = len(raw)\n2797\t        w = len(raw[0]) if raw else 0\n2798\t        visited = [[False] * w for _ in range(h)]\n2799\t        comps = []\n2800\t        for r in range(h):\n2801\t            for c in range(w):\n2802\t                if raw[r][c] != color or visited[r][c]:\n2803\t                    continue\n2804\t                comp = []\n2805\t                queue = [(r, c)]\n2806\t                while queue:\n2807\t                    rr, cc = queue.pop()\n2808\t                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n2809\t                        continue\n2810\t                    if visited[rr][cc] or raw[rr][cc] != color:\n2811\t                        continue\n2812\t                    visited[rr][cc] = True\n2813\t                    comp.append((rr, cc))\n2814\t                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n2815\t                        queue.append((rr + dr, cc + dc))\n2816\t                comps.append(comp)\n2817\t        return comps\n2818\t\n2819\t\n2820\t# ======================================================================\n2821\t# DescendOperator -- placeholder for deeper KG exploration\n2822\t# ======================================================================\n2823\t\n2824\tclass DescendOperator(Operator):\n2825\t    \"\"\"\n2826\t    Placeholder: moves focus to a deeper KG level when current-level\n2827\t    analysis is insufficient. Not yet needed for the basic pipeline.\n2828\t    \"\"\"\n2829\t\n2830\t    def __init__(self):\n2831\t        super().__init__(\"descend\")\n2832\t\n2833\t    def precondition(self, wm) -> bool:\n2834\t        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n2835\t\n2836\t    def effect(self, wm):\n2837\t        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n2838\t\n2839\t\n2840\t# ======================================================================\n2841\t# PredictOperator -- apply rule to test input\n2842\t# ======================================================================\n2843\t\n2844\tclass PredictOperator(Operator):\n2845\t    \"\"\"\n2846\t    Reads the best rule from active-rules and applies it to each test\n2847\t    pair's input grid to produce a predicted output grid.\n2848\t    \"\"\"\n2849\t"}]},"parent_tool_use_id":null,"session_id":"2cacda48-5f60-4a2f-a847-59e549259f88","uuid":"68592ddb-59e5-496a-bd16-edf5e329a926","timestamp":"2026-04-29T00:17:43.961Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/active_operators.py","content":"        if not counts:\n            return None\n        # Pick max count; on tie, smallest color value\n        best_n = max(counts.values())\n        candidates = [k for k, v in counts.items() if v == best_n]\n        return min(candidates)\n\n    @staticmethod\n    def _draw_corner_l_shoot(raw, bg):\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        out = [row[:] for row in raw]\n        for r in range(h):\n            for c in range(w):\n                v = raw[r][c]\n                if v == bg:\n                    continue\n                dists = (\n                    r + c,                      # TL\n                    r + (w - 1 - c),            # TR\n                    (h - 1 - r) + c,            # BL\n                    (h - 1 - r) + (w - 1 - c),  # BR\n                )\n                best = min(range(4), key=lambda i: dists[i])\n                cr = 0 if best in (0, 1) else h - 1\n                cc = 0 if best in (0, 2) else w - 1\n                r0, r1 = (cr, r) if cr <= r else (r, cr)\n                c0, c1 = (cc, c) if cc <= c else (c, cc)\n                for rr in range(r0, r1 + 1):\n                    out[rr][c] = v\n                for cc2 in range(c0, c1 + 1):\n                    out[r][cc2] = v\n        return out\n\n    @staticmethod\n    def _draw_corner_diagonal_blocks(grid, r0, c0, tl, tr, bl, br):\n        h = len(grid)\n        w = len(grid[0]) if grid else 0\n        # (block_top_left_offset_from_source_TL, fill_color)\n        specs = [\n            ((-2, -2), br),  # TL direction → opposite corner color\n            ((-2, +2), bl),  # TR direction\n            ((+2, -2), tr),  # BL direction\n            ((+2, +2), tl),  # BR direction\n        ]\n        for (dr, dc), color in specs:\n            br0 = r0 + dr\n            bc0 = c0 + dc\n            for rr in range(br0, br0 + 2):\n                for cc in range(bc0, bc0 + 2):\n                    if 0 <= rr < h and 0 <= cc < w:\n                        grid[rr][cc] = color\n\n    @staticmethod\n    def _find_components(raw, color):\n        \"\"\"Return 4-connected components of `color` in `raw` as lists of (r, c).\"\"\"\n        h = len(raw)\n        w = len(raw[0]) if raw else 0\n        visited = [[False] * w for _ in range(h)]\n        comps = []\n        for r in range(h):\n            for c in range(w):\n                if raw[r][c] != color or visited[r][c]:\n                    continue\n                comp = []\n                queue = [(r, c)]\n                while queue:\n                    rr, cc = queue.pop()\n                    if rr < 0 or rr >= h or cc < 0 or cc >= w:\n                        continue\n                    if visited[rr][cc] or raw[rr][cc] != color:\n                        continue\n                    visited[rr][cc] = True\n                    comp.append((rr, cc))\n                    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                        queue.append((rr + dr, cc + dc))\n                comps.append(comp)\n        return comps\n\n\n# ======================================================================\n# DescendOperator -- placeholder for deeper KG exploration\n# ======================================================================\n\nclass DescendOperator(Operator):\n    \"\"\"\n    Placeholder: moves focus to a deeper KG level when current-level\n    analysis is insufficient. Not yet needed for the basic pipeline.\n    \"\"\"\n\n    def __init__(self):\n        super().__init__(\"descend\")\n\n    def precondition(self, wm) -> bool:\n        raise NotImplementedError(\"DescendOperator.precondition() not implemented.\")\n\n    def effect(self, wm):\n        raise NotImplementedError(\"DescendOperator.effect() not implemented.\")\n\n\n# ======================================================================\n# PredictOperator -- apply rule to test input\n# ======================================================================\n\nclass PredictOperator(Operator):\n    \"\"\"\n    Reads the best rule from active-rules and applies it to each test\n    pair's input grid to produce a predicted output grid.\n    \"\"\"\n","numLines":110,"startLine":2740,"totalLines":3542}}}
