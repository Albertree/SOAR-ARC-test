y_stack_with_mirror(example_pairs)\n316\t\n317\t        # Strategy 6: rectangle interior fill — hollow rect borders get interior\n318\t        #   filled with a color determined by interior dimensions\n319\t        if rule is None:\n320\t            rule = self._try_rect_interior_fill(example_pairs)\n321\t\n322\t        # Strategy 7: staircase extend right — 1-row input becomes a triangular\n323\t        #   stack of rows where each row's prefix grows by one cell\n324\t        if rule is None:\n325\t            rule = self._try_staircase_extend_right(example_pairs)\n326\t\n327\t        # Strategy 8: corner quadrant fill — 4 single-cell corner markers\n328\t        #   surround a solid inner rectangle which is split into quadrants\n329\t        if rule is None:\n330\t            rule = self._try_corner_quadrant_fill(example_pairs)\n331\t\n332\t        # Strategy 9: diamond connector — collinear '+'-shaped 4-cell objects\n333\t        #   are joined by lines of a marker color\n334\t        if rule is None:\n335\t            rule = self._try_diamond_connector(example_pairs)\n336\t\n337\t        # Strategy 10: axis line keep — output preserves a single row or\n338\t        #   column of the input; everything else collapses to background\n339\t        if rule is None:\n340\t            rule = self._try_axis_line_keep(example_pairs)\n341\t\n342\t        # Strategy 11: recolor by component size — single fg color split into\n343\t        #   connected components, each recolored by cell count\n344\t        if rule is None:\n345\t            rule = self._try_recolor_by_size(example_pairs)\n346\t\n347\t        # Strategy 12: rect interior marker fill — hollow-border rectangles\n348\t        #   get interior background cells filled with a constant marker color,\n349\t        #   while pre-existing foreground cells inside are preserved\n350\t        if rule is None:\n351\t            rule = self._try_rect_interior_marker_fill(example_pairs)\n352\t\n353\t        # Strategy 13: ob