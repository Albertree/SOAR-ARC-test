{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AwHhjtEBAGNBgYiVFqGKss","type":"tool_result","content":"1\t\"\"\"\n2\tmemory — SOAR procedural memory (rule storage and retrieval).\n3\t\n4\tEach rule is stored as a JSON file in procedural_memory/:\n5\t  procedural_memory/rule_001.json\n6\t  procedural_memory/rule_002.json\n7\t  ...\n8\t\n9\tRule schema:\n10\t  {\n11\t    \"id\":          <int>          — unique sequential ID,\n12\t    \"concept\":     \"<str>\"        — short human-readable name (e.g. \"swap_two_colors\"),\n13\t    \"category\":    \"<str>\"        — color_transform | spatial_transform |\n14\t                                    geometric_transform | fill_transform | other,\n15\t    \"rule\":        { ... }        — the actual rule parameters used by PredictOperator,\n16\t    \"covers\":      [\"<task_id>\"]  — all tasks this rule has successfully handled,\n17\t    \"source_task\": \"<task_id>\"    — task that first triggered discovery of this rule,\n18\t    \"created_at\":  \"<ISO>\"        — creation timestamp,\n19\t    \"times_reused\": <int>         — how often the fast-path reused this rule\n20\t  }\n21\t\n22\tDesign goal: FEW, GENERAL rules — not many specific ones.\n23\tWhen a new rule is equivalent to an existing one, the existing rule's\n24\t\"covers\" list is extended rather than creating a duplicate file.\n25\t\"\"\"\n26\t\n27\timport json\n28\timport os\n29\tfrom datetime import datetime\n30\t\n31\tPROCEDURAL_MEMORY_ROOT = \"procedural_memory\"\n32\t\n33\t\n34\t# ======================================================================\n35\t# Public API\n36\t# ======================================================================\n37\t\n38\tdef save_rule_to_ltm(rule: dict, task_hex: str,\n39\t                     procedural_memory_root: str = PROCEDURAL_MEMORY_ROOT) -> str:\n40\t    \"\"\"\n41\t    Save a learned rule to procedural_memory.\n42\t\n43\t    If an equivalent rule already exists, extend its \"covers\" list and return\n44\t    its path — no duplicate file is created.\n45\t\n46\t    Returns the file path of the saved (or updated) rule.\n47\t    \"\"\"\n48\t    os.makedirs(procedural_memory_root, exist_ok=True)\n49\t\n50\t    existing = sorted(\n51\t        f for f in os.listdir(procedural_memory_root)\n52\t        if f.startswith(\"rule_\") and f.endswith(\".json\")\n53\t    )\n54\t\n55\t    # Check for equivalent rule — update covers instead of duplicating\n56\t    for fname in existing:\n57\t        path = os.path.join(procedural_memory_root, fname)\n58\t        try:\n59\t            with open(path, \"r\") as fh:\n60\t                stored = json.load(fh)\n61\t            if _rules_equivalent(stored.get(\"rule\", {}), rule):\n62\t                covers = stored.get(\"covers\", [stored.get(\"source_task\", \"\")])\n63\t                if task_hex not in covers:\n64\t                    covers.append(task_hex)\n65\t                    stored[\"covers\"] = covers\n66\t                    with open(path, \"w\") as fh:\n67\t                        json.dump(stored, fh, indent=2)\n68\t                return path\n69\t        except (json.JSONDecodeError, IOError):\n70\t            continue\n71\t\n72\t    # New rule — assign next ID and build full entry\n73\t    next_id = len(existing) + 1\n74\t    entry = {\n75\t        \"id\": next_id,\n76\t        \"concept\": _infer_concept(rule),\n77\t        \"category\": _infer_category(rule),\n78\t        \"rule\": rule,\n79\t        \"covers\": [task_hex],\n80\t        \"source_task\": task_hex,\n81\t        \"created_at\": datetime.now().isoformat(),\n82\t        \"times_reused\": 0,\n83\t    }\n84\t\n85\t    filename = f\"rule_{next_id:03d}.json\"\n86\t    path = os.path.join(procedural_memory_root, filename)\n87\t    with open(path, \"w\") as fh:\n88\t        json.dump(entry, fh, indent=2)\n89\t\n90\t    return path\n91\t\n92\t\n93\tdef load_all_rules(procedural_memory_root: str = PROCEDURAL_MEMORY_ROOT) -> list:\n94\t    \"\"\"\n95\t    Load all stored rules. Returns list of entry dicts sorted by\n96\t    times_reused descending so the most-proven rules are tried first.\n97\t    \"\"\"\n98\t    if not os.path.isdir(procedural_memory_root):\n99\t        return []\n100\t\n101\t    rules = []\n102\t    for fname in sorted(os.listdir(procedural_memory_root)):\n103\t        if not (fname.startswith(\"rule_\") and fname.endswith(\".json\")):\n104\t            continue\n105\t        path = os.path.join(procedural_memory_root, fname)\n106\t        try:\n107\t            with open(path, \"r\") as fh:\n108\t                entry = json.load(fh)\n109\t            entry[\"_path\"] = path\n110\t            rules.append(entry)\n111\t        except (json.JSONDecodeError, IOError):\n112\t            continue\n113\t\n114\t    rules.sort(key=lambda e: e.get(\"times_reused\", 0), reverse=True)\n115\t    return rules\n116\t\n117\t\n118\tdef increment_reuse_count(entry: dict) -> None:\n119\t    \"\"\"Increment times_reused for a stored rule and persist the change.\"\"\"\n120\t    path = entry.get(\"_path\")\n121\t    if not path or not os.path.exists(path):\n122\t        return\n123\t    try:\n124\t        with open(path, \"r\") as fh:\n125\t            data = json.load(fh)\n126\t        data[\"times_reused\"] = data.get(\"times_reused\", 0) + 1\n127\t        with open(path, \"w\") as fh:\n128\t            json.dump(data, fh, indent=2)\n129\t    except (json.JSONDecodeError, IOError):\n130\t        pass\n131\t\n132\t\n133\tdef load_rules_from_ltm(task_hex: str,\n134\t                        semantic_memory_root: str = \"semantic_memory\") -> list:\n135\t    \"\"\"Legacy interface — task_hex unused, loads all rules.\"\"\"\n136\t    return load_all_rules()\n137\t\n138\t\n139\tdef chunk_from_substate(substate: dict) -> dict:\n140\t    \"\"\"Placeholder — extract rule from resolved substate.\"\"\"\n141\t    return {}\n142\t\n143\t\n144\t# ======================================================================\n145\t# Internal helpers\n146\t# ======================================================================\n147\t\n148\tdef _rules_equivalent(a: dict, b: dict) -> bool:\n149\t    \"\"\"\n150\t    Return True if two rules produce identical transformations.\n151\t\n152\t    Keys in JSON are always strings; keys produced by the pipeline may be\n153\t    integers. Both sides are normalised to string keys before comparison.\n154\t    \"\"\"\n155\t    if a.get(\"type\") != b.get(\"type\"):\n156\t        return False\n157\t\n158\t    t = a.get(\"type\")\n159\t\n160\t    if t == \"color_mapping\":\n161\t        return _norm_mapping(a.get(\"mapping\")) == _norm_mapping(b.get(\"mapping\"))\n162\t\n163\t    if t == \"recolor_sequential\":\n164\t        return (\n165\t            a.get(\"sort_key\") == b.get(\"sort_key\")\n166\t            and a.get(\"start_color\") == b.get(\"start_color\")\n167\t            and sorted(a.get(\"source_colors\") or []) == sorted(b.get(\"source_colors\") or [])\n168\t        )\n169\t\n170\t    # For all other types compare the full rule dicts after key normalisation\n171\t    return _norm_dict(a) == _norm_dict(b)\n172\t\n173\t\n174\tdef _norm_mapping(mapping) -> dict:\n175\t    \"\"\"Normalise a color mapping to {str: int} regardless of source key type.\"\"\"\n176\t    if not mapping:\n177\t        return {}\n178\t    return {str(k): int(v) for k, v in mapping.items()}\n179\t\n180\t\n181\tdef _norm_dict(d: dict) -> dict:\n182\t    \"\"\"Recursively normalise all dict keys to strings.\"\"\"\n183\t    if not isinstance(d, dict):\n184\t        return d\n185\t    return {str(k): _norm_dict(v) for k, v in d.items()}\n186\t\n187\t\n188\tdef _infer_concept(rule: dict) -> str:\n189\t    \"\"\"Derive a short concept name from the rule type and parameters.\"\"\"\n190\t    t = rule.get(\"type\", \"unknown\")\n191\t    if t == \"color_mapping\":\n192\t        m = rule.get(\"mapping\", {})\n193\t        if len(m) == 2:\n194\t            return \"swap_two_colors\"\n195\t        if len(m) == 1:\n196\t            return \"remap_one_color\"\n197\t        return \"color_remap\"\n198\t    if t == \"recolor_sequential\":\n199\t        return \"recolor_objects_sequentially\"\n200\t    if t == \"identity\":\n201\t        return \"identity\"\n202\t    # For custom types added by Claude, use the type name directly\n203\t    return t.replace(\"_\", \" \").strip()\n204\t\n205\t\n206\tdef _infer_category(rule: dict) -> str:\n207\t    \"\"\"Assign a high-level category based on rule type.\"\"\"\n208\t    t = rule.get(\"type\", \"\")\n209\t    if any(k in t for k in (\"color\", \"recolor\", \"remap\", \"palette\")):\n210\t        return \"color_transform\"\n211\t    if any(k in t for k in (\"move\", \"shift\", \"translate\", \"gravity\", \"relocate\", \"slide\")):\n212\t        return \"spatial_transform\"\n213\t    if any(k in t for k in (\"scale\", \"flip\", \"rotate\", \"mirror\", \"reflect\")):\n214\t        return \"geometric_transform\"\n215\t    if any(k in t for k in (\"fill\", \"border\", \"enclosed\", \"flood\")):\n216\t        return \"fill_transform\"\n217\t    return \"other\"\n218\t"}]},"parent_tool_use_id":null,"session_id":"e734d638-950d-4abe-b90f-fe5c1f887be5","uuid":"5177e00d-b814-4712-afe1-27f1828d08e5","timestamp":"2026-04-29T03:13:08.852Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/agent/memory.py","content":"\"\"\"\nmemory — SOAR procedural memory (rule storage and retrieval).\n\nEach rule is stored as a JSON file in procedural_memory/:\n  procedural_memory/rule_001.json\n  procedural_memory/rule_002.json\n  ...\n\nRule schema:\n  {\n    \"id\":          <int>          — unique sequential ID,\n    \"concept\":     \"<str>\"        — short human-readable name (e.g. \"swap_two_colors\"),\n    \"category\":    \"<str>\"        — color_transform | spatial_transform |\n                                    geometric_transform | fill_transform | other,\n    \"rule\":        { ... }        — the actual rule parameters used by PredictOperator,\n    \"covers\":      [\"<task_id>\"]  — all tasks this rule has successfully handled,\n    \"source_task\": \"<task_id>\"    — task that first triggered discovery of this rule,\n    \"created_at\":  \"<ISO>\"        — creation timestamp,\n    \"times_reused\": <int>         — how often the fast-path reused this rule\n  }\n\nDesign goal: FEW, GENERAL rules — not many specific ones.\nWhen a new rule is equivalent to an existing one, the existing rule's\n\"covers\" list is extended rather than creating a duplicate file.\n\"\"\"\n\nimport json\nimport os\nfrom datetime import datetime\n\nPROCEDURAL_MEMORY_ROOT = \"procedural_memory\"\n\n\n# ======================================================================\n# Public API\n# ======================================================================\n\ndef save_rule_to_ltm(rule: dict, task_hex: str,\n                     procedural_memory_root: str = PROCEDURAL_MEMORY_ROOT) -> str:\n    \"\"\"\n    Save a learned rule to procedural_memory.\n\n    If an equivalent rule already exists, extend its \"covers\" list and return\n    its path — no duplicate file is created.\n\n    Returns the file path of the saved (or updated) rule.\n    \"\"\"\n    os.makedirs(procedural_memory_root, exist_ok=True)\n\n    existing = sorted(\n        f for f in os.listdir(procedural_memory_root)\n        if f.startswith(\"rule_\") and f.endswith(\".json\")\n    )\n\n    # Check for equivalent rule — update covers instead of duplicating\n    for fname in existing:\n        path = os.path.join(procedural_memory_root, fname)\n        try:\n            with open(path, \"r\") as fh:\n                stored = json.load(fh)\n            if _rules_equivalent(stored.get(\"rule\", {}), rule):\n                covers = stored.get(\"covers\", [stored.get(\"source_task\", \"\")])\n                if task_hex not in covers:\n                    covers.append(task_hex)\n                    stored[\"covers\"] = covers\n                    with open(path, \"w\") as fh:\n                        json.dump(stored, fh, indent=2)\n                return path\n        except (json.JSONDecodeError, IOError):\n            continue\n\n    # New rule — assign next ID and build full entry\n    next_id = len(existing) + 1\n    entry = {\n        \"id\": next_id,\n        \"concept\": _infer_concept(rule),\n        \"category\": _infer_category(rule),\n        \"rule\": rule,\n        \"covers\": [task_hex],\n        \"source_task\": task_hex,\n        \"created_at\": datetime.now().isoformat(),\n        \"times_reused\": 0,\n    }\n\n    filename = f\"rule_{next_id:03d}.json\"\n    path = os.path.join(procedural_memory_root, filename)\n    with open(path, \"w\") as fh:\n        json.dump(entry, fh, indent=2)\n\n    return path\n\n\ndef load_all_rules(procedural_memory_root: str = PROCEDURAL_MEMORY_ROOT) -> list:\n    \"\"\"\n    Load all stored rules. Returns list of entry dicts sorted by\n    times_reused descending so the most-proven rules are tried first.\n    \"\"\"\n    if not os.path.isdir(procedural_memory_root):\n        return []\n\n    rules = []\n    for fname in sorted(os.listdir(procedural_memory_root)):\n        if not (fname.startswith(\"rule_\") and fname.endswith(\".json\")):\n            continue\n        path = os.path.join(procedural_memory_root, fname)\n        try:\n            with open(path, \"r\") as fh:\n                entry = json.load(fh)\n            entry[\"_path\"] = path\n            rules.append(entry)\n        except (json.JSONDecodeError, IOError):\n            continue\n\n    rules.sort(key=lambda e: e.get(\"times_reused\", 0), reverse=True)\n    return rules\n\n\ndef increment_reuse_count(entry: dict) -> None:\n    \"\"\"Increment times_reused for a stored rule and persist the change.\"\"\"\n    path = entry.get(\"_path\")\n    if not path or not os.path.exists(path):\n        return\n    try:\n        with open(path, \"r\") as fh:\n            data = json.load(fh)\n        data[\"times_reused\"] = data.get(\"times_reused\", 0) + 1\n        with open(path, \"w\") as fh:\n            json.dump(data, fh, indent=2)\n    except (json.JSONDecodeError, IOError):\n        pass\n\n\ndef load_rules_from_ltm(task_hex: str,\n                        semantic_memory_root: str = \"semantic_memory\") -> list:\n    \"\"\"Legacy interface — task_hex unused, loads all rules.\"\"\"\n    return load_all_rules()\n\n\ndef chunk_from_substate(substate: dict) -> dict:\n    \"\"\"Placeholder — extract rule from resolved substate.\"\"\"\n    return {}\n\n\n# ======================================================================\n# Internal helpers\n# ======================================================================\n\ndef _rules_equivalent(a: dict, b: dict) -> bool:\n    \"\"\"\n    Return True if two rules produce identical transformations.\n\n    Keys in JSON are always strings; keys produced by the pipeline may be\n    integers. Both sides are normalised to string keys before comparison.\n    \"\"\"\n    if a.get(\"type\") != b.get(\"type\"):\n        return False\n\n    t = a.get(\"type\")\n\n    if t == \"color_mapping\":\n        return _norm_mapping(a.get(\"mapping\")) == _norm_mapping(b.get(\"mapping\"))\n\n    if t == \"recolor_sequential\":\n        return (\n            a.get(\"sort_key\") == b.get(\"sort_key\")\n            and a.get(\"start_color\") == b.get(\"start_color\")\n            and sorted(a.get(\"source_colors\") or []) == sorted(b.get(\"source_colors\") or [])\n        )\n\n    # For all other types compare the full rule dicts after key normalisation\n    return _norm_dict(a) == _norm_dict(b)\n\n\ndef _norm_mapping(mapping) -> dict:\n    \"\"\"Normalise a color mapping to {str: int} regardless of source key type.\"\"\"\n    if not mapping:\n        return {}\n    return {str(k): int(v) for k, v in mapping.items()}\n\n\ndef _norm_dict(d: dict) -> dict:\n    \"\"\"Recursively normalise all dict keys to strings.\"\"\"\n    if not isinstance(d, dict):\n        return d\n    return {str(k): _norm_dict(v) for k, v in d.items()}\n\n\ndef _infer_concept(rule: dict) -> str:\n    \"\"\"Derive a short concept name from the rule type and parameters.\"\"\"\n    t = rule.get(\"type\", \"unknown\")\n    if t == \"color_mapping\":\n        m = rule.get(\"mapping\", {})\n        if len(m) == 2:\n            return \"swap_two_colors\"\n        if len(m) == 1:\n            return \"remap_one_color\"\n        return \"color_remap\"\n    if t == \"recolor_sequential\":\n        return \"recolor_objects_sequentially\"\n    if t == \"identity\":\n        return \"identity\"\n    # For custom types added by Claude, use the type name directly\n    return t.replace(\"_\", \" \").strip()\n\n\ndef _infer_category(rule: dict) -> str:\n    \"\"\"Assign a high-level category based on rule type.\"\"\"\n    t = rule.get(\"type\", \"\")\n    if any(k in t for k in (\"color\", \"recolor\", \"remap\", \"palette\")):\n        return \"color_transform\"\n    if any(k in t for k in (\"move\", \"shift\", \"translate\", \"gravity\", \"relocate\", \"slide\")):\n        return \"spatial_transform\"\n    if any(k in t for k in (\"scale\", \"flip\", \"rotate\", \"mirror\", \"reflect\")):\n        return \"geometric_transform\"\n    if any(k in t for k in (\"fill\", \"border\", \"enclosed\", \"flood\")):\n        return \"fill_transform\"\n    return \"other\"\n","numLines":218,"startLine":1,"totalLines":218}}}
