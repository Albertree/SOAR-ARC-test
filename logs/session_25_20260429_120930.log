None","+","+        return {\"type\": \"zigzag_grid_shear\", \"confidence\": 1.0}","+","     # ---- strategy: gravity to floor -------------------------------------"," ","     def _try_gravity_to_floor(self, example_pairs):"]}],"userModified":false,"replaceAll":false}}
