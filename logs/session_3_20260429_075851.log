,"+        A group consists of: a solid rectangle filled with one non-bg color","+        (the 'inner color'), with side lengths >= 2 and even, surrounded by","+        4 single cells at the diagonal-adjacent positions, each a distinct","+        non-bg color (and distinct from the inner color). Returns a list of","+        dicts {r0,r1,c0,c1, inner_color, tl, tr, bl, br}, or empty list.\"\"\"","+        h = len(raw)","+        w = len(raw[0]) if raw else 0"," ","-        tl, tr = color_at((r0, c0)), color_at((r0, c1))","-        bl, br = color_at((r1, c0)), color_at((r1, c1))","-","-        ih = r1 - r0 - 1","-        iw = c1 - c0 - 1","-        if ih < 2 or iw < 2 or ih % 2 != 0 or iw % 2 != 0:","-            return None","-","-        # Inner cells must be exactly the 'inner' color, with no extras.","-        inner_cells = [(r, c) for r in range(r0 + 1, r1)","-                       for c in range(c0 + 1, c1)]","-        for (r, c) in inner_cells:","-            if raw_in[r][c] != inner:","-                return None","-        if sorted(color_cells[inner]) != sorted(inner_cells):","-            return None","-","-        hh = ih // 2","-        ww = iw // 2","+        # 4-connected components of every non-bg color","+        visited = [[False] * w for _ in range(h)]","+        groups = []","         for r in range(h):","             for c in range(w):","-                if (r, c) in expected_corners:","-                    if raw_out[r][c] != bg:","-                        return None","-                elif r0 < r < r1 and c0 < c < c1:","-                    is_top = r < r0 + 1 + hh","-                    is_left = c < c0 + 1 + ww","+                if raw[r][c] == bg or visited[r][c]:","+                    continue","+                color = raw[r][c]","+                comp = []","+                queue = [(r, c)]","+                while queue:","+                    rr, cc = queue.pop()","+                    if rr < 0 or rr >= h or cc < 0 or cc >= w:","+