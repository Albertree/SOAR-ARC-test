{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017xuuQ9P2mPt91XDbBgW7PK","type":"tool_result","content":"1\t\"\"\"\n2\tSequential learning loop — feeds tasks to the SOAR agent one by one.\n3\tThe agent accumulates rules in procedural_memory across tasks.\n4\t\n5\tUsage:\n6\t  python run_learn.py                        # all training tasks\n7\t  python run_learn.py --split evaluation     # evaluation tasks\n8\t  python run_learn.py --limit 100            # first 100 tasks\n9\t  python run_learn.py --log-wm              # show WM logs per task\n10\t  python run_learn.py --shuffle              # random task order\n11\t\"\"\"\n12\t\n13\timport os\n14\timport sys\n15\timport json\n16\timport time\n17\timport random\n18\timport argparse\n19\timport subprocess\n20\tfrom datetime import datetime\n21\t\n22\t\n23\tdef _git_branch() -> str:\n24\t    \"\"\"Return the current git branch name, or unknown if unavailable.\"\"\"\n25\t    try:\n26\t        return subprocess.check_output(\n27\t            [\"git\", \"rev-parse\", \"--abbrev-ref\", \"HEAD\"],\n28\t            stderr=subprocess.DEVNULL,\n29\t        ).decode().strip()\n30\t    except Exception:\n31\t        return \"unknown\"\n32\t\n33\tfrom managers.arc_manager import ARCManager\n34\tfrom agent.active_agent import ActiveSoarAgent\n35\tfrom agent.memory import load_all_rules\n36\tfrom basics.html_report import HTMLReport\n37\t\n38\t\n39\tdef parse_args():\n40\t    p = argparse.ArgumentParser(description=\"SOAR learning loop\")\n41\t    p.add_argument(\"--split\", default=None,\n42\t                   help=\"Force ARC_AGI split: 'training' (1000 tasks) or 'evaluation' (120 tasks). \"\n43\t                        \"Omit to use data/ARC_easy/ when present.\")\n44\t    p.add_argument(\"--limit\", type=int, default=None, help=\"max tasks to run\")\n45\t    p.add_argument(\"--shuffle\", action=\"store_true\", help=\"randomize task order\")\n46\t    p.add_argument(\"--seed\", type=int, default=42, help=\"random seed for shuffle\")\n47\t    p.add_argument(\"--log-wm\", action=\"store_true\", help=\"print WM logs per task\")\n48\t    p.add_argument(\"--viz\", action=\"store_true\", help=\"show input/predicted/answer grids\")\n49\t    return p.parse_args()\n50\t\n51\t\n52\tdef get_task_list(split, data_root=\"data\", force_split=False):\n53\t    \"\"\"Get sorted list of task IDs for a split.\n54\t\n55\t    If data/ARC_easy/ exists AND force_split is False, use it directly.\n56\t    Pass force_split=True (via --split training/evaluation) to use ARC_AGI instead.\n57\t    \"\"\"\n58\t    if not force_split:\n59\t        easy_dir = os.path.join(data_root, \"ARC_easy\")\n60\t        if os.path.isdir(easy_dir):\n61\t            return sorted(f.replace(\".json\", \"\") for f in os.listdir(easy_dir) if f.endswith(\".json\"))\n62\t\n63\t    split_dir = os.path.join(data_root, \"ARC_AGI\", split)\n64\t    if not os.path.isdir(split_dir):\n65\t        print(f\"[!] Directory not found: {split_dir}\")\n66\t        sys.exit(1)\n67\t    return sorted(f.replace(\".json\", \"\") for f in os.listdir(split_dir) if f.endswith(\".json\"))\n68\t\n69\t\n70\tdef check_correct(predicted, task):\n71\t    \"\"\"Check if predicted grids match the ground truth.\"\"\"\n72\t    if predicted is None:\n73\t        return False\n74\t    answers = []\n75\t    for pair in task.test_pairs:\n76\t        if hasattr(pair, \"output\") and pair.output is not None:\n77\t            answers.append(pair.output.contents)\n78\t    if not answers:\n79\t        return False\n80\t    pred = predicted\n81\t    if pred and not isinstance(pred[0], list):\n82\t        pred = [pred]\n83\t    if len(pred) != len(answers):\n84\t        return False\n85\t    return all(p == a for p, a in zip(pred, answers))\n86\t\n87\t\n88\tdef _show_viz(task, predicted, is_correct):\n89\t    \"\"\"Show input, predicted, and ground truth grids side by side (ANSI colors).\"\"\"\n90\t    from basics.viz import _print_side_by_side\n91\t\n92\t    for i, pair in enumerate(task.test_pairs):\n93\t        grids = [pair.input_grid.raw]\n94\t        labels = [\"input\"]\n95\t\n96\t        if predicted is not None:\n97\t            pred = predicted if isinstance(predicted[0], list) else [predicted]\n98\t            if i < len(pred):\n99\t                grids.append(pred[i])\n100\t                labels.append(\"predicted\")\n101\t\n102\t        if hasattr(pair, \"output\") and pair.output is not None:\n103\t            grids.append(pair.output.contents)\n104\t            labels.append(\"answer\")\n105\t\n106\t        tag = \"MATCH\" if is_correct else \"MISMATCH\"\n107\t        print(f\"  {'  |  '.join(labels)}  << {tag}\")\n108\t        _print_side_by_side(grids, gap=6)\n109\t    print()\n110\t\n111\t\n112\tdef main():\n113\t    args = parse_args()\n114\t\n115\t    manager = ARCManager(data_root=\"data\", semantic_memory_root=\"semantic_memory\")\n116\t    agent = ActiveSoarAgent(\n117\t        semantic_memory_root=\"semantic_memory\",\n118\t        procedural_memory_root=\"procedural_memory\",\n119\t        max_steps=50,\n120\t    )\n121\t\n122\t    split = args.split or \"training\"\n123\t    force_split = args.split is not None\n124\t    task_hexes = get_task_list(split, force_split=force_split)\n125\t    if args.shuffle:\n126\t        random.seed(args.seed)\n127\t        random.shuffle(task_hexes)\n128\t    if args.limit is not None:\n129\t        task_hexes = task_hexes[:args.limit]\n130\t\n131\t    total = len(task_hexes)\n132\t    correct_count = 0\n133\t    error_count = 0\n134\t    stored_rule_hits = 0\n135\t    pipeline_discoveries = 0\n136\t\n137\t    # Log file (always saved to logs/)\n138\t    os.makedirs(\"logs\", exist_ok=True)\n139\t    timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n140\t    branch = _git_branch()\n141\t    log_path = f\"logs/learn_{timestamp}.log\"\n142\t    log_file = open(log_path, \"w\")\n143\t\n144\t    # Root txt file — only when --split is explicitly given (e.g. --split training)\n145\t    root_log_path = None\n146\t    root_log_file = None\n147\t    if force_split:\n148\t        root_log_path = f\"run_learn_{branch}_{split}_{timestamp}.txt\"\n149\t        root_log_file = open(root_log_path, \"w\")\n150\t\n151\t    # HTML report — only when --viz and --split are both given\n152\t    html_report = None\n153\t    html_path = None\n154\t    if args.viz and force_split:\n155\t        html_path = f\"run_learn_{branch}_{split}_{timestamp}.html\"\n156\t        html_report = HTMLReport(split=split, timestamp=timestamp)\n157\t\n158\t    def log(msg):\n159\t        line = f\"[{datetime.now().strftime('%H:%M:%S')}] {msg}\"\n160\t        print(line)\n161\t        log_file.write(line + \"\\n\")\n162\t        log_file.flush()\n163\t        if root_log_file:\n164\t            root_log_file.write(line + \"\\n\")\n165\t            root_log_file.flush()\n166\t\n167\t    start_time = time.time()\n168\t    initial_rules = len(load_all_rules(\"procedural_memory\"))\n169\t\n170\t    log(f\"=== SOAR Learning Loop ===\")\n171\t    log(f\"Split: {split} | Tasks: {total} | Stored rules: {initial_rules}\")\n172\t    log(f\"Log: {log_path}\")\n173\t    log(\"\")\n174\t\n175\t    for idx, task_hex in enumerate(task_hexes):\n176\t        task_start = time.time()\n177\t\n178\t        try:\n179\t            task = manager.load_task(task_hex)\n180\t            predicted = agent.solve(task)\n181\t            is_correct = check_correct(predicted, task)\n182\t            elapsed = time.time() - task_start\n183\t\n184\t            info = agent.last_solve_info\n185\t            method = info.get(\"method\", \"?\")\n186\t            rule_type = info.get(\"rule_type\", \"?\")\n187\t            steps = info.get(\"steps\", 0)\n188\t\n189\t            if is_correct:\n190\t                correct_count += 1\n191\t            if method == \"stored_rule\":\n192\t                stored_rule_hits += 1\n193\t            if method == \"pipeline\" and rule_type != \"identity\" and rule_type != \"none\":\n194\t                pipeline_discoveries += 1\n195\t\n196\t            status = \"CORRECT\" if is_correct else \"INCORRECT\"\n197\t            method_str = f\"stored({info.get('rule_source', '?')})\" if method == \"stored_rule\" else f\"pipeline(steps={steps})\"\n198\t\n199\t            log(f\"[{idx+1}/{total}] {task_hex}: {status}  rule={rule_type}  via={method_str}  ({elapsed:.1f}s)\")\n200\t\n201\t            if args.viz:\n202\t                _show_viz(task, predicted, is_correct)\n203\t\n204\t            if html_report:\n205\t                html_report.add_task(task_hex, status, rule_type, method_str,\n206\t                                     task, predicted)\n207\t\n208\t        except Exception as e:\n209\t            error_count += 1\n210\t            log(f\"[{idx+1}/{total}] {task_hex}: ERROR ({e})\")\n211\t            if html_report:\n212\t                html_report.add_task(task_hex, \"ERROR\", \"?\", \"?\", task, None) \\\n213\t                    if 'task' in dir() else None\n214\t\n215\t    elapsed_total = time.time() - start_time\n216\t    final_rules = len(load_all_rules(\"procedural_memory\"))\n217\t\n218\t    log(\"\")\n219\t    log(\"=\" * 55)\n220\t    log(f\"Tasks:       {total}  ({error_count} errors)\")\n221\t    log(f\"Correct:     {correct_count} / {total}  ({correct_count/max(total,1)*100:.1f}%)\")\n222\t    log(f\"Rules:       {initial_rules} -> {final_rules}  (+{final_rules - initial_rules} learned)\")\n223\t    log(f\"Reused:      {stored_rule_hits} times (stored rule hit)\")\n224\t    log(f\"Discovered:  {pipeline_discoveries} new rules from pipeline\")\n225\t    log(f\"Time:        {elapsed_total:.0f}s  ({elapsed_total/max(total,1):.1f}s/task)\")\n226\t    log(\"=\" * 55)\n227\t\n228\t    log_file.close()\n229\t    if root_log_file:\n230\t        root_log_file.close()\n231\t        print(f\"Text output saved → {root_log_path}\")\n232\t\n233\t    if html_report:\n234\t        html_report.summary = {\n235\t            \"correct\": correct_count,\n236\t            \"total\": total,\n237\t            \"rules_before\": initial_rules,\n238\t            \"rules_after\": final_rules,\n239\t            \"elapsed\": f\"{elapsed_total:.0f}\",\n240\t        }\n241\t        html_report.write(html_path)\n242\t        print(f\"HTML report saved → {html_path}\")\n243\t\n244\t    # Write summary to session_log.md\n245\t    session_log_path = \"logs/session_log.md\"\n246\t    with open(session_log_path, \"a\") as f:\n247\t        f.write(f\"\\n---\\n## Learning Loop -- {datetime.now().strftime('%Y-%m-%d %H:%M')}\\n\\n\")\n248\t        f.write(f\"- Split: {args.split}, Tasks: {total}\\n\")\n249\t        f.write(f\"- Correct: {correct_count} / {total} ({correct_count/max(total,1)*100:.1f}%)\\n\")\n250\t        f.write(f\"- Rules: {initial_rules} -> {final_rules} (+{final_rules - initial_rules} learned)\\n\")\n251\t        f.write(f\"- Stored rule hits: {stored_rule_hits}\\n\")\n252\t        f.write(f\"- Time: {elapsed_total:.0f}s\\n\")\n253\t        f.write(f\"- Log: {log_path}\\n\")\n254\t\n255\t\n256\tif __name__ == \"__main__\":\n257\t    main()\n258\t"}]},"parent_tool_use_id":null,"session_id":"3fed7f85-792d-4d37-88c2-f10a44b2632b","uuid":"69134c8f-31ab-4c9e-beaf-32f0f0150e62","timestamp":"2026-04-28T23:05:03.336Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sir_k/Desktop/SOAR-ARC-test/run_learn.py","content":"\"\"\"\nSequential learning loop — feeds tasks to the SOAR agent one by one.\nThe agent accumulates rules in procedural_memory across tasks.\n\nUsage:\n  python run_learn.py                        # all training tasks\n  python run_learn.py --split evaluation     # evaluation tasks\n  python run_learn.py --limit 100            # first 100 tasks\n  python run_learn.py --log-wm              # show WM logs per task\n  python run_learn.py --shuffle              # random task order\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport time\nimport random\nimport argparse\nimport subprocess\nfrom datetime import datetime\n\n\ndef _git_branch() -> str:\n    \"\"\"Return the current git branch name, or unknown if unavailable.\"\"\"\n    try:\n        return subprocess.check_output(\n            [\"git\", \"rev-parse\", \"--abbrev-ref\", \"HEAD\"],\n            stderr=subprocess.DEVNULL,\n        ).decode().strip()\n    except Exception:\n        return \"unknown\"\n\nfrom managers.arc_manager import ARCManager\nfrom agent.active_agent import ActiveSoarAgent\nfrom agent.memory import load_all_rules\nfrom basics.html_report import HTMLReport\n\n\ndef parse_args():\n    p = argparse.ArgumentParser(description=\"SOAR learning loop\")\n    p.add_argument(\"--split\", default=None,\n                   help=\"Force ARC_AGI split: 'training' (1000 tasks) or 'evaluation' (120 tasks). \"\n                        \"Omit to use data/ARC_easy/ when present.\")\n    p.add_argument(\"--limit\", type=int, default=None, help=\"max tasks to run\")\n    p.add_argument(\"--shuffle\", action=\"store_true\", help=\"randomize task order\")\n    p.add_argument(\"--seed\", type=int, default=42, help=\"random seed for shuffle\")\n    p.add_argument(\"--log-wm\", action=\"store_true\", help=\"print WM logs per task\")\n    p.add_argument(\"--viz\", action=\"store_true\", help=\"show input/predicted/answer grids\")\n    return p.parse_args()\n\n\ndef get_task_list(split, data_root=\"data\", force_split=False):\n    \"\"\"Get sorted list of task IDs for a split.\n\n    If data/ARC_easy/ exists AND force_split is False, use it directly.\n    Pass force_split=True (via --split training/evaluation) to use ARC_AGI instead.\n    \"\"\"\n    if not force_split:\n        easy_dir = os.path.join(data_root, \"ARC_easy\")\n        if os.path.isdir(easy_dir):\n            return sorted(f.replace(\".json\", \"\") for f in os.listdir(easy_dir) if f.endswith(\".json\"))\n\n    split_dir = os.path.join(data_root, \"ARC_AGI\", split)\n    if not os.path.isdir(split_dir):\n        print(f\"[!] Directory not found: {split_dir}\")\n        sys.exit(1)\n    return sorted(f.replace(\".json\", \"\") for f in os.listdir(split_dir) if f.endswith(\".json\"))\n\n\ndef check_correct(predicted, task):\n    \"\"\"Check if predicted grids match the ground truth.\"\"\"\n    if predicted is None:\n        return False\n    answers = []\n    for pair in task.test_pairs:\n        if hasattr(pair, \"output\") and pair.output is not None:\n            answers.append(pair.output.contents)\n    if not answers:\n        return False\n    pred = predicted\n    if pred and not isinstance(pred[0], list):\n        pred = [pred]\n    if len(pred) != len(answers):\n        return False\n    return all(p == a for p, a in zip(pred, answers))\n\n\ndef _show_viz(task, predicted, is_correct):\n    \"\"\"Show input, predicted, and ground truth grids side by side (ANSI colors).\"\"\"\n    from basics.viz import _print_side_by_side\n\n    for i, pair in enumerate(task.test_pairs):\n        grids = [pair.input_grid.raw]\n        labels = [\"input\"]\n\n        if predicted is not None:\n            pred = predicted if isinstance(predicted[0], list) else [predicted]\n            if i < len(pred):\n                grids.append(pred[i])\n                labels.append(\"predicted\")\n\n        if hasattr(pair, \"output\") and pair.output is not None:\n            grids.append(pair.output.contents)\n            labels.append(\"answer\")\n\n        tag = \"MATCH\" if is_correct else \"MISMATCH\"\n        print(f\"  {'  |  '.join(labels)}  << {tag}\")\n        _print_side_by_side(grids, gap=6)\n    print()\n\n\ndef main():\n    args = parse_args()\n\n    manager = ARCManager(data_root=\"data\", semantic_memory_root=\"semantic_memory\")\n    agent = ActiveSoarAgent(\n        semantic_memory_root=\"semantic_memory\",\n        procedural_memory_root=\"procedural_memory\",\n        max_steps=50,\n    )\n\n    split = args.split or \"training\"\n    force_split = args.split is not None\n    task_hexes = get_task_list(split, force_split=force_split)\n    if args.shuffle:\n        random.seed(args.seed)\n        random.shuffle(task_hexes)\n    if args.limit is not None:\n        task_hexes = task_hexes[:args.limit]\n\n    total = len(task_hexes)\n    correct_count = 0\n    error_count = 0\n    stored_rule_hits = 0\n    pipeline_discoveries = 0\n\n    # Log file (always saved to logs/)\n    os.makedirs(\"logs\", exist_ok=True)\n    timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n    branch = _git_branch()\n    log_path = f\"logs/learn_{timestamp}.log\"\n    log_file = open(log_path, \"w\")\n\n    # Root txt file — only when --split is explicitly given (e.g. --split training)\n    root_log_path = None\n    root_log_file = None\n    if force_split:\n        root_log_path = f\"run_learn_{branch}_{split}_{timestamp}.txt\"\n        root_log_file = open(root_log_path, \"w\")\n\n    # HTML report — only when --viz and --split are both given\n    html_report = None\n    html_path = None\n    if args.viz and force_split:\n        html_path = f\"run_learn_{branch}_{split}_{timestamp}.html\"\n        html_report = HTMLReport(split=split, timestamp=timestamp)\n\n    def log(msg):\n        line = f\"[{datetime.now().strftime('%H:%M:%S')}] {msg}\"\n        print(line)\n        log_file.write(line + \"\\n\")\n        log_file.flush()\n        if root_log_file:\n            root_log_file.write(line + \"\\n\")\n            root_log_file.flush()\n\n    start_time = time.time()\n    initial_rules = len(load_all_rules(\"procedural_memory\"))\n\n    log(f\"=== SOAR Learning Loop ===\")\n    log(f\"Split: {split} | Tasks: {total} | Stored rules: {initial_rules}\")\n    log(f\"Log: {log_path}\")\n    log(\"\")\n\n    for idx, task_hex in enumerate(task_hexes):\n        task_start = time.time()\n\n        try:\n            task = manager.load_task(task_hex)\n            predicted = agent.solve(task)\n            is_correct = check_correct(predicted, task)\n            elapsed = time.time() - task_start\n\n            info = agent.last_solve_info\n            method = info.get(\"method\", \"?\")\n            rule_type = info.get(\"rule_type\", \"?\")\n            steps = info.get(\"steps\", 0)\n\n            if is_correct:\n                correct_count += 1\n            if method == \"stored_rule\":\n                stored_rule_hits += 1\n            if method == \"pipeline\" and rule_type != \"identity\" and rule_type != \"none\":\n                pipeline_discoveries += 1\n\n            status = \"CORRECT\" if is_correct else \"INCORRECT\"\n            method_str = f\"stored({info.get('rule_source', '?')})\" if method == \"stored_rule\" else f\"pipeline(steps={steps})\"\n\n            log(f\"[{idx+1}/{total}] {task_hex}: {status}  rule={rule_type}  via={method_str}  ({elapsed:.1f}s)\")\n\n            if args.viz:\n                _show_viz(task, predicted, is_correct)\n\n            if html_report:\n                html_report.add_task(task_hex, status, rule_type, method_str,\n                                     task, predicted)\n\n        except Exception as e:\n            error_count += 1\n            log(f\"[{idx+1}/{total}] {task_hex}: ERROR ({e})\")\n            if html_report:\n                html_report.add_task(task_hex, \"ERROR\", \"?\", \"?\", task, None) \\\n                    if 'task' in dir() else None\n\n    elapsed_total = time.time() - start_time\n    final_rules = len(load_all_rules(\"procedural_memory\"))\n\n    log(\"\")\n    log(\"=\" * 55)\n    log(f\"Tasks:       {total}  ({error_count} errors)\")\n    log(f\"Correct:     {correct_count} / {total}  ({correct_count/max(total,1)*100:.1f}%)\")\n    log(f\"Rules:       {initial_rules} -> {final_rules}  (+{final_rules - initial_rules} learned)\")\n    log(f\"Reused:      {stored_rule_hits} times (stored rule hit)\")\n    log(f\"Discovered:  {pipeline_discoveries} new rules from pipeline\")\n    log(f\"Time:        {elapsed_total:.0f}s  ({elapsed_total/max(total,1):.1f}s/task)\")\n    log(\"=\" * 55)\n\n    log_file.close()\n    if root_log_file:\n        root_log_file.close()\n        print(f\"Text output saved → {root_log_path}\")\n\n    if html_report:\n        html_report.summary = {\n            \"correct\": correct_count,\n            \"total\": total,\n            \"rules_before\": initial_rules,\n            \"rules_after\": final_rules,\n            \"elapsed\": f\"{elapsed_total:.0f}\",\n        }\n        html_report.write(html_path)\n        print(f\"HTML report saved → {html_path}\")\n\n    # Write summary to session_log.md\n    session_log_path = \"logs/session_log.md\"\n    with open(session_log_path, \"a\") as f:\n        f.write(f\"\\n---\\n## Learning Loop -- {datetime.now().strftime('%Y-%m-%d %H:%M')}\\n\\n\")\n        f.write(f\"- Split: {args.split}, Tasks: {total}\\n\")\n        f.write(f\"- Correct: {correct_count} / {total} ({correct_count/max(total,1)*100:.1f}%)\\n\")\n        f.write(f\"- Rules: {initial_rules} -> {final_rules} (+{final_rules - initial_rules} learned)\\n\")\n        f.write(f\"- Stored rule hits: {stored_rule_hits}\\n\")\n        f.write(f\"- Time: {elapsed_total:.0f}s\\n\")\n        f.write(f\"- Log: {log_path}\\n\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":258,"startLine":1,"totalLines":258}}}
